---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ZERO OS — 404">

<div class="page-404">
  <div class="err-code">404</div>
  <h1 class="err-title">Signal not found</h1>
  <p class="err-desc">The regime you're looking for doesn't exist — or was detected and removed.</p>
  <a href="/" class="err-cta">← Return to ZERO OS</a>
</div>

</BaseLayout>

<style>
  .page-404 {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 80vh;
    text-align: center;
    padding: 2rem 1.25rem;
  }
  .err-code {
    font-family: var(--font-head);
    font-size: clamp(4rem, 15vw, 8rem);
    font-weight: 800;
    color: var(--phosphor);
    opacity: 0.15;
    line-height: 1;
    margin-bottom: -1rem;
  }
  .err-title {
    font-family: var(--font-head);
    font-size: clamp(1rem, 3vw, 1.4rem);
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.5rem;
  }
  .err-desc {
    font-size: 0.65rem;
    color: var(--text-dim);
    max-width: 320px;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }
  .err-cta {
    font-family: var(--font-head);
    font-size: 0.6rem;
    font-weight: 700;
    color: var(--phosphor);
    text-decoration: none;
    padding: 0.5rem 1rem;
    border: 1px solid rgba(200,255,0,0.2);
    transition: border-color 0.3s, box-shadow 0.3s;
  }
  .err-cta:hover {
    border-color: rgba(200,255,0,0.5);
    box-shadow: 0 0 12px rgba(200,255,0,0.08);
  }
</style>
