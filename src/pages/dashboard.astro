---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ZERO OS — Live Market Intelligence" description="Should you trade right now? Real-time regime detection tells you which strategies work and which are traps.">

<div class="page">
<div class="page-inner">

  <!-- NAV -->
  <nav class="dash-nav">
    <a href="/" class="nav-back"><span class="p">←</span> ZERO OS</a>
    <div class="nav-right">
      <span class="live-dot"></span>
      <span class="nav-live p" id="nav-status">CONNECTING...</span>
      <span class="nav-ts dim" id="nav-ts"></span>
    </div>
  </nav>

  <!-- THE VERDICT -->
  <div class="verdict-pane" id="verdict-pane">
    <div class="verdict-loading" id="verdict-loading">
      <span class="p">▸</span> Reading market state...
    </div>
    <div class="verdict-content" id="verdict-content" style="display:none">
      <h1 class="verdict-headline" id="verdict-headline"></h1>
      <p class="verdict-sub dim" id="verdict-sub"></p>
      <div class="regime-bar" id="regime-bar"></div>
      <div class="regime-bar-labels dim" id="regime-bar-labels"></div>
    </div>
  </div>

  <!-- COIN CARDS -->
  <div class="cards-grid" id="cards-grid"></div>

  <!-- HOW TO READ -->
  <div class="legend-pane">
    <div class="legend-hdr"><span class="dim">■</span> HOW TO READ THIS</div>
    <div class="legend-body">
      <p>Traditional indicators — RSI, MACD, Bollinger Bands — assume markets behave consistently. They don't.</p>
      <p>Markets shift between states: <span class="p">trending</span>, <span class="a">reverting</span>, <span class="red">chaotic</span>, and <span class="ice">shifting</span>. A momentum signal that prints money in a trending market will destroy you in a chaotic one.</p>
      <p>ZERO detects which state each market is in <em>right now</em> and tells you which strategies work and which are traps. Check here before you trade.</p>
    </div>
  </div>

  <!-- FOOTER -->
  <footer class="dash-footer">
    <span class="p">◇</span> <span class="dim">ZERO OS · Data updates every 15 minutes</span>
  </footer>

</div>
</div>

</BaseLayout>

<style>
  .page {
    margin: 0.5rem;
    border: 1px solid rgba(200,255,0,0.4);
    min-height: calc(100vh - 1rem);
    padding: 0;
    overflow: hidden;
  }
  .page-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0.75rem 1.5rem 1.5rem;
  }

  /* NAV */
  .dash-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0 0.75rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1rem;
  }
  .nav-back {
    font-family: var(--font-head);
    font-size: 0.85rem;
    font-weight: 700;
    text-decoration: none;
    color: var(--text-dim);
  }
  .nav-back:hover { color: var(--phosphor); }
  .nav-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-head);
    font-size: 0.75rem;
  }
  .live-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--phosphor);
    animation: livePulse 2s ease infinite;
  }
  @keyframes livePulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 6px var(--phosphor-glow); }
    50% { opacity: 0.3; box-shadow: none; }
  }
  .nav-ts { font-size: 0.65rem; }

  /* VERDICT */
  .verdict-pane {
    border: 1px solid var(--border);
    background: rgba(0,0,0,0.5);
    padding: 2rem 1.5rem;
    margin-bottom: 1rem;
    text-align: center;
  }
  .verdict-loading {
    font-family: var(--font-head);
    font-size: 0.9rem;
    color: var(--text-dim);
  }
  .verdict-headline {
    font-family: var(--font-head);
    font-size: clamp(1.1rem, 3vw, 1.6rem);
    font-weight: 700;
    line-height: 1.4;
    color: var(--text);
    margin: 0 0 0.5rem;
  }
  .verdict-sub {
    font-size: 0.85rem;
    margin: 0 0 1.25rem;
  }

  /* REGIME BAR */
  .regime-bar {
    display: flex;
    height: 8px;
    border-radius: 4px;
    overflow: hidden;
    margin: 0 auto;
    max-width: 500px;
  }
  .regime-bar-labels {
    display: flex;
    justify-content: center;
    gap: 1.25rem;
    margin-top: 0.5rem;
    font-family: var(--font-head);
    font-size: 0.6rem;
    letter-spacing: 0.05em;
  }
  .bar-label { display: flex; align-items: center; gap: 0.3rem; }
  .bar-dot { width: 6px; height: 6px; border-radius: 50%; display: inline-block; }

  /* CARDS */
  .cards-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }
  .coin-card {
    border: 1px solid var(--border);
    background: rgba(0,0,0,0.4);
    transition: border-color 0.2s;
  }
  .coin-card:hover { border-color: rgba(200,255,0,0.2); }
  .card-main {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 1rem 1.25rem;
    cursor: pointer;
    user-select: none;
  }
  .card-left { flex: 1; }
  .card-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  .card-coin {
    font-family: var(--font-head);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
  }
  .card-price {
    font-family: var(--font-head);
    font-size: 0.85rem;
    color: var(--text-dim);
  }
  .card-regime {
    font-family: var(--font-head);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    padding: 0.15rem 0.5rem;
    display: inline-block;
    margin-bottom: 0.4rem;
  }
  .card-advice {
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--text-dim);
  }
  .card-right {
    display: flex;
    align-items: center;
    padding-left: 1rem;
  }
  .card-dot {
    width: 14px; height: 14px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .card-expand-hint {
    font-family: var(--font-head);
    font-size: 0.7rem;
    color: var(--text-dim);
    opacity: 0.5;
    margin-top: 0.25rem;
  }

  /* PROOF (collapsed by default) */
  .card-proof {
    display: none;
    padding: 0 1.25rem 1rem;
    border-top: 1px solid var(--border);
  }
  .card-proof.open { display: block; }
  .proof-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.4rem 0;
    border-bottom: 1px solid rgba(26,26,26,0.3);
    font-size: 0.8rem;
  }
  .proof-row:last-child { border-bottom: none; }
  .proof-label {
    font-family: var(--font-head);
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--text-dim);
    min-width: 80px;
  }
  .proof-val {
    font-family: var(--font-head);
    font-size: 0.85rem;
    font-weight: 700;
    min-width: 50px;
    text-align: right;
  }
  .proof-explain {
    flex: 1;
    color: var(--text-dim);
    font-size: 0.75rem;
    padding: 0 1rem;
    text-align: right;
  }

  /* REGIME COLORS */
  .regime-trending { color: var(--phosphor); border: 1px solid var(--phosphor); background: rgba(200,255,0,0.08); }
  .regime-reverting { color: var(--amber); border: 1px solid var(--amber); background: rgba(255,176,0,0.08); }
  .regime-chaotic { color: var(--red); border: 1px solid var(--red); background: rgba(255,51,51,0.08); }
  .regime-shift { color: var(--ice); border: 1px solid var(--ice); background: rgba(0,212,255,0.06); }
  .regime-neutral, .regime-unknown { color: var(--text-dim); border: 1px solid var(--border); }

  .dot-trending { background: var(--phosphor); }
  .dot-reverting { background: var(--amber); }
  .dot-chaotic { background: var(--red); }
  .dot-shift { background: var(--ice); }
  .dot-neutral, .dot-unknown { background: var(--text-dim); }

  /* LEGEND */
  .legend-pane {
    border: 1px solid var(--border);
    background: rgba(0,0,0,0.3);
    margin-bottom: 1rem;
  }
  .legend-hdr {
    font-family: var(--font-head);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    padding: 0.5rem 1rem;
    border-bottom: 1px solid var(--border);
    background: rgba(10,10,10,0.6);
    color: var(--text-dim);
  }
  .legend-body {
    padding: 1rem 1.25rem;
    font-size: 0.85rem;
    line-height: 1.7;
    color: var(--text-dim);
  }
  .legend-body p { margin: 0 0 0.75rem; }
  .legend-body p:last-child { margin: 0; }

  /* FOOTER */
  .dash-footer {
    text-align: center;
    padding: 1rem 0;
    font-family: var(--font-head);
    font-size: 0.7rem;
  }

  /* MOBILE */
  @media (max-width: 640px) {
    .page-inner { padding: 0.5rem 0.75rem 1rem; }
    .verdict-pane { padding: 1.25rem 1rem; }
    .card-main { padding: 0.75rem 1rem; }
    .proof-explain { display: none; }
  }
  @media (min-width: 700px) {
    .cards-grid { grid-template-columns: 1fr 1fr; }
  }
</style>

<script>
// ═══ REGIME ADVICE ═══
const ADVICE = {
  trending: {
    generic: "Momentum is real. Trend-following strategies have an edge right now.",
    specifics: {
      BTC: "Bitcoin is trending. EMA crossovers and MACD signals are reliable. Don't fade the move.",
      ETH: "Ethereum is in trend mode. Breakouts are likely continuation, not fakeouts.",
      SOL: "Solana is trending hard. Momentum plays work. Don't try to call the top.",
      DOGE: "Doge is riding momentum. Meme coins trend fast — ride it but set stops.",
      AVAX: "AVAX is trending. Follow the flow, don't fight it.",
      LINK: "Chainlink is in a trend. Oracle narrative is driving real flows.",
      ARB: "Arbitrum is trending. L2 momentum is real right now.",
      NEAR: "NEAR is trending. Follow the breakout.",
      SUI: "SUI is in trend mode. New L1 momentum — ride with stops.",
      INJ: "Injective is trending. DeFi infrastructure moving."
    }
  },
  reverting: {
    generic: "Prices are snapping back to mean. Fade the extremes — buy dips, sell rips.",
    specifics: {
      BTC: "Bitcoin is range-bound. RSI oversold/overbought signals actually work right now. Fade extremes.",
      ETH: "Ethereum is reverting. Bollinger band bounces are reliable. Don't chase breakouts.",
      SOL: "Solana is mean-reverting. Buy the dip, sell the rip. Breakout signals are traps.",
      DOGE: "Doge is bouncing between levels. Range trade it, don't bet on direction.",
      AVAX: "AVAX is range-bound. Mean reversion strategies work here.",
      LINK: "LINK is oscillating. Fade the moves, don't follow them.",
      ARB: "ARB is reverting. Buy support, sell resistance.",
      NEAR: "NEAR is range-bound. Don't chase, fade.",
      SUI: "SUI is mean-reverting. Extremes get punished.",
      INJ: "INJ is oscillating. Classic mean reversion setup."
    }
  },
  chaotic: {
    generic: "Market is unpredictable. Most indicators are unreliable. Reduce exposure or sit out.",
    specifics: {
      BTC: "Bitcoin is chaotic. RSI, MACD, Bollinger — none of them are reliable right now. Reduce size or wait.",
      ETH: "Ethereum is chaotic. Every signal contradicts the next. Small positions only.",
      SOL: "Solana is in chaos. High volatility, no direction. Your indicators are lying to you.",
      DOGE: "Doge is chaotic. Meme coin in chaos = pure gambling. Stay out.",
      AVAX: "AVAX is unpredictable. No edge exists right now. Preserve capital.",
      LINK: "LINK is chaotic. Signals are noise. Wait for a regime change.",
      ARB: "ARB is in chaos. L2 tokens amplify market disorder. Sit this out.",
      NEAR: "NEAR is chaotic. No reliable patterns. Reduce or wait.",
      SUI: "SUI is chaotic. Low-cap in chaos = maximum risk. Sit out.",
      INJ: "INJ is in chaos mode. Signals are unreliable. Wait for clarity."
    }
  },
  shift: {
    generic: "Market is transitioning between states. Signals will conflict. Wait for the new regime to settle.",
    specifics: {
      BTC: "Bitcoin is shifting regimes. Old signals dying, new ones forming. Wait for clarity.",
      ETH: "Ethereum is in transition. Conflicting signals are expected. Reduce and watch.",
      SOL: "Solana is shifting. The rules are changing — don't use yesterday's playbook.",
      DOGE: "Doge is transitioning. Impossible to know what works until the shift completes.",
      AVAX: "AVAX is shifting states. Hold off on new positions.",
      LINK: "LINK is in regime transition. Wait for the dust to settle.",
      ARB: "ARB is shifting. L2 regime changes can be violent. Stand aside.",
      NEAR: "NEAR is transitioning. New regime forming — patience.",
      SUI: "SUI is shifting. Don't trade the transition.",
      INJ: "INJ is in regime shift. Wait for the new state to establish."
    }
  },
  neutral: {
    generic: "No clear market state. Random walk territory. Small positions only, no conviction trades.",
    specifics: {}
  },
  unknown: {
    generic: "Unable to determine market state. Treat as high risk.",
    specifics: {}
  }
};

function getAdvice(coin, regime) {
  const r = ADVICE[regime] || ADVICE.unknown;
  return r.specifics[coin] || r.generic;
}

function formatPrice(p) {
  if (p == null) return '';
  if (p >= 1000) return '$' + p.toLocaleString('en-US', { maximumFractionDigits: 0 });
  if (p >= 1) return '$' + p.toFixed(2);
  if (p >= 0.01) return '$' + p.toFixed(4);
  return '$' + p.toFixed(6);
}

function explainHurst(h, regime) {
  if (h == null) return '—';
  if (h > 0.6) return 'Strong trending bias — but check chaos level';
  if (h > 0.55) return 'Slight trending tendency';
  if (h < 0.4) return 'Strong mean-reversion — prices snap back';
  if (h < 0.45) return 'Slight mean-reverting tendency';
  return 'Near random walk — no clear edge';
}

function explainDFA(d, regime) {
  if (d == null) return '—';
  if (d > 0.6) return 'Confirms persistence in price moves';
  if (d > 0.55) return 'Weak persistence detected';
  if (d < 0.4) return 'Anti-persistent — moves tend to reverse';
  if (d < 0.45) return 'Weak anti-persistence';
  return 'No clear structural bias';
}

function explainLyapunov(ly, regime) {
  if (ly == null) return '—';
  if (ly > 1.5) return 'High chaos — small changes cause big swings. Signals unreliable.';
  if (ly > 0.8) return 'Moderate unpredictability — trade with caution';
  if (ly > 0) return 'Low chaos — signals are more trustworthy';
  return 'Stable — unusual for crypto';
}

function explainRSI(rsi, regime) {
  if (rsi == null) return '—';
  if (regime === 'chaotic') {
    return rsi > 70 ? 'Shows overbought — but meaningless in chaos' : rsi < 30 ? 'Shows oversold — but meaningless in chaos' : 'Mid-range — irrelevant in chaos';
  }
  if (regime === 'reverting') {
    return rsi > 70 ? 'Overbought — likely to reverse (mean reversion works)' : rsi < 30 ? 'Oversold — likely to bounce (mean reversion works)' : 'Mid-range — wait for extremes';
  }
  if (regime === 'trending') {
    return rsi > 70 ? 'Overbought — but may continue in trend' : rsi < 30 ? 'Oversold — potential trend entry' : 'Trending, room to run';
  }
  return rsi > 70 ? 'Overbought' : rsi < 30 ? 'Oversold' : 'Neutral';
}

const REGIME_LABELS = { trending: 'TRENDING', reverting: 'REVERTING', chaotic: 'CHAOTIC', shift: 'SHIFTING', neutral: 'NEUTRAL', unknown: 'UNKNOWN' };
const REGIME_COLORS = { trending: '#c8ff00', reverting: '#ffb000', chaotic: '#ff3333', shift: '#00d4ff', neutral: '#8a8278', unknown: '#8a8278' };

function generateVerdict(counts, total) {
  const { trending = 0, reverting = 0, chaotic = 0, shift = 0 } = counts;
  let headline, sub;

  if (chaotic >= total * 0.6) {
    headline = `${chaotic} of ${total} markets are unpredictable right now. Most strategies will fail.`;
    sub = "This is not the time to be aggressive. Reduce exposure across the board.";
  } else if (chaotic >= total * 0.4) {
    headline = `${chaotic} of ${total} markets are chaotic. Tread carefully.`;
    sub = "Some opportunities exist but the majority of signals are unreliable.";
  } else if (trending >= total * 0.5) {
    headline = `${trending} of ${total} markets are trending. Momentum strategies have an edge.`;
    sub = "Follow the flow. EMA crossovers and breakout signals are working.";
  } else if (reverting >= total * 0.4) {
    headline = `${reverting} of ${total} markets are mean-reverting. Fade the extremes.`;
    sub = "Buy dips, sell rips. RSI and Bollinger signals are reliable right now.";
  } else if (shift >= total * 0.3) {
    headline = `${shift} of ${total} markets are transitioning. Wait for clarity.`;
    sub = "Old rules are dying, new ones forming. Patience beats action.";
  } else {
    headline = `Markets are split: ${trending} trending, ${chaotic} chaotic, ${reverting} reverting.`;
    sub = "Pick your spots carefully. Not every coin is in the same state.";
  }

  return { headline, sub };
}

async function loadDashboard() {
  try {
    const r = await fetch('/api/dashboard');
    if (!r.ok) throw new Error('API error');
    const data = await r.json();
    if (!data.live || !data.coins) throw new Error('No data');

    // Update nav
    document.getElementById('nav-status').textContent = 'LIVE';
    document.getElementById('nav-ts').textContent = new Date(data.timestamp).toLocaleTimeString();

    // Sort: chaotic first (highest risk first)
    const order = { chaotic: 0, shift: 1, neutral: 2, reverting: 3, trending: 4 };
    const sorted = Object.entries(data.coins).sort((a, b) => (order[a[1]._regime] ?? 2) - (order[b[1]._regime] ?? 2));
    const total = sorted.length;

    // Count regimes
    const counts = {};
    for (const [, d] of sorted) { counts[d._regime] = (counts[d._regime] || 0) + 1; }

    // THE VERDICT
    const verdict = generateVerdict(counts, total);
    document.getElementById('verdict-headline').textContent = verdict.headline;
    document.getElementById('verdict-sub').textContent = verdict.sub;

    // Regime bar
    const bar = document.getElementById('regime-bar');
    const labels = document.getElementById('regime-bar-labels');
    bar.innerHTML = '';
    labels.innerHTML = '';
    for (const regime of ['trending', 'reverting', 'chaotic', 'shift']) {
      const c = counts[regime] || 0;
      if (c === 0) continue;
      const seg = document.createElement('div');
      seg.style.flex = c;
      seg.style.background = REGIME_COLORS[regime];
      seg.style.opacity = '0.8';
      bar.appendChild(seg);

      const lbl = document.createElement('span');
      lbl.className = 'bar-label';
      lbl.innerHTML = `<span class="bar-dot" style="background:${REGIME_COLORS[regime]}"></span> ${c} ${REGIME_LABELS[regime]}`;
      labels.appendChild(lbl);
    }

    document.getElementById('verdict-loading').style.display = 'none';
    document.getElementById('verdict-content').style.display = 'block';

    // COIN CARDS
    const grid = document.getElementById('cards-grid');
    grid.innerHTML = '';

    for (const [coin, d] of sorted) {
      const regime = d._regime || 'unknown';
      const advice = getAdvice(coin, regime);
      const price = formatPrice(d.CLOSE_PRICE_15M);
      const h = d.HURST_24H;
      const dfa = d.DFA_24H;
      const ly = d.LYAPUNOV_24H;
      const rsi = d.RSI_3H30M;

      const card = document.createElement('div');
      card.className = 'coin-card';
      card.innerHTML = `
        <div class="card-main">
          <div class="card-left">
            <div class="card-top">
              <span class="card-coin">${coin}</span>
              <span class="card-price">${price}</span>
            </div>
            <div class="card-regime regime-${regime}">${REGIME_LABELS[regime] || '—'}</div>
            <div class="card-advice">${advice}</div>
            <div class="card-expand-hint">▸ show proof</div>
          </div>
          <div class="card-right">
            <div class="card-dot dot-${regime}"></div>
          </div>
        </div>
        <div class="card-proof" id="proof-${coin}">
          <div class="proof-row">
            <span class="proof-label">HURST</span>
            <span class="proof-explain">${explainHurst(h, regime)}</span>
            <span class="proof-val ${h > 0.55 ? 'p' : h < 0.45 ? 'a' : ''}">${h != null ? h.toFixed(3) : '—'}</span>
          </div>
          <div class="proof-row">
            <span class="proof-label">DFA</span>
            <span class="proof-explain">${explainDFA(dfa, regime)}</span>
            <span class="proof-val ${dfa > 0.55 ? 'p' : dfa < 0.45 ? 'a' : ''}">${dfa != null ? dfa.toFixed(3) : '—'}</span>
          </div>
          <div class="proof-row">
            <span class="proof-label">LYAPUNOV</span>
            <span class="proof-explain">${explainLyapunov(ly, regime)}</span>
            <span class="proof-val ${ly > 1.5 ? 'red' : ly > 0.8 ? 'a' : 'p'}">${ly != null ? ly.toFixed(2) : '—'}</span>
          </div>
          ${rsi != null ? `<div class="proof-row">
            <span class="proof-label">RSI</span>
            <span class="proof-explain">${explainRSI(rsi, regime)}</span>
            <span class="proof-val ${rsi > 70 ? 'a' : rsi < 30 ? 'p' : ''}">${rsi.toFixed(0)}</span>
          </div>` : ''}
        </div>
      `;

      // Toggle proof on click
      card.querySelector('.card-main').addEventListener('click', () => {
        const proof = card.querySelector('.card-proof');
        const hint = card.querySelector('.card-expand-hint');
        proof.classList.toggle('open');
        hint.textContent = proof.classList.contains('open') ? '▾ hide proof' : '▸ show proof';
      });

      grid.appendChild(card);
    }

  } catch (e) {
    document.getElementById('nav-status').textContent = 'OFFLINE';
    document.getElementById('nav-status').className = 'nav-live red';
    document.getElementById('verdict-loading').innerHTML = '<span class="red">✗</span> Failed to connect. Retrying...';
    setTimeout(loadDashboard, 10000);
  }
}

document.addEventListener('DOMContentLoaded', () => {
  loadDashboard();
  setInterval(loadDashboard, 300000);
});
</script>
</BaseLayout>
