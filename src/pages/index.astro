  .trades-table td {
    padding: 0.4rem 0.6rem;
    text-align: right;
    border-bottom: 1px solid rgba(26,26,26,0.3);
    font-variant-numeric: tabular-nums;
    color: var(--text);
  }
  .trades-table td:first-child {
    text-align: left;
    font-weight: 700;
  }
  .trades-table tr:hover { background: rgba(200,255,0,0.02); }
  @media (max-width: 639px) {
    .tt-hide-mobile { display: none; }
