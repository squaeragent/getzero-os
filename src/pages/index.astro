---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ZERO OS — Self-Custodial Trading Agent">

<div class="page">

  <!-- CRT BOOT -->
  <header class="hero">
    <div class="boot-sequence">
      <pre class="boot-line b1"><span class="p">ZERO OS</span> v0.1 .................... <span class="p">BOOT</span></pre>
      <pre class="boot-line b2"><span class="p">ENVY MATRIX</span> .................... <span class="p">REGIME DETECTION</span></pre>
      <pre class="boot-line b3"><span class="p">PORTFOLIO ENGINE</span> ............... <span class="p">SELF-CUSTODIAL</span></pre>
    </div>

    <div class="logo-wrap">
      <pre class="logo-art">████████╗ ███████╗ ██████╗   ██████╗
╚══███╔═╝ ██╔════╝ ██╔══██╗ ██╔═══██╗
  ███╔╝   █████╗   ██████╔╝ ██║   ██║
 ███╔╝    ██╔══╝   ██╔══██╗ ██║   ██║
████████╗ ███████╗ ██║  ██║ ╚██████╔╝
╚═══════╝ ╚══════╝ ╚═╝  ╚═╝  ╚═════╝</pre>
      <div class="crt-scanline"></div>
    </div>

    <h1 class="hero-title">Install a trading agent.<br>Your keys. Your machine. Your edge.</h1>

    <p class="hero-sub">
      Self-custodial AI that detects market regimes, manages your portfolio, 
      and rebalances automatically. 14 out of 15 coins profitable in Monte Carlo simulation.
    </p>

    <div class="hero-cta">
      <a href="#access" class="btn-primary">Request Early Access</a>
      <a href="#how" class="btn-ghost">How it works ↓</a>
      <a href="/thesis" class="btn-ghost">Read the thesis</a>
    </div>
  </header>

  <!-- LIVE SIGNAL MATRIX -->
  <section class="section matrix-section" id="signals">
    <div class="matrix-head">
      <p class="section-label p">SIGNAL MATRIX — LIVE</p>
      <span class="matrix-status" id="matrix-status">scanning</span>
    </div>
    <div class="matrix-wrap">
      <canvas id="matrix-canvas"></canvas>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="section reveal" id="how">
    <p class="section-label p reveal-child">HOW IT WORKS</p>
    <h2 class="section-title reveal-child">Three minutes. Then it runs forever.</h2>

    <div class="steps reveal-child">
      <div class="step tilt-card">
        <div class="step-num p">01</div>
        <h3 class="step-title">Install</h3>
        <p class="step-desc dim">One command. Runs on your machine. Your keys never leave your device. No cloud. No trust required.</p>
      </div>
      <div class="step tilt-card">
        <div class="step-num a">02</div>
        <h3 class="step-title">Connect</h3>
        <p class="step-desc dim">Link your exchange API. Set your risk limits. Choose your mode — from observation-only to fully autonomous.</p>
      </div>
      <div class="step tilt-card">
        <div class="step-num ice">03</div>
        <h3 class="step-title">Trade</h3>
        <p class="step-desc dim">The agent detects regimes, manages your portfolio, executes trades, and rebalances — 24/7, on your terms.</p>
      </div>
    </div>
  </section>

  <!-- MODES -->
  <section class="section reveal">
    <p class="section-label a reveal-child">MODES</p>
    <h2 class="section-title reveal-child">You choose the level of autonomy</h2>

    <div class="modes reveal-child">
      <div class="mode tilt-card">
        <div class="mode-header">
          <span class="mode-name">OBSERVE</span>
          <span class="mode-tag dim">FREE</span>
        </div>
        <p class="mode-desc dim">Watch the agent think. See regime shifts, signals, portfolio analysis. No trades executed. Training wheels.</p>
      </div>
      <div class="mode tilt-card">
        <div class="mode-header">
          <span class="mode-name a">SIGNAL</span>
          <span class="mode-tag a">COMPUTE</span>
        </div>
        <p class="mode-desc dim">Agent generates buy/sell signals with reasoning. You execute manually. Full control, informed decisions.</p>
      </div>
      <div class="mode tilt-card">
        <div class="mode-header">
          <span class="mode-name ice">SEMI-AUTO</span>
          <span class="mode-tag ice">COMPUTE</span>
        </div>
        <p class="mode-desc dim">Agent prepares trades and notifies you. One tap to approve. Kill switch always available.</p>
      </div>
      <div class="mode tilt-card mode-auto">
        <div class="mode-header">
          <span class="mode-name p">AUTO</span>
          <span class="mode-tag p">COMPUTE</span>
        </div>
        <p class="mode-desc dim">Full autonomy within your risk parameters. Portfolio management, rebalancing, position sizing — all regime-aware. 24/7.</p>
      </div>
    </div>
  </section>

  <!-- THE INTELLIGENCE -->
  <section class="section reveal">
    <p class="section-label p reveal-child">THE INTELLIGENCE</p>
    <h2 class="section-title reveal-child">Traditional indicators assume one regime. Markets have many.</h2>

    <div class="edge-contrast reveal-child">
      <div class="edge-row">
        <span class="edge-them dim">RSI says overbought</span>
        <span class="edge-us p">We know if RSI even applies in this regime</span>
      </div>
      <div class="edge-row">
        <span class="edge-them dim">MACD shows a crossover</span>
        <span class="edge-us p">We tell you if that crossover is meaningful or a trap ↓</span>
      </div>
    </div>

    <div class="regime-viz reveal-child">
      <div class="rv-bar-group">
        <div class="rv-bar">
          <span class="rv-label dim">HURST</span>
          <div class="rv-track">
            <div class="rv-fill" id="rv-hurst"></div>
            <div class="rv-marker" id="rv-hurst-marker"></div>
          </div>
          <span class="rv-val" id="rv-hurst-val">0.50</span>
        </div>
        <div class="rv-bar">
          <span class="rv-label dim">DFA</span>
          <div class="rv-track">
            <div class="rv-fill" id="rv-dfa"></div>
            <div class="rv-marker" id="rv-dfa-marker"></div>
          </div>
          <span class="rv-val" id="rv-dfa-val">0.50</span>
        </div>
        <div class="rv-bar">
          <span class="rv-label dim">LYAPUNOV</span>
          <div class="rv-track">
            <div class="rv-fill rv-fill-lyap" id="rv-lyap"></div>
            <div class="rv-marker" id="rv-lyap-marker"></div>
          </div>
          <span class="rv-val" id="rv-lyap-val">0.00</span>
        </div>
      </div>
      <div class="rv-output">
        <div class="rv-regime-badge" id="rv-badge">SCANNING</div>
        <p class="rv-verdict" id="rv-verdict">Your MACD crossover is → <span class="p">ANALYZING</span></p>
      </div>
    </div>
  </section>

  <!-- BACKTEST RESULTS -->
  <section class="section reveal">
    <p class="section-label a reveal-child">MONTE CARLO BACKTEST</p>
    <h2 class="section-title reveal-child">14 out of 15 coins profitable. Even at the 5th percentile.</h2>
    <p class="bt-sub dim reveal-child">Monte Carlo simulation across 15 assets. Median returns, worst-case scenarios, and drawdown limits — all from the Envy Matrix regime detection engine.</p>
    
    <div class="bt-table-wrap reveal-child">
      <table class="bt-table">
        <thead>
          <tr>
            <th class="bt-coin">COIN</th>
            <th>RETURN</th>
            <th>WIN RATE</th>
            <th>MAX DD</th>
            <th class="bt-hide-mobile">p5 RETURN*</th>
          </tr>
        </thead>
        <tbody>
          <tr><td class="bt-coin">BTC</td><td class="p">+52.2%</td><td>50.9%</td><td class="bt-dd">-14.9%</td><td class="p bt-hide-mobile">+35.3%</td></tr>
          <tr><td class="bt-coin">ETH</td><td class="p">+77.4%</td><td>39.8%</td><td class="bt-dd">-28.3%</td><td class="p bt-hide-mobile">+42.0%</td></tr>
          <tr><td class="bt-coin">SOL</td><td class="p">+86.5%</td><td>43.4%</td><td class="bt-dd">-16.0%</td><td class="p bt-hide-mobile">+50.4%</td></tr>
          <tr><td class="bt-coin">ARB</td><td class="p">+95.8%</td><td>37.1%</td><td class="bt-dd">-23.1%</td><td class="p bt-hide-mobile">+45.6%</td></tr>
          <tr><td class="bt-coin">CRV</td><td class="p">+127.0%</td><td>34.7%</td><td class="bt-dd bt-dd-hot">-31.5%</td><td class="p bt-hide-mobile">+43.7%</td></tr>
          <tr><td class="bt-coin">KPEPE</td><td class="p">+256.1%</td><td>37.7%</td><td class="bt-dd">-20.4%</td><td class="p bt-hide-mobile">+165.0%</td></tr>
          <tr><td class="bt-coin">KBONK</td><td class="p">+224.6%</td><td>32.6%</td><td class="bt-dd bt-dd-hot">-29.2%</td><td class="p bt-hide-mobile">+143.2%</td></tr>
          <tr><td class="bt-coin">TRX</td><td class="p">+59.4%</td><td class="bt-wr-best">61.3%</td><td class="bt-dd bt-dd-safe">-8.3%</td><td class="p bt-hide-mobile">+47.8%</td></tr>
          <tr><td class="bt-coin">DOGE</td><td class="p">+47.6%</td><td>38.2%</td><td class="bt-dd">-19.7%</td><td class="p bt-hide-mobile">+20.1%</td></tr>
          <tr><td class="bt-coin">KSHIB</td><td class="p">+117.7%</td><td>43.0%</td><td class="bt-dd">-17.8%</td><td class="p bt-hide-mobile">+70.7%</td></tr>
          <tr class="bt-neg"><td class="bt-coin">PAXG</td><td class="dim">-5.1%</td><td>49.2%</td><td class="bt-dd bt-dd-safe">-11.3%</td><td class="red bt-hide-mobile">-14.1%</td></tr>
        </tbody>
      </table>
    </div>

    <p class="bt-footnote dim reveal-child">* p5 = 5th percentile of Monte Carlo simulations. 95% of outcomes were better than this number.</p>

    <div class="bt-highlights reveal-child">
      <div class="bt-stat tilt-card">
        <div class="bt-stat-val p">14/15</div>
        <div class="bt-stat-label dim">coins profitable at median</div>
      </div>
      <div class="bt-stat tilt-card">
        <div class="bt-stat-val a">37%</div>
        <div class="bt-stat-label dim">avg win rate — wins are 3-5x larger than losses</div>
      </div>
      <div class="bt-stat tilt-card">
        <div class="bt-stat-val ice">p5 positive</div>
        <div class="bt-stat-label dim">even the worst 5% of simulations are profitable</div>
      </div>
    </div>
  </section>

  <!-- COMPUTE -->
  <section class="section reveal">
    <p class="section-label p reveal-child">COMPUTE</p>
    <h2 class="section-title reveal-child">Pay for intelligence with your wallet</h2>

    <div class="compute-desc reveal-child">
      <p class="dim" style="font-size: 0.65rem; line-height: 1.7; max-width: 500px;">Observe mode is free. Signal, Semi-Auto, and Auto modes consume compute — regime detection, Monte Carlo simulations, strategy updates. Pay directly from your wallet with any token. No subscriptions. No fiat. Crypto-native.</p>
    </div>
  </section>

  <!-- SELF-CUSTODIAL -->
  <section class="section reveal">
    <p class="section-label ice reveal-child">SELF-CUSTODIAL</p>
    <h2 class="section-title reveal-child">Your keys never leave your machine</h2>

    <div class="custody-grid reveal-child">
      <div class="custody-item">
        <span class="custody-num p">01</span>
        <span class="custody-label">API keys stored locally, encrypted at rest</span>
      </div>
      <div class="custody-item">
        <span class="custody-num p">02</span>
        <span class="custody-label">All trades execute from your device</span>
      </div>
      <div class="custody-item">
        <span class="custody-num p">03</span>
        <span class="custody-label">Kill switch — pause everything instantly</span>
      </div>
      <div class="custody-item">
        <span class="custody-num p">04</span>
        <span class="custody-label">Built-in position limits and daily loss caps</span>
      </div>
      <div class="custody-item">
        <span class="custody-num p">05</span>
        <span class="custody-label">No cloud dependency — runs offline if needed</span>
      </div>
    </div>
  </section>

  <!-- TERMINAL CTA (with status merged) -->
  <section class="section cta-section reveal" id="access">
    <div class="term-cta reveal-child">
      <div class="term-header">
        <span class="dim">zero-os</span>
        <span class="term-dots">
          <span class="dot dot-r"></span>
          <span class="dot dot-a"></span>
          <span class="dot dot-p"></span>
        </span>
      </div>
      <div class="term-body">
        <p class="term-line dim term-cursor">$ zero-os --status</p>
        <p class="term-line"><span class="p">&gt;</span> Regime detection engine: <span class="p">BUILT</span></p>
        <p class="term-line"><span class="p">&gt;</span> Signal API: <span class="a">PRE-LAUNCH</span></p>
        <p class="term-line"><span class="p">&gt;</span> Seeking design partners — funds and desks who want first access.</p>
        <p class="term-line dim" style="margin-top:0.5rem">$ zero-os request_access</p>
        <form class="term-form" id="access-form" action="#" method="POST">
          <div class="term-input-row">
            <span class="p">email:</span>
            <input type="email" id="access-email" class="term-input" placeholder="you@fund.com" required autocomplete="email">
          </div>
          <button type="submit" class="term-submit">SUBMIT ↵</button>
        </form>
        <p class="term-confirm" id="term-confirm" style="display:none">
          <span class="p">✓ ACCESS_REQUEST_QUEUED</span><br>
          <span class="dim">ref: ZOS-<span id="req-id">0000</span> — we'll be in touch.</span>
        </p>
        <p class="term-error" id="term-error" style="display:none">
          <span class="red">✗ CONNECTION_ERROR</span><br>
          <span class="dim">Try again or email <a href="mailto:degenie@getzero.dev" style="color:var(--phosphor);">degenie@getzero.dev</a> directly.</span>
        </p>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer reveal">
    <span class="p">◇</span> <span class="dim">ZERO OS</span>
  </footer>

</div>

</BaseLayout>

<style>
  .page {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  /* CRT */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.05) 2px, rgba(0,0,0,0.05) 4px);
    pointer-events: none;
    z-index: 100;
  }
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse 70% 70% at 50% 50%, transparent 0%, transparent 85%, rgba(0,0,0,0.15) 92%, rgba(0,0,0,0.4) 100%);
    pointer-events: none;
    z-index: 101;
  }

  /* HERO */
  .hero { padding: 2.5rem 0 2rem; border-bottom: 1px solid var(--border); }
  .boot-sequence { margin-bottom: 1.25rem; }
  .boot-line {
    font-family: var(--font-head);
    font-size: clamp(0.4rem, 2.5vw, 0.55rem);
    color: var(--text-dim);
    margin: 0;
    line-height: 1.8;
    opacity: 0;
    animation: bootIn 0.3s ease forwards;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .b1 { animation-delay: 0.2s; }
  .b2 { animation-delay: 0.5s; }
  .b3 { animation-delay: 0.8s; }
  @keyframes bootIn {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .logo-wrap { position: relative; margin-bottom: 1.5rem; overflow: hidden; }
  .logo-art {
    font-family: var(--font-head);
    font-size: clamp(7px, calc((100vw - 30px) / 38), 22px);
    line-height: 1.15;
    color: var(--phosphor);
    text-shadow: 0 0 8px var(--phosphor-glow), 0 0 24px rgba(200,255,0,0.12);
    white-space: pre;
    margin: 0;
    background: transparent;
    border: none;
    animation: logoIn 0.6s ease 1s both;
  }
  @keyframes logoIn {
    0% { opacity: 0; filter: brightness(4) blur(2px); }
    50% { opacity: 0.7; filter: brightness(1.8) blur(0.5px); }
    100% { opacity: 1; filter: brightness(1); }
  }
  .crt-scanline {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--phosphor);
    opacity: 0.06;
    animation: scanDrop 3s linear infinite;
    pointer-events: none;
  }
  @keyframes scanDrop { 0% { top: 0; } 100% { top: 100%; } }

  .hero-title {
    font-family: var(--font-head);
    font-size: clamp(1.3rem, 4.5vw, 2rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--text);
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
    animation: fadeUp 0.5s ease 1.4s both;
  }
  .hero-sub {
    font-size: 0.8rem;
    color: var(--text-dim);
    line-height: 1.7;
    max-width: 480px;
    margin-bottom: 1.25rem;
    animation: fadeUp 0.5s ease 1.6s both;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-cta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    animation: fadeUp 0.5s ease 1.8s both;
  }
  .btn-primary {
    font-family: var(--font-head);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--bg);
    background: var(--phosphor);
    border: none;
    padding: 0.6rem 1.2rem;
    text-decoration: none;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .btn-primary:hover { opacity: 0.85; }
  .btn-ghost {
    font-family: var(--font-head);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--text-dim);
    padding: 0.6rem 1.2rem;
    text-decoration: none;
    border: 1px solid var(--border);
    transition: border-color 0.15s, color 0.15s;
  }
  .btn-ghost:hover { border-color: var(--text-dim); color: var(--text); }

  /* ═══ ORCHESTRATED BOOT SEQUENCE ═══ */
  .matrix-section {
    opacity: 0;
    transform: translateY(16px);
    animation: sectionIn 0.8s ease 2.4s both;
  }
  @keyframes sectionIn {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Number counter animation */
  .counter-animate {
    display: inline-block;
    animation: counterPop 0.4s ease both;
  }
  @keyframes counterPop {
    0% { opacity: 0; transform: translateY(8px) scale(0.8); }
    60% { transform: translateY(-2px) scale(1.05); }
    100% { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* Step/card stagger entrance */
  .reveal.visible .step:nth-child(1),
  .reveal.visible .mode:nth-child(1) { transition-delay: 0s; }
  .reveal.visible .step:nth-child(2),
  .reveal.visible .mode:nth-child(2) { transition-delay: 0.12s; }
  .reveal.visible .step:nth-child(3),
  .reveal.visible .mode:nth-child(3) { transition-delay: 0.24s; }
  .reveal.visible .mode:nth-child(4) { transition-delay: 0.36s; }

  .step, .mode {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.5s ease, transform 0.5s ease, border-color 0.4s, box-shadow 0.4s;
  }
  .reveal.visible .step,
  .reveal.visible .mode {
    opacity: 1;
    transform: translateY(0);
  }

  /* Custody items stagger */
  .custody-item {
    opacity: 0;
    transform: translateX(-8px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .reveal.visible .custody-item:nth-child(1) { transition-delay: 0s; }
  .reveal.visible .custody-item:nth-child(2) { transition-delay: 0.08s; }
  .reveal.visible .custody-item:nth-child(3) { transition-delay: 0.16s; }
  .reveal.visible .custody-item:nth-child(4) { transition-delay: 0.24s; }
  .reveal.visible .custody-item:nth-child(5) { transition-delay: 0.32s; }
  .reveal.visible .custody-item {
    opacity: 1;
    transform: translateX(0);
  }

  /* Hover micro-interactions */
  .tilt-card {
    transform: perspective(600px) rotateX(var(--tilt-x, 0deg)) rotateY(var(--tilt-y, 0deg));
    transition: transform 0.15s ease, border-color 0.4s, box-shadow 0.4s;
    will-change: transform;
  }
  .step:hover, .mode:hover {
    border-color: rgba(200,255,0,0.12);
    box-shadow: 0 0 16px rgba(200,255,0,0.03);
  }
  .custody-item:hover .custody-num {
    text-shadow: 0 0 8px var(--phosphor-glow);
    transition: text-shadow 0.3s;
  }

  /* Edge row entrance */
  .edge-row {
    opacity: 0;
    transform: translateX(-12px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .reveal.visible .edge-row:nth-child(1) { transition-delay: 0.1s; }
  .reveal.visible .edge-row:nth-child(2) { transition-delay: 0.25s; }
  .reveal.visible .edge-row {
    opacity: 1;
    transform: translateX(0);
  }

  /* Backtest table row entrance — only plays when parent section is visible */
  .bt-table tbody tr {
    opacity: 0;
    transform: translateY(6px);
  }
  .reveal.visible .bt-table tbody tr {
    animation: rowIn 0.3s ease both;
  }
  .reveal.visible .bt-table tbody tr:nth-child(1) { animation-delay: 0.05s; }
  .reveal.visible .bt-table tbody tr:nth-child(2) { animation-delay: 0.09s; }
  .reveal.visible .bt-table tbody tr:nth-child(3) { animation-delay: 0.13s; }
  .reveal.visible .bt-table tbody tr:nth-child(4) { animation-delay: 0.17s; }
  .reveal.visible .bt-table tbody tr:nth-child(5) { animation-delay: 0.21s; }
  .reveal.visible .bt-table tbody tr:nth-child(6) { animation-delay: 0.25s; }
  .reveal.visible .bt-table tbody tr:nth-child(7) { animation-delay: 0.29s; }
  .reveal.visible .bt-table tbody tr:nth-child(8) { animation-delay: 0.33s; }
  .reveal.visible .bt-table tbody tr:nth-child(9) { animation-delay: 0.37s; }
  .reveal.visible .bt-table tbody tr:nth-child(10) { animation-delay: 0.41s; }
  .reveal.visible .bt-table tbody tr:nth-child(11) { animation-delay: 0.45s; }
