---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ZERO ARENA — Agent Leaderboard" description="Public leaderboard tracking autonomous trading agents on Hyperliquid. Every agent. On-chain. Verified.">
  <div class="page">
    <div class="terminal-border">

      <!-- NAV BAR -->
      <div class="nav-bar">
        <a href="/" class="nav-item nav-active">◇ ZERO ARENA</a>
        <a href="/portfolio" class="nav-item">PORTFOLIO</a>
        <a href="/thesis" class="nav-item">THESIS</a>
        <span class="nav-live"><span class="live-dot">●</span> LIVE ON HYPERLIQUID</span>
      </div>

      <!-- HEADER -->
      <div class="arena-header">
        <h1 class="arena-title">ZERO ARENA</h1>
        <p class="arena-sub">Every agent. On-chain. Verified.</p>
      </div>

      <!-- AGGREGATE STATS -->
      <div class="stats-bar" id="stats-bar">
        <div class="stat-item">
          <div class="stat-label">AGENTS TRACKED</div>
          <div class="stat-value" id="stat-agents">—</div>
        </div>
        <div class="stat-item">
          <div class="stat-label">7D VOLUME</div>
          <div class="stat-value" id="stat-volume">—</div>
        </div>
        <div class="stat-item">
          <div class="stat-label">PROFITABLE</div>
          <div class="stat-value" id="stat-profitable">—</div>
        </div>
        <div class="stat-item">
          <div class="stat-label">BEST 7D RETURN</div>
          <div class="stat-value" id="stat-best-return">—</div>
        </div>
      </div>

      <!-- TIMEFRAME SELECTOR -->
      <div class="section">
        <div class="ph tf-bar">
          <span>LEADERBOARD</span>
          <div class="tf-selector">
            <button class="tf-btn" data-tf="1">24H</button>
            <button class="tf-btn tf-active" data-tf="7">7D</button>
            <button class="tf-btn" data-tf="30">30D</button>
            <button class="tf-btn" data-tf="0">ALL</button>
          </div>
        </div>

        <!-- LEADERBOARD TABLE -->
        <div class="table-wrap">
          <table class="lb-table" id="lb-table">
            <thead>
              <tr>
                <th class="col-rank sortable" data-sort="rank">#</th>
                <th class="col-name sortable" data-sort="name">AGENT</th>
                <th class="col-wallet">WALLET</th>
                <th class="col-curve">EQUITY</th>
                <th class="col-return sortable sorted-desc" data-sort="return">RETURN %</th>
                <th class="col-trades sortable" data-sort="trades">TRADES</th>
                <th class="col-wr sortable" data-sort="winRate">WIN RATE</th>
                <th class="col-dd sortable" data-sort="maxDD">MAX DD</th>
                <th class="col-pf sortable" data-sort="pf">PF</th>
              </tr>
            </thead>
            <tbody id="lb-body">
              <tr><td colspan="9" class="muted loading-row">Fetching agent data...</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- SUBMIT FORM -->
      <div class="section">
        <div class="ph">TRACK AN AGENT</div>
        <div class="sb submit-wrap">
          <form id="track-form" autocomplete="off">
            <input type="text" id="wallet-input" placeholder="0x... wallet address" spellcheck="false" />
            <button type="submit" class="btn-track">TRACK AGENT</button>
          </form>
          <div class="submit-error" id="submit-error"></div>
        </div>
      </div>

      <!-- FOOTER -->
      <div class="footer">
        <a href="/" class="footer-link">◇ ZERO ARENA</a>
        <span class="dim" id="updated">—</span>
      </div>

    </div>
  </div>
</BaseLayout>

<style is:global>
  /* ─── PAGE ─── */
  .page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1rem;
    min-height: 100vh;
  }
  .terminal-border {
    border: 1px solid rgba(200,255,0,0.25);
    min-height: 100vh;
  }

  /* ─── NAV BAR ─── */
  .nav-bar {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 0.5rem 1rem;
    border-bottom: 1px solid var(--border);
    font-family: var(--font-head);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .nav-item {
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-item:hover { color: var(--phosphor); }
  .nav-active { color: var(--phosphor); }
  .nav-live {
    margin-left: auto;
    font-family: var(--font-head);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    color: var(--phosphor);
    text-transform: uppercase;
  }
  .live-dot {
    color: #00ff00;
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  /* ─── HEADER ─── */
  .arena-header {
    padding: 2rem 1rem 1.5rem;
    border-bottom: 1px solid var(--border);
    text-align: center;
  }
  .arena-title {
    font-family: var(--font-head);
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 800;
    color: var(--phosphor);
    letter-spacing: 0.1em;
    line-height: 1;
    margin-bottom: 0.5rem;
  }
  .arena-sub {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--text-dim);
    letter-spacing: 0.05em;
  }

  /* ─── STATS BAR ─── */
  .stats-bar {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-bottom: 1px solid var(--border);
  }
  .stat-item {
    padding: 0.75rem 1rem;
    border-right: 1px solid var(--border);
    text-align: center;
  }
  .stat-item:last-child { border-right: none; }
  .stat-label {
    font-family: var(--font-head);
    font-size: 0.5rem;
    letter-spacing: 0.12em;
    color: var(--text-dim);
    text-transform: uppercase;
    margin-bottom: 0.25rem;
  }
  .stat-value {
    font-family: var(--font-head);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--phosphor);
  }

  /* ─── SECTION ─── */
  .section {
    border-bottom: 1px solid var(--border);
    margin-bottom: 0.5rem;
  }
  .ph {
    font-family: var(--font-head);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text);
    padding: 0.5rem 1rem 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border);
    border-left: 2px solid rgba(200,255,0,0.4);
    background: rgba(0,0,0,0.6);
  }
  .sb { padding: 0.75rem 1rem 1rem; }
  .dim { opacity: 0.5; font-size: 0.6rem; }
  .muted {
    font-family: var(--font-head);
    font-size: 0.8rem;
    color: var(--text-dim);
    opacity: 0.4;
  }

  /* ─── TIMEFRAME BAR ─── */
  .tf-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .tf-selector {
    display: flex;
    gap: 0.25rem;
  }
  .tf-btn {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-dim);
    font-family: var(--font-head);
    font-size: 0.55rem;
    letter-spacing: 0.1em;
    padding: 0.2rem 0.5rem;
    cursor: pointer;
    transition: all 0.15s;
  }
  .tf-btn:hover { border-color: var(--phosphor); color: var(--text); }
  .tf-btn.tf-active {
    border-color: var(--phosphor);
    color: var(--phosphor);
    background: rgba(200,255,0,0.08);
  }

  /* ─── TABLE ─── */
  .table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .lb-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-body);
    font-size: 0.75rem;
    white-space: nowrap;
  }
  .lb-table thead th {
    font-family: var(--font-head);
    font-size: 0.55rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    padding: 0.5rem 0.6rem;
    text-align: right;
    border-bottom: 1px solid var(--border);
    user-select: none;
  }
  .lb-table thead th.sortable { cursor: pointer; }
  .lb-table thead th.sortable:hover { color: var(--phosphor); }
  .lb-table thead th.sorted-asc::after { content: ' ▲'; color: var(--phosphor); }
  .lb-table thead th.sorted-desc::after { content: ' ▼'; color: var(--phosphor); }
  .col-rank, .col-name { text-align: left; }
  .col-rank { width: 2.5rem; }
  .col-name { min-width: 7rem; }
  .col-wallet { text-align: left; min-width: 6rem; }
  .col-curve { text-align: center; min-width: 5rem; }

  .lb-table tbody td {
    padding: 0.5rem 0.6rem;
    border-bottom: 1px solid rgba(26,26,26,0.6);
    text-align: right;
    vertical-align: middle;
  }
  .lb-table tbody td:first-child,
  .lb-table tbody td:nth-child(2),
  .lb-table tbody td:nth-child(3) { text-align: left; }
  .lb-table tbody td:nth-child(4) { text-align: center; }

  .lb-table tbody tr {
    transition: background 0.15s;
  }
  .lb-table tbody tr:hover {
    background: rgba(200,255,0,0.03);
  }
  .loading-row {
    text-align: center !important;
    padding: 2rem !important;
  }

  /* ZERO OS row highlight */
  .row-zero {
    border-left: 2px solid var(--phosphor);
    background: rgba(200,255,0,0.02);
  }
  .row-zero:hover {
    background: rgba(200,255,0,0.06) !important;
  }
  .tag-our {
    font-family: var(--font-head);
    font-size: 0.45rem;
    letter-spacing: 0.08em;
    color: var(--phosphor);
    border: 1px solid rgba(200,255,0,0.35);
    padding: 0.1rem 0.3rem;
    margin-left: 0.4rem;
    vertical-align: middle;
  }
  .agent-name {
    font-weight: 600;
    color: var(--text);
  }
  .wallet-link {
    color: var(--text-dim);
    text-decoration: none;
    font-size: 0.7rem;
  }
  .wallet-link:hover {
    color: var(--phosphor);
    text-decoration: underline;
  }
  .val-green { color: var(--phosphor); }
  .val-red { color: var(--red); }
  .val-dim { color: var(--text-dim); }

  /* Sparkline */
  .sparkline {
    display: inline-flex;
    align-items: flex-end;
    gap: 1px;
    height: 20px;
    vertical-align: middle;
  }
  .spark-bar {
    width: 3px;
    min-height: 1px;
    border-radius: 1px 1px 0 0;
  }

  /* ─── SUBMIT FORM ─── */
  .submit-wrap { padding: 1rem; }
  #track-form {
    display: flex;
    gap: 0.5rem;
  }
  #wallet-input {
    flex: 1;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: var(--font-body);
    font-size: 0.8rem;
    padding: 0.5rem 0.75rem;
    outline: none;
    transition: border-color 0.2s;
  }
  #wallet-input:focus {
    border-color: var(--phosphor);
  }
  #wallet-input::placeholder {
    color: var(--text-dim);
    opacity: 0.5;
  }
  .btn-track {
    background: transparent;
    border: 1px solid var(--phosphor);
    color: var(--phosphor);
    font-family: var(--font-head);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    padding: 0.5rem 1rem;
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .btn-track:hover {
    background: rgba(200,255,0,0.1);
  }
  .submit-error {
    font-family: var(--font-head);
    font-size: 0.65rem;
    color: var(--red);
    margin-top: 0.5rem;
    min-height: 1em;
  }

  /* ─── FOOTER ─── */
  .footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
    font-family: var(--font-head);
    font-size: 0.55rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .footer-link {
    color: var(--text-dim);
    text-decoration: none;
  }
  .footer-link:hover { color: var(--phosphor); }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 640px) {
    .stats-bar {
      grid-template-columns: repeat(2, 1fr);
    }
    .stat-item:nth-child(2) { border-right: none; }
    .arena-title { font-size: 2rem; }
    #track-form { flex-direction: column; }
    .btn-track { width: 100%; }
  }
</style>

<script is:inline>
(function() {
  'use strict';

  const HL_API = 'https://api.hyperliquid.xyz/info';
  const ZERO_WALLET = '0xC7b52216e7BC13de0cd010aa12CAcb6D774453a2';
  const STORAGE_KEY = 'arena_wallets';
  const CACHE_KEY = 'arena_fills_cache';
  const EXPLORER = 'https://app.hyperliquid.xyz/explorer/address/';

  // ─── State ───
  let agents = [];
  let currentTf = 7; // days, 0 = all
  let sortKey = 'return';
  let sortAsc = false;
  let fillsCache = {};

  // ─── Helpers ───
  function shortAddr(a) { return a.slice(0, 6) + '…' + a.slice(-4); }
  function fmt$(v) {
    if (v == null || isNaN(v)) return '—';
    if (Math.abs(v) >= 1e6) return '$' + (v / 1e6).toFixed(2) + 'M';
    if (Math.abs(v) >= 1e3) return '$' + (v / 1e3).toFixed(1) + 'K';
    return '$' + v.toFixed(2);
  }
  function fmtPct(v) {
    if (v == null || isNaN(v)) return '—';
    return (v >= 0 ? '+' : '') + v.toFixed(2) + '%';
  }
  function fmtNum(v) {
    if (v == null || isNaN(v)) return '—';
    return v.toLocaleString();
  }

  // ─── localStorage for tracked wallets ───
  function getTracked() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (raw) {
        const arr = JSON.parse(raw);
        // Always include ZERO wallet
        if (!arr.find(w => w.addr.toLowerCase() === ZERO_WALLET.toLowerCase())) {
          arr.unshift({ addr: ZERO_WALLET, name: 'ZERO OS' });
        }
        return arr;
      }
    } catch(e) {}
    return [{ addr: ZERO_WALLET, name: 'ZERO OS' }];
  }
  function saveTracked(list) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(list));
  }

  // ─── Fills cache (incremental) ───
  function loadFillsCache() {
    try {
      const raw = localStorage.getItem(CACHE_KEY);
      if (raw) fillsCache = JSON.parse(raw);
    } catch(e) { fillsCache = {}; }
  }
  function saveFillsCache() {
    try {
      // Keep only last 10 agents to avoid quota issues
      const keys = Object.keys(fillsCache);
      if (keys.length > 10) {
        const keep = keys.slice(-10);
        const trimmed = {};
        keep.forEach(k => trimmed[k] = fillsCache[k]);
        fillsCache = trimmed;
      }
      localStorage.setItem(CACHE_KEY, JSON.stringify(fillsCache));
    } catch(e) {}
  }

  // ─── HL API fetch ───
  async function hlPost(type, user, extra) {
    const body = { type, user, ...extra };
    const res = await fetch(HL_API, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    if (!res.ok) throw new Error(`HL API ${res.status}`);
    return res.json();
  }

  // ─── Fetch all fills, paginated ───
  async function fetchAllFills(addr) {
    const cached = fillsCache[addr.toLowerCase()] || { fills: [], lastTime: 0 };
    let allFills = cached.fills;
    let startTime = cached.lastTime || 0;
    let page = 0;
    const PAGE_SIZE = 500; // default page size from HL

    // Fetch new fills since last cached time
    while (true) {
      let params = { aggregateByTime: false };
      if (startTime > 0) params.startTime = startTime;

      const batch = await hlPost('userFills', addr, params);
      if (!batch || batch.length === 0) break;

      // Merge only new fills (dedupe by time+coin+side)
      const existingKeys = new Set(allFills.map(f => f.time + f.coin + f.side));
      let newCount = 0;
      for (const f of batch) {
        const key = f.time + f.coin + f.side;
        if (!existingKeys.has(key)) {
          allFills.push(f);
          existingKeys.add(key);
          newCount++;
        }
      }

      if (batch.length < PAGE_SIZE || newCount === 0) break;
      startTime = batch[batch.length - 1].time + 1;
      page++;
      if (page > 20) break; // safety
    }

    // Sort chronologically
    allFills.sort((a, b) => a.time - b.time);

    // Update cache
    if (allFills.length > 0) {
      fillsCache[addr.toLowerCase()] = {
        fills: allFills,
        lastTime: allFills[allFills.length - 1].time
      };
    }

    return allFills;
  }

  // ─── Compute metrics from fills ───
  function computeMetrics(fills, tfDays) {
    const now = Date.now();
    const cutoff = tfDays > 0 ? now - tfDays * 86400000 : 0;
    const filtered = fills.filter(f => f.time >= cutoff);

    if (filtered.length === 0) {
      return { returnPct: 0, trades: 0, winRate: 0, maxDD: 0, pf: 0, netPnl: 0, volume: 0, curve: [] };
    }

    let totalWin = 0, totalLoss = 0, wins = 0, trades = 0, volume = 0;
    let curve = [];
    let cumPnl = 0;
    let peak = 0, maxDD = 0;

    for (const f of filtered) {
      const pnl = parseFloat(f.closedPnl || '0');
      const fee = parseFloat(f.fee || '0');
      const sz = parseFloat(f.sz || '0');
      const px = parseFloat(f.px || '0');
      volume += sz * px;

      if (pnl !== 0) {
        const net = pnl - fee;
        cumPnl += net;
        trades++;
        if (net > 0) { totalWin += net; wins++; }
        else { totalLoss += Math.abs(net); }

        if (cumPnl > peak) peak = cumPnl;
        const dd = peak > 0 ? ((peak - cumPnl) / peak) * 100 : 0;
        if (dd > maxDD) maxDD = dd;

        curve.push(cumPnl);
      }
    }

    return {
      returnPct: cumPnl, // raw P&L, will convert to % once we have equity
      netPnl: cumPnl,
      trades,
      winRate: trades > 0 ? (wins / trades) * 100 : 0,
      maxDD,
      pf: totalLoss > 0 ? totalWin / totalLoss : (totalWin > 0 ? Infinity : 0),
      volume,
      curve
    };
  }

  // ─── Fetch single agent data ───
  async function fetchAgent(tracked) {
    const addr = tracked.addr;
    try {
      const [clearing, spotClearing, fills] = await Promise.all([
        hlPost('clearinghouseState', addr),
        hlPost('spotClearinghouseState', addr),
        fetchAllFills(addr)
      ]);

      const perpValue = parseFloat(clearing?.marginSummary?.accountValue || '0');
      const spotBalances = spotClearing?.balances || [];
      const usdcBal = spotBalances.find(b => b.coin === 'USDC');
      const spotUSDC = parseFloat(usdcBal?.total || '0');
      const equity = spotUSDC + perpValue;

      const metrics = computeMetrics(fills, currentTf);

      // Return % relative to starting equity
      const startEquity = equity - metrics.netPnl;
      const returnPct = startEquity > 0 ? (metrics.netPnl / startEquity) * 100 : 0;

      return {
        addr,
        name: tracked.name || shortAddr(addr),
        isZero: addr.toLowerCase() === ZERO_WALLET.toLowerCase(),
        equity,
        returnPct,
        ...metrics,
        returnPct // override with computed %
      };
    } catch(e) {
      console.warn('Failed to fetch agent', addr, e);
      return {
        addr,
        name: tracked.name || shortAddr(addr),
        isZero: addr.toLowerCase() === ZERO_WALLET.toLowerCase(),
        equity: 0, returnPct: 0, trades: 0, winRate: 0, maxDD: 0, pf: 0, netPnl: 0, volume: 0, curve: []
      };
    }
  }

  // ─── Render sparkline ───
  function renderSparkline(curve) {
    if (!curve || curve.length < 2) return '<span class="val-dim">—</span>';
    // Take last 14 points
    const pts = curve.slice(-14);
    const maxAbs = Math.max(...pts.map(Math.abs), 0.01);
    let html = '<div class="sparkline">';
    for (let i = 0; i < pts.length; i++) {
      const v = pts[i];
      const prev = i > 0 ? pts[i - 1] : 0;
      const delta = v - prev;
      const h = Math.max(1, Math.round((Math.abs(v) / maxAbs) * 18));
      const color = delta >= 0 ? 'var(--phosphor)' : 'var(--red)';
      html += `<div class="spark-bar" style="height:${h}px;background:${color}"></div>`;
    }
    html += '</div>';
    return html;
  }

  // ─── Render table ───
  function renderTable() {
    const tbody = document.getElementById('lb-body');
    if (agents.length === 0) {
      tbody.innerHTML = '<tr><td colspan="9" class="muted loading-row">No agents tracked yet</td></tr>';
      return;
    }

    // Sort
    const sorted = [...agents];
    sorted.sort((a, b) => {
      let va, vb;
      switch (sortKey) {
        case 'rank': case 'return': va = a.returnPct; vb = b.returnPct; break;
        case 'name': return sortAsc ? a.name.localeCompare(b.name) : b.name.localeCompare(a.name);
        case 'trades': va = a.trades; vb = b.trades; break;
        case 'winRate': va = a.winRate; vb = b.winRate; break;
        case 'maxDD': va = a.maxDD; vb = b.maxDD; break;
        case 'pf': va = a.pf === Infinity ? 9999 : a.pf; vb = b.pf === Infinity ? 9999 : b.pf; break;
        default: va = a.returnPct; vb = b.returnPct;
      }
      return sortAsc ? va - vb : vb - va;
    });

    let html = '';
    sorted.forEach((ag, i) => {
      const rank = i + 1;
      const isZero = ag.isZero;
      const rowClass = isZero ? 'row-zero' : '';
      const nameHtml = isZero
        ? `<span class="agent-name">${ag.name}</span><span class="tag-our">OUR AGENT</span>`
        : `<span class="agent-name">${ag.name}</span>`;
      const retClass = ag.returnPct >= 0 ? 'val-green' : 'val-red';
      const pfDisplay = ag.pf === Infinity ? '∞' : ag.pf.toFixed(2);

      html += `<tr class="${rowClass}">
        <td>${rank}</td>
        <td>${nameHtml}</td>
        <td><a class="wallet-link" href="${EXPLORER}${ag.addr}" target="_blank" rel="noopener">${shortAddr(ag.addr)}</a></td>
        <td>${renderSparkline(ag.curve)}</td>
        <td class="${retClass}">${fmtPct(ag.returnPct)}</td>
        <td>${fmtNum(ag.trades)}</td>
        <td>${ag.winRate.toFixed(1)}%</td>
        <td class="val-red">${ag.maxDD.toFixed(2)}%</td>
        <td>${pfDisplay}</td>
      </tr>`;
    });

    tbody.innerHTML = html;
  }

  // ─── Update aggregate stats ───
  function updateStats() {
    const el = (id) => document.getElementById(id);
    el('stat-agents').textContent = agents.length;

    const totalVol = agents.reduce((s, a) => s + (a.volume || 0), 0);
    el('stat-volume').textContent = fmt$(totalVol);

    const profitable = agents.filter(a => a.returnPct > 0).length;
    el('stat-profitable').textContent = `${profitable}/${agents.length}`;

    const best = agents.reduce((b, a) => Math.max(b, a.returnPct), -Infinity);
    const bestEl = el('stat-best-return');
    bestEl.textContent = agents.length > 0 ? fmtPct(best) : '—';
    bestEl.className = 'stat-value ' + (best >= 0 ? 'val-green' : 'val-red');

    el('updated').textContent = 'Updated ' + new Date().toLocaleTimeString();
  }

  // ─── Master refresh ───
  let refreshing = false;
  async function refreshAll() {
    if (refreshing) return;
    refreshing = true;

    const tracked = getTracked();
    const results = await Promise.all(tracked.map(t => fetchAgent(t)));
    agents = results;

    saveFillsCache();
    renderTable();
    updateStats();
    refreshing = false;
  }

  // ─── Sort click handler ───
  function setupSort() {
    document.querySelectorAll('.sortable').forEach(th => {
      th.addEventListener('click', () => {
        const key = th.dataset.sort;
        if (sortKey === key) {
          sortAsc = !sortAsc;
        } else {
          sortKey = key;
          sortAsc = false;
        }
        // Update header classes
        document.querySelectorAll('.sortable').forEach(h => {
          h.classList.remove('sorted-asc', 'sorted-desc');
        });
        th.classList.add(sortAsc ? 'sorted-asc' : 'sorted-desc');
        renderTable();
      });
    });
  }

  // ─── Timeframe selector ───
  function setupTf() {
    document.querySelectorAll('.tf-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.tf-btn').forEach(b => b.classList.remove('tf-active'));
        btn.classList.add('tf-active');
        currentTf = parseInt(btn.dataset.tf);
        refreshAll();
      });
    });
  }

  // ─── Submit form ───
  function setupForm() {
    const form = document.getElementById('track-form');
    const input = document.getElementById('wallet-input');
    const error = document.getElementById('submit-error');

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const val = input.value.trim();
      error.textContent = '';

      if (!/^0x[a-fA-F0-9]{40}$/.test(val)) {
        error.textContent = 'Invalid Ethereum address format';
        return;
      }

      const tracked = getTracked();
      if (tracked.find(w => w.addr.toLowerCase() === val.toLowerCase())) {
        error.textContent = 'Agent already tracked';
        return;
      }

      tracked.push({ addr: val, name: shortAddr(val) });
      saveTracked(tracked);
      input.value = '';
      refreshAll();
    });
  }

  // ─── Refresh scheduler ───
  function startScheduler() {
    // Top 10 every 60s, rest every 5min
    setInterval(() => {
      refreshAll();
    }, 60000);
  }

  // ─── Init ───
  function init() {
    loadFillsCache();
    setupSort();
    setupTf();
    setupForm();
    refreshAll();
    startScheduler();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
