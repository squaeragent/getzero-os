---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ZERO OS — Trading Intelligence Infrastructure">

<div class="page">

  <!-- CRT BOOT -->
  <header class="hero">
    <div class="boot-sequence">
      <pre class="boot-line b1"><span class="p">ZERO OS</span> v0.1 .................... <span class="p">INIT</span></pre>
      <pre class="boot-line b2"><span class="p">SIGNAL MATRIX</span> ................... <span class="p">147 FEATURES</span></pre>
      <pre class="boot-line b3"><span class="p">AGENTS</span> .......................... <span class="p">250 ACTIVE</span></pre>
    </div>

    <div class="logo-wrap">
      <pre class="logo-art">████████╗ ███████╗ ██████╗   ██████╗
╚══███╔═╝ ██╔════╝ ██╔══██╗ ██╔═══██╗
  ███╔╝   █████╗   ██████╔╝ ██║   ██║
 ███╔╝    ██╔══╝   ██╔══██╗ ██║   ██║
████████╗ ███████╗ ██║  ██║ ╚██████╔╝
╚═══════╝ ╚══════╝ ╚═╝  ╚═╝  ╚═════╝</pre>
      <div class="crt-scanline"></div>
    </div>

    <h1 class="hero-title">AI that trades better than you.<br>And you're okay with it.</h1>

    <p class="hero-sub">
      250 agents scanning 147 features across 6 timeframes, 24/7. 
      Signals no one else has. A marketplace where the best ML wins.
    </p>

    <div class="hero-cta">
      <a href="#access" class="btn-primary">Request Access</a>
      <a href="#signals" class="btn-ghost">See the signals ↓</a>
    </div>
  </header>

  <!-- LIVE SIGNAL MATRIX -->
  <section class="section" id="signals">
    <div class="matrix-head">
      <p class="section-label p">SIGNAL MATRIX — LIVE</p>
      <span class="matrix-status" id="matrix-status">scanning</span>
    </div>
    <div class="matrix-wrap">
      <canvas id="matrix-canvas"></canvas>
    </div>
  </section>

  <!-- PROPOSAL A: REGIME VISUALIZER -->
  <section class="section reveal">
    <p class="section-label p reveal-child">THE EDGE</p>
    <h2 class="section-title reveal-child">Your indicators assume the market never changes. It does.</h2>
    
    <div class="regime-viz reveal-child">
      <div class="rv-bar-group">
        <div class="rv-bar">
          <span class="rv-label dim">HURST</span>
          <div class="rv-track">
            <div class="rv-fill" id="rv-hurst"></div>
            <div class="rv-marker" id="rv-hurst-marker"></div>
          </div>
          <span class="rv-val" id="rv-hurst-val">0.50</span>
        </div>
        <div class="rv-bar">
          <span class="rv-label dim">DFA</span>
          <div class="rv-track">
            <div class="rv-fill" id="rv-dfa"></div>
            <div class="rv-marker" id="rv-dfa-marker"></div>
          </div>
          <span class="rv-val" id="rv-dfa-val">0.50</span>
        </div>
        <div class="rv-bar">
          <span class="rv-label dim">LYAPUNOV</span>
          <div class="rv-track">
            <div class="rv-fill rv-fill-lyap" id="rv-lyap"></div>
            <div class="rv-marker" id="rv-lyap-marker"></div>
          </div>
          <span class="rv-val" id="rv-lyap-val">0.00</span>
        </div>
      </div>
      <div class="rv-output">
        <div class="rv-regime-badge" id="rv-badge">SCANNING</div>
        <p class="rv-verdict" id="rv-verdict">Your MACD crossover is → <span class="p">ANALYZING</span></p>
      </div>
    </div>
  </section>

  <!-- PROPOSAL B: ANIMATED COUNTER CARDS -->
  <section class="section reveal">
    <p class="section-label a reveal-child">EMERGENT</p>
    <h2 class="section-title reveal-child">None of these were programmed</h2>
    <div class="discovery-grid reveal-child">
      <div class="disc-card" data-counter="0.41" data-prefix="H = " data-decimals="2">
        <div class="disc-val p">H = 0.00</div>
        <p>Mean-reverting territory — reversal windows no human hypothesized</p>
      </div>
      <div class="disc-card" data-counter="30" data-prefix="<" data-suffix="% HR" data-decimals="0">
        <div class="disc-val a">&lt;0% HR</div>
        <p>Low hit rate, massive payoff — the wins dominate</p>
      </div>
      <div class="disc-card" data-counter="1" data-prefix="Δ " data-suffix="" data-text="SENT" data-decimals="-1">
        <div class="disc-val ice">Δ SENT</div>
        <p>Analyst-crowd divergence — contrarian signal invisible to price</p>
      </div>
    </div>
  </section>

  <!-- PROPOSAL C: PROGRESSIVE LAYERS + ACTIVE FLYWHEEL -->
  <section class="section reveal">
    <p class="section-label p reveal-child">THREE LAYERS</p>

    <div class="layer-block l1 reveal-child">
      <div class="layer-border"></div>
      <div class="layer-content">
        <h3 class="layer-title"><span class="p">L1</span> Signal-as-a-Service <span class="layer-tag p">LIVE</span></h3>
        <p class="layer-desc dim">Raw alpha via API. Not indicators — discoveries. For funds and trading desks that have infrastructure but not this data edge.</p>
      </div>
    </div>

    <div class="layer-block l2 reveal-child">
      <div class="layer-border layer-border-a"></div>
      <div class="layer-content">
        <h3 class="layer-title"><span class="a">L2</span> Agent Marketplace <span class="layer-tag a">BUILDING</span></h3>
        <p class="layer-desc dim">Engineers build predictors → agents find combinations → best agents attract capital → engineers earn revenue share.</p>
        <div class="flywheel" id="flywheel">
          <span class="fw-step" data-fw="0">Engineers</span>
          <span class="fw-arrow p">→</span>
          <span class="fw-step" data-fw="1">Predictors</span>
          <span class="fw-arrow p">→</span>
          <span class="fw-step" data-fw="2">Agents</span>
          <span class="fw-arrow p">→</span>
          <span class="fw-step" data-fw="3">Capital</span>
          <span class="fw-arrow p">→</span>
          <span class="fw-step" data-fw="4">Revenue</span>
          <span class="fw-arrow p">↩</span>
        </div>
      </div>
    </div>

    <div class="layer-block l3 last reveal-child">
      <div class="layer-border layer-border-ice"></div>
      <div class="layer-content">
        <h3 class="layer-title"><span class="ice">L3</span> One-click execution <span class="layer-tag ice">VISION</span></h3>
        <p class="layer-desc dim">14 months live PnL. Verified Sharpe. Documented drawdown. One button.</p>
      </div>
    </div>

    <blockquote class="vision-quote reveal-child">
      The line between a trading system and a world model starts to blur. 
      That is the point we are building toward.
    </blockquote>
  </section>

  <!-- PROPOSAL D: TERMINAL CTA -->
  <section class="section cta-section reveal" id="access">
    <div class="term-cta reveal-child">
      <div class="term-header">
        <span class="dim">zero-os</span>
        <span class="term-dots">
          <span class="dot dot-r"></span>
          <span class="dot dot-a"></span>
          <span class="dot dot-p"></span>
        </span>
      </div>
      <div class="term-body">
        <p class="term-line dim">$ zero-os request_access</p>
        <p class="term-line"><span class="p">&gt;</span> Signal API for funds. Marketplace for engineers.</p>
        <p class="term-line"><span class="p">&gt;</span> Early access is limited.</p>
        <form class="term-form" id="access-form" action="#" method="POST">
          <div class="term-input-row">
            <span class="p">email:</span>
            <input type="email" id="access-email" class="term-input" placeholder="you@fund.com" required autocomplete="email">
          </div>
          <button type="submit" class="term-submit">SUBMIT ↵</button>
        </form>
        <p class="term-confirm" id="term-confirm" style="display:none">
          <span class="p">✓ ACCESS_REQUEST_QUEUED</span><br>
          <span class="dim">ref: ZOS-<span id="req-id">0000</span> — we review every application.</span>
        </p>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer reveal">
    <span class="p">◇</span> <span class="dim">ZERO OS</span>
  </footer>

</div>

</BaseLayout>

<style>
  .page {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  /* CRT */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.05) 2px, rgba(0,0,0,0.05) 4px);
    pointer-events: none;
    z-index: 100;
  }
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse 70% 70% at 50% 50%, transparent 0%, transparent 85%, rgba(0,0,0,0.15) 92%, rgba(0,0,0,0.4) 100%);
    pointer-events: none;
    z-index: 101;
  }

  /* HERO */
  .hero { padding: 2.5rem 0 2rem; border-bottom: 1px solid var(--border); }
  .boot-sequence { margin-bottom: 1.25rem; }
  .boot-line {
    font-family: var(--font-head);
    font-size: 0.55rem;
    color: var(--text-dim);
    margin: 0;
    line-height: 1.8;
    opacity: 0;
    animation: bootIn 0.3s ease forwards;
  }
  .b1 { animation-delay: 0.2s; }
  .b2 { animation-delay: 0.5s; }
  .b3 { animation-delay: 0.8s; }
  @keyframes bootIn {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .logo-wrap { position: relative; margin-bottom: 1.5rem; overflow: hidden; }
  .logo-art {
    font-family: var(--font-head);
    font-size: clamp(7px, calc((100vw - 30px) / 38), 22px);
    line-height: 1.15;
    color: var(--phosphor);
    text-shadow: 0 0 8px var(--phosphor-glow), 0 0 24px rgba(200,255,0,0.12);
    white-space: pre;
    margin: 0;
    background: transparent;
    border: none;
    animation: logoIn 0.6s ease 1s both;
  }
  @keyframes logoIn {
    0% { opacity: 0; filter: brightness(4) blur(2px); }
    50% { opacity: 0.7; filter: brightness(1.8) blur(0.5px); }
    100% { opacity: 1; filter: brightness(1); }
  }
  .crt-scanline {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--phosphor);
    opacity: 0.06;
    animation: scanDrop 3s linear infinite;
    pointer-events: none;
  }
  @keyframes scanDrop { 0% { top: 0; } 100% { top: 100%; } }

  .hero-title {
    font-family: var(--font-head);
    font-size: clamp(1.3rem, 4.5vw, 2rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--text);
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
    animation: fadeUp 0.5s ease 1.4s both;
  }
  .hero-sub {
    font-size: 0.8rem;
    color: var(--text-dim);
    line-height: 1.7;
    max-width: 480px;
    margin-bottom: 1.25rem;
    animation: fadeUp 0.5s ease 1.6s both;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-cta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    animation: fadeUp 0.5s ease 1.8s both;
  }
  .btn-primary {
    font-family: var(--font-head);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--bg);
    background: var(--phosphor);
    border: none;
    padding: 0.6rem 1.2rem;
    text-decoration: none;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .btn-primary:hover { opacity: 0.85; }
  .btn-ghost {
    font-family: var(--font-head);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--text-dim);
    padding: 0.6rem 1.2rem;
    text-decoration: none;
    border: 1px solid var(--border);
    transition: border-color 0.15s, color 0.15s;
  }
  .btn-ghost:hover { border-color: var(--text-dim); color: var(--text); }

  /* MATRIX */
  .matrix-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.4rem;
  }
  .matrix-status {
    font-family: var(--font-head);
    font-size: 0.5rem;
    color: var(--phosphor);
    letter-spacing: 0.05em;
    animation: pulse 2s ease infinite;
  }
  @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.5; } }

  .matrix-wrap {
    position: relative;
    border: 1px solid var(--border);
    background: rgba(0,0,0,0.6);
    overflow: hidden;
    animation: matrixBreathe 4s ease-in-out infinite;
  }
  @keyframes matrixBreathe {
    0%,100% { box-shadow: 0 0 0px transparent, inset 0 0 0px transparent; border-color: var(--border); }
    50% { box-shadow: 0 0 12px rgba(200,255,0,0.04), inset 0 0 20px rgba(200,255,0,0.02); border-color: rgba(200,255,0,0.15); }
  }
  #matrix-canvas {
    display: block;
    width: 100%;
    image-rendering: pixelated;
  }
  /* regime badge animations handled in canvas via opacity cycling */

  /* SECTIONS */
  .section { padding: 2.5rem 0; border-bottom: 1px solid var(--border); }
  .section-label {
    font-family: var(--font-head);
    font-size: 0.45rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    margin-bottom: 0.5rem;
  }
  .section-title {
    font-family: var(--font-head);
    font-size: clamp(1rem, 3.5vw, 1.4rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--text);
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
  }

  /* ═══ PROPOSAL E: SCROLL REVEAL ═══ */
  .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .reveal.visible { opacity: 1; transform: translateY(0); }
  .reveal-child { opacity: 0; transform: translateY(12px); transition: opacity 0.5s ease, transform 0.5s ease; }
  .reveal.visible .reveal-child { opacity: 1; transform: translateY(0); }
  .reveal.visible .reveal-child:nth-child(1) { transition-delay: 0s; }
  .reveal.visible .reveal-child:nth-child(2) { transition-delay: .1s; }
  .reveal.visible .reveal-child:nth-child(3) { transition-delay: .2s; }
  .reveal.visible .reveal-child:nth-child(4) { transition-delay: .3s; }
  .reveal.visible .reveal-child:nth-child(5) { transition-delay: .4s; }
  .reveal.visible .reveal-child:nth-child(6) { transition-delay: .5s; }

  /* ═══ PROPOSAL A: REGIME VISUALIZER ═══ */
  .regime-viz { margin-top: 1rem; }
  .rv-bar-group { display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 1.25rem; }
  .rv-bar {
    display: grid;
    grid-template-columns: 70px 1fr 42px;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-head);
  }
  .rv-label { font-size: 0.5rem; font-weight: 700; letter-spacing: 0.1em; text-align: right; }
  .rv-track {
    position: relative;
    height: 20px;
    background: rgba(26,26,26,0.6);
    border: 1px solid var(--border);
    overflow: hidden;
  }
  .rv-fill {
    position: absolute;
    top: 0; left: 0; bottom: 0;
    width: 50%;
    background: linear-gradient(90deg, rgba(200,255,0,0.15), rgba(200,255,0,0.05));
    transition: width 0.8s ease, background 0.8s ease;
  }
  .rv-fill-lyap {
    background: linear-gradient(90deg, rgba(0,212,255,0.1), rgba(255,51,51,0.15));
  }
  .rv-marker {
    position: absolute;
    top: 2px; bottom: 2px;
    width: 3px;
    left: 50%;
    background: var(--phosphor);
    box-shadow: 0 0 8px var(--phosphor-glow);
    transition: left 0.8s ease, background 0.8s ease, box-shadow 0.8s ease;
  }
  .rv-val {
    font-size: 0.6rem;
    font-weight: 700;
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }
  .rv-output {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .rv-regime-badge {
    font-family: var(--font-head);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    padding: 0.3rem 0.8rem;
    border: 1px solid var(--border);
    transition: all 0.5s ease;
  }
  .rv-regime-badge.trending { color: var(--phosphor); border-color: var(--phosphor); background: rgba(200,255,0,0.08); box-shadow: 0 0 12px rgba(200,255,0,0.1); }
  .rv-regime-badge.reverting { color: var(--amber); border-color: var(--amber); background: rgba(255,176,0,0.08); box-shadow: 0 0 12px rgba(255,176,0,0.1); }
  .rv-regime-badge.chaotic { color: var(--red); border-color: var(--red); background: rgba(255,51,51,0.08); box-shadow: 0 0 12px rgba(255,51,51,0.1); animation: chaosPulse 0.8s ease infinite; }
  .rv-regime-badge.shift { color: var(--ice); border-color: var(--ice); background: rgba(0,212,255,0.06); }
  @keyframes chaosPulse { 0%,100%{opacity:1;}50%{opacity:.5;} }
  .rv-verdict {
    font-family: var(--font-head);
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--text);
  }

  /* ═══ PROPOSAL B: DISCOVERY CARDS ═══ */
  .discovery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }
  @media (max-width: 639px) {
    .discovery-grid { grid-template-columns: 1fr; }
  }
  .disc-card {
    border: 1px solid var(--border);
    padding: 1.5rem 1rem;
    text-align: center;
    transition: border-color 0.4s, box-shadow 0.4s, background 0.4s;
    position: relative;
    overflow: hidden;
  }
  .disc-card::before {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    width: 0; height: 0;
    border-radius: 50%;
    transition: width 0.6s, height 0.6s, top 0.3s, left 0.3s, opacity 0.6s;
    opacity: 0;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }
  .disc-card.counted::before {
    width: 120px; height: 120px;
    opacity: 1;
  }
  .disc-card:nth-child(1)::before { background: radial-gradient(circle, rgba(200,255,0,0.08), transparent 70%); }
  .disc-card:nth-child(2)::before { background: radial-gradient(circle, rgba(255,176,0,0.08), transparent 70%); }
  .disc-card:nth-child(3)::before { background: radial-gradient(circle, rgba(0,212,255,0.08), transparent 70%); }
  .disc-val {
    font-family: var(--font-head);
    font-size: 1.6rem;
    font-weight: 700;
    margin-bottom: 0.3rem;
    position: relative;
  }
  .disc-card p { font-size: 0.6rem; color: var(--text-dim); line-height: 1.5; position: relative; }

  /* ═══ PROPOSAL C: PROGRESSIVE LAYERS ═══ */
  .layer-block {
    display: flex;
    gap: 0;
    margin-bottom: 1.25rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid rgba(26,26,26,0.3);
  }
  .layer-block.last { border-bottom: none; margin-bottom: 0.5rem; padding-bottom: 0.5rem; }
  .layer-border {
    width: 3px;
    flex-shrink: 0;
    background: var(--phosphor);
    border-radius: 2px;
    margin-right: 1rem;
    box-shadow: 0 0 8px var(--phosphor-glow);
  }
  .layer-border-a { background: var(--amber); box-shadow: 0 0 8px rgba(255,176,0,0.2); }
  .layer-border-ice { background: var(--ice); box-shadow: 0 0 8px rgba(0,212,255,0.2); opacity: 0.5; }
  .layer-content { flex: 1; }
  .l2 { opacity: 0.85; }
  .l3 { opacity: 0.6; }
  .layer-title {
    font-family: var(--font-head);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.35rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .layer-tag {
    font-size: 0.45rem;
    letter-spacing: 0.15em;
    padding: 0.15rem 0.4rem;
    border: 1px solid currentColor;
    opacity: 0.7;
  }
  .layer-desc {
    font-size: 0.7rem;
    line-height: 1.6;
    max-width: 500px;
  }

  /* FLYWHEEL — animated */
  .flywheel {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-top: 0.75rem;
    font-family: var(--font-head);
    font-size: 0.6rem;
  }
  .fw-step {
    color: var(--text-dim);
    font-weight: 700;
    padding: 0.25rem 0.5rem;
    border: 1px solid var(--border);
    transition: color 0.4s, border-color 0.4s, box-shadow 0.4s, background 0.4s;
  }
  .fw-step.active {
    color: var(--phosphor);
    border-color: var(--phosphor);
    background: rgba(200,255,0,0.06);
    box-shadow: 0 0 10px rgba(200,255,0,0.1);
  }
  .fw-arrow {
    font-size: 0.8rem;
    transition: color 0.3s;
  }

  /* VISION */
  .vision-quote {
    font-family: var(--font-head);
    font-size: clamp(0.8rem, 2.5vw, 1rem);
    font-weight: 700;
    color: var(--text);
    line-height: 1.4;
    border-left: 2px solid var(--phosphor);
    padding-left: 1rem;
    margin-top: 1.5rem;
    max-width: 460px;
  }

  /* ═══ PROPOSAL D: TERMINAL CTA ═══ */
  .cta-section { border-bottom: none; padding: 2.5rem 0 1.5rem; }
  .term-cta {
    border: 1px solid var(--border);
    background: rgba(0,0,0,0.6);
    overflow: hidden;
    max-width: 480px;
    margin: 0 auto;
  }
  .term-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.4rem 0.75rem;
    background: rgba(26,26,26,0.5);
    border-bottom: 1px solid var(--border);
    font-family: var(--font-head);
    font-size: 0.5rem;
  }
  .term-dots { display: flex; gap: 4px; }
  .dot { width: 6px; height: 6px; border-radius: 50%; }
  .dot-r { background: #ff5f56; }
  .dot-a { background: #ffbd2e; }
  .dot-p { background: #27c93f; }
  .term-body {
    padding: 1rem 1.25rem;
    font-family: var(--font-head);
    font-size: 0.7rem;
  }
  .term-line {
    margin-bottom: 0.3rem;
    line-height: 1.6;
  }
  .term-form { margin-top: 0.75rem; }
  .term-input-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
    font-size: 0.75rem;
  }
  .term-input {
    font-family: var(--font-head);
    font-size: 0.75rem;
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--border);
    color: var(--text);
    padding: 0.3rem 0;
    flex: 1;
    outline: none;
    transition: border-color 0.2s;
    caret-color: var(--phosphor);
  }
  .term-input:focus { border-color: var(--phosphor); }
  .term-input::placeholder { color: var(--text-dim); }
  .term-submit {
    font-family: var(--font-head);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--bg);
    background: var(--phosphor);
    border: none;
    padding: 0.5rem 1rem;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .term-submit:hover { opacity: 0.85; }
  .term-confirm {
    font-size: 0.65rem;
    line-height: 1.7;
    margin-top: 0.5rem;
  }

  /* FOOTER */
  .footer {
    padding: 1.5rem 0;
    font-family: var(--font-head);
    font-size: 0.55rem;
    letter-spacing: 0.05em;
    text-align: center;
    border-top: 1px solid var(--border);
  }

  /* UTILITY */
  .p { color: var(--phosphor); }
  .a { color: var(--amber); }
  .ice { color: var(--ice); }
  .dim { color: var(--text-dim); }
  .red { color: var(--red); }
</style>

<script>
// ═══════════════════════════════════════════════════
// ZERO OS — Canvas Heat Map Matrix (fully canvas-rendered)
// ═══════════════════════════════════════════════════

const COINS = ['BTC','ETH','SOL','DOGE','AVAX','LINK','ARB','OP','SUI','MATIC','NEAR','INJ'];
const COLS = ['HURST','DFA','SENT','LYAP','FLOW'];
const NC = COLS.length;
const ROW_H = 30;
const HDR_H = 26;
const PAD = 10;
const DPR = Math.min(window.devicePixelRatio || 1, 2);

// palette
const CLR = {
  phosphor: [200,255,0],
  amber: [255,176,0],
  red: [255,51,51],
  ice: [0,212,255],
  text: [232,228,223],
  dim: [138,130,120],
  bg: [5,5,5],
  line: [26,26,26]
};

const S = {
  data: [], canvas: null, ctx: null,
  w: 0, h: 0, coinW: 54, regW: 90, colW: 0,
  glows: [], time: 0
};

function rnd(a,b){return Math.random()*(b-a)+a;}
function lerp(a,b,t){return a+(b-a)*t;}

function regime(h,d,ly){
  if(ly>.85)return 'chaotic';
  if(h<.45&&d<.45)return 'reverting';
  if(h>.55&&d>.55)return 'trending';
  if((h<.45&&d>.55)||(h>.55&&d<.45))return 'shift';
  return '';
}

function heatRGBA(norm, alpha){
  const d=Math.abs(norm-.5)*2;
  const i=Math.pow(d,.7);
  const c=norm<.5?CLR.phosphor:CLR.amber;
  return `rgba(${c[0]},${c[1]},${c[2]},${i*alpha})`;
}

function initData(){
  COINS.forEach(coin=>{
    const v=[rnd(.28,.72),rnd(.30,.70),rnd(-1,1),rnd(-.1,1.1),rnd(-3,3)];
    S.data.push({coin,v:[...v],t:[...v],reg:regime(v[0],v[1],v[3]),rt:0});
  });
}

function setup(){
  const c=document.getElementById('matrix-canvas');
  const wrap=c.parentElement;
  const w=wrap.clientWidth;
  const h=HDR_H+COINS.length*ROW_H+2;
  c.width=w*DPR; c.height=h*DPR;
  c.style.width=w+'px'; c.style.height=h+'px';
  S.canvas=c; S.ctx=c.getContext('2d');
  S.ctx.scale(DPR,DPR);
  S.w=w; S.h=h;
  S.colW=(w-S.coinW-S.regW-PAD*2)/NC;
}

function rgba(c,a){return `rgba(${c[0]},${c[1]},${c[2]},${a})`;}

function draw(){
  const {ctx,w,h,coinW,colW,regW}=S;
  const dataX=PAD+coinW;

  ctx.clearRect(0,0,w,h);

  // header
  ctx.fillStyle='rgba(0,0,0,0.4)';
  ctx.fillRect(0,0,w,HDR_H);
  ctx.font='bold 9px JetBrains Mono, monospace';
  ctx.fillStyle=rgba(CLR.dim,.5);
  ctx.textBaseline='middle';
  ctx.textAlign='left';
  ctx.fillText('ASSET',PAD,HDR_H/2);
  ctx.textAlign='center';
  COLS.forEach((c,j)=>{
    ctx.fillText(c, dataX+j*colW+colW/2, HDR_H/2);
  });
  ctx.textAlign='right';
  ctx.fillText('REGIME', w-PAD, HDR_H/2);

  // header line
  ctx.fillStyle=rgba(CLR.line,.6);
  ctx.fillRect(0,HDR_H,w,1);

  // rows
  S.data.forEach((d,i)=>{
    const y=HDR_H+1+i*ROW_H;

    // alternating row bg
    if(i%2===0){
      ctx.fillStyle='rgba(255,255,255,0.008)';
      ctx.fillRect(0,y,w,ROW_H);
    }

    // heat cells
    d.v.forEach((val,j)=>{
      const x=dataX+j*colW;
      let norm;
      if(j<2) norm=val;
      else if(j===2) norm=(val+1)/2;
      else if(j===3) norm=1-Math.min(val,1.2)/1.2;
      else norm=(val+3)/6;

      // cell bg
      ctx.fillStyle=heatRGBA(norm,.3);
      ctx.fillRect(x+2, y+3, colW-4, ROW_H-6);

      // subtle border on hot cells
      const intensity=Math.abs(norm-.5)*2;
      if(intensity>.6){
        ctx.strokeStyle=heatRGBA(norm,.2);
        ctx.lineWidth=1;
        ctx.strokeRect(x+2.5, y+3.5, colW-5, ROW_H-7);
      }
    });

    // row line
    ctx.fillStyle=rgba(CLR.line,.25);
    ctx.fillRect(0, y+ROW_H-1, w, 1);

    // coin label
    ctx.font='bold 10px JetBrains Mono, monospace';
    ctx.fillStyle=rgba(CLR.text,.85);
    ctx.textAlign='left';
    ctx.textBaseline='middle';
    ctx.fillText(d.coin, PAD, y+ROW_H/2);

    // values
    ctx.font='10px JetBrains Mono, monospace';
    ctx.textAlign='center';
    d.v.forEach((val,j)=>{
      let norm;
      if(j<2) norm=val;
      else if(j===2) norm=(val+1)/2;
      else if(j===3) norm=1-Math.min(val,1.2)/1.2;
      else norm=(val+3)/6;

      const intensity=Math.abs(norm-.5)*2;
      if(intensity>.5){
        const c=norm<.5?CLR.phosphor:CLR.amber;
        ctx.fillStyle=rgba(c, .6+intensity*.4);
      } else {
        ctx.fillStyle=rgba(CLR.text,.55);
      }
      ctx.fillText(val.toFixed(2), dataX+j*colW+colW/2, y+ROW_H/2);
    });

    // regime badge
    if(d.reg){
      const labels={trending:'TRENDING',reverting:'REVERTING',chaotic:'CHAOTIC',shift:'SHIFT'};
      const colors={trending:CLR.phosphor,reverting:CLR.amber,chaotic:CLR.red,shift:CLR.ice};
      const bgAlphas={trending:.12,reverting:.1,chaotic:.15,shift:.08};
      const label=labels[d.reg];
      const clr=colors[d.reg];
      
      ctx.font='bold 8px JetBrains Mono, monospace';
      const tw=ctx.measureText(label).width;
      const px=w-PAD-tw-10;
      const py=y+ROW_H/2-6;
      const pw=tw+10;
      const ph=13;

      // badge bg
      let badgeAlpha=bgAlphas[d.reg];
      if(d.reg==='chaotic'){
        badgeAlpha*=.5+.5*Math.abs(Math.sin(S.time*4));
      }
      if(d.reg==='shift'){
        const osc=Math.sin(S.time*2)*.5+.5;
        const c1=CLR.ice, c2=CLR.amber;
        const cr=Math.round(lerp(c1[0],c2[0],osc));
        const cg=Math.round(lerp(c1[1],c2[1],osc));
        const cb=Math.round(lerp(c1[2],c2[2],osc));
        ctx.fillStyle=`rgba(${cr},${cg},${cb},.08)`;
        ctx.fillRect(px,py,pw,ph);
        ctx.fillStyle=`rgba(${cr},${cg},${cb},.85)`;
      } else {
        ctx.fillStyle=rgba(clr,badgeAlpha);
        ctx.fillRect(px,py,pw,ph);
        ctx.fillStyle=rgba(clr, d.reg==='chaotic'? .5+.5*Math.abs(Math.sin(S.time*4)) : .85);
      }
      ctx.textAlign='center';
      ctx.textBaseline='middle';
      ctx.fillText(label, px+pw/2, y+ROW_H/2);

      // glow halo for active regimes
      if(d.reg==='trending'||d.reg==='chaotic'){
        const grad=ctx.createRadialGradient(px+pw/2,y+ROW_H/2,0,px+pw/2,y+ROW_H/2,pw);
        grad.addColorStop(0,rgba(clr,.06));
        grad.addColorStop(1,'rgba(0,0,0,0)');
        ctx.fillStyle=grad;
        ctx.fillRect(px-pw/2,y,pw*2,ROW_H);
      }
    } else {
      ctx.font='10px JetBrains Mono, monospace';
      ctx.fillStyle=rgba(CLR.dim,.2);
      ctx.textAlign='right';
      ctx.fillText('—', w-PAD, y+ROW_H/2);
    }
  });

  // glow bursts
  S.glows=S.glows.filter(g=>{
    const x=PAD+S.coinW+g.col*S.colW+S.colW/2;
    const y=HDR_H+1+g.row*ROW_H+ROW_H/2;
    const r=g.i*35;
    const grad=ctx.createRadialGradient(x,y,0,x,y,r);
    grad.addColorStop(0,`rgba(200,255,0,${g.i*.2})`);
    grad.addColorStop(1,'rgba(200,255,0,0)');
    ctx.fillStyle=grad;
    ctx.fillRect(x-r,y-r,r*2,r*2);
    g.i-=g.d;
    return g.i>.01;
  });
}

function tick(){
  S.time+=1/60;
  S.data.forEach((d,i)=>{
    d.v.forEach((_,j)=>{ d.v[j]=lerp(d.v[j],d.t[j],.06); });
    if(Math.random()<.025){
      const j=Math.floor(Math.random()*NC);
      const nt=j<2?rnd(.25,.75):j===2?rnd(-1,1):j===3?rnd(-.1,1.2):rnd(-3,3);
      if(Math.abs(nt-d.v[j])>.12) S.glows.push({row:i,col:j,i:1,d:.015});
      d.t[j]=nt;
    }
    d.rt--;
    if(d.rt<=0){d.reg=regime(d.v[0],d.v[1],d.v[3]);d.rt=40+Math.floor(Math.random()*80);}
  });
}

function updateStatus(){
  const n=S.data.filter(d=>d.reg).length;
  const el=document.getElementById('matrix-status');
  if(el) el.textContent=n+' regime'+(n!==1?'s':'')+' detected';
}

let fc=0;
function frame(){
  tick();
  draw();
  if(fc%30===0) updateStatus();
  fc++;
  requestAnimationFrame(frame);
}

function resize(){
  const wrap=S.canvas.parentElement;
  const w=wrap.clientWidth;
  const h=HDR_H+COINS.length*ROW_H+2;
  S.canvas.width=w*DPR; S.canvas.height=h*DPR;
  S.canvas.style.width=w+'px'; S.canvas.style.height=h+'px';
  S.ctx=S.canvas.getContext('2d'); S.ctx.scale(DPR,DPR);
  S.w=w; S.h=h; S.colW=(w-S.coinW-S.regW-PAD*2)/NC;
}

document.addEventListener('DOMContentLoaded',()=>{
  initData(); setup(); updateStatus();
  requestAnimationFrame(frame);
  window.addEventListener('resize',resize);

  // ═══ PROPOSAL E: SCROLL REVEAL ═══
  const obs = new IntersectionObserver((entries)=>{
    entries.forEach(e=>{ if(e.isIntersecting){ e.target.classList.add('visible'); } });
  }, { threshold: 0.15 });
  document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));

  // ═══ PROPOSAL A: REGIME VISUALIZER ═══
  const rvState = { h: 0.5, d: 0.5, ly: 0.0, ht: 0.5, dt: 0.5, lt: 0.0 };
  function rvTick() {
    if(Math.random()<.04) rvState.ht = rnd(.25,.75);
    if(Math.random()<.04) rvState.dt = rnd(.25,.75);
    if(Math.random()<.03) rvState.lt = rnd(-.1,1.1);
    rvState.h = lerp(rvState.h, rvState.ht, .03);
    rvState.d = lerp(rvState.d, rvState.dt, .03);
    rvState.ly = lerp(rvState.ly, rvState.lt, .03);

    const hPct = rvState.h * 100;
    const dPct = rvState.d * 100;
    const lPct = Math.max(0, Math.min(rvState.ly, 1.2)) / 1.2 * 100;

    document.getElementById('rv-hurst').style.width = hPct + '%';
    document.getElementById('rv-hurst-marker').style.left = hPct + '%';
    document.getElementById('rv-hurst-val').textContent = rvState.h.toFixed(2);
    document.getElementById('rv-dfa').style.width = dPct + '%';
    document.getElementById('rv-dfa-marker').style.left = dPct + '%';
    document.getElementById('rv-dfa-val').textContent = rvState.d.toFixed(2);
    document.getElementById('rv-lyap').style.width = lPct + '%';
    document.getElementById('rv-lyap-marker').style.left = lPct + '%';
    document.getElementById('rv-lyap-val').textContent = rvState.ly.toFixed(2);

    // regime + verdict
    const badge = document.getElementById('rv-badge');
    const verdict = document.getElementById('rv-verdict');
    let reg = '', vtext = '', cls = '';
    if(rvState.ly > .85) {
      reg='CHAOTIC'; cls='chaotic';
      vtext='Your MACD crossover is → <span class="red">UNRELIABLE</span>';
    } else if(rvState.h<.45 && rvState.d<.45) {
      reg='REVERTING'; cls='reverting';
      vtext='Your MACD crossover is → <span class="a">A TRAP</span>';
    } else if(rvState.h>.55 && rvState.d>.55) {
      reg='TRENDING'; cls='trending';
      vtext='Your MACD crossover is → <span class="p">MEANINGFUL</span>';
    } else if((rvState.h<.45&&rvState.d>.55)||(rvState.h>.55&&rvState.d<.45)) {
      reg='SHIFT'; cls='shift';
      vtext='Your MACD crossover is → <span class="ice">TRANSITIONING</span>';
    } else {
      reg='SCANNING'; cls='';
      vtext='Your MACD crossover is → <span class="dim">ANALYZING</span>';
    }
    badge.textContent = reg;
    badge.className = 'rv-regime-badge ' + cls;
    verdict.innerHTML = vtext;

    // marker colors
    const hMarker = document.getElementById('rv-hurst-marker');
    const dMarker = document.getElementById('rv-dfa-marker');
    const lMarker = document.getElementById('rv-lyap-marker');
    hMarker.style.background = rvState.h<.45?'var(--amber)':rvState.h>.55?'var(--phosphor)':'var(--text-dim)';
    hMarker.style.boxShadow = rvState.h<.45?'0 0 8px rgba(255,176,0,.3)':rvState.h>.55?'0 0 8px var(--phosphor-glow)':'none';
    dMarker.style.background = rvState.d<.45?'var(--amber)':rvState.d>.55?'var(--phosphor)':'var(--text-dim)';
    dMarker.style.boxShadow = rvState.d<.45?'0 0 8px rgba(255,176,0,.3)':rvState.d>.55?'0 0 8px var(--phosphor-glow)':'none';
    lMarker.style.background = rvState.ly>.7?'var(--red)':rvState.ly<.2?'var(--ice)':'var(--text-dim)';
    lMarker.style.boxShadow = rvState.ly>.7?'0 0 8px rgba(255,51,51,.3)':'none';
  }
  setInterval(rvTick, 50);

  // ═══ PROPOSAL B: ANIMATED COUNTERS ═══
  const counterObs = new IntersectionObserver((entries)=>{
    entries.forEach(e=>{
      if(!e.isIntersecting) return;
      const card = e.target;
      if(card.classList.contains('counted')) return;
      const target = parseFloat(card.dataset.counter);
      const prefix = card.dataset.prefix || '';
      const suffix = card.dataset.suffix || '';
      const decimals = parseInt(card.dataset.decimals);
      const valEl = card.querySelector('.disc-val');
      if(decimals === -1) { card.classList.add('counted'); return; } // text-only (Δ SENT)
      let cur = 0;
      const step = target / 40;
      const iv = setInterval(()=>{
        cur += step;
        if(cur >= target) { cur = target; clearInterval(iv); }
        if(decimals > 0) valEl.textContent = prefix + cur.toFixed(decimals);
        else valEl.textContent = prefix + Math.round(cur) + suffix;
      }, 25);
      card.classList.add('counted');
    });
  }, { threshold: 0.5 });
  document.querySelectorAll('.disc-card').forEach(el=>counterObs.observe(el));

  // ═══ PROPOSAL C: FLYWHEEL ANIMATION ═══
  let fwIdx = 0;
  setInterval(()=>{
    document.querySelectorAll('.fw-step').forEach(el=>el.classList.remove('active'));
    const steps = document.querySelectorAll('.fw-step');
    if(steps[fwIdx]) steps[fwIdx].classList.add('active');
    fwIdx = (fwIdx + 1) % steps.length;
  }, 800);

  // ═══ PROPOSAL D: TERMINAL CTA ═══
  const form = document.getElementById('access-form');
  if(form) form.addEventListener('submit', (e)=>{
    e.preventDefault();
    const email = document.getElementById('access-email').value;
    if(!email) return;
    document.getElementById('req-id').textContent = Math.random().toString(36).substr(2,6).toUpperCase();
    form.style.display = 'none';
    document.getElementById('term-confirm').style.display = 'block';
  });
});
</script>
