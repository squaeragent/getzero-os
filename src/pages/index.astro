  .red { color: var(--red); }
</style>

<script is:inline>
// ═══════════════════════════════════════════════════
// ZERO OS — Canvas Heat Map Matrix
// ═══════════════════════════════════════════════════

const ALL_COINS = ['BTC','ETH','SOL','DOGE','AVAX','LINK','ARB','SUI','NEAR','INJ'];
const isMobile = window.innerWidth < 640;
const COINS = isMobile ? ALL_COINS.slice(0, 8) : ALL_COINS;
let LIVE_DATA = null;
const COLS = isMobile ? ['TREND','PATTERN','CHAOS','FLOW'] : ['TREND','PATTERN','SENT','CHAOS','FLOW'];
const NC = COLS.length;
const ROW_H = isMobile ? 34 : 30;
const HDR_H = isMobile ? 28 : 26;
const PAD = isMobile ? 6 : 10;
const DPR = Math.min(window.devicePixelRatio || 1, 2);

const CLR = {
  phosphor: [200,255,0],
  amber: [255,176,0],
  red: [255,51,51],
  ice: [0,212,255],
  text: [232,228,223],
  dim: [138,130,120],
  bg: [5,5,5],
  line: [26,26,26]
};

const S = {
  data: [], canvas: null, ctx: null,
  w: 0, h: 0, coinW: isMobile ? 44 : 54, regW: isMobile ? 72 : 90, colW: 0,
  glows: [], time: 0
};

function rnd(a,b){return Math.random()*(b-a)+a;}
function lerp(a,b,t){return a+(b-a)*t;}

function regime(h,d,ly){
  if(ly>.85)return 'chaotic';
  if(h<.45&&d<.45)return 'reverting';
  if(h>.55&&d>.55)return 'trending';
  if((h<.45&&d>.55)||(h>.55&&d<.45))return 'shift';
  return '';
}

function heatRGBA(norm, alpha){
  const d=Math.abs(norm-.5)*2;
  const i=Math.pow(d,.7);
  const c=norm<.5?CLR.phosphor:CLR.amber;
  return 'rgba('+c[0]+','+c[1]+','+c[2]+','+i*alpha+')';
}

const SEEDS = {
  BTC:  {h:[.47,.53], d:[.47,.53], s:[-.2,.2],  ly:[.10,.35], fl:[-.8,.8]},
  ETH:  {h:[.38,.46], d:[.37,.45], s:[-.3,.3],  ly:[.15,.45], fl:[-1.2,1.2]},
  SOL:  {h:[.56,.66], d:[.57,.65], s:[-.4,.4],  ly:[.20,.55], fl:[-1.5,1.5]},
  DOGE: {h:[.40,.52], d:[.42,.50], s:[-.6,.7],  ly:[.70,.95], fl:[-2.5,2.5]},
  AVAX: {h:[.36,.44], d:[.37,.45], s:[-.3,.3],  ly:[.20,.50], fl:[-1.2,1.2]},
  LINK: {h:[.48,.54], d:[.48,.54], s:[-.2,.25], ly:[.12,.40], fl:[-.9,1.0]},
  ARB:  {h:[.56,.64], d:[.38,.46], s:[-.4,.4],  ly:[.30,.60], fl:[-1.8,1.8]},
  SUI:  {h:[.58,.68], d:[.56,.65], s:[-.4,.5],  ly:[.25,.60], fl:[-1.8,2.0]},
  NEAR: {h:[.55,.63], d:[.54,.62], s:[-.35,.4], ly:[.22,.55], fl:[-1.5,1.8]},
  INJ:  {h:[.42,.50], d:[.44,.52], s:[-.5,.6],  ly:[.65,.90], fl:[-2.2,2.2]}
};

const COL_MAP = COLS.map(function(c){return {TREND:0,PATTERN:1,SENT:2,CHAOS:3,FLOW:4}[c];});

function initData(){
  COINS.forEach(function(coin){
    var s=SEEDS[coin];
    var full;
    if(LIVE_DATA && LIVE_DATA[coin]){
      var ld=LIVE_DATA[coin];
      var h=ld.HURST_24H!=null?ld.HURST_24H:rnd(s.h[0],s.h[1]);
      var d=ld.DFA_24H!=null?ld.DFA_24H:rnd(s.d[0],s.d[1]);
      var sent=ld.XONE_AVG_NET!=null?(ld.XONE_AVG_NET/100):rnd(s.s[0],s.s[1]);
      var ly=ld.LYAPUNOV_24H!=null?Math.min(ld.LYAPUNOV_24H,2)/2:rnd(s.ly[0],s.ly[1]);
      var fl=ld.ROC_3H!=null?ld.ROC_3H:rnd(s.fl[0],s.fl[1]);
      full=[h,d,sent,ly,fl];
      s.h=[Math.max(0,h-.03),Math.min(1,h+.03)];
      s.d=[Math.max(0,d-.03),Math.min(1,d+.03)];
      s.s=[sent-.08,sent+.08];
      s.ly=[Math.max(0,ly-.03),Math.min(1,ly+.03)];
      s.fl=[fl-.5,fl+.5];
    } else {
      full=[rnd(s.h[0],s.h[1]),rnd(s.d[0],s.d[1]),rnd(s.s[0],s.s[1]),rnd(s.ly[0],s.ly[1]),rnd(s.fl[0],s.fl[1])];
    }
    var v=COL_MAP.map(function(i){return full[i];});
    var isLive = LIVE_DATA && LIVE_DATA[coin];
    S.data.push({coin:coin,v:v.slice(),t:v.slice(),full:full.slice(),reg:regime(full[0],full[1],full[3]),rt:0,seeds:s,liveLocked:!!isLive});
  });
}

function fetchLiveData(){
  // ENVY proxy killed — was costing $168/mo on Vercel serverless.
  // Matrix uses static seed data. Live data available via Intelligence API
  // at api.getzero.dev (Cloudflare tunnel, zero Vercel cost).
  fetch('https://api.getzero.dev/world').then(function(r){
    if(!r.ok)return;
    return r.json();
  }).then(function(d){
    if(!d||!d.coins)return;
    // Convert Intelligence API format to matrix format
    var matrix = {};
    for(var coin in d.coins){
      var ind = d.coins[coin].indicators || {};
      matrix[coin] = {
        HURST_24H: ind.HURST_24H,
        DFA_24H: ind.DFA_24H,
        XONE_AVG_NET: ind.XONE_AVG_NET,
        LYAPUNOV_24H: ind.LYAPUNOV_24H,
        ROC_3H: ind.ROC_3H
      };
    }
    d = {live: true, matrix: matrix};
    if(!d||!d.live||!d.matrix)return;
    LIVE_DATA=d.matrix;
    S.data.forEach(function(row){
      var ld=LIVE_DATA[row.coin];
      if(!ld)return;
      var h=ld.HURST_24H!=null?ld.HURST_24H:row.full[0];
      var df=ld.DFA_24H!=null?ld.DFA_24H:row.full[1];
      var sent=ld.XONE_AVG_NET!=null?(ld.XONE_AVG_NET/100):row.full[2];
      var ly=ld.LYAPUNOV_24H!=null?Math.min(ld.LYAPUNOV_24H,2)/2:row.full[3];
      var fl=ld.ROC_3H!=null?ld.ROC_3H:row.full[4];
      row.full=[h,df,sent,ly,fl];
      row.t=COL_MAP.map(function(i){return row.full[i];});
      row.seeds.h=[Math.max(0,h-.03),Math.min(1,h+.03)];
      row.seeds.d=[Math.max(0,df-.03),Math.min(1,df+.03)];
      row.seeds.s=[sent-.08,sent+.08];
      row.seeds.ly=[Math.max(0,ly-.03),Math.min(1,ly+.03)];
      row.seeds.fl=[fl-.5,fl+.5];
      row.reg=regime(h,df,ly);
      row.liveLocked=true;
    });
    var lbl=document.querySelector('.matrix-label');
    if(lbl){lbl.innerHTML='REGIME MAP — <span class="p">LIVE</span>';}
    updateRegimeVerdict();
  }).catch(function(e){console.warn('Envy API unavailable, using simulation',e);});
}


function setup(){
  var c=document.getElementById('matrix-canvas');
  var wrap=c.parentElement;
  var w=wrap.clientWidth;
  var h=HDR_H+COINS.length*ROW_H+2;
  c.width=w*DPR; c.height=h*DPR;
  c.style.width=w+'px'; c.style.height=h+'px';
  S.canvas=c; S.ctx=c.getContext('2d');
  S.ctx.scale(DPR,DPR);
  S.w=w; S.h=h;
  S.colW=(w-S.coinW-S.regW-PAD*2)/NC;
}

function rgba(c,a){return 'rgba('+c[0]+','+c[1]+','+c[2]+','+a+')';}

function draw(){
  var ctx=S.ctx, w=S.w, h=S.h, coinW=S.coinW, colW=S.colW, regW=S.regW;
  var dataX=PAD+coinW;

  ctx.clearRect(0,0,w,h);

  ctx.fillStyle='rgba(0,0,0,0.4)';
  ctx.fillRect(0,0,w,HDR_H);
  ctx.font='bold '+(isMobile?'10':'9')+'px JetBrains Mono, monospace';
  ctx.fillStyle=rgba(CLR.dim,.5);
  ctx.textBaseline='middle';
  ctx.textAlign='left';
  ctx.fillText('ASSET',PAD,HDR_H/2);
  ctx.textAlign='center';
  COLS.forEach(function(c,j){
    ctx.fillText(c, dataX+j*colW+colW/2, HDR_H/2);
  });
  ctx.textAlign='right';
  ctx.fillText('REGIME', w-PAD, HDR_H/2);

  ctx.fillStyle=rgba(CLR.line,.6);
  ctx.fillRect(0,HDR_H,w,1);

  S.data.forEach(function(d,i){
    var y=HDR_H+1+i*ROW_H;

    if(i%2===0){
      ctx.fillStyle='rgba(255,255,255,0.008)';
      ctx.fillRect(0,y,w,ROW_H);
    }

    d.v.forEach(function(val,j){
      var x=dataX+j*colW;
      var fi=COL_MAP[j];
      var norm;
      if(fi<2) norm=val;
      else if(fi===2) norm=(val+1)/2;
      else if(fi===3) norm=1-Math.min(val,1.2)/1.2;
      else norm=(val+3)/6;

      ctx.fillStyle=heatRGBA(norm,.3);
      ctx.fillRect(x+2, y+3, colW-4, ROW_H-6);

      var intensity=Math.abs(norm-.5)*2;
      if(intensity>.6){
        ctx.strokeStyle=heatRGBA(norm,.2);
        ctx.lineWidth=1;
        ctx.strokeRect(x+2.5, y+3.5, colW-5, ROW_H-7);
      }
    });

    ctx.fillStyle=rgba(CLR.line,.25);
    ctx.fillRect(0, y+ROW_H-1, w, 1);

    ctx.font='bold '+(isMobile?'11':'10')+'px JetBrains Mono, monospace';
    ctx.fillStyle=rgba(CLR.text,.85);
    ctx.textAlign='left';
    ctx.textBaseline='middle';
    ctx.fillText(d.coin, PAD, y+ROW_H/2);

    ctx.font=(isMobile?'11':'10')+'px JetBrains Mono, monospace';
    ctx.textAlign='center';
    d.v.forEach(function(val,j){
      var fi=COL_MAP[j];
      var norm;
      if(fi<2) norm=val;
      else if(fi===2) norm=(val+1)/2;
      else if(fi===3) norm=1-Math.min(val,1.2)/1.2;
      else norm=(val+3)/6;

      var intensity=Math.abs(norm-.5)*2;
      if(intensity>.5){
        var c=norm<.5?CLR.phosphor:CLR.amber;
        ctx.fillStyle=rgba(c, .6+intensity*.4);
      } else {
        ctx.fillStyle=rgba(CLR.text,.55);
      }
      ctx.fillText(val.toFixed(2), dataX+j*colW+colW/2, y+ROW_H/2);
    });

    if(d.reg){
      var labels={trending:'TRENDING',reverting:'REVERTING',chaotic:'CHAOTIC',shift:'SHIFT'};
      var colors={trending:CLR.phosphor,reverting:CLR.amber,chaotic:CLR.red,shift:CLR.ice};
      var bgAlphas={trending:.12,reverting:.1,chaotic:.15,shift:.08};
      var label=labels[d.reg];
      var clr=colors[d.reg];

      ctx.font='bold 8px JetBrains Mono, monospace';
      var tw=ctx.measureText(label).width;
      var px=w-PAD-tw-10;
      var py=y+ROW_H/2-6;
      var pw=tw+10;
      var ph=13;

      var badgeAlpha=bgAlphas[d.reg];
      if(d.reg==='chaotic'){
        badgeAlpha*=.5+.5*Math.abs(Math.sin(S.time*4));
      }
      if(d.reg==='shift'){
        var osc=Math.sin(S.time*2)*.5+.5;
        var c1=CLR.ice, c2=CLR.amber;
        var cr=Math.round(lerp(c1[0],c2[0],osc));
        var cg=Math.round(lerp(c1[1],c2[1],osc));
        var cb=Math.round(lerp(c1[2],c2[2],osc));
        ctx.fillStyle='rgba('+cr+','+cg+','+cb+',.08)';
        ctx.fillRect(px,py,pw,ph);
        ctx.fillStyle='rgba('+cr+','+cg+','+cb+',.85)';
      } else {
        ctx.fillStyle=rgba(clr,badgeAlpha);
        ctx.fillRect(px,py,pw,ph);
        ctx.fillStyle=rgba(clr, d.reg==='chaotic'? .5+.5*Math.abs(Math.sin(S.time*4)) : .85);
      }
      ctx.textAlign='center';
      ctx.textBaseline='middle';
      ctx.fillText(label, px+pw/2, y+ROW_H/2);

      if(d.reg==='trending'||d.reg==='chaotic'){
        var grad=ctx.createRadialGradient(px+pw/2,y+ROW_H/2,0,px+pw/2,y+ROW_H/2,pw);
        grad.addColorStop(0,rgba(clr,.06));
        grad.addColorStop(1,'rgba(0,0,0,0)');
        ctx.fillStyle=grad;
        ctx.fillRect(px-pw/2,y,pw*2,ROW_H);
      }
    } else {
      ctx.font='10px JetBrains Mono, monospace';
      ctx.fillStyle=rgba(CLR.dim,.2);
      ctx.textAlign='right';
      ctx.fillText('—', w-PAD, y+ROW_H/2);
    }
  });

  S.glows=S.glows.filter(function(g){
    var x=PAD+S.coinW+g.col*S.colW+S.colW/2;
    var y=HDR_H+1+g.row*ROW_H+ROW_H/2;
    var r=g.i*35;
    var grad=S.ctx.createRadialGradient(x,y,0,x,y,r);
    grad.addColorStop(0,'rgba(200,255,0,'+g.i*.2+')');
    grad.addColorStop(1,'rgba(200,255,0,0)');
    S.ctx.fillStyle=grad;
    S.ctx.fillRect(x-r,y-r,r*2,r*2);
    g.i-=g.d;
    return g.i>.01;
  });
}

function tick(){
  S.time+=1/60;
  S.data.forEach(function(d,i){
    d.v.forEach(function(_,j){ d.v[j]=lerp(d.v[j],d.t[j],.06); });
    if(Math.random()<.025){
      var j=Math.floor(Math.random()*NC);
      var fi=COL_MAP[j];
      var s=d.seeds;
      var ranges=[[s.h[0],s.h[1]],[s.d[0],s.d[1]],[s.s[0],s.s[1]],[s.ly[0],s.ly[1]],[s.fl[0],s.fl[1]]];
      var nt=rnd(ranges[fi][0],ranges[fi][1]);
      if(Math.abs(nt-d.v[j])>.08) S.glows.push({row:i,col:j,i:1,d:.015});
      d.t[j]=nt;
      d.full[fi]=nt;
    }
    d.rt--;
    if(d.rt<=0&&!d.liveLocked){d.reg=regime(d.full[0],d.full[1],d.full[3]);d.rt=40+Math.floor(Math.random()*80);}
  });
}

function updateStatus(){
  var n=S.data.filter(function(d){return d.reg;}).length;
  var el=document.getElementById('matrix-status');
  if(!el) return;
  var newText = n+' state'+(n!==1?'s':'')+' detected';
  if(el.textContent !== newText && el.textContent !== '40 coins') {
    el.style.opacity = '0';
    setTimeout(function(){
      el.textContent = newText;
      el.style.opacity = '1';
    }, 150);
  } else if(el.textContent === '40 coins') {
    el.textContent = newText;
  }
}

var fc=0;
function frame(){
  tick();
  draw();
  if(fc%30===0) updateStatus();
  fc++;
  requestAnimationFrame(frame);
}

function resize(){
  var wrap=S.canvas.parentElement;
  var w=wrap.clientWidth;
  var h=HDR_H+COINS.length*ROW_H+2;
  S.canvas.width=w*DPR; S.canvas.height=h*DPR;
  S.canvas.style.width=w+'px'; S.canvas.style.height=h+'px';
  S.ctx=S.canvas.getContext('2d'); S.ctx.scale(DPR,DPR);
  S.w=w; S.h=h; S.colW=(w-S.coinW-S.regW-PAD*2)/NC;
}

// ═══ REGIME VERDICT UPDATER ═══
function updateRegimeVerdict(){
  var btc = LIVE_DATA && LIVE_DATA.BTC;
  if(!btc) return;
  var h = btc.HURST_24H != null ? btc.HURST_24H : 0.5;
  var d = btc.DFA_24H != null ? btc.DFA_24H : 0.5;
  var ly = btc.LYAPUNOV_24H != null ? Math.min(btc.LYAPUNOV_24H, 2)/2 : 0.3;
  rvState.ht = h; rvState.dt = d; rvState.lt = ly;
  rvScenarios.length = 0;
  rvScenarios.push({h:[h-.04,h+.04],d:[d-.04,d+.04],ly:[Math.max(0,ly-.05),ly+.05],label:'live'});
  rvScene = rvScenarios[0];
}

// ═══ LIVE PERFORMANCE DATA ═══
function fetchPerformanceData(){
  fetch('https://api.getzero.dev/performance').then(function(r){
    if(!r.ok) throw new Error('performance API');
    return r.json();
  }).then(function(data){
    renderPerformance(data);
  }).catch(function(){
    // Fallback to portfolio.json
    fetch('/api/portfolio.json').then(function(r){return r.json();}).then(function(data){
      renderPerformanceFromPortfolio(data);
    }).catch(function(e){console.warn('Performance data unavailable',e);});
  });
}

function renderPerformance(data){
  // API returns: total_trades, win_rate, total_pnl_usd, win_loss_ratio, wins, losses
  var equity = 115 + (data.total_pnl_usd || 0);
  document.getElementById('perf-equity').textContent = '$'+equity.toFixed(2);

  var trades = data.total_trades || 0;
  document.getElementById('perf-trades').textContent = trades;
  var statusTrades = document.getElementById('status-trades');
  if(statusTrades) statusTrades.textContent = trades;

  if(data.win_rate != null) {
    var wr = document.getElementById('perf-winrate');
    wr.textContent = data.win_rate.toFixed(1)+'%';
    wr.className = 'perf-stat-val '+(data.win_rate>=50?'p':'a');
  }
  if(data.win_loss_ratio != null) document.getElementById('perf-ratio').textContent = data.win_loss_ratio.toFixed(2)+'x';

  if(data.total_pnl_usd != null) {
    var pnlEl = document.getElementById('perf-pnl');
    pnlEl.textContent = (data.total_pnl_usd>=0?'+$':'-$')+Math.abs(data.total_pnl_usd).toFixed(2);
    pnlEl.className = 'perf-stat-val '+(data.total_pnl_usd>=0?'p':'red');
  }

  // Fallback to portfolio.json for equity curve and trades table
  fetch('/api/portfolio.json').then(function(r){return r.json();}).then(function(pdata){
    var curve = pdata.liveEquityCurve || [];
    if(curve.length > 1) drawEquityCurve(curve);
    var closed = ((pdata.liveTrading||{}).closed||[]).slice(-5).reverse();
    if(closed.length) renderTrades(closed);
  }).catch(function(){});
}

function renderPerformanceFromPortfolio(data){
  var lt = data.liveTrading;
  if(!lt) return;

  var capital = lt.capital || 100;
  var closed = lt.closed || [];
  var trades = lt.trades || closed.length;
  var wins = lt.wins || closed.filter(function(t){return t.pnl_usd>0;}).length;
  var winRate = trades > 0 ? wins/trades : 0;

  // Calculate current equity from curve
  var curve = data.liveEquityCurve || [];
  var equity = curve.length > 0 ? curve[curve.length-1].v : capital;

  // Win/loss ratio
  var totalWinPnl = 0, totalLossPnl = 0, winCount = 0, lossCount = 0;
  closed.forEach(function(t){
    if(t.pnl_usd > 0){ totalWinPnl += t.pnl_usd; winCount++; }
    else if(t.pnl_usd < 0){ totalLossPnl += Math.abs(t.pnl_usd); lossCount++; }
  });
  var avgWin = winCount > 0 ? totalWinPnl/winCount : 0;
  var avgLoss = lossCount > 0 ? totalLossPnl/lossCount : 1;
  var ratio = avgLoss > 0 ? avgWin/avgLoss : 0;

  var pnlPct = ((equity - capital) / capital) * 100;

  document.getElementById('perf-equity').textContent = '$'+equity.toFixed(2);
  document.getElementById('perf-trades').textContent = trades;
  document.getElementById('status-trades').textContent = trades;

  var wrEl = document.getElementById('perf-winrate');
  wrEl.textContent = (winRate*100).toFixed(1)+'%';
  wrEl.className = 'perf-stat-val '+(winRate>=0.5?'p':'a');

  document.getElementById('perf-ratio').textContent = ratio.toFixed(2);

  var pnlEl = document.getElementById('perf-pnl');
  pnlEl.textContent = (pnlPct>=0?'+':'')+pnlPct.toFixed(2)+'%';
  pnlEl.className = 'perf-stat-val '+(pnlPct>=0?'p':'red');

  if(curve.length >= 2) drawEquityCurve(curve);

  // Last 5 closed trades
  var recent = closed.slice(-5).reverse();
  renderTrades(recent.map(function(t){
    var holdMs = new Date(t.exit_time) - new Date(t.entry_time);
    var holdH = Math.round(holdMs / 3600000);
    var holdStr = holdH >= 24 ? Math.round(holdH/24)+'d' : holdH+'h';
    return {
      coin: t.coin,
      direction: t.direction,
      pnl: t.pnl_pct != null ? t.pnl_pct : (t.pnl_usd/t.size_usd*100),
      holdTime: holdStr
    };
  }));
}

function drawEquityCurve(curve){
  var canvas = document.getElementById('equity-canvas');
  if(!canvas || curve.length < 2) return;
  var wrap = canvas.parentElement;
  var w = wrap.clientWidth;
  var h = 100;
  var dpr = Math.min(window.devicePixelRatio || 1, 2);
  canvas.width = w * dpr;
  canvas.height = h * dpr;
  canvas.style.width = w + 'px';
  canvas.style.height = h + 'px';
  var ctx = canvas.getContext('2d');
  ctx.scale(dpr, dpr);

  var padT = 12, padR = 8, padB = 4, padL = 8;
  var cw = w - padL - padR;
  var ch = h - padT - padB;

  var vals = curve.map(function(p){ return typeof p === 'number' ? p : p.v; });
  var minV = Math.min.apply(null, vals);
  var maxV = Math.max.apply(null, vals);
  if(maxV === minV){ maxV = minV + 1; }

  var startV = vals[0];
  var endV = vals[vals.length - 1];
  var isUp = endV >= startV;
  var lineClr = isUp ? 'rgba(200,255,0,0.9)' : 'rgba(255,51,51,0.9)';
  var fillClr = isUp ? 'rgba(200,255,0,0.06)' : 'rgba(255,51,51,0.06)';

  // Draw fill
  ctx.beginPath();
  ctx.moveTo(padL, padT + ch);
  vals.forEach(function(v, i){
    var x = padL + (i / (vals.length - 1)) * cw;
    var y = padT + ch - ((v - minV) / (maxV - minV)) * ch;
    ctx.lineTo(x, y);
  });
  ctx.lineTo(padL + cw, padT + ch);
  ctx.closePath();
  ctx.fillStyle = fillClr;
  ctx.fill();

  // Draw line
  ctx.beginPath();
  vals.forEach(function(v, i){
    var x = padL + (i / (vals.length - 1)) * cw;
    var y = padT + ch - ((v - minV) / (maxV - minV)) * ch;
    if(i === 0) ctx.moveTo(x, y);
    else ctx.lineTo(x, y);
  });
  ctx.strokeStyle = lineClr;
  ctx.lineWidth = 1.5;
  ctx.stroke();

  // Endpoint dot
  var lastX = padL + cw;
  var lastY = padT + ch - ((endV - minV) / (maxV - minV)) * ch;
  ctx.beginPath();
  ctx.arc(lastX, lastY, 3, 0, Math.PI * 2);
  ctx.fillStyle = lineClr;
  ctx.fill();
}

function renderTrades(trades){
  var tbody = document.getElementById('trades-body');
  if(!tbody || !trades || trades.length === 0) {
    if(tbody) tbody.innerHTML = '<tr><td colspan="4" class="dim" style="text-align:center;padding:1rem">no closed trades yet</td></tr>';
    return;
  }
  tbody.innerHTML = '';
  trades.forEach(function(t){
    var tr = document.createElement('tr');
    var pnl = typeof t.pnl_pct === 'number' ? t.pnl_pct : (typeof t.pnl === 'number' ? t.pnl : parseFloat(t.pnl_pct||t.pnl||0));
    var pnlStr = (pnl>=0?'+':'')+pnl.toFixed(2)+'%';
    var pnlCls = pnl >= 0 ? 'p' : 'red';
    var dirCls = t.direction === 'LONG' ? 'p' : 'a';
    // Compute hold time from timestamps
    var holdTime = '—';
    if(t.entry_time && t.exit_time){
      var ms = new Date(t.exit_time) - new Date(t.entry_time);
      var mins = Math.floor(ms/60000);
      holdTime = mins < 60 ? mins+'m' : Math.floor(mins/60)+'h '+mins%60+'m';
    } else if(t.holdTime) {
      holdTime = t.holdTime;
    }
    tr.innerHTML = '<td>'+t.coin+'</td>'+
      '<td class="'+dirCls+'">'+t.direction+'</td>'+
      '<td class="'+pnlCls+'">'+pnlStr+'</td>'+
      '<td class="tt-hide-mobile dim">'+holdTime+'</td>';
    tbody.appendChild(tr);
  });
}

// ═══ REGIME FETCH ═══
function fetchRegimeData(){
  fetch('https://api.getzero.dev/regime').then(function(r){
    if(!r.ok) throw new Error('regime API');
    return r.json();
  }).then(function(data){
    // Update regime badge and verdict with real data
    var coins = data.coins || data;
    var btc = coins.BTC || coins.btc;
    if(btc && btc.regime){
      var badge = document.getElementById('rv-badge');
      var verdict = document.getElementById('rv-verdict');
      if(badge) badge.textContent = btc.regime.toUpperCase();
      if(verdict) verdict.innerHTML = 'BTC regime: <span class="p">' + btc.regime.toUpperCase() + '</span>' + (btc.timeframe_pattern ? ' — ' + btc.timeframe_pattern.replace(/_/g,' ').toLowerCase() : '');
    }
    // Also try to get Hurst/DFA/Lyapunov from Envy fetch (already handled)
  }).catch(function(){
    // Regime data handled by envy fallback
  });
}

// ═══ MAIN INIT ═══
var rvScenarios = [
  {h:[.58,.68], d:[.57,.66], ly:[.15,.40], label:'trending'},
  {h:[.35,.44], d:[.36,.44], ly:[.10,.35], label:'reverting'},
  {h:[.42,.52], d:[.44,.54], ly:[.80,1.05], label:'chaotic'},
  {h:[.58,.65], d:[.38,.46], ly:[.30,.55], label:'shift'},
  {h:[.46,.54], d:[.46,.54], ly:[.20,.50], label:'stable'},
];
var rvScene = rvScenarios[Math.floor(Math.random()*rvScenarios.length)];
var rvSceneTimer = 120 + Math.floor(Math.random()*200);
var rvState = { h: 0.5, d: 0.5, ly: 0.3, ht: 0.5, dt: 0.5, lt: 0.3 };

document.addEventListener('DOMContentLoaded', function(){
  initData(); setup();
  setTimeout(function(){ updateStatus(); requestAnimationFrame(frame); }, 1500);
  fetchLiveData();
  fetchPerformanceData();
  fetchRegimeData();
  setInterval(fetchLiveData, 300000);

  // ═══ CHARACTER-BY-CHARACTER BOOT TYPING ═══
  function typeBootLine(el, delay) {
    var text = el.getAttribute('data-text') || '';
    el.innerHTML = '<span class="boot-cursor">█</span>';
    var i = 0;
    setTimeout(function(){
      var interval = setInterval(function(){
        if(i < text.length) {
          var displayed = text.substring(0, i+1);
          displayed = displayed
            .replace(/ZERO OS/g, '<span class="p">ZERO OS</span>')
            .replace(/BOOT/g, '<span class="p">BOOT</span>')
            .replace(/COGNITIVE LOOP/g, '<span class="p">COGNITIVE LOOP</span>')
            .replace(/14 AGENTS/g, '<span class="p">14 AGENTS</span>')
            .replace(/ADVERSARY/g, '<span class="red">ADVERSARY</span>')
            .replace(/13 ATTACKS/g, '<span class="red">13 ATTACKS</span>')
            .replace(/HYPERLIQUID/g, '<span class="p">HYPERLIQUID</span>')
            .replace(/LIVE/g, '<span class="p">LIVE</span>');
          el.innerHTML = displayed + '<span class="boot-cursor">█</span>';
          i++;
        } else {
          var final = text
            .replace(/ZERO OS/g, '<span class="p">ZERO OS</span>')
            .replace(/BOOT/g, '<span class="p">BOOT</span>')
            .replace(/COGNITIVE LOOP/g, '<span class="p">COGNITIVE LOOP</span>')
            .replace(/14 AGENTS/g, '<span class="p">14 AGENTS</span>')
            .replace(/ADVERSARY/g, '<span class="red">ADVERSARY</span>')
            .replace(/13 ATTACKS/g, '<span class="red">13 ATTACKS</span>')
            .replace(/HYPERLIQUID/g, '<span class="p">HYPERLIQUID</span>')
            .replace(/LIVE/g, '<span class="p">LIVE</span>');
          el.innerHTML = final;
          el.style.textShadow = '0 0 8px rgba(200,255,0,0.4)';
          setTimeout(function() { el.style.textShadow = 'none'; }, 200);
          clearInterval(interval);
        }
      }, 18);
    }, delay);
  }
  document.querySelectorAll('.boot-line').forEach(function(el, idx) {
    typeBootLine(el, idx * 300);
  });

  // ═══ SCROLL REVEAL ═══
  var obs = new IntersectionObserver(function(entries){
    entries.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('visible'); } });
  }, { threshold: 0.05, rootMargin: '0px 0px 50px 0px' });
  document.querySelectorAll('.reveal').forEach(function(el){obs.observe(el);});

  // ═══ COUNTER ANIMATIONS (triggered on scroll reveal) ═══
  var counterObs = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(e.isIntersecting) {
        e.target.querySelectorAll('[data-count-to]').forEach(function(el){
          var target = parseInt(el.getAttribute('data-count-to'));
          var suffix = el.getAttribute('data-count-suffix') || '';
          if(isNaN(target)) return;
          var current = 0;
          var steps = 30;
          var increment = target / steps;
          var stepTime = 40;
          var interval = setInterval(function(){
            current += increment;
            if(current >= target) { current = target; clearInterval(interval); }
            el.textContent = Math.round(current) + suffix;
          }, stepTime);
        });
        counterObs.unobserve(e.target);
      }
    });
  }, { threshold: 0.3 });
  document.querySelectorAll('.perf-stats').forEach(function(el){ counterObs.observe(el); });

  window.addEventListener('resize', function(){
    resize();
    // Re-draw equity curve on resize
    var canvas = document.getElementById('equity-canvas');
    if(canvas && canvas._curveData) drawEquityCurve(canvas._curveData);
  });

  // ═══ REGIME VISUALIZER ═══
  function rvTick() {
    rvSceneTimer--;
    if(rvSceneTimer<=0){
      rvScene = rvScenarios[Math.floor(Math.random()*rvScenarios.length)];
      rvSceneTimer = 120 + Math.floor(Math.random()*200);
    }
    if(Math.random()<.04) rvState.ht = rnd(rvScene.h[0],rvScene.h[1]);
    if(Math.random()<.04) rvState.dt = rnd(rvScene.d[0],rvScene.d[1]);
    if(Math.random()<.03) rvState.lt = rnd(rvScene.ly[0],rvScene.ly[1]);
    rvState.h = lerp(rvState.h, rvState.ht, .03);
    rvState.d = lerp(rvState.d, rvState.dt, .03);
    rvState.ly = lerp(rvState.ly, rvState.lt, .03);

    var hPct = rvState.h * 100;
    var dPct = rvState.d * 100;
    var lPct = Math.max(0, Math.min(rvState.ly, 1.2)) / 1.2 * 100;

    document.getElementById('rv-hurst').style.width = hPct + '%';
    document.getElementById('rv-hurst-marker').style.left = hPct + '%';
    document.getElementById('rv-hurst-val').textContent = rvState.h.toFixed(2);
    document.getElementById('rv-dfa').style.width = dPct + '%';
    document.getElementById('rv-dfa-marker').style.left = dPct + '%';
    document.getElementById('rv-dfa-val').textContent = rvState.d.toFixed(2);
    document.getElementById('rv-lyap').style.width = lPct + '%';
    document.getElementById('rv-lyap-marker').style.left = lPct + '%';
    document.getElementById('rv-lyap-val').textContent = rvState.ly.toFixed(2);

    var badge = document.getElementById('rv-badge');
    var verdict = document.getElementById('rv-verdict');
    var reg = '', vtext = '', cls = '';
    if(rvState.ly > .85) {
      reg='CHAOTIC'; cls='chaotic';
      vtext='BTC regime: <span class="red">CHAOTIC</span> → all entries blocked';
    } else if(rvState.h<.45 && rvState.d<.45) {
      reg='REVERTING'; cls='reverting';
      vtext='BTC regime: <span class="a">REVERTING</span> → trend signals suppressed';
    } else if(rvState.h>.55 && rvState.d>.55) {
      reg='TRENDING'; cls='trending';
      vtext='BTC regime: <span class="p">TRENDING</span> → shorts blocked by macro gate';
    } else if((rvState.h<.45&&rvState.d>.55)||(rvState.h>.55&&rvState.d<.45)) {
      reg='SHIFT'; cls='shift';
      vtext='BTC regime: <span class="ice">SHIFT</span> → reduced position sizing';
    } else {
      reg='SCANNING'; cls='';
      vtext='BTC regime: <span class="dim">ANALYZING</span>';
    }
    badge.textContent = reg;
    badge.className = 'rv-regime-badge ' + cls;
    verdict.innerHTML = vtext;

    var hMarker = document.getElementById('rv-hurst-marker');
    var dMarker = document.getElementById('rv-dfa-marker');
    var lMarker = document.getElementById('rv-lyap-marker');
    hMarker.style.background = rvState.h<.45?'var(--amber)':rvState.h>.55?'var(--phosphor)':'var(--text-dim)';
    hMarker.style.boxShadow = rvState.h<.45?'0 0 8px rgba(255,176,0,.3)':rvState.h>.55?'0 0 8px var(--phosphor-glow)':'none';
    dMarker.style.background = rvState.d<.45?'var(--amber)':rvState.d>.55?'var(--phosphor)':'var(--text-dim)';
    dMarker.style.boxShadow = rvState.d<.45?'0 0 8px rgba(255,176,0,.3)':rvState.d>.55?'0 0 8px var(--phosphor-glow)':'none';
    lMarker.style.background = rvState.ly>.7?'var(--red)':rvState.ly<.2?'var(--ice)':'var(--text-dim)';
    lMarker.style.boxShadow = rvState.ly>.7?'0 0 8px rgba(255,51,51,.3)':'none';
  }
  setInterval(rvTick, 50);

  // ═══ TILT ON HOVER ═══
  document.querySelectorAll('.tilt-card').forEach(function(card){
    card.addEventListener('mousemove', function(e){
      var r=card.getBoundingClientRect();
      var x=(e.clientX-r.left)/r.width-.5;
      var y=(e.clientY-r.top)/r.height-.5;
      card.style.setProperty('--tilt-y',x*4+'deg');
      card.style.setProperty('--tilt-x',-y*4+'deg');
    });
    card.addEventListener('mouseleave', function(){
      card.style.setProperty('--tilt-y','0deg');
      card.style.setProperty('--tilt-x','0deg');
    });
  });
});
</script>
