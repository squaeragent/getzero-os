  .red { color: var(--red); }
</style>

<script>
// ═══════════════════════════════════════════════════
// ZERO OS — Canvas Heat Map Matrix (fully canvas-rendered)
// ═══════════════════════════════════════════════════

const ALL_COINS = ['BTC','ETH','SOL','DOGE','AVAX','LINK','ARB','OP','SUI','MATIC','NEAR','INJ'];
const COINS = window.innerWidth < 640 ? ALL_COINS.slice(0, 8) : ALL_COINS;
const COLS = ['HURST','DFA','SENT','LYAP','FLOW'];
const NC = COLS.length;
const ROW_H = 30;
const HDR_H = 26;
const PAD = 10;
const DPR = Math.min(window.devicePixelRatio || 1, 2);

// palette
const CLR = {
  phosphor: [200,255,0],
  amber: [255,176,0],
  red: [255,51,51],
  ice: [0,212,255],
  text: [232,228,223],
  dim: [138,130,120],
  bg: [5,5,5],
  line: [26,26,26]
};

const S = {
  data: [], canvas: null, ctx: null,
  w: 0, h: 0, coinW: 54, regW: 90, colW: 0,
  glows: [], time: 0
};

function rnd(a,b){return Math.random()*(b-a)+a;}
function lerp(a,b,t){return a+(b-a)*t;}

function regime(h,d,ly){
  if(ly>.85)return 'chaotic';
  if(h<.45&&d<.45)return 'reverting';
  if(h>.55&&d>.55)return 'trending';
  if((h<.45&&d>.55)||(h>.55&&d<.45))return 'shift';
  return '';
}

function heatRGBA(norm, alpha){
  const d=Math.abs(norm-.5)*2;
  const i=Math.pow(d,.7);
  const c=norm<.5?CLR.phosphor:CLR.amber;
  return `rgba(${c[0]},${c[1]},${c[2]},${i*alpha})`;
}

// Realistic seed ranges per coin (based on typical crypto market behavior)
const SEEDS = {
  BTC:  {h:[.47,.53], d:[.48,.54], s:[-.3,.3],  ly:[.1,.4],  fl:[-1,1]},
  ETH:  {h:[.44,.52], d:[.45,.53], s:[-.4,.4],  ly:[.15,.5], fl:[-1.5,1.5]},
  SOL:  {h:[.38,.48], d:[.40,.50], s:[-.5,.5],  ly:[.3,.7],  fl:[-2,2]},
  DOGE: {h:[.33,.45], d:[.35,.47], s:[-.6,.8],  ly:[.4,.9],  fl:[-2.5,2.5]},
  AVAX: {h:[.40,.52], d:[.42,.54], s:[-.4,.4],  ly:[.2,.6],  fl:[-1.5,1.5]},
  LINK: {h:[.42,.54], d:[.44,.56], s:[-.3,.3],  ly:[.15,.5], fl:[-1,1.5]},
  ARB:  {h:[.36,.48], d:[.38,.52], s:[-.5,.5],  ly:[.3,.7],  fl:[-2,2]},
  OP:   {h:[.38,.50], d:[.40,.52], s:[-.4,.4],  ly:[.2,.6],  fl:[-1.5,1.5]},
  SUI:  {h:[.35,.47], d:[.37,.49], s:[-.5,.6],  ly:[.3,.8],  fl:[-2,2.5]},
  MATIC:{h:[.41,.53], d:[.43,.55], s:[-.3,.3],  ly:[.15,.5], fl:[-1,1]},
  NEAR: {h:[.37,.49], d:[.39,.51], s:[-.4,.5],  ly:[.25,.65],fl:[-1.5,2]},
  INJ:  {h:[.34,.46], d:[.36,.48], s:[-.5,.6],  ly:[.35,.75],fl:[-2,2.5]}
};

function initData(){
  COINS.forEach(coin=>{
    const s=SEEDS[coin];
    const v=[rnd(s.h[0],s.h[1]),rnd(s.d[0],s.d[1]),rnd(s.s[0],s.s[1]),rnd(s.ly[0],s.ly[1]),rnd(s.fl[0],s.fl[1])];
    S.data.push({coin,v:[...v],t:[...v],reg:regime(v[0],v[1],v[3]),rt:0,seeds:s});
  });
}

function setup(){
  const c=document.getElementById('matrix-canvas');
  const wrap=c.parentElement;
  const w=wrap.clientWidth;
  const h=HDR_H+COINS.length*ROW_H+2;
  c.width=w*DPR; c.height=h*DPR;
  c.style.width=w+'px'; c.style.height=h+'px';
  S.canvas=c; S.ctx=c.getContext('2d');
  S.ctx.scale(DPR,DPR);
  S.w=w; S.h=h;
  S.colW=(w-S.coinW-S.regW-PAD*2)/NC;
}

function rgba(c,a){return `rgba(${c[0]},${c[1]},${c[2]},${a})`;}

function draw(){
  const {ctx,w,h,coinW,colW,regW}=S;
  const dataX=PAD+coinW;

  ctx.clearRect(0,0,w,h);

  // header
  ctx.fillStyle='rgba(0,0,0,0.4)';
  ctx.fillRect(0,0,w,HDR_H);
  ctx.font='bold 9px JetBrains Mono, monospace';
  ctx.fillStyle=rgba(CLR.dim,.5);
  ctx.textBaseline='middle';
  ctx.textAlign='left';
  ctx.fillText('ASSET',PAD,HDR_H/2);
  ctx.textAlign='center';
  COLS.forEach((c,j)=>{
    ctx.fillText(c, dataX+j*colW+colW/2, HDR_H/2);
  });
  ctx.textAlign='right';
  ctx.fillText('REGIME', w-PAD, HDR_H/2);

  // header line
  ctx.fillStyle=rgba(CLR.line,.6);
  ctx.fillRect(0,HDR_H,w,1);

  // rows
  S.data.forEach((d,i)=>{
    const y=HDR_H+1+i*ROW_H;

    // alternating row bg
    if(i%2===0){
      ctx.fillStyle='rgba(255,255,255,0.008)';
      ctx.fillRect(0,y,w,ROW_H);
    }

    // heat cells
    d.v.forEach((val,j)=>{
      const x=dataX+j*colW;
      let norm;
      if(j<2) norm=val;
      else if(j===2) norm=(val+1)/2;
      else if(j===3) norm=1-Math.min(val,1.2)/1.2;
      else norm=(val+3)/6;

      // cell bg
      ctx.fillStyle=heatRGBA(norm,.3);
      ctx.fillRect(x+2, y+3, colW-4, ROW_H-6);

      // subtle border on hot cells
      const intensity=Math.abs(norm-.5)*2;
      if(intensity>.6){
        ctx.strokeStyle=heatRGBA(norm,.2);
        ctx.lineWidth=1;
        ctx.strokeRect(x+2.5, y+3.5, colW-5, ROW_H-7);
      }
    });

    // row line
    ctx.fillStyle=rgba(CLR.line,.25);
    ctx.fillRect(0, y+ROW_H-1, w, 1);

    // coin label
    ctx.font='bold 10px JetBrains Mono, monospace';
    ctx.fillStyle=rgba(CLR.text,.85);
    ctx.textAlign='left';
    ctx.textBaseline='middle';
    ctx.fillText(d.coin, PAD, y+ROW_H/2);

    // values
    ctx.font='10px JetBrains Mono, monospace';
    ctx.textAlign='center';
    d.v.forEach((val,j)=>{
      let norm;
      if(j<2) norm=val;
      else if(j===2) norm=(val+1)/2;
      else if(j===3) norm=1-Math.min(val,1.2)/1.2;
      else norm=(val+3)/6;

      const intensity=Math.abs(norm-.5)*2;
      if(intensity>.5){
        const c=norm<.5?CLR.phosphor:CLR.amber;
        ctx.fillStyle=rgba(c, .6+intensity*.4);
      } else {
        ctx.fillStyle=rgba(CLR.text,.55);
      }
      ctx.fillText(val.toFixed(2), dataX+j*colW+colW/2, y+ROW_H/2);
    });

    // regime badge
    if(d.reg){
      const labels={trending:'TRENDING',reverting:'REVERTING',chaotic:'CHAOTIC',shift:'SHIFT'};
      const colors={trending:CLR.phosphor,reverting:CLR.amber,chaotic:CLR.red,shift:CLR.ice};
      const bgAlphas={trending:.12,reverting:.1,chaotic:.15,shift:.08};
      const label=labels[d.reg];
      const clr=colors[d.reg];
      
      ctx.font='bold 8px JetBrains Mono, monospace';
      const tw=ctx.measureText(label).width;
      const px=w-PAD-tw-10;
      const py=y+ROW_H/2-6;
      const pw=tw+10;
      const ph=13;

      // badge bg
      let badgeAlpha=bgAlphas[d.reg];
      if(d.reg==='chaotic'){
        badgeAlpha*=.5+.5*Math.abs(Math.sin(S.time*4));
      }
      if(d.reg==='shift'){
        const osc=Math.sin(S.time*2)*.5+.5;
        const c1=CLR.ice, c2=CLR.amber;
        const cr=Math.round(lerp(c1[0],c2[0],osc));
        const cg=Math.round(lerp(c1[1],c2[1],osc));
        const cb=Math.round(lerp(c1[2],c2[2],osc));
        ctx.fillStyle=`rgba(${cr},${cg},${cb},.08)`;
        ctx.fillRect(px,py,pw,ph);
        ctx.fillStyle=`rgba(${cr},${cg},${cb},.85)`;
      } else {
        ctx.fillStyle=rgba(clr,badgeAlpha);
        ctx.fillRect(px,py,pw,ph);
        ctx.fillStyle=rgba(clr, d.reg==='chaotic'? .5+.5*Math.abs(Math.sin(S.time*4)) : .85);
      }
      ctx.textAlign='center';
      ctx.textBaseline='middle';
      ctx.fillText(label, px+pw/2, y+ROW_H/2);

      // glow halo for active regimes
      if(d.reg==='trending'||d.reg==='chaotic'){
        const grad=ctx.createRadialGradient(px+pw/2,y+ROW_H/2,0,px+pw/2,y+ROW_H/2,pw);
        grad.addColorStop(0,rgba(clr,.06));
        grad.addColorStop(1,'rgba(0,0,0,0)');
        ctx.fillStyle=grad;
        ctx.fillRect(px-pw/2,y,pw*2,ROW_H);
      }
    } else {
      ctx.font='10px JetBrains Mono, monospace';
      ctx.fillStyle=rgba(CLR.dim,.2);
      ctx.textAlign='right';
      ctx.fillText('—', w-PAD, y+ROW_H/2);
    }
  });

  // glow bursts
  S.glows=S.glows.filter(g=>{
    const x=PAD+S.coinW+g.col*S.colW+S.colW/2;
    const y=HDR_H+1+g.row*ROW_H+ROW_H/2;
    const r=g.i*35;
    const grad=ctx.createRadialGradient(x,y,0,x,y,r);
    grad.addColorStop(0,`rgba(200,255,0,${g.i*.2})`);
    grad.addColorStop(1,'rgba(200,255,0,0)');
    ctx.fillStyle=grad;
    ctx.fillRect(x-r,y-r,r*2,r*2);
    g.i-=g.d;
    return g.i>.01;
  });
}

function tick(){
  S.time+=1/60;
  S.data.forEach((d,i)=>{
    d.v.forEach((_,j)=>{ d.v[j]=lerp(d.v[j],d.t[j],.06); });
    if(Math.random()<.025){
      const j=Math.floor(Math.random()*NC);
      const s=d.seeds;
      const ranges=[[s.h[0],s.h[1]],[s.d[0],s.d[1]],[s.s[0],s.s[1]],[s.ly[0],s.ly[1]],[s.fl[0],s.fl[1]]];
      const nt=rnd(ranges[j][0],ranges[j][1]);
      if(Math.abs(nt-d.v[j])>.08) S.glows.push({row:i,col:j,i:1,d:.015});
      d.t[j]=nt;
    }
    d.rt--;
    if(d.rt<=0){d.reg=regime(d.v[0],d.v[1],d.v[3]);d.rt=40+Math.floor(Math.random()*80);}
  });
}

function updateStatus(){
  const n=S.data.filter(d=>d.reg).length;
  const el=document.getElementById('matrix-status');
  if(el) el.textContent=n+' regime'+(n!==1?'s':'')+' detected';
}

let fc=0;
function frame(){
  tick();
  draw();
  if(fc%30===0) updateStatus();
  fc++;
  requestAnimationFrame(frame);
}

function resize(){
  const wrap=S.canvas.parentElement;
  const w=wrap.clientWidth;
  const h=HDR_H+COINS.length*ROW_H+2;
  S.canvas.width=w*DPR; S.canvas.height=h*DPR;
  S.canvas.style.width=w+'px'; S.canvas.style.height=h+'px';
  S.ctx=S.canvas.getContext('2d'); S.ctx.scale(DPR,DPR);
  S.w=w; S.h=h; S.colW=(w-S.coinW-S.regW-PAD*2)/NC;
}

document.addEventListener('DOMContentLoaded',()=>{
  initData(); setup(); updateStatus();
  requestAnimationFrame(frame);
  window.addEventListener('resize',resize);

  // ═══ PROPOSAL E: SCROLL REVEAL ═══
  const obs = new IntersectionObserver((entries)=>{
    entries.forEach(e=>{ if(e.isIntersecting){ e.target.classList.add('visible'); } });
  }, { threshold: 0.15 });
  document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));

  // ═══ PROPOSAL A: REGIME VISUALIZER ═══
  const rvState = { h: 0.5, d: 0.5, ly: 0.0, ht: 0.5, dt: 0.5, lt: 0.0 };
  function rvTick() {
    if(Math.random()<.04) rvState.ht = rnd(.25,.75);
    if(Math.random()<.04) rvState.dt = rnd(.25,.75);
    if(Math.random()<.03) rvState.lt = rnd(-.1,1.1);
    rvState.h = lerp(rvState.h, rvState.ht, .03);
    rvState.d = lerp(rvState.d, rvState.dt, .03);
    rvState.ly = lerp(rvState.ly, rvState.lt, .03);

    const hPct = rvState.h * 100;
    const dPct = rvState.d * 100;
    const lPct = Math.max(0, Math.min(rvState.ly, 1.2)) / 1.2 * 100;

    document.getElementById('rv-hurst').style.width = hPct + '%';
    document.getElementById('rv-hurst-marker').style.left = hPct + '%';
    document.getElementById('rv-hurst-val').textContent = rvState.h.toFixed(2);
    document.getElementById('rv-dfa').style.width = dPct + '%';
    document.getElementById('rv-dfa-marker').style.left = dPct + '%';
    document.getElementById('rv-dfa-val').textContent = rvState.d.toFixed(2);
    document.getElementById('rv-lyap').style.width = lPct + '%';
    document.getElementById('rv-lyap-marker').style.left = lPct + '%';
    document.getElementById('rv-lyap-val').textContent = rvState.ly.toFixed(2);

    // regime + verdict
    const badge = document.getElementById('rv-badge');
    const verdict = document.getElementById('rv-verdict');
    let reg = '', vtext = '', cls = '';
    if(rvState.ly > .85) {
      reg='CHAOTIC'; cls='chaotic';
      vtext='Your MACD crossover is → <span class="red">UNRELIABLE</span>';
    } else if(rvState.h<.45 && rvState.d<.45) {
      reg='REVERTING'; cls='reverting';
      vtext='Your MACD crossover is → <span class="a">A TRAP</span>';
    } else if(rvState.h>.55 && rvState.d>.55) {
      reg='TRENDING'; cls='trending';
      vtext='Your MACD crossover is → <span class="p">MEANINGFUL</span>';
    } else if((rvState.h<.45&&rvState.d>.55)||(rvState.h>.55&&rvState.d<.45)) {
      reg='SHIFT'; cls='shift';
      vtext='Your MACD crossover is → <span class="ice">TRANSITIONING</span>';
    } else {
      reg='SCANNING'; cls='';
      vtext='Your MACD crossover is → <span class="dim">ANALYZING</span>';
    }
    badge.textContent = reg;
    badge.className = 'rv-regime-badge ' + cls;
    verdict.innerHTML = vtext;

    // marker colors
    const hMarker = document.getElementById('rv-hurst-marker');
    const dMarker = document.getElementById('rv-dfa-marker');
    const lMarker = document.getElementById('rv-lyap-marker');
    hMarker.style.background = rvState.h<.45?'var(--amber)':rvState.h>.55?'var(--phosphor)':'var(--text-dim)';
    hMarker.style.boxShadow = rvState.h<.45?'0 0 8px rgba(255,176,0,.3)':rvState.h>.55?'0 0 8px var(--phosphor-glow)':'none';
    dMarker.style.background = rvState.d<.45?'var(--amber)':rvState.d>.55?'var(--phosphor)':'var(--text-dim)';
    dMarker.style.boxShadow = rvState.d<.45?'0 0 8px rgba(255,176,0,.3)':rvState.d>.55?'0 0 8px var(--phosphor-glow)':'none';
    lMarker.style.background = rvState.ly>.7?'var(--red)':rvState.ly<.2?'var(--ice)':'var(--text-dim)';
    lMarker.style.boxShadow = rvState.ly>.7?'0 0 8px rgba(255,51,51,.3)':'none';
  }
  setInterval(rvTick, 50);

  // ═══ PROPOSAL F: LIVING DISCOVERY CARDS ═══
  // Card 1: Hurst mean-reversion wave
  const hurstCanvas = document.getElementById('disc-hurst');
  const hurstCtx = hurstCanvas.getContext('2d');
  let hurstVal = 0.41;
  let hurstBuf = [];
  for(let i=0;i<100;i++) hurstBuf.push(30+Math.sin(i*.15)*15);

  function drawHurst(){
    const w=hurstCanvas.width, h=hurstCanvas.height;
    hurstCtx.clearRect(0,0,w,h);
    // bounds lines
    hurstCtx.strokeStyle='rgba(200,255,0,0.1)';
    hurstCtx.setLineDash([3,3]);
    hurstCtx.beginPath(); hurstCtx.moveTo(0,15); hurstCtx.lineTo(w,15); hurstCtx.stroke();
    hurstCtx.beginPath(); hurstCtx.moveTo(0,45); hurstCtx.lineTo(w,45); hurstCtx.stroke();
    hurstCtx.setLineDash([]);
    // wave
    const last=hurstBuf[hurstBuf.length-1];
    const next=last+rnd(-3,3);
    const clamped=Math.max(10,Math.min(50,next+(30-next)*.05));
    hurstBuf.push(clamped); if(hurstBuf.length>100) hurstBuf.shift();
    hurstCtx.beginPath();
    hurstCtx.strokeStyle='rgba(200,255,0,0.6)';
    hurstCtx.lineWidth=1.5;
    hurstBuf.forEach((v,i)=>{
      const x=i*(w/100);
      i===0?hurstCtx.moveTo(x,v):hurstCtx.lineTo(x,v);
    });
    hurstCtx.stroke();
    // update val
    hurstVal=lerp(hurstVal,.41+rnd(-.03,.03),.02);
    document.getElementById('disc-hurst-val').textContent='H = '+hurstVal.toFixed(2);
  }

  // Card 2: Win/loss ticker
  const wlCanvas = document.getElementById('disc-winloss');
  const wlCtx = wlCanvas.getContext('2d');
  let wlDots = [];
  let wlWins = 0, wlTotal = 0;
  for(let i=0;i<40;i++){const w=Math.random()<.28;wlDots.push({x:i*5,win:w});if(w)wlWins++;wlTotal++;}

  function drawWinLoss(){
    const w=wlCanvas.width, h=wlCanvas.height;
    wlCtx.clearRect(0,0,w,h);
    if(Math.random()<.15){
      const win=Math.random()<.28;
      wlDots.push({x:0,win,flash:win?1:0});
      if(win) wlWins++;
      wlTotal++;
      if(wlDots.length>40){const old=wlDots.shift();if(old.win)wlWins--;wlTotal--;}
    }
    wlDots.forEach((d,i)=>{
      d.x=i*(w/40)+w/80;
      const y=h/2;
      const r=d.win?4:2;
      if(d.win){
        wlCtx.fillStyle=`rgba(255,176,0,${0.5+(d.flash||0)*0.5})`;
        if(d.flash>0){
          const grad=wlCtx.createRadialGradient(d.x,y,0,d.x,y,12);
          grad.addColorStop(0,'rgba(255,176,0,0.3)');
          grad.addColorStop(1,'rgba(255,176,0,0)');
          wlCtx.fillStyle=grad;
          wlCtx.fillRect(d.x-12,y-12,24,24);
          wlCtx.fillStyle='rgba(255,176,0,0.9)';
          d.flash-=.02;
        }
      } else {
        wlCtx.fillStyle='rgba(138,130,120,0.25)';
      }
      wlCtx.beginPath();
      wlCtx.arc(d.x,y,r,0,Math.PI*2);
      wlCtx.fill();
    });
    const hr=wlTotal>0?Math.round(wlWins/wlTotal*100):0;
    document.getElementById('disc-hr-val').textContent='<'+hr+'% HR';
  }

  // Card 3: Sentiment divergence
  const sentCanvas = document.getElementById('disc-sent');
  const sentCtx = sentCanvas.getContext('2d');
  let analystPos = 20, crowdPos = 40, analystT = 20, crowdT = 40;

  function drawSent(){
    const w=sentCanvas.width, h=sentCanvas.height;
    sentCtx.clearRect(0,0,w,h);
    if(Math.random()<.02) analystT=rnd(10,50);
    if(Math.random()<.02) crowdT=rnd(10,50);
    analystPos=lerp(analystPos,analystT,.03);
    crowdPos=lerp(crowdPos,crowdT,.03);
    // labels
    sentCtx.font='bold 7px JetBrains Mono, monospace';
    sentCtx.fillStyle='rgba(138,130,120,0.5)';
    sentCtx.textAlign='left';
    sentCtx.fillText('ANALYSTS',4,18);
    sentCtx.fillText('CROWD',4,42);
    // bars
    const barX=60;
    const barW=w-barX-8;
    // analyst bar
    const aW=analystPos/60*barW;
    sentCtx.fillStyle='rgba(0,212,255,0.25)';
    sentCtx.fillRect(barX,10,aW,12);
    sentCtx.fillStyle='rgba(0,212,255,0.7)';
    sentCtx.fillRect(barX+aW-2,10,2,12);
    // crowd bar
    const cW=crowdPos/60*barW;
    sentCtx.fillStyle='rgba(255,176,0,0.2)';
    sentCtx.fillRect(barX,34,cW,12);
    sentCtx.fillStyle='rgba(255,176,0,0.6)';
    sentCtx.fillRect(barX+cW-2,34,2,12);
    // divergence indicator
    const div=Math.abs(analystPos-crowdPos)/60;
    if(div>.3){
      sentCtx.fillStyle=`rgba(0,212,255,${div*.3})`;
      sentCtx.fillRect(0,0,w,h);
    }
  }

  // Resize canvases to container
  function resizeDiscCanvases(){
    document.querySelectorAll('.disc-canvas').forEach(c=>{
      c.width=c.parentElement.clientWidth;
      c.height=60;
    });
  }
  resizeDiscCanvases();
  window.addEventListener('resize',resizeDiscCanvases);

  // Animate all discovery cards
  function discFrame(){
    drawHurst(); drawWinLoss(); drawSent();
    requestAnimationFrame(discFrame);
  }
  requestAnimationFrame(discFrame);

  // ═══ PROPOSAL H: CIRCULAR FLYWHEEL ANIMATION ═══
  let fwIdx = 0;
  setInterval(()=>{
    document.querySelectorAll('.fw-node').forEach(el=>el.classList.remove('fw-active'));
    const nodes = document.querySelectorAll('.fw-node');
    if(nodes[fwIdx]) nodes[fwIdx].classList.add('fw-active');
    fwIdx = (fwIdx + 1) % nodes.length;
  }, 800);

  // ═══ PROPOSAL I: TILT ON HOVER ═══
  document.querySelectorAll('.tilt-card').forEach(card=>{
    card.addEventListener('mousemove',(e)=>{
      const r=card.getBoundingClientRect();
      const x=(e.clientX-r.left)/r.width-.5;
      const y=(e.clientY-r.top)/r.height-.5;
      card.style.setProperty('--tilt-y',x*4+'deg');
      card.style.setProperty('--tilt-x',-y*4+'deg');
    });
    card.addEventListener('mouseleave',()=>{
      card.style.setProperty('--tilt-y','0deg');
      card.style.setProperty('--tilt-x','0deg');
    });
  });

  // ═══ PROPOSAL D: TERMINAL CTA ═══
  const form = document.getElementById('access-form');
  if(form) form.addEventListener('submit', async(e)=>{
    e.preventDefault();
    const email = document.getElementById('access-email').value;
    if(!email) return;
    const btn = form.querySelector('.term-submit');
    btn.textContent = 'SUBMITTING...';
    btn.disabled = true;
    try {
      const res = await fetch('/api/waitlist', {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({email})
      });
      const data = await res.json();
      document.getElementById('req-id').textContent = data.ref || 'ZOS-' + Math.random().toString(36).substr(2,6).toUpperCase();
    } catch(e) {
      document.getElementById('req-id').textContent = 'ZOS-' + Math.random().toString(36).substr(2,6).toUpperCase();
    }
    form.style.display = 'none';
    document.getElementById('term-confirm').style.display = 'block';
  });
});
</script>
