---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ZERO OS — Adversarial Trading Intelligence">

<div class="page">

  <div class="page-inner">

  <!-- CRT BOOT + MATRIX (two-column hero) -->
  <header class="hero hero-split">
    <div class="hero-left">
      <div class="boot-sequence">
        <pre class="boot-line b1" data-text="ZERO OS v0.2 ........................ BOOT"></pre>
        <pre class="boot-line b2" data-text="COGNITIVE LOOP ...................... 14 AGENTS"></pre>
        <pre class="boot-line b3" data-text="ADVERSARY .......................... 13 ATTACKS"></pre>
        <pre class="boot-line b4" data-text="HYPERLIQUID ........................ LIVE"></pre>
      </div>

      <div class="logo-wrap">
        <pre class="logo-art">████████╗ ███████╗ ██████╗   ██████╗
╚══███╔═╝ ██╔════╝ ██╔══██╗ ██╔═══██╗
  ███╔╝   █████╗   ██████╔╝ ██║   ██║
 ███╔╝    ██╔══╝   ██╔══██╗ ██║   ██║
████████╗ ███████╗ ██║  ██║ ╚██████╔╝
╚═══════╝ ╚══════╝ ╚═╝  ╚═╝  ╚═════╝</pre>
        <div class="crt-scanline"></div>
      </div>

      <h1 class="hero-title">An intelligence that challenges itself before it trades.</h1>

      <p class="hero-bridge">Every hypothesis gets killed before it touches real money.</p>

      <p class="hero-sub">
        14 agents. 40 coins. 81 indicators. Adversarial cognition on Hyperliquid.
      </p>

      <div class="hero-cta">
        <a href="/portfolio" class="btn-primary">See live performance →</a>
        <a href="/thesis" class="btn-ghost">Read the thesis →</a>
      </div>
    </div>

    <div class="hero-right">
      <div class="matrix-head">
        <p class="section-label p matrix-label">REGIME MAP — LIVE</p>
        <span class="matrix-status" id="matrix-status">40 coins</span>
      </div>
      <div class="matrix-wrap">
        <canvas id="matrix-canvas"></canvas>
      </div>
    </div>
  </header>

  <!-- ═══ PANE: ADVERSARY + REGIME ═══ -->
  <div class="pane-grid reveal">
    <div class="pane">
      <div class="pane-header"><span class="p">■</span> THE ADVERSARY <span class="pane-dim">— 13 attacks</span></div>
      <div class="pane-body">
        <p class="pane-text">Every trade hypothesis passes through 13 adversarial attack vectors before execution. Regime mismatch. Funding headwind. Macro alignment. Family track record. Portfolio stress. The system doesn't just predict — it attacks its own predictions.</p>
        <div class="edge-contrast">
          <div class="edge-row">
            <span class="edge-them dim">Signal says LONG</span>
            <span class="edge-us p">→ 13 attacks ask why it's wrong</span>
          </div>
          <div class="edge-row">
            <span class="edge-them dim">Backtest shows 76% WR</span>
            <span class="edge-us p">→ Genealogy tracks if that family actually wins</span>
          </div>
        </div>
      </div>
    </div>
    <div class="pane">
      <div class="pane-header"><span class="p">■</span> LIVE REGIME <span class="pane-dim">— 40 coins</span></div>
      <div class="pane-body">
        <div class="regime-viz">
          <div class="rv-bar-group">
            <div class="rv-bar">
              <span class="rv-label dim">TREND</span>
              <div class="rv-track">
                <div class="rv-fill" id="rv-hurst"></div>
                <div class="rv-marker" id="rv-hurst-marker"></div>
              </div>
              <span class="rv-val" id="rv-hurst-val">0.50</span>
            </div>
            <div class="rv-bar">
              <span class="rv-label dim">PATTERN</span>
              <div class="rv-track">
                <div class="rv-fill" id="rv-dfa"></div>
                <div class="rv-marker" id="rv-dfa-marker"></div>
              </div>
              <span class="rv-val" id="rv-dfa-val">0.50</span>
            </div>
            <div class="rv-bar">
              <span class="rv-label dim">CHAOS</span>
              <div class="rv-track">
                <div class="rv-fill rv-fill-lyap" id="rv-lyap"></div>
                <div class="rv-marker" id="rv-lyap-marker"></div>
              </div>
              <span class="rv-val" id="rv-lyap-val">0.00</span>
            </div>
          </div>
          <div class="rv-output">
            <div class="rv-regime-badge" id="rv-badge">SCANNING</div>
            <p class="rv-verdict" id="rv-verdict">BTC regime: <span class="dim">ANALYZING</span></p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ PANE: LIVE PERFORMANCE ═══ -->
  <div class="pane-full reveal" id="proof">
    <div class="pane">
      <div class="pane-header"><span class="a">▲</span> LIVE PERFORMANCE <span class="pane-dim">— Hyperliquid</span></div>
      <div class="pane-body">
        <div class="perf-stats" id="perf-stats">
          <div class="perf-stat tilt-card">
            <div class="perf-stat-val p" id="perf-equity">—</div>
            <div class="perf-stat-label dim">EQUITY</div>
          </div>
          <div class="perf-stat tilt-card">
            <div class="perf-stat-val a" id="perf-trades">—</div>
            <div class="perf-stat-label dim">TRADES</div>
          </div>
          <div class="perf-stat tilt-card">
            <div class="perf-stat-val" id="perf-winrate">—</div>
            <div class="perf-stat-label dim">WIN RATE</div>
          </div>
          <div class="perf-stat tilt-card">
            <div class="perf-stat-val ice" id="perf-ratio">—</div>
            <div class="perf-stat-label dim">WIN/LOSS RATIO</div>
          </div>
          <div class="perf-stat tilt-card">
            <div class="perf-stat-val" id="perf-pnl">—</div>
            <div class="perf-stat-label dim">P&amp;L</div>
          </div>
        </div>
        <div class="equity-curve-wrap">
          <canvas id="equity-canvas"></canvas>
        </div>
        <div class="recent-trades-wrap">
          <table class="trades-table" id="trades-table">
            <thead>
              <tr>
                <th class="tt-coin">COIN</th>
                <th>DIRECTION</th>
                <th>P&amp;L</th>
                <th class="tt-hide-mobile">HOLD TIME</th>
              </tr>
            </thead>
            <tbody id="trades-body">
              <tr><td colspan="4" class="dim" style="text-align:center;padding:1rem">loading...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ PANE: COGNITIVE LOOP ═══ -->
  <div class="pane-full reveal">
    <div class="pane">
      <div class="pane-header"><span class="p">■</span> COGNITIVE LOOP</div>
      <div class="pane-body">
        <div class="loop-flow">
          <div class="loop-stage reveal-child">
            <div class="loop-name">PERCEIVE</div>
            <div class="loop-desc dim">81 indicators across 40 coins</div>
            <div class="loop-metric dim">3 data sources</div>
          </div>
          <div class="loop-arrow dim reveal-child">→</div>
          <div class="loop-stage reveal-child">
            <div class="loop-name">HYPOTHESIZE</div>
            <div class="loop-desc dim">1,190 signals scored by composite</div>
            <div class="loop-metric dim">161 families tracked</div>
          </div>
          <div class="loop-arrow dim reveal-child">→</div>
          <div class="loop-stage loop-stage-alert reveal-child">
            <div class="loop-name red">CHALLENGE</div>
            <div class="loop-desc dim">13 adversarial attacks</div>
            <div class="loop-metric dim">71% kill accuracy</div>
          </div>
          <div class="loop-arrow dim reveal-child">→</div>
          <div class="loop-stage reveal-child">
            <div class="loop-name">ACT</div>
            <div class="loop-desc dim">Hyperliquid perps, on-chain stops</div>
            <div class="loop-metric dim">&lt; 50ms execution</div>
          </div>
          <div class="loop-arrow dim reveal-child">→</div>
          <div class="loop-stage reveal-child">
            <div class="loop-name">EVOLVE</div>
            <div class="loop-desc dim">Counterfactual learning</div>
            <div class="loop-metric dim">Weights evolve from outcomes</div>
          </div>
        </div>
        <p class="loop-feedback dim">↻ every trade feeds back into the next decision</p>
      </div>
    </div>
  </div>

  <!-- ═══ PANE: SYSTEM STATUS ═══ -->
  <div class="pane-full reveal" id="status">
    <div class="pane">
      <div class="pane-header"><span class="p">■</span> SYSTEM STATUS</div>
      <div class="pane-body pane-term">
        <p class="term-line dim">$ zero-os status</p>
        <p class="term-line"><span class="p">▸</span> cognitive_loop: <span class="p">LIVE</span> — 14 agents operational</p>
        <p class="term-line"><span class="p">▸</span> trades_executed: <span class="p" id="status-trades">—</span></p>
        <p class="term-line"><span class="p">▸</span> adversary_accuracy: <span class="p">71%</span></p>
        <p class="term-line"><span class="p">▸</span> regime_coverage: <span class="p">40 coins</span></p>
        <p class="term-line"><span class="p">▸</span> data_sources: <span class="p">3</span> (indicators + funding + orderbook)</p>
        <p class="term-line"><span class="p">▸</span> uptime: <span class="p">operational</span></p>
        <p class="term-line term-cursor"><span class="p">▸</span> api: <span class="dim">api.getzero.dev</span> [internal]</p>
      </div>
    </div>
  </div>

  <!-- FOOTER -->
  <footer class="footer reveal">
    <span class="p">◇</span> <span class="dim">ZERO OS</span>
  </footer>

  </div><!-- /page-inner -->
</div>

</BaseLayout>

<style>
  html, body { overflow-x: hidden; max-width: 100vw; }
  .page {
    margin: 0.5rem;
    border: 1px solid rgba(200,255,0,0.4);
    min-height: calc(100vh - 1rem);
    padding: 0;
    position: relative;
    overflow: hidden;
    animation: borderFlash 0.3s ease 0.95s both;
  }
  .page::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(200,255,0,0.012) 2px, rgba(200,255,0,0.012) 4px);
    pointer-events: none;
    z-index: 0;
  }
  .page-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0.75rem 3rem 2rem;
  }

  /* CRT */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.03) 2px, rgba(0,0,0,0.03) 4px);
    pointer-events: none;
    z-index: 100;
  }
  @media (max-width: 639px) {
    body::before { opacity: 0.5; }
    .page { margin: 0.5rem auto; min-height: calc(100vh - 1rem); }
    .page-inner { padding: 0.5rem 1rem 1.25rem; }
  }
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse 80% 80% at 50% 50%, transparent 0%, transparent 90%, rgba(0,0,0,0.1) 95%, rgba(0,0,0,0.2) 100%);
    pointer-events: none;
    z-index: 101;
  }
  @media (max-width: 639px) {
    body::after { display: none; }
  }

  /* HERO — two-column split on desktop */
  .hero-split {
    display: grid;
    grid-template-columns: 45% 55%;
    gap: 2rem;
    align-items: start;
  }
  @media (max-width: 900px) {
    .hero-split { grid-template-columns: 1fr; }
  }
  .hero-right {
    padding-top: 1rem;
  }
  .hero { padding: 0.5rem 0 2rem; border-bottom: 1px solid var(--border); }
  .boot-sequence { margin-bottom: 1.25rem; }
  .boot-line {
    font-family: var(--font-head);
    font-size: clamp(0.7rem, 2vw, 0.85rem);
    color: var(--text-dim);
    margin: 0;
    line-height: 1.8;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
    min-height: 1.8em;
    transition: text-shadow 0.2s ease;
  }
  .boot-line .boot-cursor {
    color: var(--phosphor);
    animation: blink 0.6s step-end infinite;
  }

  .logo-wrap { position: relative; margin-bottom: 1.5rem; overflow: hidden; }
  .logo-art {
    font-family: var(--font-head);
    font-size: clamp(7px, calc((100vw - 30px) / 38), 22px);
    line-height: 1.15;
    color: var(--phosphor);
    white-space: pre;
    margin: 0;
    background: transparent;
    border: none;
    opacity: 0;
    animation: logoIn 0.4s ease 1.2s both, logoGlow 3s ease-in-out 1.7s infinite;
  }
  @keyframes logoIn {
    0% { opacity: 0; filter: brightness(4) blur(3px); text-shadow: 0 0 30px rgba(200,255,0,0.8); }
    40% { opacity: 0.8; filter: brightness(2) blur(1px); }
    100% { opacity: 1; filter: brightness(1) blur(0); }
  }
  @keyframes logoGlow {
    0%, 100% { text-shadow: 0 0 6px var(--phosphor-glow), 0 0 20px rgba(200,255,0,0.08); }
    50% { text-shadow: 0 0 12px var(--phosphor-glow), 0 0 30px rgba(200,255,0,0.15), 0 0 50px rgba(200,255,0,0.05); }
  }
  .crt-scanline {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--phosphor);
    opacity: 0.06;
    animation: scanDrop 3s linear infinite;
    pointer-events: none;
  }
  @keyframes scanDrop { 0% { top: 0; } 100% { top: 100%; } }

  .hero-title {
    font-family: var(--font-head);
    font-size: clamp(1.6rem, 5vw, 3.2rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--text);
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
    animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 1.4s both;
  }
  .hero-bridge {
    font-family: var(--font-head);
    font-size: clamp(1.1rem, 3vw, 1.5rem);
    font-weight: 700;
    color: var(--phosphor);
    margin-bottom: 1.25rem;
    animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 1.55s both;
  }
  .hero-sub {
    font-size: clamp(0.9rem, 2vw, 1.05rem);
    font-weight: 400;
    color: var(--text-dim);
    line-height: 1.7;
    max-width: 560px;
    word-wrap: break-word;
    overflow-wrap: break-word;
    margin-bottom: 1.5rem;
    animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 1.7s both;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(14px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes borderFlash {
    0% { border-color: rgba(200,255,0,0.4); box-shadow: none; }
    50% { border-color: rgba(200,255,0,0.9); box-shadow: 0 0 30px rgba(200,255,0,0.15), inset 0 0 30px rgba(200,255,0,0.05); }
    100% { border-color: rgba(200,255,0,0.4); box-shadow: none; }
  }

  .hero-cta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 1.85s both;
  }
  @media (max-width: 639px) {
    .hero-cta { flex-direction: column; }
    .hero-cta a { text-align: center; }
  }
  .btn-primary {
    font-family: var(--font-head);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--phosphor);
    background: transparent;
    border: 1px solid var(--phosphor);
    padding: 0.75rem 1.5rem;
    text-decoration: none;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: color 0.3s, background 0.3s, box-shadow 0.3s;
  }
  .btn-primary::before {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 100%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(200,255,0,0.1), transparent);
    animation: scanSweep 3s linear infinite;
  }
  @keyframes scanSweep {
    0% { left: -100%; }
    100% { left: 100%; }
  }
  .btn-primary:hover {
    background: rgba(200,255,0,0.08);
    box-shadow: 0 0 20px rgba(200,255,0,0.1), inset 0 0 20px rgba(200,255,0,0.05);
    color: var(--phosphor);
  }
  .btn-ghost {
    font-family: var(--font-head);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--text-dim);
    padding: 0.75rem 1.5rem;
    text-decoration: none;
    border: 1px solid var(--border);
    transition: border-color 0.3s, color 0.3s, box-shadow 0.3s;
  }
  .btn-ghost:hover {
    border-color: rgba(200,255,0,0.25);
    color: var(--text);
    box-shadow: 0 0 12px rgba(200,255,0,0.04);
  }

  /* ═══ ORCHESTRATED BOOT SEQUENCE ═══ */
  .hero-right {
    opacity: 0;
    transform: translateY(12px);
    animation: sectionIn 0.7s cubic-bezier(0.16, 1, 0.3, 1) 1.9s both;
  }
  @keyframes sectionIn {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Number counter animation */
  .counter-animate {
    display: inline-block;
    animation: counterPop 0.4s ease both;
  }
  @keyframes counterPop {
    0% { opacity: 0; transform: translateY(8px) scale(0.8); }
    60% { transform: translateY(-2px) scale(1.05); }
    100% { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* Hover micro-interactions */
  .tilt-card {
    transform: perspective(600px) rotateX(var(--tilt-x, 0deg)) rotateY(var(--tilt-y, 0deg));
    transition: transform 0.15s ease, border-color 0.4s, box-shadow 0.4s;
    will-change: transform;
    transform-style: preserve-3d;
  }
  @media (hover: hover) {
    .tilt-card:hover { transform: perspective(600px) rotateX(var(--tilt-x,0deg)) rotateY(var(--tilt-y,0deg)); }
  }

  /* Edge row entrance */
  .edge-row {
    opacity: 0;
    transform: translateX(-8px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .reveal.visible .edge-row:nth-child(1) { transition-delay: 0.1s; }
  .reveal.visible .edge-row:nth-child(2) { transition-delay: 0.25s; }
  .reveal.visible .edge-row {
    opacity: 1;
    transform: translateX(0);
  }

  /* Terminal CTA typing cursor */
  .term-line::after {
    content: '';
    display: inline-block;
    width: 0;
    height: 0;
  }
  .term-cursor::after {
    content: '█';
    animation: blink 1s step-end infinite;
    color: var(--phosphor);
    font-weight: 400;
  }
  @keyframes blink { 0%,50% { opacity: 1; } 51%,100% { opacity: 0; } }

  /* MATRIX */
  .matrix-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.4rem;
  }
  .matrix-status {
    font-family: var(--font-head);
    font-size: 0.65rem;
    color: var(--phosphor);
    letter-spacing: 0.05em;
    animation: pulse 2s ease infinite;
    transition: opacity 0.15s ease;
  }
  @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.5; } }

  .matrix-wrap {
    position: relative;
    border: 1px solid var(--border);
    background: rgba(0,0,0,0.6);
    overflow: hidden;
    max-width: 100%;
    animation: matrixBreathe 4s ease-in-out infinite;
    will-change: box-shadow, border-color;
  }
  @keyframes matrixBreathe {
    0%,100% { box-shadow: 0 0 0px transparent, inset 0 0 0px transparent; border-color: var(--border); }
    50% { box-shadow: 0 0 12px rgba(200,255,0,0.04), inset 0 0 20px rgba(200,255,0,0.02); border-color: rgba(200,255,0,0.15); }
  }
  #matrix-canvas {
    display: block;
    width: 100%;
    image-rendering: pixelated;
  }

  /* ═══ PANE SYSTEM — Terminal panels ═══ */
  .pane-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }
  .pane-full { margin-bottom: 0.5rem; }
  .pane {
    border: 1px solid var(--border);
    background: rgba(0,0,0,0.4);
  }
  .pane-header {
    font-family: var(--font-head);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    padding: 0.5rem 1rem;
    border-bottom: 1px solid var(--border);
    background: rgba(10,10,10,0.6);
    color: var(--text-dim);
  }
  .pane-dim { font-weight: 400; opacity: 0.5; font-size: 0.6rem; letter-spacing: 0.05em; }
  .pane-body { padding: 1.25rem; overflow: hidden; }
  .pane-text {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text-dim);
    margin-bottom: 1rem;
  }
  .pane-term {
    font-family: var(--font-head);
    font-size: 0.85rem;
  }
  @media (max-width: 900px) {
    .pane-grid { grid-template-columns: 1fr; }
  }

  /* ═══ SCROLL REVEAL ═══ */
  .reveal {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }
  .reveal-child {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1), transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal.visible .reveal-child { opacity: 1; transform: translateY(0); }
  .reveal.visible .reveal-child:nth-child(1) { transition-delay: 0s; }
  .reveal.visible .reveal-child:nth-child(2) { transition-delay: .06s; }
  .reveal.visible .reveal-child:nth-child(3) { transition-delay: .12s; }
  .reveal.visible .reveal-child:nth-child(4) { transition-delay: .18s; }
  .reveal.visible .reveal-child:nth-child(5) { transition-delay: .24s; }
  .reveal.visible .reveal-child:nth-child(6) { transition-delay: .30s; }
  .reveal.visible .reveal-child:nth-child(7) { transition-delay: .36s; }
