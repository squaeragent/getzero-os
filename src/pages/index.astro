---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ZERO OS — AI trades better than you">

<div class="page">

  <div class="page-inner">

  <!-- CRT BOOT + MATRIX (two-column hero) -->
  <header class="hero hero-split">
    <div class="hero-left">
      <div class="boot-sequence">
        <pre class="boot-line b1" data-text="ZERO OS v0.1 .................... BOOT"></pre>
        <pre class="boot-line b2" data-text="ENVY MATRIX .................... ACTIVE"></pre>
        <pre class="boot-line b3" data-text="PORTFOLIO ENGINE ............... SELF-CUSTODIAL"></pre>
      </div>

      <div class="logo-wrap">
        <pre class="logo-art">████████╗ ███████╗ ██████╗   ██████╗
╚══███╔═╝ ██╔════╝ ██╔══██╗ ██╔═══██╗
  ███╔╝   █████╗   ██████╔╝ ██║   ██║
 ███╔╝    ██╔══╝   ██╔══██╗ ██║   ██║
████████╗ ███████╗ ██║  ██║ ╚██████╔╝
╚═══════╝ ╚══════╝ ╚═╝  ╚═╝  ╚═════╝</pre>
        <div class="crt-scanline"></div>
      </div>

      <h1 class="hero-title">AI trades better than you.<br>And you're OK with it.</h1>

      <p class="hero-sub">
        79 dimensions of market intelligence. Self-custodial.<br>
        Every other trading bot reads 5 indicators and guesses. This one doesn't guess.
      </p>

      <p class="hero-tertiary">Agent · Skill · CLI — works with OpenClaw, Claude Code, Perplexity Computer</p>

      <div class="hero-cta">
        <a href="#access" class="btn-primary">Request Early Access →</a>
        <a href="/thesis" class="btn-ghost">Read the thesis →</a>
      </div>
    </div>

    <div class="hero-right">
      <div class="matrix-head">
        <p class="section-label p">SIGNAL MATRIX — DEMO</p>
        <span class="matrix-status" id="matrix-status">scanning</span>
      </div>
      <div class="matrix-wrap">
        <canvas id="matrix-canvas"></canvas>
      </div>
    </div>
  </header>

  <!-- PROOF -->
  <section class="section reveal" id="proof">
    <p class="section-label a reveal-child">MONTE CARLO BACKTEST</p>
    <h2 class="section-title reveal-child">14 out of 15 coins profitable. Even at the 5th percentile.</h2>
    <p class="bt-sub dim reveal-child">Monte Carlo simulation across 15 assets, 12 months of historical data, 10,000 runs per coin. Includes 0.1% taker fees and 0.05% slippage per trade. The agent only enters when market conditions confirm the strategy applies.</p>
    
    <div class="bt-table-wrap reveal-child">
      <table class="bt-table">
        <thead>
          <tr>
            <th class="bt-coin">COIN</th>
            <th>RETURN</th>
            <th>WIN RATE</th>
            <th>MAX DD</th>
            <th class="bt-hide-mobile">p5 RETURN*</th>
          </tr>
        </thead>
        <tbody>
          <tr><td class="bt-coin">BTC</td><td class="p">+52.2%</td><td>50.9%</td><td class="bt-dd">-14.9%</td><td class="p bt-hide-mobile">+35.3%</td></tr>
          <tr><td class="bt-coin">ETH</td><td class="p">+77.4%</td><td>39.8%</td><td class="bt-dd">-28.3%</td><td class="p bt-hide-mobile">+42.0%</td></tr>
          <tr><td class="bt-coin">SOL</td><td class="p">+86.5%</td><td>43.4%</td><td class="bt-dd">-16.0%</td><td class="p bt-hide-mobile">+50.4%</td></tr>
          <tr><td class="bt-coin">ARB</td><td class="p">+95.8%</td><td>37.1%</td><td class="bt-dd">-23.1%</td><td class="p bt-hide-mobile">+45.6%</td></tr>
          <tr><td class="bt-coin">CRV</td><td class="p">+127.0%</td><td>34.7%</td><td class="bt-dd bt-dd-hot">-31.5%</td><td class="p bt-hide-mobile">+43.7%</td></tr>
          <tr><td class="bt-coin">KPEPE</td><td class="p">+256.1%</td><td>37.7%</td><td class="bt-dd">-20.4%</td><td class="p bt-hide-mobile">+165.0%</td></tr>
          <tr><td class="bt-coin">KBONK</td><td class="p">+224.6%</td><td>32.6%</td><td class="bt-dd bt-dd-hot">-29.2%</td><td class="p bt-hide-mobile">+143.2%</td></tr>
          <tr><td class="bt-coin">TRX</td><td class="p">+59.4%</td><td class="bt-wr-best">61.3%</td><td class="bt-dd bt-dd-safe">-8.3%</td><td class="p bt-hide-mobile">+47.8%</td></tr>
          <tr><td class="bt-coin">DOGE</td><td class="p">+47.6%</td><td>38.2%</td><td class="bt-dd">-19.7%</td><td class="p bt-hide-mobile">+20.1%</td></tr>
          <tr><td class="bt-coin">KSHIB</td><td class="p">+117.7%</td><td>43.0%</td><td class="bt-dd">-17.8%</td><td class="p bt-hide-mobile">+70.7%</td></tr>
          <tr class="bt-neg"><td class="bt-coin">PAXG</td><td class="dim">-5.1%</td><td>49.2%</td><td class="bt-dd bt-dd-safe">-11.3%</td><td class="red bt-hide-mobile">-14.1%</td></tr>
        </tbody>
      </table>
    </div>

    <p class="bt-footnote dim reveal-child">* p5 = 5th percentile of Monte Carlo simulations. 95% of outcomes were better than this number.</p>

    <div class="bt-highlights reveal-child">
      <div class="bt-stat tilt-card">
        <div class="bt-stat-val p" data-count-to="14" data-count-suffix="/15">0/15</div>
        <div class="bt-stat-label dim">coins profitable at median</div>
      </div>
      <div class="bt-stat tilt-card">
        <div class="bt-stat-val a" data-count-to="37" data-count-suffix="%">0%</div>
        <div class="bt-stat-label dim">avg win rate — wins 3-5x larger</div>
      </div>
      <div class="bt-stat tilt-card">
        <div class="bt-stat-val ice">p5+</div>
        <div class="bt-stat-label dim">worst 5% still profitable</div>
      </div>
    </div>
  </section>

  <!-- MID-PAGE CTA -->
  <div class="mid-cta reveal">
    <a href="#access" class="btn-primary">Become a design partner →</a>
    <span class="mid-cta-note dim">Design partners — funds, desks, and builders who want first access.</span>
  </div>

  <!-- THE INTELLIGENCE -->
  <section class="section reveal">
    <p class="section-label p reveal-child">WHY IT'S SMARTER</p>
    <h2 class="section-title reveal-child">Your agent sees what others can't.</h2>
    <p class="intel-explain dim reveal-child">79 dimensions. Technical indicators across 7 timeframes, Ichimoku cloud system, regime detection, social sentiment analysis, candlestick pattern recognition. Your bot checks RSI. Ours checks everything — and knows when RSI is lying.</p>

    <div class="edge-contrast reveal-child">
      <div class="edge-row">
        <span class="edge-them dim">RSI says overbought</span>
        <span class="edge-us p">We know if RSI even applies right now</span>
      </div>
      <div class="edge-row">
        <span class="edge-them dim">MACD shows a crossover</span>
        <span class="edge-us p">We tell you if that crossover is meaningful or a trap</span>
      </div>
    </div>

    <div class="regime-viz reveal-child">
      <div class="rv-bar-group">
        <div class="rv-bar">
          <span class="rv-label dim">TREND <span style="font-size:0.35rem;opacity:0.5">(Hurst)</span></span>
          <div class="rv-track">
            <div class="rv-fill" id="rv-hurst"></div>
            <div class="rv-marker" id="rv-hurst-marker"></div>
          </div>
          <span class="rv-val" id="rv-hurst-val">0.50</span>
        </div>
        <div class="rv-bar">
          <span class="rv-label dim">PATTERN <span style="font-size:0.35rem;opacity:0.5">(DFA)</span></span>
          <div class="rv-track">
            <div class="rv-fill" id="rv-dfa"></div>
            <div class="rv-marker" id="rv-dfa-marker"></div>
          </div>
          <span class="rv-val" id="rv-dfa-val">0.50</span>
        </div>
        <div class="rv-bar">
          <span class="rv-label dim">CHAOS <span style="font-size:0.35rem;opacity:0.5">(Lyapunov)</span></span>
          <div class="rv-track">
            <div class="rv-fill rv-fill-lyap" id="rv-lyap"></div>
            <div class="rv-marker" id="rv-lyap-marker"></div>
          </div>
          <span class="rv-val" id="rv-lyap-val">0.00</span>
        </div>
      </div>
      <div class="rv-output">
        <div class="rv-regime-badge" id="rv-badge">SCANNING</div>
        <p class="rv-verdict" id="rv-verdict">Your MACD crossover is → <span class="p">ANALYZING</span></p>
      </div>
    </div>
  </section>

  <!-- MODES + AGENT (two-column) -->
  <section class="section reveal">
    <div class="dual-grid">
      <div class="dual-col">
        <p class="section-label a reveal-child">MODES</p>
        <h2 class="section-title reveal-child">You choose the autonomy level</h2>
        <div class="mode-gradient reveal-child">
          <div class="mode-step" style="--mode-opacity: 0.4">
            <div class="mode-bar"></div>
            <div class="mode-content">
              <span class="mode-label dim">OBSERVE</span>
              <span class="mode-meta dim">FREE</span>
            </div>
            <p class="mode-desc-inline dim">Watch the agent think. No trades.</p>
          </div>
          <div class="mode-step" style="--mode-opacity: 0.6">
            <div class="mode-bar a"></div>
            <div class="mode-content">
              <span class="mode-label a">SIGNAL</span>
              <span class="mode-meta dim">COMPUTE</span>
            </div>
            <p class="mode-desc-inline dim">Agent generates signals. You execute.</p>
          </div>
          <div class="mode-step" style="--mode-opacity: 0.8">
            <div class="mode-bar ice"></div>
            <div class="mode-content">
              <span class="mode-label ice">SEMI-AUTO</span>
              <span class="mode-meta dim">COMPUTE</span>
            </div>
            <p class="mode-desc-inline dim">Agent prepares trades. One tap to approve.</p>
          </div>
          <div class="mode-step" style="--mode-opacity: 1">
            <div class="mode-bar p"></div>
            <div class="mode-content">
              <span class="mode-label p">AUTO</span>
              <span class="mode-meta p">FULL AUTONOMY</span>
            </div>
            <p class="mode-desc-inline dim">24/7 portfolio management within your risk parameters.</p>
          </div>
        </div>
      </div>
      <div class="dual-col">
        <p class="section-label ice reveal-child">THE AGENT</p>
        <h2 class="section-title reveal-child">Three ways to run</h2>
        <div class="agent-list reveal-child">
          <p class="agent-point dim"><span class="p">AGENT</span> — Ships with OpenClaw runtime. Install, configure, trade. No existing AI setup needed.</p>
          <p class="agent-point dim"><span class="p">SKILL</span> — Plug into OpenClaw, Claude Code, Perplexity Computer, or any agentic framework.</p>
          <p class="agent-point dim"><span class="p">CLI</span> — Direct command-line control. Script it, automate it, integrate it.</p>
        </div>
        <div class="custody-list reveal-child">
          <p class="agent-point dim"><span class="p">✓</span> Keys managed locally, encrypted at rest</p>
          <p class="agent-point dim"><span class="p">✓</span> Kill switch — pause everything instantly</p>
          <p class="agent-point dim"><span class="p">✓</span> Built-in position limits and daily loss caps</p>
        </div>
      </div>
    </div>
  </section>

  <!-- TERMINAL CTA (credibility merged in) -->
  <section class="section cta-section reveal" id="access">
    <div class="term-cta reveal-child">
      <div class="term-header">
        <span class="dim">zero-os</span>
        <span class="term-dots">
          <span class="dot dot-r"></span>
          <span class="dot dot-a"></span>
          <span class="dot dot-p"></span>
        </span>
      </div>
      <div class="term-body">
        <p class="term-line dim term-cursor">$ zero-os --status</p>
        <p class="term-line"><span class="p">&gt;</span> Intelligence engine: <span class="p">BUILT</span></p>
        <p class="term-line"><span class="p">&gt;</span> Signal API: <span class="a">PRE-LAUNCH</span></p>
        <p class="term-line"><span class="p">&gt;</span> Methodology: <a href="/thesis" style="color:var(--phosphor);">/thesis</a></p>
        <p class="term-line"><span class="p">&gt;</span> Self-custodial: your keys, your machine, verifiable</p>
        <p class="term-line"><span class="p">&gt;</span> Onboarding design partners — funds, desks, and builders.</p>
        <p class="term-line dim" style="margin-top:0.5rem">$ zero-os request_access</p>
        <form class="term-form" id="access-form" action="#" method="POST">
          <div class="term-input-row">
            <span class="p">email:</span>
            <input type="email" id="access-email" class="term-input" placeholder="you@fund.com" required autocomplete="email">
          </div>
          <button type="submit" class="term-submit">SUBMIT ↵</button>
        </form>
        <p class="term-confirm" id="term-confirm" style="display:none">
          <span class="p">✓ ACCESS_REQUEST_QUEUED</span><br>
          <span class="dim">ref: ZOS-<span id="req-id">0000</span> — we'll be in touch.</span>
        </p>
        <p class="term-error" id="term-error" style="display:none">
          <span class="red">✗ CONNECTION_ERROR</span><br>
          <span class="dim">Try again later.</span>
        </p>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer reveal">
    <span class="p">◇</span> <span class="dim">ZERO OS</span>
  </footer>

  </div><!-- /page-inner -->
</div>

</BaseLayout>

<style>
  .page {
    margin: 0.5rem;
    border: 1px solid rgba(200,255,0,0.4);
    min-height: calc(100vh - 1rem);
    padding: 0;
    position: relative;
    animation: borderFlash 0.3s ease 0.95s both;
  }
  .page::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(200,255,0,0.012) 2px, rgba(200,255,0,0.012) 4px);
    pointer-events: none;
    z-index: 0;
  }
  .page-inner { padding: 0.75rem 3rem 2rem; }

  /* CRT */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.03) 2px, rgba(0,0,0,0.03) 4px);
    pointer-events: none;
    z-index: 100;
  }
  @media (max-width: 639px) {
    body::before { opacity: 0.5; }
    .page { margin: 0.5rem auto; min-height: calc(100vh - 1rem); }
    .page-inner { padding: 0.5rem 1rem 1.25rem; }
  }
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse 80% 80% at 50% 50%, transparent 0%, transparent 90%, rgba(0,0,0,0.1) 95%, rgba(0,0,0,0.2) 100%);
    pointer-events: none;
    z-index: 101;
  }
  @media (max-width: 639px) {
    body::after { display: none; }
  }

  /* HERO — two-column split on desktop */
  .hero-split {
    display: grid;
    grid-template-columns: 45% 55%;
    gap: 2rem;
    align-items: start;
  }
  @media (max-width: 900px) {
    .hero-split { grid-template-columns: 1fr; }
  }
  .hero-left { }
  .hero-right { 
    padding-top: 1rem;
  }
  /* Dual-column layout for modes + agent */
  .dual-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }
  @media (max-width: 900px) {
    .dual-grid { grid-template-columns: 1fr; }
  }
  .dual-col { }
  .agent-list { margin-bottom: 1.25rem; }
  .custody-list { 
    border-top: 1px solid var(--border); 
    padding-top: 1rem; 
  }
  .hero { padding: 0.5rem 0 2rem; border-bottom: 1px solid var(--border); }
  .boot-sequence { margin-bottom: 1.25rem; }
  .boot-line {
    font-family: var(--font-head);
    font-size: clamp(0.5rem, 2.5vw, 0.7rem);
    color: var(--text-dim);
    margin: 0;
    line-height: 1.8;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-height: 1.8em;
    transition: text-shadow 0.2s ease;
  }
  .boot-line .boot-cursor {
    color: var(--phosphor);
    animation: blink 0.6s step-end infinite;
  }

  .logo-wrap { position: relative; margin-bottom: 1.5rem; overflow: hidden; }
  .logo-art {
    font-family: var(--font-head);
    font-size: clamp(7px, calc((100vw - 30px) / 38), 22px);
    line-height: 1.15;
    color: var(--phosphor);
    white-space: pre;
    margin: 0;
    background: transparent;
    border: none;
    opacity: 0;
    animation: logoIn 0.4s ease 1.0s both, logoGlow 3s ease-in-out 1.5s infinite;
  }
  @keyframes logoIn {
    0% { opacity: 0; filter: brightness(4) blur(3px); text-shadow: 0 0 30px rgba(200,255,0,0.8); }
    40% { opacity: 0.8; filter: brightness(2) blur(1px); }
    100% { opacity: 1; filter: brightness(1) blur(0); }
  }
  @keyframes logoGlow {
    0%, 100% { text-shadow: 0 0 6px var(--phosphor-glow), 0 0 20px rgba(200,255,0,0.08); }
    50% { text-shadow: 0 0 12px var(--phosphor-glow), 0 0 30px rgba(200,255,0,0.15), 0 0 50px rgba(200,255,0,0.05); }
  }
  .crt-scanline {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--phosphor);
    opacity: 0.06;
    animation: scanDrop 3s linear infinite;
    pointer-events: none;
  }
  @keyframes scanDrop { 0% { top: 0; } 100% { top: 100%; } }

  .hero-title {
    font-family: var(--font-head);
    font-size: clamp(1.3rem, 4.5vw, 2rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--text);
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
    animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 1.2s both;
  }
  .hero-sub {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-dim);
    line-height: 1.7;
    max-width: 520px;
    margin-bottom: 1.25rem;
    animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 1.4s both;
  }
  .hero-tertiary {
    font-family: var(--font-head);
    font-size: 0.65rem;
    color: var(--text-dim);
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
    animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 1.55s both;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(14px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes borderFlash {
    0% { border-color: rgba(200,255,0,0.4); box-shadow: none; }
    50% { border-color: rgba(200,255,0,0.9); box-shadow: 0 0 30px rgba(200,255,0,0.15), inset 0 0 30px rgba(200,255,0,0.05); }
    100% { border-color: rgba(200,255,0,0.4); box-shadow: none; }
  }

  .hero-cta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 1.65s both;
  }
  @media (max-width: 639px) {
    .hero-cta { flex-direction: column; }
    .hero-cta a { text-align: center; }
  }
  .btn-primary {
    font-family: var(--font-head);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--phosphor);
    background: transparent;
    border: 1px solid var(--phosphor);
    padding: 0.6rem 1.2rem;
    text-decoration: none;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: color 0.3s, background 0.3s, box-shadow 0.3s;
  }
  .btn-primary::before {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 100%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(200,255,0,0.1), transparent);
    animation: scanSweep 3s linear infinite;
  }
  @keyframes scanSweep {
    0% { left: -100%; }
    100% { left: 100%; }
  }
  .btn-primary:hover {
    background: rgba(200,255,0,0.08);
    box-shadow: 0 0 20px rgba(200,255,0,0.1), inset 0 0 20px rgba(200,255,0,0.05);
    color: var(--phosphor);
  }
  .btn-ghost {
    font-family: var(--font-head);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--text-dim);
    padding: 0.6rem 1.2rem;
    text-decoration: none;
    border: 1px solid var(--border);
    transition: border-color 0.3s, color 0.3s, box-shadow 0.3s;
  }
  .btn-ghost:hover {
    border-color: rgba(200,255,0,0.25);
    color: var(--text);
    box-shadow: 0 0 12px rgba(200,255,0,0.04);
  }

  /* ═══ ORCHESTRATED BOOT SEQUENCE ═══ */
  .hero-right {
    opacity: 0;
    transform: translateY(12px);
    animation: sectionIn 0.7s cubic-bezier(0.16, 1, 0.3, 1) 1.7s both;
  }
  @keyframes sectionIn {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Number counter animation */
  .counter-animate {
    display: inline-block;
    animation: counterPop 0.4s ease both;
  }
  @keyframes counterPop {
    0% { opacity: 0; transform: translateY(8px) scale(0.8); }
    60% { transform: translateY(-2px) scale(1.05); }
    100% { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* Mode step stagger */
  .mode-step {
    opacity: 0;
    transform: translateX(-6px);
    transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1), transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), background 0.3s;
  }
  .reveal.visible .mode-step:nth-child(1) { transition-delay: 0.05s; }
  .reveal.visible .mode-step:nth-child(2) { transition-delay: 0.15s; }
  .reveal.visible .mode-step:nth-child(3) { transition-delay: 0.25s; }
  .reveal.visible .mode-step:nth-child(4) { transition-delay: 0.35s; }
  .reveal.visible .mode-step {
    opacity: var(--mode-opacity, 1);
    transform: translateX(0);
  }

  /* Agent point stagger */
  .agent-point {
    opacity: 0;
    transform: translateX(-4px);
