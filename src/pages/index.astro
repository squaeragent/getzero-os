    if(i%2===0){ctx.fillStyle='rgba(255,255,255,0.006)'; ctx.fillRect(0,y,w,ROW_H);}
    d.v.forEach((val,j)=>{
      const fi=COL_MAP[j];
      let norm=fi<2?val:fi===2?(val+1)/2:fi===3?1-Math.min(val,1.2)/1.2:(val+3)/6;
      ctx.fillStyle=heatRGBA(norm,.28); ctx.fillRect(dX+j*colW+2,y+3,colW-4,ROW_H-6);
    });
    ctx.fillStyle=rgba(CLR.line,.22); ctx.fillRect(0,y+ROW_H-1,w,1);
    ctx.font='bold '+(isMob?'11':'10')+'px JetBrains Mono, monospace';
    ctx.fillStyle=rgba(CLR.text,.85); ctx.textAlign='left'; ctx.textBaseline='middle';
    ctx.fillText(d.coin,PAD,y+ROW_H/2);
    ctx.font=(isMob?'11':'10')+'px JetBrains Mono, monospace'; ctx.textAlign='center';
    d.v.forEach((val,j)=>{
      const fi=COL_MAP[j];
      let norm=fi<2?val:fi===2?(val+1)/2:fi===3?1-Math.min(val,1.2)/1.2:(val+3)/6;
      const intensity=Math.abs(norm-.5)*2;
      ctx.fillStyle=intensity>.5?rgba(norm<.5?CLR.phosphor:CLR.amber,.6+intensity*.4):rgba(CLR.text,.5);
      ctx.fillText(val.toFixed(2),dX+j*colW+colW/2,y+ROW_H/2);
    });
    if(d.reg){
      const labels={trending:'TRENDING',reverting:'REVERTING',chaotic:'CHAOTIC',shift:'SHIFT'};
      const colors={trending:CLR.phosphor,reverting:CLR.amber,chaotic:CLR.red,shift:CLR.ice};
      const label=labels[d.reg], clr=colors[d.reg];
      ctx.font='bold 8px JetBrains Mono, monospace';
      const tw=ctx.measureText(label).width;
      const px=w-PAD-tw-10, py=y+ROW_H/2-6, pw=tw+10, ph=13;
      let ba={trending:.12,reverting:.1,chaotic:.15,shift:.08}[d.reg];
      if(d.reg==='chaotic') ba*=.5+.5*Math.abs(Math.sin(S.time*4));
      ctx.fillStyle=rgba(clr,ba); ctx.fillRect(px,py,pw,ph);
      ctx.fillStyle=rgba(clr,d.reg==='chaotic'?.5+.5*Math.abs(Math.sin(S.time*4)):.85);
      ctx.textAlign='center'; ctx.textBaseline='middle';
      ctx.fillText(label,px+pw/2,y+ROW_H/2);
    } else {
      ctx.font='10px JetBrains Mono, monospace'; ctx.fillStyle=rgba(CLR.dim,.2); ctx.textAlign='right';
      ctx.fillText('—',w-PAD,y+ROW_H/2);
    }
  });
  S.glows=S.glows.filter(g=>{
    const x=PAD+S.coinW+g.col*S.colW+S.colW/2, y=HDR_H+1+g.row*ROW_H+ROW_H/2, r=g.i*35;
    const grad=ctx.createRadialGradient(x,y,0,x,y,r);
    grad.addColorStop(0,`rgba(0,255,65,${g.i*.18})`); grad.addColorStop(1,'rgba(0,255,65,0)');
    ctx.fillStyle=grad; ctx.fillRect(x-r,y-r,r*2,r*2);
    g.i-=g.d; return g.i>.01;
  });
}
function tick(){
  S.time+=1/60;
  S.data.forEach((d,i)=>{
    d.v.forEach((_,j)=>{d.v[j]=lerp(d.v[j],d.t[j],.06);});
    if(Math.random()<.025){
      const j=Math.floor(Math.random()*NC), fi=COL_MAP[j];
      const s=d.seeds;
      const ranges=[[s.h[0],s.h[1]],[s.d[0],s.d[1]],[s.s[0],s.s[1]],[s.ly[0],s.ly[1]],[s.fl[0],s.fl[1]]];
      const nt=rnd(ranges[fi][0],ranges[fi][1]);
      if(Math.abs(nt-d.v[j])>.08) S.glows.push({row:i,col:j,i:1,d:.015});
      d.t[j]=nt; d.full[fi]=nt;
    }
    d.rt--; if(d.rt<=0){d.reg=regime(d.full[0],d.full[1],d.full[3]);d.rt=40+Math.floor(Math.random()*80);}
  });
}
function updateStatus(){
  const n=S.data.filter(d=>d.reg).length;
  const el=document.getElementById('matrix-status'); if(!el)return;
  const txt=n+' regime'+(n!==1?'s':'')+' detected';
  if(el.textContent!==txt){el.style.opacity='0';setTimeout(()=>{el.textContent=txt;el.style.opacity='1';},150);}
}
let fc=0;
function frame(){tick();draw();if(fc%30===0)updateStatus();fc++;requestAnimationFrame(frame);}
function resize(){
  if(!S.canvas)return;
  const w=S.canvas.parentElement.clientWidth, h=HDR_H+COINS.length*ROW_H+2;
  S.canvas.width=w*DPR; S.canvas.height=h*DPR;
  S.canvas.style.width=w+'px'; S.canvas.style.height=h+'px';
  S.ctx=S.canvas.getContext('2d'); S.ctx.scale(DPR,DPR);
  S.w=w; S.h=h; S.colW=(w-S.coinW-S.regW-PAD*2)/NC;
}

// ═══ BOOT TYPING ═══
function typeBootLine(el,delay){
  const text=el.getAttribute('data-text')||'';
  el.innerHTML='<span class="bcursor">█</span>';
  let i=0;
  setTimeout(()=>{
    const iv=setInterval(()=>{
      if(i<text.length){
        let d=text.substring(0,i+1)
          .replace(/ZERO OS/g,'<span class="pg">ZERO OS</span>')
          .replace(/BOOT/g,'<span class="pg">BOOT</span>')
          .replace(/ENVY MATRIX/g,'<span class="pg">ENVY MATRIX</span>')
          .replace(/ACTIVE/g,'<span class="pg">ACTIVE</span>')
          .replace(/PORTFOLIO ENGINE/g,'<span class="pg">PORTFOLIO ENGINE</span>')
          .replace(/SELF-CUSTODIAL/g,'<span class="pg">SELF-CUSTODIAL</span>');
        el.innerHTML=d+'<span class="bcursor">█</span>'; i++;
      } else {
        let f=text
          .replace(/ZERO OS/g,'<span class="pg">ZERO OS</span>')
          .replace(/BOOT/g,'<span class="pg">BOOT</span>')
          .replace(/ENVY MATRIX/g,'<span class="pg">ENVY MATRIX</span>')
          .replace(/ACTIVE/g,'<span class="pg">ACTIVE</span>')
          .replace(/PORTFOLIO ENGINE/g,'<span class="pg">PORTFOLIO ENGINE</span>')
          .replace(/SELF-CUSTODIAL/g,'<span class="pg">SELF-CUSTODIAL</span>');
        el.innerHTML=f; clearInterval(iv);
      }
    },16);
  },delay);
}

// ═══ NAV SCROLL GLASS ═══
function handleNavScroll(){
  const nav=document.getElementById('site-nav');
  if(!nav)return;
  nav.classList.toggle('scrolled',window.scrollY>60);
}

// ═══ COUNTER ANIMATION ═══
function animCount(el){
  const to=parseInt(el.getAttribute('data-count-to'));
  const suffix=el.getAttribute('data-count-suffix')||'';
  if(isNaN(to))return;
  let cur=0; const steps=28, dur=1100, st=dur/steps, inc=to/steps;
  const iv=setInterval(()=>{
    cur+=inc; if(cur>=to){cur=to;clearInterval(iv);}
    el.textContent=Math.round(cur)+suffix;
  },st);
}

// ═══ REGIME GAUGE ═══
const rvScenes=[
  {h:[.58,.68],d:[.57,.66],ly:[.15,.40],label:'trending'},
  {h:[.35,.44],d:[.36,.44],ly:[.10,.35],label:'reverting'},
  {h:[.42,.52],d:[.44,.54],ly:[.80,1.05],label:'chaotic'},
  {h:[.58,.65],d:[.38,.46],ly:[.30,.55],label:'shift'},
  {h:[.46,.54],d:[.46,.54],ly:[.20,.50],label:'stable'},
];
let rvScene=rvScenes[0], rvTimer=200;
const rv={h:.5,d:.5,ly:.3,ht:.5,dt:.5,lt:.3};
function rvTick(){
  rvTimer--; if(rvTimer<=0){rvScene=rvScenes[Math.floor(Math.random()*rvScenes.length)];rvTimer=120+Math.floor(Math.random()*200);}
  if(Math.random()<.04)rv.ht=rnd(rvScene.h[0],rvScene.h[1]);
  if(Math.random()<.04)rv.dt=rnd(rvScene.d[0],rvScene.d[1]);
  if(Math.random()<.03)rv.lt=rnd(rvScene.ly[0],rvScene.ly[1]);
  rv.h=lerp(rv.h,rv.ht,.03); rv.d=lerp(rv.d,rv.dt,.03); rv.ly=lerp(rv.ly,rv.lt,.03);
  const hPct=rv.h*100, dPct=rv.d*100, lPct=Math.max(0,Math.min(rv.ly,1.2))/1.2*100;
  const set=(id,val)=>{const e=document.getElementById(id);if(e)e.style.width=val+'%';};
  const setL=(id,val)=>{const e=document.getElementById(id);if(e)e.style.left=val+'%';};
  const setT=(id,val)=>{const e=document.getElementById(id);if(e)e.textContent=val;};
  set('rv-hurst',hPct); setL('rv-hurst-marker',hPct); setT('rv-hurst-val',rv.h.toFixed(2));
  set('rv-dfa',dPct); setL('rv-dfa-marker',dPct); setT('rv-dfa-val',rv.d.toFixed(2));
  set('rv-lyap',lPct); setL('rv-lyap-marker',lPct); setT('rv-lyap-val',rv.ly.toFixed(2));
  const badge=document.getElementById('rv-badge'), verdict=document.getElementById('rv-verdict');
  if(!badge||!verdict)return;
  let reg='',cls='',vtxt='';
  if(rv.ly>.85){reg='CHAOTIC';cls='chaotic';vtxt='Your MACD crossover is → <span class="red">UNRELIABLE</span>';}
  else if(rv.h<.45&&rv.d<.45){reg='REVERTING';cls='reverting';vtxt='Your MACD crossover is → <span class="amber">A TRAP</span>';}
  else if(rv.h>.55&&rv.d>.55){reg='TRENDING';cls='trending';vtxt='Your MACD crossover is → <span class="pg">MEANINGFUL</span>';}
  else if((rv.h<.45&&rv.d>.55)||(rv.h>.55&&rv.d<.45)){reg='SHIFT';cls='shift';vtxt='Your MACD crossover is → <span class="ice">TRANSITIONING</span>';}
  else{reg='SCANNING';cls='';vtxt='Your MACD crossover is → <span class="dim">ANALYZING</span>';}
  badge.textContent=reg; badge.className='r-badge '+cls; verdict.innerHTML=vtxt;
  const hm=document.getElementById('rv-hurst-marker'),dm=document.getElementById('rv-dfa-marker'),lm=document.getElementById('rv-lyap-marker');
  if(hm){hm.style.background=rv.h<.45?'var(--amber)':rv.h>.55?'var(--phosphor)':'var(--tx2)';hm.style.boxShadow=rv.h>.55?'0 0 8px rgba(0,255,65,.3)':rv.h<.45?'0 0 8px rgba(255,176,0,.2)':'none';}
  if(dm){dm.style.background=rv.d<.45?'var(--amber)':rv.d>.55?'var(--phosphor)':'var(--tx2)';dm.style.boxShadow=rv.d>.55?'0 0 8px rgba(0,255,65,.3)':rv.d<.45?'0 0 8px rgba(255,176,0,.2)':'none';}
  if(lm){lm.style.background=rv.ly>.7?'var(--red)':rv.ly<.2?'var(--ice)':'var(--tx2)';lm.style.boxShadow=rv.ly>.7?'0 0 8px rgba(255,68,68,.3)':'none';}
}

document.addEventListener('DOMContentLoaded',()=>{
  // Nav scroll
  window.addEventListener('scroll',handleNavScroll,{passive:true});
  handleNavScroll();

  // Boot typing
  document.querySelectorAll('.bl').forEach((el,i)=>typeBootLine(el,i*380));

  // Matrix init (delayed to sync with boot)
  initData(); setup();
  setTimeout(()=>{updateStatus();requestAnimationFrame(frame);},1600);
  window.addEventListener('resize',resize);

  // Gauge ticker
  setInterval(rvTick,50);

  // Scroll reveal
  const obs=new IntersectionObserver(entries=>{
    entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible');});
  },{threshold:0.05,rootMargin:'0px 0px 60px 0px'});
  document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));

  // Counter on reveal
  const cObs=new IntersectionObserver(entries=>{
    entries.forEach(e=>{
      if(e.isIntersecting){
        e.target.querySelectorAll('[data-count-to]').forEach(el=>animCount(el));
        cObs.unobserve(e.target);
      }
    });
  },{threshold:0.3});
  document.querySelectorAll('.stats').forEach(el=>cObs.observe(el));

  // Tilt cards
  document.querySelectorAll('.tilt-card').forEach(card=>{
    card.addEventListener('mousemove',e=>{
      const r=card.getBoundingClientRect();
      const x=(e.clientX-r.left)/r.width-.5, y=(e.clientY-r.top)/r.height-.5;
      card.style.transform=`perspective(600px) rotateX(${-y*5}deg) rotateY(${x*5}deg)`;
    });
    card.addEventListener('mouseleave',()=>{card.style.transform='';});
  });

  // Terminal form
  const form=document.getElementById('access-form');
  if(form) form.addEventListener('submit',async e=>{
    e.preventDefault();
    const email=document.getElementById('access-email').value;
    const btn=form.querySelector('.t-submit');
    btn.textContent='SUBMITTING...'; btn.disabled=true;
    try{
      const res=await fetch('/api/waitlist',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email})});
      if(!res.ok)throw new Error();
      const data=await res.json();
      document.getElementById('req-id').textContent=data.ref||'ZOS-'+Math.random().toString(36).substr(2,6).toUpperCase();
      form.style.display='none';
      document.getElementById('term-confirm').style.display='block';
    }catch{
      btn.textContent='SUBMIT ↵'; btn.disabled=false;
      document.getElementById('term-error').style.display='block';
    }
  });
});
</script>
