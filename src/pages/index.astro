---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ZERO OS — Autonomous Trading Agent" description="A trading agent that scans 40 markets, shows its reasoning, and lets you decide. Self-custodial. Run it on your machine.">

<div class="page">
<div class="terminal-border">

  <!-- ═══ HERO ═══ -->
  <header class="hero">
    <div class="logo-wrap">
      <pre class="logo-art">████████╗ ███████╗ ██████╗   ██████╗
╚══███╔═╝ ██╔════╝ ██╔══██╗ ██╔═══██╗
  ███╔╝   █████╗   ██████╔╝ ██║   ██║
 ███╔╝    ██╔══╝   ██╔══██╗ ██║   ██║
████████╗ ███████╗ ██║  ██║ ╚██████╔╝
╚═══════╝ ╚══════╝ ╚═╝  ╚═╝  ╚═════╝</pre>
      <div class="logo-text">ZERO OS</div>
    </div>
    <p class="hero-sub">A trading agent that scans 40 markets, shows its reasoning, and lets you decide.</p>
  </header>

  <!-- ═══ LIVE REASONING ═══ -->
  <section class="section">
    <div class="sh">◇ AGENT REASONING — <span class="live-dot">●</span> LIVE</div>
    <div class="reasoning-body" id="reasoning">
      <div class="muted">Connecting to signal engine...</div>
    </div>
  </section>

  <!-- ═══ PROOF STRIP ═══ -->
  <section class="proof-strip" id="proof-strip">
    <a href="/portfolio" class="proof-link">
      <span class="proof-item"><span class="pl">VALUE</span> <span class="pv" id="pf-value">—</span></span>
      <span class="proof-item"><span class="pl">P&L</span> <span class="pv" id="pf-pnl">—</span></span>
      <span class="proof-item"><span class="pl">TRADES</span> <span class="pv" id="pf-trades">—</span></span>
      <span class="proof-item"><span class="pl">WIN RATE</span> <span class="pv" id="pf-wr">—</span></span>
      <span class="proof-item"><span class="pl">DAY</span> <span class="pv" id="pf-days">—</span></span>
      <span class="proof-arr">→ LIVE PORTFOLIO</span>
    </a>
  </section>

  <!-- ═══ 4 MODES ═══ -->
  <section class="section">
    <div class="sh">THE PRODUCT — 4 LEVELS OF TRUST</div>
    <div class="modes-body">

      <div class="mode-card">
        <div class="mode-head">
          <span class="mode-num">01</span>
          <span class="mode-name">OBSERVE</span>
          <span class="mode-tag learn">LEARN</span>
        </div>
        <div class="mode-screen">
          <div class="ms-line"><span class="ms-coin">SOL</span> <span class="ms-dim">Hurst: 0.80 (trending) · DFA: 0.61 · Lyapunov: 1.68</span></div>
          <div class="ms-line"><span class="ms-dim">→ RSI: 56 (neutral) — skip</span></div>
          <div class="ms-line"><span class="ms-dim">→ 12 signals evaluated. 0 fired. Waiting.</span></div>
          <div class="ms-line ms-verdict">No trade. Market is trending but no entry conditions met.</div>
        </div>
        <p class="mode-desc">Watch the agent think. See every indicator, every decision, every reason it chose NOT to trade. No positions opened.</p>
      </div>

      <div class="mode-card">
        <div class="mode-head">
          <span class="mode-num">02</span>
          <span class="mode-name">SIGNAL</span>
          <span class="mode-tag validate">VALIDATE</span>
        </div>
        <div class="mode-screen">
          <div class="ms-line"><span class="ms-fire">🔥</span> <span class="ms-coin">ETH</span> <span class="ms-long">LONG</span> <span class="ms-dim">signal fired</span></div>
          <div class="ms-line"><span class="ms-dim">Social momentum divergence · Sharpe 2.09 · 72% win rate</span></div>
          <div class="ms-line"><span class="ms-dim">Entry: $2,331 · Exit: XONE ≤ -15 or MACD ≤ -0.002</span></div>
          <div class="ms-line ms-verdict">[APPROVE] &nbsp; [REJECT] &nbsp; [DETAILS]</div>
        </div>
        <p class="mode-desc">Agent generates signals with full reasoning. You decide which to take. Every signal comes with backtested Sharpe ratio, win rate, and exit conditions.</p>
      </div>

      <div class="mode-card">
        <div class="mode-head">
          <span class="mode-num">03</span>
          <span class="mode-name">SEMI-AUTO</span>
          <span class="mode-tag trust">TRUST</span>
        </div>
        <div class="mode-screen">
          <div class="ms-line"><span class="ms-dim">Signal approved. Executing...</span></div>
          <div class="ms-line"><span class="ms-coin">ETH</span> <span class="ms-long">LONG</span> <span class="ms-dim">$15.00 @ $2,331 · Stop loss: $2,214 (-5%)</span></div>
          <div class="ms-line"><span class="ms-dim">Monitoring exit conditions every 15 min.</span></div>
          <div class="ms-line ms-verdict">⏸ KILL SWITCH — pause all trading instantly</div>
        </div>
        <p class="mode-desc">One tap to approve. Agent executes and monitors. Kill switch pauses everything instantly. You stay in control.</p>
      </div>

      <div class="mode-card">
        <div class="mode-head">
          <span class="mode-num">04</span>
          <span class="mode-name">AUTO</span>
          <span class="mode-tag delegate">DELEGATE</span>
        </div>
        <div class="mode-screen">
          <div class="ms-line"><span class="ms-dim">3 positions open · Daily loss: -$2.10 / -$10.00 limit</span></div>
          <div class="ms-line"><span class="ms-coin">BTC</span> <span class="ms-long">LONG</span> <span class="ms-dim">+0.4%</span> &nbsp; <span class="ms-coin">SOL</span> <span class="ms-short">SHORT</span> <span class="ms-dim">-0.2%</span> &nbsp; <span class="ms-coin">ETH</span> <span class="ms-long">LONG</span> <span class="ms-dim">+1.1%</span></div>
          <div class="ms-line"><span class="ms-dim">Max position: 15% · Max daily loss: 10% · Leverage: 1x</span></div>
          <div class="ms-line ms-verdict">24/7 within your risk parameters. Your keys, your machine.</div>
        </div>
        <p class="mode-desc">Full autonomy within your risk limits. Position caps, daily loss limits, stop losses on every trade. Runs on your machine with locally encrypted keys.</p>
      </div>

    </div>
  </section>

  <!-- ═══ TRUST ═══ -->
  <section class="section">
    <div class="sh">SELF-CUSTODIAL</div>
    <div class="trust-body">
      <div class="trust-grid">
        <div class="trust-item">
          <span class="trust-check">✓</span>
          <div>
            <span class="trust-title">Your keys, your machine</span>
            <span class="trust-desc">API keys encrypted locally. Never transmitted. Agent runs on your hardware.</span>
          </div>
        </div>
        <div class="trust-item">
          <span class="trust-check">✓</span>
          <div>
            <span class="trust-title">Kill switch</span>
            <span class="trust-desc">Pause all trading instantly. Close all positions. One command.</span>
          </div>
        </div>
        <div class="trust-item">
          <span class="trust-check">✓</span>
          <div>
            <span class="trust-title">Risk limits enforced</span>
            <span class="trust-desc">Position caps, daily loss limits, per-trade stop losses. Can't be overridden by the agent.</span>
          </div>
        </div>
        <div class="trust-item">
          <span class="trust-check">✓</span>
          <div>
            <span class="trust-title">Open reasoning</span>
            <span class="trust-desc">Every decision logged. Every signal with entry/exit rules. No black box.</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="section">
    <div class="sh">GET STARTED</div>
    <div class="cta-body">
      <div class="cta-grid">
        <a href="/portfolio" class="cta-btn cta-primary">
          <span class="cta-label">Watch it trade</span>
          <span class="cta-sub">Live paper portfolio</span>
        </a>
        <a href="/thesis" class="cta-btn">
          <span class="cta-label">Read the methodology</span>
          <span class="cta-sub">Hurst, DFA, Lyapunov</span>
        </a>
        <a href="https://github.com/squaeragent/getzero-os" class="cta-btn" target="_blank">
          <span class="cta-label">View the source</span>
          <span class="cta-sub">GitHub repo</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ FOOTER ═══ -->
  <footer class="footer">
    <span>◇ ZERO OS</span>
    <span class="muted" id="footer-status">operational</span>
  </footer>

</div>
</div>

</BaseLayout>

<style is:global>
  :root {
    --phosphor: #c8ff00;
    --phosphor-glow: rgba(200,255,0,0.15);
    --amber: #ffb000;
    --ice: #00d4ff;
    --red: #ff3333;
    --text: #e8e4df;
    --text-dim: #8a8278;
    --bg: #050505;
    --surface: #0a0a0a;
    --border: #1a1a1a;
    --font-head: 'JetBrains Mono', monospace;
    --font-body: 'IBM Plex Mono', monospace;
  }

  /* ─── PAGE ─── */
  .page {
    max-width: 900px;
    margin: 0 auto;
    padding: 1rem;
    min-height: 100vh;
  }
  .terminal-border {
    border: 1px solid rgba(200,255,0,0.4);
  }

  /* ─── HERO ─── */
  .hero {
    padding: 2rem 1.25rem 1.5rem;
    border-bottom: 1px solid var(--border);
    text-align: center;
  }
  .logo-wrap {
    margin-bottom: 1rem;
  }
  .logo-art {
    font-family: var(--font-head);
    font-size: clamp(6px, 2.2vw, 16px);
    line-height: 1.2;
    color: var(--phosphor);
    text-align: center;
    margin: 0;
    white-space: pre;
  }
  .logo-text {
    display: none;
    font-family: var(--font-head);
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--phosphor);
    letter-spacing: 0.15em;
    text-align: center;
  }
  .hero-sub {
    font-family: var(--font-body);
    font-size: clamp(0.85rem, 2.5vw, 1.1rem);
    line-height: 1.6;
    color: var(--text);
    margin: 0;
    max-width: 600px;
    margin: 0 auto;
  }

  /* ─── SECTIONS ─── */
  .section {
    border-bottom: 1px solid var(--border);
    padding-bottom: 0;
  }
  .section + .section {
    margin-top: 0;
  }
  .sh {
    font-family: var(--font-head);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
    padding: 0.5rem 1.25rem;
    border-bottom: 1px solid var(--border);
    background: rgba(0,0,0,0.6);
  }
  .muted {
    font-family: var(--font-head);
    font-size: 0.75rem;
    color: var(--text-dim);
    opacity: 0.4;
  }
  .live-dot {
    color: var(--phosphor);
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  /* ─── REASONING BLOCK ─── */
  .reasoning-body {
    padding: 1rem 1.25rem;
    font-family: var(--font-head);
    font-size: 0.75rem;
    line-height: 1.8;
    min-height: 120px;
  }
  .r-line {
    margin-bottom: 0.15rem;
  }
  .r-coin {
    color: var(--phosphor);
    font-weight: 700;
  }
  .r-dim { color: var(--text-dim); }
  .r-fire { color: var(--amber); }
  .r-skip { color: var(--text-dim); opacity: 0.6; }
  .r-verdict {
    color: var(--text);
    margin-top: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--border);
  }
  .r-long { color: var(--phosphor); font-weight: 700; }
  .r-short { color: #cc4422; font-weight: 700; }

  /* ─── PROOF STRIP ─── */
  .proof-strip {
    border-bottom: 1px solid var(--border);
    background: rgba(200,255,0,0.03);
  }
  .proof-link {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 0.6rem 1.25rem;
    text-decoration: none;
    flex-wrap: wrap;
    transition: background 0.2s;
  }
  .proof-link:hover {
    background: rgba(200,255,0,0.06);
  }
  .proof-item {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .pl {
    font-family: var(--font-head);
    font-size: 0.45rem;
    letter-spacing: 0.15em;
    color: var(--text-dim);
    text-transform: uppercase;
  }
  .pv {
    font-family: var(--font-head);
    font-size: 0.85rem;
    color: var(--phosphor);
    font-weight: 700;
  }
  .proof-arr {
    font-family: var(--font-head);
    font-size: 0.6rem;
    color: var(--text-dim);
    margin-left: auto;
    letter-spacing: 0.1em;
  }

  /* ─── MODES ─── */
  .modes-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .mode-card {
    border: 1px solid var(--border);
    overflow: hidden;
  }
  .mode-card:nth-child(1) { border-left: 2px solid var(--text-dim); }
  .mode-card:nth-child(2) { border-left: 2px solid var(--amber); }
  .mode-card:nth-child(3) { border-left: 2px solid var(--phosphor); }
  .mode-card:nth-child(4) { border-left: 2px solid var(--ice); }
  .mode-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border);
    background: rgba(0,0,0,0.4);
  }
  .mode-num {
    font-family: var(--font-head);
    font-size: 0.6rem;
    color: var(--text-dim);
    opacity: 0.5;
  }
  .mode-name {
    font-family: var(--font-head);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: 0.08em;
  }
  .mode-tag {
    font-family: var(--font-head);
    font-size: 0.5rem;
    letter-spacing: 0.1em;
    padding: 0.1rem 0.35rem;
    border-radius: 2px;
    margin-left: auto;
  }
  .mode-tag.learn { color: var(--text-dim); border: 1px solid var(--border); }
  .mode-tag.validate { color: var(--amber); border: 1px solid rgba(255,176,0,0.3); }
  .mode-tag.trust { color: var(--phosphor); border: 1px solid rgba(200,255,0,0.3); }
  .mode-tag.delegate { color: var(--ice); border: 1px solid rgba(0,212,255,0.3); }
  .mode-screen {
    padding: 0.75rem;
    background: rgba(0,0,0,0.6);
    font-family: var(--font-head);
    font-size: 0.7rem;
    line-height: 1.7;
  }
  .ms-line { margin-bottom: 0.1rem; }
  .ms-coin { color: var(--phosphor); font-weight: 700; }
  .ms-dim { color: var(--text-dim); }
  .ms-fire { font-size: 0.65rem; }
  .ms-long { color: var(--phosphor); font-weight: 700; }
  .ms-short { color: #cc4422; font-weight: 700; }
  .ms-verdict {
    color: var(--text);
    margin-top: 0.3rem;
    padding-top: 0.3rem;
    border-top: 1px solid var(--border);
    font-size: 0.65rem;
  }
  .mode-desc {
    font-family: var(--font-body);
    font-size: 0.8rem;
    line-height: 1.6;
    color: var(--text-dim);
    padding: 0.75rem;
    margin: 0;
  }

  /* ─── TRUST ─── */
  .trust-body {
    padding: 1rem 1.25rem;
  }
  .trust-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .trust-item {
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
  }
  .trust-check {
    color: var(--phosphor);
    font-family: var(--font-head);
    font-size: 0.85rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }
  .trust-title {
    font-family: var(--font-head);
    font-size: 0.75rem;
    color: var(--text);
    display: block;
    margin-bottom: 0.2rem;
  }
  .trust-desc {
    font-family: var(--font-body);
    font-size: 0.7rem;
    color: var(--text-dim);
    line-height: 1.5;
    display: block;
  }

  /* ─── CTA ─── */
  .cta-body {
    padding: 1.25rem;
  }
  .cta-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
  }
  .cta-btn {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 1rem;
    border: 1px solid var(--border);
    text-decoration: none;
    transition: border-color 0.2s, background 0.2s;
    text-align: center;
  }
  .cta-btn:hover {
    border-color: rgba(200,255,0,0.4);
    background: rgba(200,255,0,0.03);
  }
  .cta-primary {
    border-color: var(--phosphor);
    background: rgba(200,255,0,0.08);
  }
  .cta-primary:hover {
    background: rgba(200,255,0,0.14);
  }
  .cta-label {
    font-family: var(--font-head);
    font-size: 0.8rem;
    color: var(--phosphor);
    font-weight: 700;
  }
  .cta-sub {
    font-family: var(--font-head);
    font-size: 0.6rem;
    color: var(--text-dim);
  }

  /* ─── FOOTER ─── */
  .footer {
    display: flex;
    justify-content: space-between;
    padding: 0.5rem 1.25rem;
    font-family: var(--font-head);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    color: var(--text-dim);
  }

  /* ─── MOBILE ─── */
  @media (max-width: 600px) {
    .page { padding: 0.5rem; }
    .hero { padding: 1.5rem 1rem 1rem; }
    .trust-grid { grid-template-columns: 1fr; }
    .cta-grid { grid-template-columns: 1fr; }
    .proof-link { gap: 1rem; }
    .proof-arr { display: none; }
  }
  @media (max-width: 420px) {
    .logo-art { display: none; }
    .logo-text { display: block; }
  }
</style>

<script is:inline>
(function(){
  const PORTFOLIO_API = '/api/portfolio.json';
  const ENVY_API = '/api/envy?coins=BTC,ETH,SOL,DOGE,AVAX,LINK,ARB,NEAR,SUI,INJ&indicators=HURST_24H,DFA_24H,LYAPUNOV_24H,RSI_3H30M,XONE_AVG_NET,CLOSE_PRICE_15M';

  // ─── PROOF STRIP ───
  function loadProof(){
    fetch(PORTFOLIO_API).then(r=>r.json()).then(d=>{
      if(!d.summary) return;
      const s=d.summary;
      document.getElementById('pf-value').textContent='$'+s.currentValue.toLocaleString('en',{minimumFractionDigits:0,maximumFractionDigits:0});
      const pnlEl=document.getElementById('pf-pnl');
      pnlEl.textContent=(s.pnlPct>=0?'+':'')+s.pnlPct.toFixed(2)+'%';
      pnlEl.style.color=s.pnl>=0?'var(--phosphor)':'var(--red)';
      document.getElementById('pf-trades').textContent=s.totalTrades;
      document.getElementById('pf-wr').textContent=s.winRate!=null?s.winRate.toFixed(0)+'%':'—';
      document.getElementById('pf-days').textContent=s.daysRunning;

      // Also build reasoning from recent fires + positions
      buildReasoning(d);
    }).catch(()=>{});
  }

  // ─── LIVE REASONING ───
  function buildReasoning(portfolioData){
    const el=document.getElementById('reasoning');
    const fires=portfolioData.recentFires||[];
    const positions=portfolioData.positions||[];

    let html='';

    // Show what the agent is currently monitoring
    const coins=['BTC','ETH','SOL','DOGE','AVAX','LINK','ARB','NEAR','SUI','INJ'];
    const firedCoins=new Set(fires.slice(-5).map(f=>f.coin));
    const openCoins=new Set(positions.map(p=>p.coin));

    // Last scan summary
    const lastFire=fires[fires.length-1];
    const lastTime=lastFire?new Date(lastFire.time).toISOString().replace('T',' ').slice(5,16)+' UTC':'—';

    html+='<div class="r-line r-dim">Last scan: '+lastTime+' · '+coins.length+' markets · 300+ signals evaluated</div>';
    html+='<div class="r-line r-dim" style="margin-bottom:0.5rem">─────────────────────────────────</div>';

    // Show recent fires (last 5)
    const recentFires=fires.slice(-5).reverse();
    if(recentFires.length>0){
      for(const f of recentFires){
        const name=(f.signal||'').replace(/_/g,' ').toLowerCase().slice(0,50);
        const dirCls=f.direction==='LONG'?'r-long':'r-short';
        html+='<div class="r-line">';
        html+='<span class="r-fire">▸</span> ';
        html+='<span class="r-coin">'+f.coin+'</span> ';
        html+='<span class="'+dirCls+'">'+f.direction+'</span> ';
        html+='<span class="r-dim">· '+name+'</span>';
        html+='</div>';
        html+='<div class="r-line r-dim" style="padding-left:1rem">Sharpe '+(f.sharpe||0).toFixed(2)+' · '+(f.win_rate||0).toFixed(0)+'% win rate · entry $'+(f.price||0).toLocaleString('en',{maximumFractionDigits:2})+'</div>';
      }
    } else {
      html+='<div class="r-line r-dim">No signals fired recently. Scanning...</div>';
    }

    // Quiet coins
    const quietCoins=coins.filter(c=>!firedCoins.has(c)&&!openCoins.has(c));
    if(quietCoins.length>0){
      html+='<div class="r-line r-dim" style="margin-top:0.5rem">'+quietCoins.join(', ')+' — scanned, no entry conditions met. Waiting.</div>';
    }

    // Verdict
    const totalOpen=positions.length;
    const totalClosed=portfolioData.closed?portfolioData.closed.length:0;
    html+='<div class="r-verdict">';
    html+=totalOpen+' position'+(totalOpen!==1?'s':'')+' open · '+totalClosed+' trades closed · ';
    html+='agent is '+(recentFires.length>0?'active':'scanning');
    html+='</div>';

    el.innerHTML=html;
  }

  // ─── INIT ───
  loadProof();
  setInterval(loadProof, 60000);
})();
</script>
