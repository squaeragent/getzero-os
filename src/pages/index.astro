---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ZERO OS" description="Adversarial cognition engine. 14 agents. 40 coins. Live on Hyperliquid.">
<div class="page">
<div class="terminal-border">

  <!-- NAV -->
  <div class="nav-bar">
    <span class="nav-item nav-active">◇ ZERO OS</span>
    <a href="/portfolio" class="nav-item">PORTFOLIO</a>
    <a href="/thesis" class="nav-item">THESIS</a>
  </div>

  <!-- HERO -->
  <div class="hero-section">
    <div class="hero-body">
      <h1 class="hero-title">Adversarial Cognition Engine</h1>
      <p class="hero-sub">A system that challenges its own predictions before acting on them.</p>
      <p class="hero-sub dim">Live on Hyperliquid. Real money. No paper trading.</p>
    </div>
  </div>

  <!-- LIVE STATS -->
  <div class="section">
    <div class="ph">LIVE PERFORMANCE</div>
    <div class="sb">
      <div class="stats-row" id="stats-row">
        <div class="stat">
          <div class="stat-value" id="s-equity">$—</div>
          <div class="stat-label">EQUITY</div>
        </div>
        <div class="stat">
          <div class="stat-value" id="s-trades">—</div>
          <div class="stat-label">TRADES</div>
        </div>
        <div class="stat">
          <div class="stat-value" id="s-wr">—</div>
          <div class="stat-label">WIN RATE</div>
        </div>
        <div class="stat">
          <div class="stat-value" id="s-ratio">—</div>
          <div class="stat-label">WIN/LOSS RATIO</div>
        </div>
        <div class="stat">
          <div class="stat-value" id="s-pnl">—</div>
          <div class="stat-label">REALIZED P&L</div>
        </div>
      </div>
      <div class="eq-wrap">
        <canvas id="equity-canvas" width="860" height="100"></canvas>
      </div>
    </div>
  </div>

  <!-- OPEN POSITIONS -->
  <div class="section">
    <div class="ph">OPEN POSITIONS <span class="dim" id="pos-count"></span></div>
    <div class="sb" id="positions-body">
      <span class="muted">Loading...</span>
    </div>
  </div>

  <!-- MARKET STATE -->
  <div class="section">
    <div class="ph">MARKET STATE — <span id="coin-count">40</span> COINS</div>
    <div class="sb">
      <div class="regime-bar" id="regime-bar"></div>
      <div class="regime-legend" id="regime-legend"></div>
      <div class="macro-line" id="macro-line"></div>
    </div>
  </div>

  <!-- HOW IT WORKS -->
  <div class="section">
    <div class="ph">ARCHITECTURE</div>
    <div class="sb">
      <div class="arch-flow">
        <div class="arch-stage">
          <div class="arch-name">PERCEIVE</div>
          <div class="arch-desc">81 indicators · 40 coins · regime classification</div>
        </div>
        <div class="arch-arrow">→</div>
        <div class="arch-stage">
          <div class="arch-name">HYPOTHESIZE</div>
          <div class="arch-desc">1,190 signals · composite scoring · genealogy</div>
        </div>
        <div class="arch-arrow">→</div>
        <div class="arch-stage arch-adversary">
          <div class="arch-name">CHALLENGE</div>
          <div class="arch-desc" id="adv-desc">13 attacks · evolving weights · counterfactual validation</div>
        </div>
        <div class="arch-arrow">→</div>
        <div class="arch-stage">
          <div class="arch-name">ACT</div>
          <div class="arch-desc">Hyperliquid perps · on-chain stops · position sync</div>
        </div>
        <div class="arch-arrow">→</div>
        <div class="arch-stage">
          <div class="arch-name">EVOLVE</div>
          <div class="arch-desc">Parameter evolution · adversary evolution · signal blacklisting</div>
        </div>
      </div>
      <div class="arch-loop">↻ every trade feeds back into the next decision</div>
    </div>
  </div>

  <!-- KEY NUMBERS -->
  <div class="section">
    <div class="ph">SYSTEM</div>
    <div class="sb">
      <div class="sys-grid">
        <div class="sys-item"><span class="sys-val">14</span> <span class="sys-key">agents</span></div>
        <div class="sys-item"><span class="sys-val">40</span> <span class="sys-key">coins monitored</span></div>
        <div class="sys-item"><span class="sys-val">81</span> <span class="sys-key">indicators per coin</span></div>
        <div class="sys-item"><span class="sys-val">1,190</span> <span class="sys-key">signals in library</span></div>
        <div class="sys-item"><span class="sys-val">13</span> <span class="sys-key">adversarial attacks</span></div>
        <div class="sys-item"><span class="sys-val" id="s-counterfactual">172</span> <span class="sys-key">counterfactual validations</span></div>
        <div class="sys-item"><span class="sys-val" id="s-adv-accuracy">71%</span> <span class="sys-key">adversary accuracy</span></div>
        <div class="sys-item"><span class="sys-val" id="s-families">161</span> <span class="sys-key">signal families tracked</span></div>
      </div>
    </div>
  </div>

  <!-- RECENT TRADES -->
  <div class="section">
    <div class="ph">RECENT TRADES <span class="dim" id="closed-count"></span></div>
    <div class="sb" id="trades-body">
      <span class="muted">Loading...</span>
    </div>
  </div>

  <!-- FOOTER -->
  <div class="footer">
    <span class="dim">◇ ZERO OS — adversarial cognition engine</span>
  </div>

</div>
</div>
</BaseLayout>

<style is:global>
  .page {
    max-width: 960px;
    margin: 0 auto;
    padding: 1rem;
    min-height: 100vh;
  }
  .terminal-border {
    border: 1px solid rgba(200,255,0,0.25);
    min-height: 100vh;
  }

  /* NAV */
  .nav-bar {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 0.5rem 1rem;
    border-bottom: 1px solid var(--border);
    font-family: var(--font-head);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .nav-item { color: var(--text-dim); text-decoration: none; transition: color 0.2s; }
  .nav-item:hover { color: var(--phosphor); }
  .nav-active { color: var(--phosphor); border-bottom: 1px solid var(--phosphor); padding-bottom: 0.25rem; }

  /* HERO */
  .hero-section { border-bottom: 1px solid var(--border); }
  .hero-body { padding: 2rem 1rem 1.5rem; }
  .hero-title {
    font-family: var(--font-head);
    font-size: clamp(1.4rem, 5vw, 2.2rem);
    font-weight: 700;
    color: var(--phosphor);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }
  .hero-sub {
    font-family: var(--font-body);
    font-size: clamp(0.85rem, 2.5vw, 1rem);
    color: var(--text);
    margin-top: 0.5rem;
    line-height: 1.4;
  }
  .dim { opacity: 0.5; }

  /* SECTIONS */
  .section { border-bottom: 1px solid var(--border); }
  .ph {
    font-family: var(--font-head);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text);
    padding: 0.5rem 1rem 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border);
    border-left: 2px solid rgba(200,255,0,0.4);
    background: rgba(0,0,0,0.6);
  }
  .sb { padding: 0.75rem 1rem; }
  .muted { font-family: var(--font-head); font-size: 0.8rem; color: var(--text-dim); opacity: 0.4; }

  /* STATS ROW */
  .stats-row {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }
  .stat { flex: 1; min-width: 80px; }
  .stat-value {
    font-family: var(--font-head);
    font-size: clamp(1.2rem, 4vw, 1.8rem);
    font-weight: 700;
    color: var(--phosphor);
    line-height: 1;
  }
  .stat-label {
    font-family: var(--font-head);
    font-size: 0.5rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-top: 0.2rem;
  }

  /* EQUITY CURVE */
  .eq-wrap { margin-top: 0.5rem; }
  .eq-wrap canvas { width: 100%; height: 100px; display: block; }

  /* POSITIONS */
  .pos-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--border);
    font-family: var(--font-head);
    font-size: 0.75rem;
  }
  .pos-card:last-child { border-bottom: none; }
  .pos-coin { font-weight: 700; min-width: 50px; }
  .pos-dir { font-size: 0.6rem; letter-spacing: 0.08em; padding: 0.1rem 0.3rem; }
  .pos-long { color: #33ff66; border: 1px solid rgba(51,255,102,0.3); }
  .pos-short { color: #ff3333; border: 1px solid rgba(255,51,51,0.3); }
  .pos-entry { color: var(--text-dim); }
  .pos-regime { color: var(--text-dim); font-size: 0.6rem; opacity: 0.6; }
  .pos-pnl { margin-left: auto; font-weight: 600; }
  .c-pos { color: #33ff66; }
  .c-neg { color: #ff3333; }

  /* REGIME BAR */
  .regime-bar {
    display: flex;
    height: 6px;
    border-radius: 1px;
    overflow: hidden;
    margin-bottom: 0.5rem;
  }
  .regime-bar div { transition: width 0.5s; }
  .regime-legend {
    display: flex;
    gap: 1rem;
    font-family: var(--font-head);
    font-size: 0.6rem;
    color: var(--text-dim);
    flex-wrap: wrap;
  }
  .regime-legend span::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    margin-right: 4px;
    vertical-align: middle;
  }
  .macro-line {
    font-family: var(--font-head);
    font-size: 0.7rem;
    color: var(--text-dim);
    margin-top: 0.5rem;
  }

  /* ARCHITECTURE */
  .arch-flow {
    display: flex;
    align-items: flex-start;
    gap: 0.25rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .arch-stage {
    flex: 1;
    min-width: 100px;
    padding: 0.5rem;
    border: 1px solid var(--border);
    text-align: center;
  }
  .arch-adversary { border-color: rgba(255,51,51,0.4); }
  .arch-name {
    font-family: var(--font-head);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--phosphor);
    margin-bottom: 0.25rem;
  }
  .arch-adversary .arch-name { color: #ff3333; }
  .arch-desc {
    font-family: var(--font-body);
    font-size: 0.6rem;
    color: var(--text-dim);
    line-height: 1.3;
  }
  .arch-arrow {
    font-family: var(--font-head);
    color: var(--text-dim);
    font-size: 0.8rem;
    padding-top: 0.75rem;
    opacity: 0.3;
  }
  .arch-loop {
    text-align: center;
    font-family: var(--font-head);
    font-size: 0.6rem;
    color: var(--text-dim);
    opacity: 0.5;
    margin-top: 0.5rem;
  }

  /* SYSTEM GRID */
  .sys-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 0.5rem;
  }
  .sys-item {
    font-family: var(--font-head);
    font-size: 0.75rem;
    padding: 0.4rem 0;
  }
  .sys-val { color: var(--phosphor); font-weight: 700; font-size: 0.9rem; }
  .sys-key { color: var(--text-dim); margin-left: 0.3rem; }

  /* TRADE LIST */
  .trade-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.35rem 0;
    border-bottom: 1px solid rgba(26,26,26,0.5);
    font-family: var(--font-head);
    font-size: 0.7rem;
  }
  .trade-row:last-child { border-bottom: none; }
  .tr-coin { font-weight: 700; min-width: 45px; }
  .tr-dir { font-size: 0.55rem; letter-spacing: 0.06em; padding: 0.05rem 0.2rem; }
  .tr-pnl { margin-left: auto; font-weight: 600; }
  .tr-reason { color: var(--text-dim); font-size: 0.6rem; opacity: 0.6; }
  .tr-time { color: var(--text-dim); font-size: 0.6rem; opacity: 0.4; }

  /* FOOTER */
  .footer {
    padding: 0.75rem 1rem;
    text-align: center;
    font-family: var(--font-head);
    font-size: 0.55rem;
    letter-spacing: 0.1em;
  }

  /* MOBILE */
  @media (max-width: 600px) {
    .arch-arrow { display: none; }
    .arch-flow { flex-direction: column; }
    .stats-row { gap: 0.75rem; }
    .stat { min-width: 60px; }
  }
</style>

<script is:inline>
(function(){
  var API = 'https://api.getzero.dev';

  function fmt$(v){ return v==null?'—': (v<0?'-$':'$')+Math.abs(v).toFixed(2); }
  function fmtPct(v){ return v==null?'—': (v>=0?'+':'')+v.toFixed(2)+'%'; }

  function ago(iso){
    if(!iso) return '';
    var s = Math.floor((Date.now() - new Date(iso).getTime()) / 1000);
    if(s<60) return s+'s ago';
    if(s<3600) return Math.floor(s/60)+'m ago';
    return Math.floor(s/3600)+'h ago';
  }

  // ─── FETCH AND RENDER ───

  function loadAll(){
    Promise.all([
      fetch(API+'/performance').then(function(r){return r.json()}).catch(function(){return null}),
      fetch(API+'/portfolio.json').then(function(r){return r.json()}).catch(function(){return null}),
      fetch(API+'/regime').then(function(r){return r.json()}).catch(function(){return null}),
      fetch(API+'/prices?coins=BTC,ETH,SOL,LINK,XPL,DOGE,AVAX,ARB,NEAR,SUI').then(function(r){return r.json()}).catch(function(){return null}),
    ]).then(function(results){
      var perf = results[0];
      var portfolio = results[1];
      var regime = results[2];
      var prices = results[3];

      if(perf) renderStats(perf);
      if(portfolio) renderPositions(portfolio, prices);
      if(portfolio) renderTrades(portfolio);
      if(portfolio) renderEquity(portfolio, perf);
      if(regime) renderRegime(regime);
    });
  }

  function renderStats(p){
    var el = function(id){ return document.getElementById(id); };
    el('s-equity').textContent = '$' + (115 + (p.total_pnl_usd||0)).toFixed(2);
    el('s-trades').textContent = p.total_trades || 0;
    el('s-wr').textContent = (p.total_trades >= 5) ? p.win_rate + '%' : '—';
    el('s-ratio').textContent = (p.total_trades >= 5) ? (p.win_loss_ratio||0).toFixed(2) + 'x' : '—';
    el('s-pnl').textContent = fmt$(p.total_pnl_usd);
    if(p.total_pnl_usd >= 0){
      el('s-pnl').classList.add('c-pos');
    } else {
      el('s-pnl').classList.add('c-neg');
    }
  }

  function renderPositions(data, prices){
    var positions = (data.liveTrading||{}).positions || [];
    var body = document.getElementById('positions-body');
    var count = document.getElementById('pos-count');
    count.textContent = '(' + positions.length + ')';

    if(!positions.length){
      body.innerHTML = '<span class="muted">No open positions</span>';
      return;
    }

    var priceMap = (prices && prices.matrix) || {};
    var html = '';
    for(var i=0; i<positions.length; i++){
      var p = positions[i];
      var dir = p.direction || 'LONG';
      var dirClass = dir === 'LONG' ? 'pos-long' : 'pos-short';
      var currentPrice = priceMap[p.coin] ? priceMap[p.coin].CLOSE_PRICE_15M : null;
      var pnl = null;
      if(currentPrice && p.entry_price){
        if(dir === 'LONG') pnl = ((currentPrice - p.entry_price) / p.entry_price) * 100;
        else pnl = ((p.entry_price - currentPrice) / p.entry_price) * 100;
      }
      var pnlStr = pnl != null ? fmtPct(pnl) : '—';
      var pnlClass = pnl != null ? (pnl >= 0 ? 'c-pos' : 'c-neg') : '';
      var regime = p.regime || '';

      html += '<div class="pos-card">';
      html += '<span class="pos-coin">' + p.coin + '</span>';
      html += '<span class="pos-dir ' + dirClass + '">' + dir + '</span>';
      html += '<span class="pos-entry">@ $' + (p.entry_price||0) + '</span>';
      if(regime) html += '<span class="pos-regime">' + regime + '</span>';
      html += '<span class="pos-pnl ' + pnlClass + '">' + pnlStr + '</span>';
      html += '</div>';
    }
    body.innerHTML = html;
  }

  function renderTrades(data){
    var closed = ((data.liveTrading||{}).closed || []).slice(-10).reverse();
    var body = document.getElementById('trades-body');
    var count = document.getElementById('closed-count');
    var total = (data.liveTrading||{}).trades || closed.length;
    count.textContent = '(last 10 of ' + total + ')';

    if(!closed.length){
      body.innerHTML = '<span class="muted">No closed trades yet</span>';
      return;
    }

    var html = '';
    for(var i=0; i<closed.length; i++){
      var t = closed[i];
      var dir = t.direction || '';
      var dirClass = dir === 'LONG' ? 'pos-long' : 'pos-short';
      var pnl = t.pnl_usd || 0;
      var pnlClass = pnl >= 0 ? 'c-pos' : 'c-neg';
      var reason = t.exit_reason || t.reason || '';
      html += '<div class="trade-row">';
      html += '<span class="tr-coin">' + (t.coin||'') + '</span>';
      html += '<span class="tr-dir ' + dirClass + '">' + dir + '</span>';
      html += '<span class="tr-reason">' + reason + '</span>';
      html += '<span class="tr-time">' + ago(t.exit_time) + '</span>';
      html += '<span class="tr-pnl ' + pnlClass + '">' + fmt$(pnl) + '</span>';
      html += '</div>';
    }
    body.innerHTML = html;
  }

  function renderEquity(data, perf){
    var curve = data.liveEquityCurve || [];
    var canvas = document.getElementById('equity-canvas');
    if(!canvas || curve.length < 2) return;

    var dpr = window.devicePixelRatio || 1;
    var w = canvas.clientWidth;
    var h = canvas.clientHeight;
    canvas.width = w * dpr;
    canvas.height = h * dpr;
    var ctx = canvas.getContext('2d');
    ctx.scale(dpr, dpr);

    var values = curve.map(function(c){ return c.equity || c.value || 115; });
    var min = Math.min.apply(null, values);
    var max = Math.max.apply(null, values);
    var range = max - min || 1;
    var currentEquity = 115 + ((perf && perf.total_pnl_usd) || 0);
    var lineColor = currentEquity >= 115 ? '#33ff66' : '#ff3333';

    ctx.strokeStyle = lineColor;
    ctx.lineWidth = 1.5;
    ctx.beginPath();
    for(var i=0; i<values.length; i++){
      var x = (i / (values.length - 1)) * w;
      var y = h - ((values[i] - min) / range) * (h - 10) - 5;
      if(i === 0) ctx.moveTo(x, y);
      else ctx.lineTo(x, y);
    }
    ctx.stroke();
  }

  var regimeColors = {trending:'#33ff66', stable:'#c8ff00', chaotic:'#ff3333', shift:'#ffb000', unknown:'#444'};

  function renderRegime(data){
    var dist = data.regime_distribution || {};
    var total = 0;
    for(var k in dist) total += dist[k];

    var bar = document.getElementById('regime-bar');
    var legend = document.getElementById('regime-legend');
    var macro = document.getElementById('macro-line');

    var barHtml = '';
    var legendHtml = '';
    var order = ['trending','stable','chaotic','shift'];
    for(var i=0; i<order.length; i++){
      var r = order[i];
      if(!dist[r]) continue;
      var pct = (dist[r] / total * 100).toFixed(0);
      var color = regimeColors[r] || '#444';
      barHtml += '<div style="width:'+pct+'%; background:'+color+'"></div>';
      legendHtml += '<span style="color:'+color+'">'+r+' '+dist[r]+'</span>';
    }
    bar.innerHTML = barHtml;
    legend.innerHTML = legendHtml;

    var m = data.macro || {};
    var parts = [];
    if(m.macro_state) parts.push(m.macro_state);
    if(m.btc_roc_24h != null) parts.push('BTC 24h: ' + (m.btc_roc_24h >= 0 ? '+' : '') + m.btc_roc_24h.toFixed(1) + '%');
    if(m.session) parts.push('Session: ' + m.session);
    macro.textContent = parts.join(' · ') || '';
  }

  // Initial load
  loadAll();
  // Refresh every 60s
  setInterval(loadAll, 60000);
})();
</script>
