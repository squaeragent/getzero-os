      justify-content: center;
      padding: 0.3rem 0;
      transform: rotate(90deg);
      font-size: 1rem;
    }
    .loop-stage {
      padding: 0.75rem;
    }
    .loop-name { font-size: 0.8rem; }
    .loop-desc { font-size: 0.7rem; }
