---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ZERO OS — Trading Intelligence Infrastructure">

<div class="page">

  <!-- CRT BOOT -->
  <header class="hero">
    <div class="boot-sequence">
      <pre class="boot-line b1"><span class="p">ZERO OS</span> v0.1 .................... <span class="p">INIT</span></pre>
      <pre class="boot-line b2"><span class="p">SIGNAL MATRIX</span> ................... <span class="p">ONLINE</span></pre>
      <pre class="boot-line b3"><span class="p">AGENTS</span> .......................... <span class="p">250 ACTIVE</span></pre>
    </div>

    <div class="logo-wrap">
      <pre class="logo-art">████████╗ ███████╗ ██████╗   ██████╗
╚══███╔═╝ ██╔════╝ ██╔══██╗ ██╔═══██╗
  ███╔╝   █████╗   ██████╔╝ ██║   ██║
 ███╔╝    ██╔══╝   ██╔══██╗ ██║   ██║
████████╗ ███████╗ ██║  ██║ ╚██████╔╝
╚═══════╝ ╚══════╝ ╚═╝  ╚═╝  ╚═════╝</pre>
      <div class="crt-scanline"></div>
    </div>

    <h1 class="hero-title">AI that trades better than you.<br>And you're okay with it.</h1>

    <p class="hero-sub">
      ZERO OS is trading intelligence infrastructure. Signals no one else has.
      Agents that find edges no human programmed. A marketplace where the best ML wins.
    </p>

    <div class="hero-cta">
      <a href="#access" class="btn-primary">Request Access</a>
      <a href="#signals" class="btn-ghost">See the signals ↓</a>
    </div>
  </header>

  <!-- LIVE SIGNAL MATRIX -->
  <section class="section" id="signals">
    <div class="matrix-head">
      <p class="section-label p">SIGNAL MATRIX — LIVE</p>
      <span class="matrix-status" id="matrix-status">3 signals active</span>
    </div>
    <div class="matrix-container">
      <div class="matrix-header">
        <span class="mh-coin">ASSET</span>
        <span class="mh-cell">HURST</span>
        <span class="mh-cell">RSI</span>
        <span class="mh-cell">SENT</span>
        <span class="mh-cell">CHAOS</span>
        <span class="mh-cell">FLOW</span>
        <span class="mh-signal">SIGNAL</span>
      </div>
      <div id="matrix-rows"></div>
    </div>
    <p class="matrix-sub dim">Every heartbeat of the market — technical, social, chaotic — flowing into one surface of intelligence.</p>
  </section>

  <!-- LAYER 1: SIGNALS -->
  <section class="section">
    <p class="section-label p">LAYER 1</p>
    <h2 class="section-title">Signals no one else has</h2>
    <p class="section-body">
      Not indicators. Not dashboards. Raw alpha — generated by agents that discovered 
      patterns no human hypothesized. Delivered as an API.
    </p>
    <div class="layer-proof">
      <div class="lp-item">
        <span class="lp-val p">147</span>
        <span class="lp-label">features in the matrix</span>
      </div>
      <div class="lp-item">
        <span class="lp-val a">6</span>
        <span class="lp-label">timeframes simultaneous</span>
      </div>
      <div class="lp-item">
        <span class="lp-val ice">24/7</span>
        <span class="lp-label">live signal generation</span>
      </div>
    </div>
    <p class="section-detail dim">
      Technical momentum. Ichimoku geometry. Bollinger compression. Chaos mathematics. 
      Social sentiment divergence. All normalized. All comparable. One API call.
    </p>
  </section>

  <!-- WHAT AGENTS FOUND -->
  <section class="section">
    <p class="section-label a">EMERGENT DISCOVERIES</p>
    <h2 class="section-title">None of these were programmed</h2>
    <div class="discovery-grid">
      <div class="disc-card">
        <div class="disc-val p">H = 0.41</div>
        <p>Hurst exponents in mean-reverting territory identify reversal windows with unusual precision</p>
      </div>
      <div class="disc-card">
        <div class="disc-val a">&lt;30% hit rate</div>
        <p>SHORT structures generating positive expectancy — the wins, when they come, dominate</p>
      </div>
      <div class="disc-card">
        <div class="disc-val ice">Δ sentiment</div>
        <p>Analyst-crowd divergence carries a contrarian signal invisible to pure price analysis</p>
      </div>
    </div>
    <p class="disc-note dim">The matrix held the pattern. The agents found it. No human wrote the rule.</p>
  </section>

  <!-- WHY IT WORKS -->
  <section class="section">
    <p class="section-label p">WHY THIS WORKS</p>
    <h2 class="section-title">Your indicators assume the market never changes. It does.</h2>
    <p class="section-body">
      RSI, MACD, Bollinger — they all assume the market behaves the same way all the time. 
      It doesn't. Sometimes trends persist. Sometimes they reverse. Sometimes it's pure noise. 
      ZERO OS knows which mode you're in <em>right now</em>.
    </p>
    <div class="chaos-grid">
      <div class="chaos-card">
        <div class="chaos-name">DFA <span class="dim">α</span></div>
        <div class="chaos-range">
          <span class="chaos-lo dim">&lt;0.5 mean-reverting</span>
          <span class="chaos-mid p">0.5 random walk</span>
          <span class="chaos-hi a">&gt;0.5 trending</span>
        </div>
        <p class="chaos-desc dim">Measures whether price movements have memory. Tells your strategy to follow momentum or fade it.</p>
      </div>
      <div class="chaos-card">
        <div class="chaos-name">Hurst <span class="dim">H</span></div>
        <div class="chaos-range">
          <span class="chaos-lo dim">&lt;0.5 anti-persistent</span>
          <span class="chaos-mid p">0.5 brownian</span>
          <span class="chaos-hi a">&gt;0.5 persistent</span>
        </div>
        <p class="chaos-desc dim">Confirms or contradicts DFA. When both agree, the regime signal is strong. When they diverge — the market is transitioning. That's a signal too.</p>
      </div>
      <div class="chaos-card">
        <div class="chaos-name">Lyapunov <span class="dim">λ</span></div>
        <div class="chaos-range">
          <span class="chaos-lo ice">≈0 stable</span>
          <span class="chaos-hi red">&gt;0 chaotic</span>
        </div>
        <p class="chaos-desc dim">Measures chaos — how sensitive the system is to small changes. High λ: reduce size, tighten stops. Low λ: your signals are reliable.</p>
      </div>
    </div>
    <p class="chaos-punchline">
      A MACD crossover in a trending regime is meaningful.<br>
      <span class="dim">The same crossover in a mean-reverting regime is a trap.</span>
    </p>
  </section>

  <!-- LAYER 2: MARKETPLACE -->
  <section class="section">
    <p class="section-label p">LAYER 2</p>
    <h2 class="section-title">The marketplace where best ML wins</h2>
    <p class="section-body">
      ML engineers build predictors. Predictors feed the matrix. Agents find combinations. 
      Best agents attract capital. Engineers earn revenue share.
    </p>
    <div class="flywheel">
      <span class="fw-step">Engineers</span>
      <span class="fw-arrow p">→</span>
      <span class="fw-step">Predictors</span>
      <span class="fw-arrow p">→</span>
      <span class="fw-step">Agents</span>
      <span class="fw-arrow p">→</span>
      <span class="fw-step">Capital</span>
      <span class="fw-arrow p">→</span>
      <span class="fw-step">Revenue</span>
      <span class="fw-arrow p">↩</span>
    </div>
    <p class="section-detail dim">
      Not a leaderboard. A living economy. Every new predictor makes every agent smarter. 
      Every agent with track record attracts capital. The flywheel compounds.
    </p>
  </section>

  <!-- LAYER 3: VISION -->
  <section class="section">
    <p class="section-label ice">LAYER 3</p>
    <h2 class="section-title">One-click execution</h2>
    <p class="section-body">
      Research mode. Monitoring. Copy trading. An agent with 14 months of live PnL, 
      verified Sharpe, documented drawdown — and one button.
    </p>
    <blockquote class="vision-quote">
      At some point, the line between a trading system and a world model starts to blur. 
      That is the point we are building toward.
    </blockquote>
  </section>

  <!-- ARCHITECTURE -->
  <section class="section">
    <p class="section-label dim">ARCHITECTURE</p>
    <div class="arch-grid">
      <div class="arch-item">
        <span class="arch-name">Signal Matrix</span>
        <span class="arch-desc dim">— unified feature store, append-only, continuously growing</span>
      </div>
      <div class="arch-item">
        <span class="arch-name">The Gate</span>
        <span class="arch-desc dim">— authenticated producers, scoped writes, trust by design</span>
      </div>
      <div class="arch-item">
        <span class="arch-name">Agent Discovery</span>
        <span class="arch-desc dim">— autonomous edge detection, out-of-sample validation</span>
      </div>
      <div class="arch-item">
        <span class="arch-name">250 Agents</span>
        <span class="arch-desc dim">— live, competing, evolving, disposable</span>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-section" id="access">
    <h2 class="cta-title">Request access</h2>
    <p class="section-body cta-body">
      Signal API for funds and trading desks. Agent marketplace for ML engineers. 
      Early access is limited.
    </p>
    <form class="cta-form" action="#" method="POST">
      <input type="email" placeholder="your@email.com" class="cta-input" required>
      <button type="submit" class="btn-primary">Request Access</button>
    </form>
    <p class="cta-note dim">We review every application.</p>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <span class="p">◇</span> <span class="dim">ZERO OS</span>
  </footer>

</div>

</BaseLayout>

<style>
  .page {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* CRT */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.05) 2px, rgba(0,0,0,0.05) 4px);
    pointer-events: none;
    z-index: 100;
  }
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse 70% 70% at 50% 50%, transparent 0%, transparent 85%, rgba(0,0,0,0.15) 92%, rgba(0,0,0,0.4) 100%);
    pointer-events: none;
    z-index: 101;
  }

  /* HERO */
  .hero { padding: 3rem 0 2.5rem; border-bottom: 1px solid var(--border); }
  .boot-sequence { margin-bottom: 1.5rem; }
  .boot-line {
    font-family: var(--font-head);
    font-size: 0.6rem;
    color: var(--text-dim);
    margin: 0;
    line-height: 1.8;
    opacity: 0;
    animation: bootIn 0.3s ease forwards;
  }
  .b1 { animation-delay: 0.2s; }
  .b2 { animation-delay: 0.5s; }
  .b3 { animation-delay: 0.8s; }
  @keyframes bootIn {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .logo-wrap { position: relative; margin-bottom: 2rem; overflow: hidden; }
  .logo-art {
    font-family: var(--font-head);
    font-size: clamp(7px, calc((100vw - 30px) / 38), 22px);
    line-height: 1.15;
    color: var(--phosphor);
    text-shadow: 0 0 8px var(--phosphor-glow), 0 0 24px rgba(200,255,0,0.15);
    white-space: pre;
    margin: 0;
    background: transparent;
    border: none;
    animation: logoIn 0.6s ease 1s both;
  }
  @keyframes logoIn {
    0% { opacity: 0; filter: brightness(4) blur(2px); }
    50% { opacity: 0.7; filter: brightness(1.8) blur(0.5px); }
    100% { opacity: 1; filter: brightness(1); }
  }
  .crt-scanline {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--phosphor);
    opacity: 0.06;
    animation: scanDrop 3s linear infinite;
    pointer-events: none;
  }
  @keyframes scanDrop { 0% { top: 0; } 100% { top: 100%; } }

  .hero-title {
    font-family: var(--font-head);
    font-size: clamp(1.3rem, 4.5vw, 2rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--text);
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    animation: fadeUp 0.5s ease 1.4s both;
  }
  .hero-sub {
    font-size: 0.85rem;
    color: var(--text-dim);
    line-height: 1.7;
    max-width: 520px;
    margin-bottom: 1.5rem;
    animation: fadeUp 0.5s ease 1.6s both;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-cta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    animation: fadeUp 0.5s ease 1.8s both;
  }
  .btn-primary {
    font-family: var(--font-head);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--bg);
    background: var(--phosphor);
    border: none;
    padding: 0.65rem 1.3rem;
    text-decoration: none;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .btn-primary:hover { opacity: 0.85; }
  .btn-ghost {
    font-family: var(--font-head);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--text-dim);
    padding: 0.65rem 1.3rem;
    text-decoration: none;
    border: 1px solid var(--border);
    transition: border-color 0.15s, color 0.15s;
  }
  .btn-ghost:hover { border-color: var(--text-dim); color: var(--text); }

  /* MATRIX */
  .matrix-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.5rem;
  }
  .matrix-status {
    font-family: var(--font-head);
    font-size: 0.55rem;
    color: var(--phosphor);
    letter-spacing: 0.05em;
    animation: pulse 2s ease infinite;
  }
  @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.5; } }

  .matrix-container {
    font-family: var(--font-head);
    font-size: 0.6rem;
    overflow-x: auto;
    border: 1px solid var(--border);
    background: rgba(0,0,0,0.4);
  }
  .matrix-header {
    display: grid;
    grid-template-columns: 52px repeat(5, 1fr) 110px;
    padding: 0.4rem 0.6rem;
    border-bottom: 1px solid var(--border);
    color: var(--text-dim);
    letter-spacing: 0.08em;
    font-size: 0.45rem;
    font-weight: 700;
  }
  .mh-signal { text-align: right; }
  .mh-cell { text-align: right; padding-right: 0.4rem; }
  .matrix-row {
    display: grid;
    grid-template-columns: 52px repeat(5, 1fr) 110px;
    padding: 0.35rem 0.6rem;
    border-bottom: 1px solid rgba(26,26,26,0.5);
    transition: background 0.6s, box-shadow 0.6s;
    align-items: center;
  }
  .matrix-row.fire {
    background: rgba(200,255,0,0.03);
    box-shadow: inset 2px 0 0 var(--phosphor);
  }
  .mr-coin { color: var(--text); font-weight: 700; font-size: 0.55rem; }
  .mr-cell {
    color: var(--text-dim);
    font-variant-numeric: tabular-nums;
    text-align: right;
    padding-right: 0.4rem;
    transition: color 0.4s, text-shadow 0.4s;
  }
  .mr-cell.hot { color: var(--phosphor); text-shadow: 0 0 4px var(--phosphor-glow); }
  .mr-cell.cold { color: var(--amber); }
  .mr-signal {
    font-weight: 700;
    font-size: 0.5rem;
    letter-spacing: 0.05em;
    text-align: right;
  }
  .mr-signal.on { color: var(--phosphor); text-shadow: 0 0 6px var(--phosphor-glow); }
  .mr-signal.off { color: rgba(138,130,120,0.3); }
  .matrix-sub { font-size: 0.6rem; margin-top: 0.5rem; }

  /* SECTIONS */
  .section { padding: 3rem 0; border-bottom: 1px solid var(--border); }
  .section-label {
    font-family: var(--font-head);
    font-size: 0.5rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    margin-bottom: 0.6rem;
  }
  .section-title {
    font-family: var(--font-head);
    font-size: clamp(1.1rem, 3.5vw, 1.5rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--text);
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }
  .section-body {
    font-size: 0.85rem;
    color: var(--text-dim);
    line-height: 1.7;
    max-width: 520px;
    margin-bottom: 1rem;
  }
  .section-detail {
    font-size: 0.7rem;
    line-height: 1.6;
    max-width: 520px;
  }

  /* LAYER PROOF */
  .layer-proof {
    display: flex;
    gap: 2rem;
    margin: 1.5rem 0;
    flex-wrap: wrap;
  }
  .lp-item { display: flex; flex-direction: column; }
  .lp-val {
    font-family: var(--font-head);
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1;
  }
  .lp-label {
    font-size: 0.65rem;
    color: var(--text-dim);
    margin-top: 0.25rem;
  }

  /* DISCOVERIES */
  .discovery-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }
  @media (min-width: 640px) {
    .discovery-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .disc-card {
    border: 1px solid var(--border);
    padding: 1.25rem;
  }
  .disc-val {
    font-family: var(--font-head);
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
  }
  .disc-card p { font-size: 0.7rem; color: var(--text-dim); line-height: 1.6; }
  .disc-note { font-size: 0.65rem; font-style: italic; }

  /* CHAOS GRID */
  .chaos-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 1.5rem 0;
  }
  .chaos-card {
    border: 1px solid var(--border);
    padding: 1rem 1.25rem;
  }
  .chaos-name {
    font-family: var(--font-head);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.5rem;
  }
  .chaos-range {
    display: flex;
    gap: 1rem;
    font-family: var(--font-head);
    font-size: 0.55rem;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }
  .chaos-desc { font-size: 0.65rem; line-height: 1.6; }
  .chaos-punchline {
    font-family: var(--font-head);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.5;
    margin-top: 1.5rem;
  }
  .red { color: var(--red); }

  /* FLYWHEEL */
  .flywheel {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin: 1.5rem 0;
    font-family: var(--font-head);
    font-size: 0.7rem;
  }
  .fw-step {
    color: var(--text);
    font-weight: 700;
    padding: 0.3rem 0.6rem;
    border: 1px solid var(--border);
  }
  .fw-arrow { font-size: 0.9rem; }

  /* VISION */
  .vision-quote {
    font-family: var(--font-head);
    font-size: clamp(0.9rem, 2.5vw, 1.1rem);
    font-weight: 700;
    color: var(--text);
    line-height: 1.4;
    border-left: 2px solid var(--phosphor);
    padding-left: 1.25rem;
    margin-top: 1.5rem;
    max-width: 500px;
  }

  /* ARCHITECTURE */
  .arch-grid {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .arch-item {
    font-family: var(--font-head);
    font-size: 0.7rem;
    display: flex;
    gap: 0.5rem;
    align-items: baseline;
    flex-wrap: wrap;
  }
  .arch-name { color: var(--text); font-weight: 700; }
  .arch-desc { font-size: 0.65rem; }

  /* CTA */
  .cta-section { border-bottom: none; padding: 3rem 0 2rem; text-align: center; }
  .cta-title {
    font-family: var(--font-head);
    font-size: clamp(1rem, 3vw, 1.4rem);
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.75rem;
  }
  .cta-body { margin: 0 auto 1.5rem; text-align: center; }
  .cta-form {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .cta-input {
    font-family: var(--font-body);
    font-size: 0.8rem;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 0.65rem 1rem;
    min-width: 240px;
    outline: none;
    transition: border-color 0.15s;
  }
  .cta-input:focus { border-color: var(--phosphor); }
  .cta-input::placeholder { color: var(--text-dim); }
  .cta-note { font-size: 0.6rem; margin-top: 0.5rem; }

  /* FOOTER */
  .footer {
    padding: 2rem 0;
    font-family: var(--font-head);
    font-size: 0.6rem;
    letter-spacing: 0.05em;
    text-align: center;
    border-top: 1px solid var(--border);
  }

  /* UTILITY */
  .p { color: var(--phosphor); }
  .a { color: var(--amber); }
  .ice { color: var(--ice); }
  .dim { color: var(--text-dim); }
</style>

<script>
const COINS = ['BTC','ETH','SOL','DOGE','AVAX','LINK','ARB','OP','SUI','MATIC','NEAR','INJ'];
const SIGS = ['REVERSAL','MOMENTUM','MEAN REV','BREAKOUT','DIVERGE'];

function r(a,b){return Math.random()*(b-a)+a;}
function f(n){return n.toFixed(2);}

function mkRow(coin){
  const h=r(.3,.7),rs=r(15,85),se=r(-1,1),ch=r(0,1.5),fl=r(-3,3);
  const fire=Math.random()<.22;
  const sig=fire?SIGS[Math.floor(Math.random()*SIGS.length)]:'';
  const row=document.createElement('div');
  row.className='matrix-row'+(fire?' fire':'');
  row.innerHTML=`
    <span class="mr-coin">${coin}</span>
    <span class="mr-cell${h<.42?' hot':h>.6?' cold':''}">${f(h)}</span>
    <span class="mr-cell${rs<25?' hot':rs>75?' cold':''}">${f(rs)}</span>
    <span class="mr-cell${Math.abs(se)>.6?' hot':''}">${f(se)}</span>
    <span class="mr-cell${ch>1?' cold':''}">${f(ch)}</span>
    <span class="mr-cell${Math.abs(fl)>2?' hot':''}">${f(fl)}</span>
    <span class="mr-signal ${fire?'on':'off'}">${sig||'—'}</span>`;
  return row;
}

function init(){
  const c=document.getElementById('matrix-rows');
  if(!c)return;
  c.innerHTML='';
  COINS.forEach(coin=>c.appendChild(mkRow(coin)));
  updateCount();
}

function updateCount(){
  const n=document.querySelectorAll('.matrix-row.fire').length;
  const s=document.getElementById('matrix-status');
  if(s)s.textContent=n+' signal'+(n!==1?'s':'')+' active';
}

function tick(){
  const rows=[...document.querySelectorAll('.matrix-row')];
  if(!rows.length)return;
  const row=rows[Math.floor(Math.random()*rows.length)];
  const cells=row.querySelectorAll('.mr-cell');
  const idx=Math.floor(Math.random()*cells.length);
  const cell=cells[idx];
  if(!cell)return;
  const v=r(-1,2);
  cell.textContent=f(v);
  cell.classList.remove('hot','cold');
  if(v>.7)cell.classList.add('hot');
  else if(v<-.5)cell.classList.add('cold');

  if(Math.random()<.06){
    const sig=row.querySelector('.mr-signal');
    const name=SIGS[Math.floor(Math.random()*SIGS.length)];
    if(sig){
      sig.textContent=name;
      sig.className='mr-signal on';
      row.classList.add('fire');
      updateCount();
      setTimeout(()=>{
        sig.textContent='—';
        sig.className='mr-signal off';
        row.classList.remove('fire');
        updateCount();
      },3000+Math.random()*5000);
    }
  }
}

document.addEventListener('DOMContentLoaded',()=>{init();setInterval(tick,350);});
</script>
