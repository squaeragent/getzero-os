---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ZERO OS — Trading Intelligence Infrastructure">

<div class="page">

  <!-- CRT BOOT SEQUENCE -->
  <header class="hero">
    <div class="boot-sequence">
      <pre class="boot-line b1"><span class="g">BIOS POST</span> ........................ <span class="g">OK</span></pre>
      <pre class="boot-line b2"><span class="g">SIGNAL MATRIX</span> ................... <span class="g">LOADING</span></pre>
      <pre class="boot-line b3"><span class="g">GATE AUTH</span> ....................... <span class="g">OK</span></pre>
    </div>

    <div class="logo-wrap">
      <pre class="logo-art">████████╗ ███████╗ ██████╗   ██████╗
╚══███╔═╝ ██╔════╝ ██╔══██╗ ██╔═══██╗
  ███╔╝   █████╗   ██████╔╝ ██║   ██║
 ███╔╝    ██╔══╝   ██╔══██╗ ██║   ██║
████████╗ ███████╗ ██║  ██║ ╚██████╔╝
╚═══════╝ ╚══════╝ ╚═╝  ╚═╝  ╚═════╝</pre>
      <pre class="logo-sub">〈◇〉 THE NERVOUS SYSTEM THAT THINKS FOR ITSELF</pre>
      <div class="crt-scanline"></div>
    </div>

    <h1 class="hero-title">Trading agents that find edges<br>you didn't know existed</h1>

    <div class="proof-bar">
      <span class="proof-item"><span class="proof-val g">147</span> features</span>
      <span class="proof-sep">·</span>
      <span class="proof-item"><span class="proof-val a">23</span> coins</span>
      <span class="proof-sep">·</span>
      <span class="proof-item"><span class="proof-val g">24/7</span> live</span>
    </div>

    <div class="hero-cta">
      <a href="#access" class="btn-primary">Get Early Access</a>
      <a href="#matrix" class="btn-ghost">See the Matrix ↓</a>
    </div>
  </header>

  <!-- LIVE MATRIX VISUALIZATION -->
  <section class="section matrix-section" id="matrix">
    <p class="section-label g">ZERO OS — SIGNAL MATRIX</p>
    <div class="matrix-container">
      <div class="matrix-header">
        <span class="mh-coin">ASSET</span>
        <span class="mh-cell">HURST</span>
        <span class="mh-cell">RSI.6</span>
        <span class="mh-cell">SENT</span>
        <span class="mh-cell">CHAOS</span>
        <span class="mh-cell">FLOW</span>
        <span class="mh-signal">SIGNAL</span>
      </div>
      <div class="matrix-rows" id="matrix-rows">
        <!-- Populated by JS -->
      </div>
    </div>
    <p class="matrix-note dim">Rows are moments in time. Columns are dimensions of reality. Every cell is a number that means something.</p>
  </section>

  <!-- HOW IT WORKS — 3 CARDS -->
  <section class="section">
    <p class="section-label g">HOW IT WORKS</p>
    <h2 class="section-title">One store. Every signal.<br>Infinite possibility.</h2>

    <div class="flow-steps">
      <div class="flow-step">
        <div class="flow-num g">01</div>
        <h3 class="flow-name">Signal Matrix</h3>
        <p class="flow-desc">Technical momentum across six timeframes. Ichimoku geometry. Bollinger compression. Chaos mathematics. Social sentiment. All normalized into one universal surface of intelligence.</p>
      </div>
      <div class="flow-arrow g">→</div>
      <div class="flow-step">
        <div class="flow-num a">02</div>
        <h3 class="flow-name">The Gate</h3>
        <p class="flow-desc">Every producer authenticated and scoped. A chaos engine cannot pollute sentiment data. The boundaries are architectural, not policy. The gate holds by design.</p>
      </div>
      <div class="flow-arrow g">→</div>
      <div class="flow-step">
        <div class="flow-num ice">03</div>
        <h3 class="flow-name">Agent Discovery</h3>
        <p class="flow-desc">Agents find combinations no human hypothesized. Validate out-of-sample. If it holds, it trades. If it decays, it dies. No human wrote the rule.</p>
      </div>
    </div>
  </section>

  <!-- PROOF — DISCOVERIES -->
  <section class="section">
    <p class="section-label a">WHAT THE AGENTS FOUND</p>
    <h2 class="section-title">None of these were programmed</h2>
    <div class="discovery-grid">
      <div class="disc-card">
        <div class="disc-val g">H=0.41</div>
        <p>Hurst exponents near 0.4 identify reversal windows with unusual precision</p>
      </div>
      <div class="disc-card">
        <div class="disc-val a">&lt;30% HR</div>
        <p>SHORT structures with low hit rates generating positive expectancy — wins dominate</p>
      </div>
      <div class="disc-card">
        <div class="disc-val ice">ΔSENT</div>
        <p>Analyst-crowd sentiment divergence carries a contrarian signal invisible to price analysis</p>
      </div>
    </div>
    <p class="disc-footer dim">The matrix held the pattern. The agents found it.</p>
  </section>

  <!-- CTA -->
  <section class="section cta-section" id="access">
    <h2 class="cta-title">First skills ship soon.<br>Get early access.</h2>
    <form class="cta-form" action="#" method="POST">
      <input type="email" placeholder="your@email.com" class="cta-input" required>
      <button type="submit" class="btn-primary">Notify me</button>
    </form>
    <p class="cta-note dim">No spam. One email when trading skills are ready.</p>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <span class="g">◇</span> <span class="dim">ZERO OS · Trading Intelligence Infrastructure</span>
  </footer>

</div>

</BaseLayout>

<style>
  .page {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
  }

  /* === CRT EFFECTS === */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.06) 2px,
      rgba(0,0,0,0.06) 4px
    );
    pointer-events: none;
    z-index: 100;
  }
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse 70% 70% at 50% 50%, transparent 0%, transparent 85%, rgba(0,0,0,0.15) 92%, rgba(0,0,0,0.4) 100%);
    pointer-events: none;
    z-index: 101;
  }

  /* === HERO === */
  .hero {
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--border);
  }

  .boot-sequence {
    margin-bottom: 1.5rem;
  }
  .boot-line {
    font-family: var(--font-head);
    font-size: 0.65rem;
    color: var(--text-dim);
    margin: 0;
    line-height: 1.8;
    opacity: 0;
    animation: bootIn 0.3s ease forwards;
  }
  .b1 { animation-delay: 0.2s; }
  .b2 { animation-delay: 0.5s; }
  .b3 { animation-delay: 0.8s; }
  @keyframes bootIn {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .logo-wrap {
    position: relative;
    margin-bottom: 2rem;
    overflow: hidden;
  }
  .logo-art {
    font-family: var(--font-head);
    font-size: clamp(7px, calc((100vw - 30px) / 38), 22px);
    line-height: 1.15;
    color: var(--phosphor);
    text-shadow: 0 0 8px var(--phosphor-glow), 0 0 24px rgba(200,255,0,0.15);
    white-space: pre;
    margin: 0;
    background: transparent;
    border: none;
    animation: logoIn 0.6s ease 1s both;
  }
  .logo-sub {
    font-family: var(--font-head);
    font-size: clamp(0.45rem, 1.8vw, 0.7rem);
    color: var(--phosphor-dim);
    letter-spacing: 0.15em;
    margin: 0.5rem 0 0;
    animation: logoIn 0.4s ease 1.4s both;
  }
  @keyframes logoIn {
    0% { opacity: 0; filter: brightness(4) blur(2px); }
    50% { opacity: 0.7; filter: brightness(1.8) blur(0.5px); }
    100% { opacity: 1; filter: brightness(1); }
  }
  .crt-scanline {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--phosphor);
    opacity: 0.08;
    animation: scanDrop 3s linear infinite;
    pointer-events: none;
  }
  @keyframes scanDrop {
    0% { top: 0; }
    100% { top: 100%; }
  }

  .hero-title {
    font-family: var(--font-head);
    font-size: clamp(1.4rem, 4.5vw, 2.2rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--text);
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
    animation: fadeUp 0.5s ease 1.6s both;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .proof-bar {
    display: flex;
    gap: 0.75rem;
    align-items: baseline;
    font-family: var(--font-head);
    font-size: 0.7rem;
    color: var(--text-dim);
    letter-spacing: 0.05em;
    margin-bottom: 2rem;
    animation: fadeUp 0.5s ease 1.8s both;
  }
  .proof-val {
    font-weight: 700;
    font-size: 0.85rem;
  }
  .proof-sep { color: var(--border); }

  .hero-cta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    animation: fadeUp 0.5s ease 2s both;
  }
  .btn-primary {
    font-family: var(--font-head);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--bg);
    background: var(--phosphor);
    border: none;
    padding: 0.7rem 1.4rem;
    text-decoration: none;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .btn-primary:hover { opacity: 0.85; }
  .btn-ghost {
    font-family: var(--font-head);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--text-dim);
    padding: 0.7rem 1.4rem;
    text-decoration: none;
    border: 1px solid var(--border);
    transition: border-color 0.15s, color 0.15s;
  }
  .btn-ghost:hover { border-color: var(--text-dim); color: var(--text); }

  /* === MATRIX === */
  .matrix-section { padding: 3rem 0; }
  .matrix-container {
    font-family: var(--font-head);
    font-size: 0.65rem;
    overflow-x: auto;
    border: 1px solid var(--border);
    background: rgba(0,0,0,0.3);
  }
  .matrix-header {
    display: grid;
    grid-template-columns: 56px repeat(5, 1fr) 120px;
    gap: 0;
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border);
    color: var(--text-dim);
    letter-spacing: 0.08em;
    font-size: 0.5rem;
    font-weight: 700;
  }
  .matrix-row {
    display: grid;
    grid-template-columns: 56px repeat(5, 1fr) 120px;
    gap: 0;
    padding: 0.4rem 0.75rem;
    border-bottom: 1px solid rgba(26,36,32,0.5);
    transition: background 0.5s;
    align-items: center;
  }
  .matrix-row.signal-fire {
    background: rgba(51,255,102,0.04);
  }
  .mr-coin {
    color: var(--text);
    font-weight: 700;
    font-size: 0.6rem;
  }
  .mr-cell {
    color: var(--text-dim);
    font-variant-numeric: tabular-nums;
    text-align: right;
    padding-right: 0.5rem;
    transition: color 0.3s;
  }
  .mr-cell.hot { color: var(--phosphor); }
  .mr-cell.cold { color: var(--amber); }
  .mr-signal {
    font-weight: 700;
    font-size: 0.55rem;
    letter-spacing: 0.05em;
    text-align: right;
  }
  .mr-signal.active { color: var(--phosphor); text-shadow: 0 0 6px var(--phosphor-glow); }
  .mr-signal.inactive { color: var(--text-dim); }
  .matrix-note {
    font-size: 0.6rem;
    margin-top: 0.75rem;
  }

  /* === SECTIONS === */
  .section {
    padding: 3rem 0;
    border-bottom: 1px solid var(--border);
  }
  .section-label {
    font-family: var(--font-head);
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    margin-bottom: 0.75rem;
  }
  .section-title {
    font-family: var(--font-head);
    font-size: clamp(1.2rem, 3.5vw, 1.6rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--text);
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
  }

  /* === FLOW STEPS === */
  .flow-steps {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .flow-steps {
      display: grid;
      grid-template-columns: 1fr auto 1fr auto 1fr;
      gap: 1rem;
      align-items: start;
    }
  }
  .flow-step {
    padding: 1.25rem;
    border: 1px solid var(--border);
  }
  .flow-num {
    font-family: var(--font-head);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
  }
  .flow-name {
    font-family: var(--font-head);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.4rem;
  }
  .flow-desc {
    font-size: 0.75rem;
    color: var(--text-dim);
    line-height: 1.6;
  }
  .flow-arrow {
    display: none;
    font-family: var(--font-head);
    font-size: 1.2rem;
    align-self: center;
    justify-self: center;
  }
  @media (min-width: 640px) {
    .flow-arrow { display: block; }
  }

  /* === DISCOVERY GRID === */
  .discovery-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  @media (min-width: 640px) {
    .discovery-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .disc-card {
    border: 1px solid var(--border);
    padding: 1.25rem;
  }
  .disc-val {
    font-family: var(--font-head);
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  .disc-card p {
    font-size: 0.75rem;
    color: var(--text-dim);
    line-height: 1.6;
  }
  .disc-footer {
    font-size: 0.7rem;
    font-style: italic;
  }

  /* === CTA === */
  .cta-section {
    border-bottom: none;
    padding: 3rem 0 2rem;
    text-align: center;
  }
  .cta-title {
    font-family: var(--font-head);
    font-size: clamp(1.1rem, 3vw, 1.5rem);
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
    margin-bottom: 1.5rem;
  }
  .cta-form {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .cta-input {
    font-family: var(--font-body);
    font-size: 0.8rem;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 0.7rem 1rem;
    min-width: 240px;
    outline: none;
    transition: border-color 0.15s;
  }
  .cta-input:focus { border-color: var(--phosphor); }
  .cta-input::placeholder { color: var(--text-dim); }
  .cta-note { font-size: 0.65rem; margin-top: 0.75rem; }

  /* === FOOTER === */
  .footer {
    padding: 2rem 0;
    font-family: var(--font-head);
    font-size: 0.65rem;
    letter-spacing: 0.05em;
    text-align: center;
    border-top: 1px solid var(--border);
  }

  /* === UTILITY === */
  .g { color: var(--phosphor); }
  .a { color: var(--amber); }
  .ice { color: var(--ice); }
  .dim { color: var(--text-dim); }
</style>

<script>
// === LIVE MATRIX ANIMATION ===
const COINS = ['BTC','ETH','SOL','DOGE','AVAX','LINK','ARB','OP','SUI','MATIC','NEAR','INJ'];
const SIGNALS = ['REVERSAL','MOMENTUM','MEAN REV','BREAKOUT','DIVERGENCE',''];

function rand(min, max) { return Math.random() * (max - min) + min; }
function fmt(n) { return n.toFixed(2); }

function createRow(coin) {
  const hurst = rand(0.3, 0.7);
  const rsi = rand(15, 85);
  const sent = rand(-1, 1);
  const chaos = rand(0, 1.5);
  const flow = rand(-3, 3);
  const hasSignal = Math.random() < 0.25;
  const signal = hasSignal ? SIGNALS[Math.floor(Math.random() * (SIGNALS.length - 1))] : '';
  
  const row = document.createElement('div');
  row.className = 'matrix-row' + (hasSignal ? ' signal-fire' : '');
  
  const hurstClass = hurst < 0.42 ? ' hot' : (hurst > 0.6 ? ' cold' : '');
  const rsiClass = rsi < 25 ? ' hot' : (rsi > 75 ? ' cold' : '');
  const sentClass = Math.abs(sent) > 0.6 ? ' hot' : '';
  const chaosClass = chaos > 1.0 ? ' cold' : '';
  const flowClass = Math.abs(flow) > 2 ? ' hot' : '';
  
  row.innerHTML = `
    <span class="mr-coin">${coin}</span>
    <span class="mr-cell${hurstClass}">${fmt(hurst)}</span>
    <span class="mr-cell${rsiClass}">${fmt(rsi)}</span>
    <span class="mr-cell${sentClass}">${fmt(sent)}</span>
    <span class="mr-cell${chaosClass}">${fmt(chaos)}</span>
    <span class="mr-cell${flowClass}">${fmt(flow)}</span>
    <span class="mr-signal ${hasSignal ? 'active' : 'inactive'}">${signal || '—'}</span>
  `;
  return row;
}

function populateMatrix() {
  const container = document.getElementById('matrix-rows');
  if (!container) return;
  container.innerHTML = '';
  COINS.forEach(coin => container.appendChild(createRow(coin)));
}

function updateRandomCell() {
  const rows = document.querySelectorAll('.matrix-row');
  if (!rows.length) return;
  const row = rows[Math.floor(Math.random() * rows.length)];
  const cells = row.querySelectorAll('.mr-cell');
  const idx = Math.floor(Math.random() * cells.length);
  const cell = cells[idx];
  if (!cell) return;
  
  const val = rand(-1, 2);
  cell.textContent = fmt(val);
  cell.classList.remove('hot','cold');
  if (val > 0.7) cell.classList.add('hot');
  else if (val < -0.5) cell.classList.add('cold');
  
  // Occasionally fire a signal
  if (Math.random() < 0.08) {
    const sig = row.querySelector('.mr-signal');
    const newSignal = SIGNALS[Math.floor(Math.random() * (SIGNALS.length - 1))];
    if (sig) {
      sig.textContent = newSignal;
      sig.className = 'mr-signal active';
      row.classList.add('signal-fire');
      setTimeout(() => {
        sig.textContent = '—';
        sig.className = 'mr-signal inactive';
        row.classList.remove('signal-fire');
      }, 3000 + Math.random() * 4000);
    }
  }
}

document.addEventListener('DOMContentLoaded', () => {
  populateMatrix();
  setInterval(updateRandomCell, 400);
});
</script>
