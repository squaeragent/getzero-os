---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ZERO OS — Trading Intelligence Infrastructure">

<div class="page">

  <!-- CRT BOOT -->
  <header class="hero">
    <div class="boot-sequence">
      <pre class="boot-line b1"><span class="p">ZERO OS</span> v0.1 .................... <span class="p">INIT</span></pre>
      <pre class="boot-line b2"><span class="p">SIGNAL MATRIX</span> ................... <span class="p">147 FEATURES</span></pre>
      <pre class="boot-line b3"><span class="p">AGENTS</span> .......................... <span class="p">250 ACTIVE</span></pre>
    </div>

    <div class="logo-wrap">
      <pre class="logo-art">████████╗ ███████╗ ██████╗   ██████╗
╚══███╔═╝ ██╔════╝ ██╔══██╗ ██╔═══██╗
  ███╔╝   █████╗   ██████╔╝ ██║   ██║
 ███╔╝    ██╔══╝   ██╔══██╗ ██║   ██║
████████╗ ███████╗ ██║  ██║ ╚██████╔╝
╚═══════╝ ╚══════╝ ╚═╝  ╚═╝  ╚═════╝</pre>
      <div class="crt-scanline"></div>
    </div>

    <h1 class="hero-title">AI that trades better than you.<br>And you're okay with it.</h1>

    <p class="hero-sub">
      250 agents scanning 147 features across 6 timeframes, 24/7. 
      Signals no one else has. A marketplace where the best ML wins.
    </p>

    <div class="hero-cta">
      <a href="#access" class="btn-primary">Request Access</a>
      <a href="#signals" class="btn-ghost">See the signals ↓</a>
    </div>
  </header>

  <!-- LIVE SIGNAL MATRIX -->
  <section class="section" id="signals">
    <div class="matrix-head">
      <p class="section-label p">SIGNAL MATRIX — LIVE</p>
      <span class="matrix-status" id="matrix-status">3 signals active</span>
    </div>
    <div class="matrix-container">
      <div class="matrix-header">
        <span class="mh-coin">ASSET</span>
        <span class="mh-cell">HURST</span>
        <span class="mh-cell">DFA</span>
        <span class="mh-cell">SENT</span>
        <span class="mh-cell">LYAP</span>
        <span class="mh-cell">FLOW</span>
        <span class="mh-signal">SIGNAL</span>
      </div>
      <div id="matrix-rows"></div>
    </div>
  </section>

  <!-- WHY THIS WORKS — compact -->
  <section class="section">
    <p class="section-label p">THE EDGE</p>
    <h2 class="section-title">Your indicators assume the market never changes. It does.</h2>
    <div class="edge-columns">
      <div class="edge-left">
        <div class="edge-item">
          <span class="edge-name">Hurst + DFA</span>
          <span class="edge-desc dim">— trending or reverting? Both agree = strong. Diverge = regime shift.</span>
        </div>
        <div class="edge-item">
          <span class="edge-name">Lyapunov λ</span>
          <span class="edge-desc dim">— chaos level. High = reduce size. Low = trust your signals.</span>
        </div>
      </div>
      <div class="edge-right">
        <p class="edge-punchline">
          A MACD crossover in a trending regime is meaningful.
          <span class="dim">The same crossover in a mean-reverting regime is a trap.</span>
        </p>
      </div>
    </div>
  </section>

  <!-- DISCOVERIES — tighter -->
  <section class="section">
    <p class="section-label a">EMERGENT</p>
    <h2 class="section-title">None of these were programmed</h2>
    <div class="discovery-grid">
      <div class="disc-card">
        <div class="disc-val p">H = 0.41</div>
        <p>Mean-reverting territory — reversal windows no human hypothesized</p>
      </div>
      <div class="disc-card">
        <div class="disc-val a">&lt;30% HR</div>
        <p>Low hit rate, massive payoff — the wins dominate</p>
      </div>
      <div class="disc-card">
        <div class="disc-val ice">Δ SENT</div>
        <p>Analyst-crowd divergence — contrarian signal invisible to price</p>
      </div>
    </div>
  </section>

  <!-- THREE LAYERS — compressed -->
  <section class="section">
    <p class="section-label p">THREE LAYERS</p>

    <div class="layer-block">
      <h3 class="layer-title"><span class="p">L1</span> Signal-as-a-Service</h3>
      <p class="layer-desc dim">Raw alpha via API. Not indicators — discoveries. For funds and trading desks that have infrastructure but not this data edge.</p>
    </div>

    <div class="layer-block">
      <h3 class="layer-title"><span class="a">L2</span> Agent Marketplace</h3>
      <p class="layer-desc dim">Engineers build predictors → agents find combinations → best agents attract capital → engineers earn revenue share.</p>
      <div class="flywheel">
        <span class="fw-step">Engineers</span>
        <span class="fw-arrow p">→</span>
        <span class="fw-step">Predictors</span>
        <span class="fw-arrow p">→</span>
        <span class="fw-step">Agents</span>
        <span class="fw-arrow p">→</span>
        <span class="fw-step">Capital</span>
        <span class="fw-arrow p">→</span>
        <span class="fw-step">Revenue</span>
        <span class="fw-arrow p">↩</span>
      </div>
    </div>

    <div class="layer-block last">
      <h3 class="layer-title"><span class="ice">L3</span> One-click execution</h3>
      <p class="layer-desc dim">14 months live PnL. Verified Sharpe. Documented drawdown. One button.</p>
    </div>

    <blockquote class="vision-quote">
      The line between a trading system and a world model starts to blur. 
      That is the point we are building toward.
    </blockquote>
  </section>

  <!-- CTA -->
  <section class="section cta-section" id="access">
    <h2 class="cta-title">Request access</h2>
    <p class="cta-desc dim">Signal API for funds. Marketplace for ML engineers. Limited.</p>
    <form class="cta-form" action="#" method="POST">
      <input type="email" placeholder="your@email.com" class="cta-input" required>
      <button type="submit" class="btn-primary">Request Access</button>
    </form>
    <p class="cta-note dim">We review every application.</p>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <span class="p">◇</span> <span class="dim">ZERO OS</span>
  </footer>

</div>

</BaseLayout>

<style>
  .page {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  /* CRT */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.05) 2px, rgba(0,0,0,0.05) 4px);
    pointer-events: none;
    z-index: 100;
  }
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse 70% 70% at 50% 50%, transparent 0%, transparent 85%, rgba(0,0,0,0.15) 92%, rgba(0,0,0,0.4) 100%);
    pointer-events: none;
    z-index: 101;
  }

  /* HERO */
  .hero { padding: 2.5rem 0 2rem; border-bottom: 1px solid var(--border); }
  .boot-sequence { margin-bottom: 1.25rem; }
  .boot-line {
    font-family: var(--font-head);
    font-size: 0.55rem;
    color: var(--text-dim);
    margin: 0;
    line-height: 1.8;
    opacity: 0;
    animation: bootIn 0.3s ease forwards;
  }
  .b1 { animation-delay: 0.2s; }
  .b2 { animation-delay: 0.5s; }
  .b3 { animation-delay: 0.8s; }
  @keyframes bootIn {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .logo-wrap { position: relative; margin-bottom: 1.5rem; overflow: hidden; }
  .logo-art {
    font-family: var(--font-head);
    font-size: clamp(7px, calc((100vw - 30px) / 38), 22px);
    line-height: 1.15;
    color: var(--phosphor);
    text-shadow: 0 0 8px var(--phosphor-glow), 0 0 24px rgba(200,255,0,0.12);
    white-space: pre;
    margin: 0;
    background: transparent;
    border: none;
    animation: logoIn 0.6s ease 1s both;
  }
  @keyframes logoIn {
    0% { opacity: 0; filter: brightness(4) blur(2px); }
    50% { opacity: 0.7; filter: brightness(1.8) blur(0.5px); }
    100% { opacity: 1; filter: brightness(1); }
  }
  .crt-scanline {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--phosphor);
    opacity: 0.06;
    animation: scanDrop 3s linear infinite;
    pointer-events: none;
  }
  @keyframes scanDrop { 0% { top: 0; } 100% { top: 100%; } }

  .hero-title {
    font-family: var(--font-head);
    font-size: clamp(1.3rem, 4.5vw, 2rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--text);
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
    animation: fadeUp 0.5s ease 1.4s both;
  }
  .hero-sub {
    font-size: 0.8rem;
    color: var(--text-dim);
    line-height: 1.7;
    max-width: 480px;
    margin-bottom: 1.25rem;
    animation: fadeUp 0.5s ease 1.6s both;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-cta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    animation: fadeUp 0.5s ease 1.8s both;
  }
  .btn-primary {
    font-family: var(--font-head);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--bg);
    background: var(--phosphor);
    border: none;
    padding: 0.6rem 1.2rem;
    text-decoration: none;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .btn-primary:hover { opacity: 0.85; }
  .btn-ghost {
    font-family: var(--font-head);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--text-dim);
    padding: 0.6rem 1.2rem;
    text-decoration: none;
    border: 1px solid var(--border);
    transition: border-color 0.15s, color 0.15s;
  }
  .btn-ghost:hover { border-color: var(--text-dim); color: var(--text); }

  /* MATRIX */
  .matrix-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.4rem;
  }
  .matrix-status {
    font-family: var(--font-head);
    font-size: 0.5rem;
    color: var(--phosphor);
    letter-spacing: 0.05em;
    animation: pulse 2s ease infinite;
  }
  @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.5; } }

  .matrix-container {
    font-family: var(--font-head);
    font-size: 0.6rem;
    overflow-x: auto;
    border: 1px solid var(--border);
    background: rgba(0,0,0,0.5);
  }
  .matrix-header {
    display: grid;
    grid-template-columns: 48px repeat(5, 1fr) 100px;
    padding: 0.35rem 0.5rem;
    border-bottom: 1px solid var(--border);
    color: var(--text-dim);
    letter-spacing: 0.08em;
    font-size: 0.42rem;
    font-weight: 700;
  }
  .mh-signal { text-align: right; }
  .mh-cell { text-align: right; padding-right: 0.3rem; }
  .matrix-row {
    display: grid;
    grid-template-columns: 48px repeat(5, 1fr) 100px;
    padding: 0.3rem 0.5rem;
    border-bottom: 1px solid rgba(26,26,26,0.3);
    transition: background 0.5s, box-shadow 0.5s;
    align-items: center;
  }
  .matrix-row.fire {
    background: rgba(200,255,0,0.04);
    box-shadow: inset 3px 0 0 var(--phosphor);
  }
  .mr-coin { color: var(--text); font-weight: 700; font-size: 0.52rem; }
  .mr-cell {
    font-variant-numeric: tabular-nums;
    text-align: right;
    padding-right: 0.3rem;
    transition: color 0.4s, text-shadow 0.4s, background 0.4s;
    border-radius: 1px;
    padding: 0.15rem 0.3rem 0.15rem 0;
  }
  /* heat map: intensity-based coloring */
  .mr-cell.neutral { color: var(--text-dim); }
  .mr-cell.warm { color: var(--phosphor); background: rgba(200,255,0,0.04); }
  .mr-cell.hot { color: var(--phosphor); background: rgba(200,255,0,0.1); text-shadow: 0 0 6px var(--phosphor-glow); }
  .mr-cell.cool { color: var(--amber); background: rgba(255,176,0,0.04); }
  .mr-cell.cold { color: var(--amber); background: rgba(255,176,0,0.1); text-shadow: 0 0 4px rgba(255,176,0,0.3); }
  .mr-signal {
    font-weight: 700;
    font-size: 0.5rem;
    letter-spacing: 0.05em;
    text-align: right;
  }
  .mr-signal.on {
    color: var(--phosphor);
    text-shadow: 0 0 8px var(--phosphor-glow);
    animation: sigPulse 1s ease infinite;
  }
  .mr-signal.off { color: rgba(138,130,120,0.2); }
  @keyframes sigPulse { 0%,100% { opacity: 1; } 50% { opacity: 0.7; } }

  /* SECTIONS */
  .section { padding: 2.5rem 0; border-bottom: 1px solid var(--border); }
  .section-label {
    font-family: var(--font-head);
    font-size: 0.45rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    margin-bottom: 0.5rem;
  }
  .section-title {
    font-family: var(--font-head);
    font-size: clamp(1rem, 3.5vw, 1.4rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--text);
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
  }

  /* EDGE SECTION */
  .edge-columns {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-top: 0.75rem;
  }
  @media (min-width: 640px) {
    .edge-columns { grid-template-columns: 1fr 1fr; }
  }
  .edge-item {
    font-family: var(--font-head);
    font-size: 0.7rem;
    margin-bottom: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .edge-name { color: var(--text); font-weight: 700; }
  .edge-desc { font-size: 0.65rem; line-height: 1.5; }
  .edge-punchline {
    font-family: var(--font-head);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.5;
    border-left: 2px solid var(--phosphor);
    padding-left: 1rem;
  }

  /* DISCOVERIES */
  .discovery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }
  @media (max-width: 639px) {
    .discovery-grid { grid-template-columns: 1fr; }
  }
  .disc-card {
    border: 1px solid var(--border);
    padding: 1.25rem 1rem;
    text-align: center;
  }
  .disc-val {
    font-family: var(--font-head);
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 0.3rem;
  }
  .disc-card p { font-size: 0.6rem; color: var(--text-dim); line-height: 1.5; }

  /* LAYERS */
  .layer-block {
    padding-bottom: 1.25rem;
    margin-bottom: 1.25rem;
    border-bottom: 1px solid rgba(26,26,26,0.4);
  }
  .layer-block.last { border-bottom: none; margin-bottom: 0.5rem; padding-bottom: 0.5rem; }
  .layer-title {
    font-family: var(--font-head);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.35rem;
  }
  .layer-desc {
    font-size: 0.7rem;
    line-height: 1.6;
    max-width: 500px;
  }

  /* FLYWHEEL */
  .flywheel {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-top: 0.75rem;
    font-family: var(--font-head);
    font-size: 0.6rem;
  }
  .fw-step {
    color: var(--text);
    font-weight: 700;
    padding: 0.25rem 0.5rem;
    border: 1px solid var(--border);
  }
  .fw-arrow { font-size: 0.8rem; }

  /* VISION */
  .vision-quote {
    font-family: var(--font-head);
    font-size: clamp(0.8rem, 2.5vw, 1rem);
    font-weight: 700;
    color: var(--text);
    line-height: 1.4;
    border-left: 2px solid var(--phosphor);
    padding-left: 1rem;
    margin-top: 1.5rem;
    max-width: 460px;
  }

  /* CTA */
  .cta-section { border-bottom: none; padding: 2.5rem 0 1.5rem; text-align: center; }
  .cta-title {
    font-family: var(--font-head);
    font-size: clamp(1rem, 3vw, 1.3rem);
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.5rem;
  }
  .cta-desc { font-size: 0.7rem; margin-bottom: 1.25rem; text-align: center; }
  .cta-form {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .cta-input {
    font-family: var(--font-body);
    font-size: 0.75rem;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 0.6rem 1rem;
    min-width: 220px;
    outline: none;
    transition: border-color 0.15s;
  }
  .cta-input:focus { border-color: var(--phosphor); }
  .cta-input::placeholder { color: var(--text-dim); }
  .cta-note { font-size: 0.55rem; margin-top: 0.4rem; }

  /* FOOTER */
  .footer {
    padding: 1.5rem 0;
    font-family: var(--font-head);
    font-size: 0.55rem;
    letter-spacing: 0.05em;
    text-align: center;
    border-top: 1px solid var(--border);
  }

  /* UTILITY */
  .p { color: var(--phosphor); }
  .a { color: var(--amber); }
  .ice { color: var(--ice); }
  .dim { color: var(--text-dim); }
  .red { color: var(--red); }
</style>

<script>
const COINS = ['BTC','ETH','SOL','DOGE','AVAX','LINK','ARB','OP','SUI','MATIC','NEAR','INJ'];
const SIGS = ['REVERSAL','MOMENTUM','MEAN REV','BREAKOUT','DIVERGE'];

function r(a,b){return Math.random()*(b-a)+a;}
function f(n){return n.toFixed(2);}

// heat intensity: maps value to CSS class
function heat(v, lo, hi) {
  if (v <= lo) return 'hot';
  if (v <= lo + (hi-lo)*0.25) return 'warm';
  if (v >= hi) return 'cold';
  if (v >= hi - (hi-lo)*0.25) return 'cool';
  return 'neutral';
}

function mkRow(coin){
  const h=r(.28,.72), dfa=r(.35,.68), se=r(-1,1), ly=r(-.2,1.2), fl=r(-3,3);
  const fire=Math.random()<.20;
  const sig=fire?SIGS[Math.floor(Math.random()*SIGS.length)]:'';
  const row=document.createElement('div');
  row.className='matrix-row'+(fire?' fire':'');
  row.innerHTML=`
    <span class="mr-coin">${coin}</span>
    <span class="mr-cell ${heat(h, .42, .58)}">${f(h)}</span>
    <span class="mr-cell ${heat(dfa, .42, .58)}">${f(dfa)}</span>
    <span class="mr-cell ${Math.abs(se)>.6?'hot':'neutral'}">${f(se)}</span>
    <span class="mr-cell ${ly>.8?'cold':ly<.1?'hot':'neutral'}">${f(ly)}</span>
    <span class="mr-cell ${Math.abs(fl)>2?(fl>0?'hot':'cold'):'neutral'}">${f(fl)}</span>
    <span class="mr-signal ${fire?'on':'off'}">${sig||'—'}</span>`;
  return row;
}

function init(){
  const c=document.getElementById('matrix-rows');
  if(!c)return;
  c.innerHTML='';
  COINS.forEach(coin=>c.appendChild(mkRow(coin)));
  updateCount();
}

function updateCount(){
  const n=document.querySelectorAll('.matrix-row.fire').length;
  const s=document.getElementById('matrix-status');
  if(s)s.textContent=n+' signal'+(n!==1?'s':'')+' active';
}

function tick(){
  const rows=[...document.querySelectorAll('.matrix-row')];
  if(!rows.length)return;
  const row=rows[Math.floor(Math.random()*rows.length)];
  const cells=row.querySelectorAll('.mr-cell');
  const idx=Math.floor(Math.random()*cells.length);
  const cell=cells[idx];
  if(!cell)return;
  
  const v=r(-.3, 1.2);
  cell.textContent=f(v);
  cell.classList.remove('hot','warm','neutral','cool','cold');
  if(v<.3) cell.classList.add('hot');
  else if(v<.42) cell.classList.add('warm');
  else if(v>.7) cell.classList.add('cold');
  else if(v>.58) cell.classList.add('cool');
  else cell.classList.add('neutral');

  // flash: row briefly glows on change
  cell.style.transition='none';
  cell.style.textShadow='0 0 8px var(--phosphor-glow)';
  requestAnimationFrame(()=>{
    cell.style.transition='text-shadow 0.6s';
    setTimeout(()=>{ cell.style.textShadow=''; },400);
  });

  if(Math.random()<.05){
    const sig=row.querySelector('.mr-signal');
    const name=SIGS[Math.floor(Math.random()*SIGS.length)];
    if(sig){
      sig.textContent=name;
      sig.className='mr-signal on';
      row.classList.add('fire');
      updateCount();
      setTimeout(()=>{
        sig.textContent='—';
        sig.className='mr-signal off';
        row.classList.remove('fire');
        updateCount();
      },3000+Math.random()*5000);
    }
  }
}

document.addEventListener('DOMContentLoaded',()=>{init();setInterval(tick,300);});
</script>
