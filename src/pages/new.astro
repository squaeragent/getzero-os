---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="ZERO OS — ZERO OS — Operating System for Trading Agents" description="Self-improving trading agent for Hyperliquid. Every trade on-chain verifiable. Watch it think in real-time.">
  <div class="page">

    <!-- PHASE 0: Terminal Header (instant) -->
    <div id="phase0" class="phase0">
      <span class="p0-logo">⟨◇⟩ ZERO OS</span>
      <span class="p0-url">getzero.dev</span>
    </div>

    <!-- PHASE 1: ASCII Logo + Tagline -->
    <div id="phase1" class="phase hidden">
      <pre class="ascii-logo">████████╗███████╗██████╗  ██████╗ 
╚══███╔═╝██╔════╝██╔══██╗██╔═══██╗
  ███╔╝  █████╗  ██████╔╝██║   ██║
 ███╔╝   ██╔══╝  ██╔══██╗██║   ██║
████████╗███████╗██║  ██║╚██████╔╝
╚═══════╝╚══════╝╚═╝  ╚═╝ ╚═════╝</pre>
      <div class="tagline">The operating system for trading agents.</div>
    </div>

    <!-- PHASE 2: Component Check -->
    <div id="phase2" class="phase hidden">
      <div class="boot-line" data-index="0">▸ loading signal engine <span class="dots">................</span> <span class="bl-val">online</span></div>
      <div class="boot-line" data-index="1">▸ loading execution engine <span class="dots">.............</span> <span class="bl-val">online</span></div>
      <div class="boot-line" data-index="2">▸ loading risk framework <span class="dots">.............</span> <span class="bl-val">online</span></div>
      <div class="boot-line" data-index="3">▸ loading immune system <span class="dots">...............</span> <span class="bl-val">online</span></div>
      <div class="boot-line" data-index="4">▸ initializing agents:</div>
      <div class="boot-line boot-agent" data-index="5">  agent/balanced <span class="dots">..................</span> <span class="bl-val">active</span></div>
      <div class="boot-status" id="boot-status">system online · 1 agent active · uptime <span id="b-uptime">—</span></div>
    </div>

    <!-- PHASE 3: Live Status -->
    <div id="phase3" class="phase hidden">
      <div class="status-box">
        <div class="sb-equity" id="p3-equity">$—</div>
        <div class="sb-pnl"><span id="p3-pnl">—</span> <span class="sb-realized">realized: <span id="p3-realized">—</span></span></div>
        <div class="sb-meta"><span class="agent-label">agent/balanced:</span> <span id="p3-trades">—</span> trades · <span id="p3-uptime2">—</span> · risk: <span id="p3-risk" class="risk-green">GREEN</span></div>
        <!-- wallet verification will be added when ready -->
      </div>
    </div>

    <!-- PHASE 4: Hook + CTAs -->
    <div id="phase4" class="phase hidden">
      <div class="hook">
        <div class="hook-line1">Most trading bots are closed boxes that repeat the same mistakes.</div>
        <div class="hook-line2">ZERO OS found 70 flaws in its own design and fixed 40 in one session.</div>
        <div class="hook-line3">Your agents run on infrastructure that audits itself.</div>
      </div>
      <div class="ctas">
        <a href="/portfolio" class="cta">→ Watch it trade live</a>
        <a href="/thesis" class="cta">→ Read how it works</a>
      </div>
    </div>

    <!-- PHASE 5: Evidence Panels -->
    <div id="phase5" class="phase hidden">
      <div class="panels">

        <!-- Panel A: Decision Stream -->
        <div class="panel">
          <div class="panel-head">DECISION STREAM — agent/balanced <span class="live-dot">● live</span></div>
          <div class="panel-body" id="pa-body"><div class="muted">Loading...</div></div>
          <a href="/portfolio" class="panel-link">→ See full decision stream</a>
        </div>

        <!-- Panel B: Signal Universe -->
        <div class="panel">
          <div class="panel-head">SIGNAL UNIVERSE <span class="panel-meta" id="pb-meta"></span></div>
          <div class="panel-body" id="pb-body"><div class="muted">Loading...</div></div>
          <a href="/portfolio" class="panel-link">→ See all signals</a>
        </div>

        <!-- Panel C: Selectivity -->
        <div class="panel">
          <div class="panel-head">SELECTIVITY — agent/balanced</div>
          <div class="panel-body" id="pc-body"><div class="muted">Loading...</div></div>
        </div>

      </div>
    </div>

    <!-- Nav (appears after boot) -->
    <nav id="main-nav" class="main-nav hidden">
      <a href="/" class="nav-item">⟨◇⟩ ZERO OS</a>
      <a href="/thesis" class="nav-item">THESIS</a>
      <a href="/portfolio" class="nav-item">PORTFOLIO</a>
      <a href="/portfolio" class="nav-item nav-live"><span class="live-dot">●</span> LIVE</a>
    </nav>

  </div>
</BaseLayout>

<style is:global>
  .page {
    max-width: 720px;
    margin: 0 auto;
    padding: 1rem 1.5rem;
    min-height: 100vh;
  }

  /* Phase 0 */
  .phase0 {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.6rem 0;
    border-bottom: 1px solid rgba(200,255,0,0.15);
    font-family: var(--font-head);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
  }
  .p0-logo { color: var(--phosphor); }
  .p0-url { color: var(--text-dim); font-size: 0.6rem; }

  /* Boot animation */
  .hidden { opacity: 0; transform: translateY(8px); pointer-events: none; }
  .phase { transition: opacity 0.4s ease, transform 0.4s ease; }
  .phase.visible { opacity: 1; transform: translateY(0); pointer-events: auto; }
  .boot-line { opacity: 0; transition: opacity 0.3s ease; }
  .boot-line.visible { opacity: 1; }

  /* Phase 1 */
  .ascii-logo {
    font-family: var(--font-head);
    font-size: clamp(0.32rem, 1.4vw, 0.55rem);
    line-height: 1.15;
    color: rgba(200,255,0,0.6);
    margin: 2rem 0 0.8rem;
    overflow-x: auto;
  }
  .tagline {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--text);
    margin-bottom: 2rem;
  }

  /* Phase 2 */
  .boot-line {
    font-family: var(--font-head);
    font-size: 0.65rem;
    color: var(--text-dim);
    line-height: 1.8;
    white-space: nowrap;
    overflow-x: auto;
  }
  .dots { color: rgba(200,255,0,0.12); }
  .bl-val { color: var(--text); }
  .boot-status {
    opacity: 0;
    transition: opacity 0.4s ease;
    font-family: var(--font-head);
    font-size: 0.7rem;
    color: var(--phosphor);
    margin-top: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px solid rgba(200,255,0,0.1);
  }
  .boot-status.visible { opacity: 1; }

  /* Phase 3 */
  .status-box {
    border: 1px solid rgba(200,255,0,0.3);
    padding: 1.5rem;
    margin: 2rem 0;
    font-family: var(--font-head);
  }
  .sb-equity {
    font-size: clamp(1.5rem, 5vw, 2.5rem);
    color: var(--phosphor);
    font-weight: 700;
    line-height: 1;
    margin-bottom: 0.4rem;
  }
  .sb-pnl {
    font-size: 0.8rem;
    color: var(--text);
    margin-bottom: 0.8rem;
  }
  .sb-realized { color: var(--text-dim); }
  .sb-meta {
    font-size: 0.7rem;
    color: var(--text-dim);
    margin-bottom: 1rem;
  }
  .risk-green { color: var(--phosphor); }
  .agent-label { color: var(--phosphor); font-size: 0.65rem; }
  .boot-agent { padding-left: 0.5rem; }
  .hook-line3 { font-size: 0.85rem; color: var(--text-dim); margin-top: 0.5rem; }
  .sb-wallet {
    font-size: 0.6rem;
    color: var(--text-dim);
    word-break: break-all;
    margin-bottom: 0.3rem;
  }
  .sb-verify {
    font-size: 0.65rem;
    color: var(--phosphor);
    text-decoration: none;
  }
  .sb-verify:hover { text-decoration: underline; }

  /* Phase 4 */
  .hook {
    margin: 2rem 0 1.5rem;
    font-family: var(--font-body);
  }
  .hook-line1 {
    font-size: 0.95rem;
    color: var(--text-dim);
    margin-bottom: 0.3rem;
  }
  .hook-line2 {
    font-size: 1.05rem;
    color: var(--text);
    font-weight: 500;
  }
  .ctas {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
    margin-top: 1rem;
  }
  .cta {
    font-family: var(--font-head);
    font-size: 0.75rem;
    color: var(--text-dim);
    text-decoration: none;
    letter-spacing: 0.03em;
    transition: color 0.2s;
  }
  .cta:hover { color: var(--phosphor); }

  /* Phase 5 */
  .panels {
    display: flex;
    gap: 1.5rem;
  }
  @media (max-width: 700px) {
    .panels { flex-direction: column; }
  }
  .panel {
    flex: 1;
    min-width: 0;
    border: 1px solid var(--border);
    padding: 0.8rem;
    font-family: var(--font-head);
  }
  .panel-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.6rem;
    color: var(--text-dim);
    letter-spacing: 0.1em;
    margin-bottom: 0.6rem;
    text-transform: uppercase;
  }
  .panel-meta { color: var(--text-dim); font-size: 0.55rem; }
  .panel-body { font-size: 0.6rem; min-height: 80px; }
  .panel-link {
    display: block;
    font-size: 0.55rem;
    color: var(--text-dim);
    text-decoration: none;
    margin-top: 0.6rem;
    padding-top: 0.4rem;
    border-top: 1px solid var(--border);
    transition: color 0.2s;
  }
  .panel-link:hover { color: var(--phosphor); }
  .muted { color: var(--text-dim); }

  /* Decision rows */
  .ds-mini { display: flex; gap: 0.4rem; align-items: baseline; padding: 0.15rem 0; border-bottom: 1px solid rgba(200,255,0,0.03); line-height: 1.4; font-size: 0.6rem; }
  .ds-mini .time { color: var(--text-dim); min-width: 2.5rem; }
  .ds-mini .coin { min-width: 4rem; font-weight: 600; }
  .ds-mini .dir { min-width: 2.5rem; }
  .ds-mini .dir.long { color: var(--phosphor); }
  .ds-mini .dir.short { color: var(--red); }
  .ds-mini .badge { padding: 0.02rem 0.2rem; border-radius: 2px; font-size: 0.5rem; min-width: 3.5rem; text-align: center; }
  .ds-mini .badge.entered { background: rgba(200,255,0,0.12); color: var(--phosphor); }
  .ds-mini .badge.closed-w { background: rgba(200,255,0,0.1); color: var(--phosphor); }
  .ds-mini .badge.closed-l { background: rgba(255,51,51,0.12); color: var(--red); }
  .ds-mini .badge.rejected { background: rgba(255,255,255,0.04); color: var(--text-dim); }
  .ds-mini .badge.blocked { background: rgba(255,51,51,0.06); color: #ff6666; }
  .ds-mini .reason { color: var(--text-dim); flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 0.5rem; }

  /* Signal grid */
  .sig-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.3rem; }
  .sig-cell { display: flex; align-items: center; gap: 0.3rem; padding: 0.2rem 0; }
  .sig-name { font-weight: 600; color: var(--phosphor); min-width: 2.5rem; }
  .sig-spark { width: 40px; height: 14px; flex-shrink: 0; }
  .sig-val { color: var(--text); font-size: 0.55rem; }
  .sig-more { color: var(--text-dim); font-size: 0.5rem; margin-top: 0.3rem; }

  /* Funnel bars */
  .fn-row { display: flex; align-items: center; gap: 0.4rem; margin-bottom: 0.4rem; font-size: 0.55rem; }
  .fn-label { min-width: 7rem; color: var(--text-dim); flex-shrink: 0; }
  .fn-bar-wrap { flex: 1; height: 12px; background: rgba(200,255,0,0.04); }
  .fn-bar { height: 100%; background: rgba(200,255,0,0.2); }
  .fn-bar.bright { background: rgba(200,255,0,0.5); }
  .fn-count { min-width: 2rem; text-align: right; color: var(--text); }
  .fn-big { font-size: clamp(1rem, 3vw, 1.4rem); color: var(--phosphor); font-weight: 700; margin: 0.5rem 0 0.2rem; }
  .fn-copy { font-size: 0.6rem; color: var(--text-dim); font-family: var(--font-body); font-style: italic; }

  /* Nav */
  .main-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 0.5rem 1.5rem;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    font-family: var(--font-head);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    z-index: 100;
    transition: opacity 0.5s ease;
  }
  .main-nav.visible { opacity: 1; pointer-events: auto; }
  .nav-item { color: var(--text-dim); text-decoration: none; transition: color 0.2s; }
  .nav-item:first-child { color: var(--phosphor); margin-right: auto; }
  .nav-item:hover { color: var(--phosphor); }
  .nav-live { color: var(--phosphor); }
  .live-dot { color: var(--phosphor); font-size: 0.5rem; animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }
</style>

<script>
(function(){
  var API = 'https://api.getzero.dev';
  var startingEquity = 746.51;
  var evalAgo = 0;
  var evalInterval = null;

  // Boot sequence timing
  var TIMING = { p1: 500, p2: 1000, p3: 1500, p4: 2000, p5: 2500, nav: 3000 };

  function reveal(id) {
    var el = document.getElementById(id);
    if (el) { el.classList.remove('hidden'); el.classList.add('visible'); }
  }

  function setText(id, val) {
    var el = document.getElementById(id);
    if (el) el.textContent = val;
  }

  // Phase 1
  setTimeout(function(){ reveal('phase1'); }, TIMING.p1);

  // Phase 2 — stagger lines
  setTimeout(function(){
    reveal('phase2');
    var lines = document.querySelectorAll('.boot-line');
    for (var i = 0; i < lines.length; i++) {
      (function(line, idx){
        setTimeout(function(){ line.classList.add('visible'); }, idx * 150);
      })(lines[i], i);
    }
    // Status line after all boot lines
    setTimeout(function(){
      var bs = document.getElementById('boot-status');
      if (bs) bs.classList.add('visible');
    }, lines.length * 150 + 200);
  }, TIMING.p2);

  // Phase 3
  setTimeout(function(){ reveal('phase3'); }, TIMING.p3);

  // Phase 4
  setTimeout(function(){ reveal('phase4'); }, TIMING.p4);

  // Phase 5
  setTimeout(function(){ reveal('phase5'); }, TIMING.p5);

  // Nav
  setTimeout(function(){ reveal('main-nav'); }, TIMING.nav);

  // --- API calls (fire in parallel) ---
  function safeJson(url) {
    return fetch(url).then(function(r){ return r.json(); }).catch(function(){ return null; });
  }

  function fmtUptime(hours) {
    if (!hours || hours < 0) return '—';
    var d = Math.floor(hours / 24);
    var h = Math.floor(hours % 24);
    return d + 'd ' + h + 'h';
  }

  // Evaluator heartbeat counter
  function startEvalCounter(ago) {
    evalAgo = Math.min(Math.max(0, Math.round(ago)), 15);
    setText('b-eval', evalAgo);
    if (evalInterval) clearInterval(evalInterval);
    evalInterval = setInterval(function(){
      evalAgo++;
      if (evalAgo > 15) evalAgo = 0;
      setText('b-eval', evalAgo);
    }, 1000);
  }

  // Populate status (Phase 2)
  function populateStatus(data) {
    if (!data) return;
    setText('b-coins', data.active_coins || '—');
    setText('b-uptime', fmtUptime(data.uptime_hours));
  }

  // Populate equity (Phase 3)
  function populateEquity(portfolio, status) {
    if (!portfolio) return;
    var lt = portfolio.liveTrading || {};
    var closed = lt.closed || [];
    var positions = lt.positions || [];

    // Realized PnL
    var realized = 0;
    for (var i = 0; i < closed.length; i++) {
      realized += (closed[i].pnl_usd || closed[i].pnl_dollars || 0);
    }

    // Equity from curve
    var curve = portfolio.liveEquityCurve || [];
    var equity = null;
    if (curve.length > 0) equity = curve[curve.length - 1].v;
    if (!equity) equity = startingEquity + realized;

    // PnL
    var totalPnl = equity - startingEquity;
    var pnlPct = (totalPnl / startingEquity * 100);

    setText('p3-equity', '$' + equity.toFixed(2));

    var pnlSign = totalPnl >= 0 ? '+' : '';
    var pnlEl = document.getElementById('p3-pnl');
    if (pnlEl) {
      pnlEl.textContent = pnlSign + pnlPct.toFixed(2) + '% ($' + pnlSign + totalPnl.toFixed(2) + ')';
      pnlEl.style.color = totalPnl >= 0 ? '#c8ff00' : '#ff3333';
    }
    setText('p3-realized', '$' + realized.toFixed(2));

    // Meta
    var trades = closed.length + positions.length;
    setText('p3-trades', trades);
    if (status) setText('p3-uptime2', fmtUptime(status.uptime_hours));
  }

  // Populate decisions (Panel A)
  function populateDecisions(decisions) {
    var body = document.getElementById('pa-body');
    if (!body) return;
    if (!decisions || !decisions.length) { body.innerHTML = '<div class="muted">No decisions yet</div>'; return; }

    var html = '';
    for (var i = 0; i < Math.min(decisions.length, 5); i++) {
      var d = decisions[i];
      var ts = d.ts ? new Date(d.ts).toISOString().slice(11,16) : '—';
      var dirClass = (d.direction || '').toLowerCase() === 'long' ? 'long' : 'short';
      var badgeClass = 'rejected';
      var badgeText = d.type || '—';
      if (d.type === 'ENTERED') badgeClass = 'entered';
      else if (d.type === 'CLOSED' && d.won) { badgeClass = 'closed-w'; badgeText = 'CLOSED'; }
      else if (d.type === 'CLOSED' && !d.won) { badgeClass = 'closed-l'; badgeText = 'CLOSED'; }
      else if (d.type === 'BLOCKED') badgeClass = 'blocked';

      var reason = d.reason || '';
      // Sanitize: strip specific numbers and internals from rejection reasons
      reason = reason.replace(/:\s*\d+.*$/g, '').replace(/_/g, ' ');
      if (d.type === 'CLOSED') {
        var pnl = d.pnl_usd || 0;
        reason = (pnl >= 0 ? '+' : '') + '$' + pnl.toFixed(2);
      }
      if (d.type === 'ENTERED') {
        // Show just the dollar amount, not the signal name
        reason = reason.replace(/@.*$/, '').trim();
      }

      html += '<div class="ds-mini">';
      html += '<span class="time">' + ts + '</span>';
      html += '<span class="coin">' + (d.coin || '—') + '</span>';
      html += '<span class="dir ' + dirClass + '">' + (d.direction || '—') + '</span>';
      html += '<span class="badge ' + badgeClass + '">' + badgeText + '</span>';
      html += '<span class="reason">' + reason + '</span>';
      html += '</div>';
    }
    body.innerHTML = html;
  }

  // Populate landscape (Panel B)
  function populateLandscape(data) {
    var body = document.getElementById('pb-body');
    var meta = document.getElementById('pb-meta');
    if (!body) return;
    if (!data || !data.coins) { body.innerHTML = '<div class="muted">No signal data</div>'; return; }

    if (meta) meta.textContent = 'active';

    var active = [];
    for (var i = 0; i < data.coins.length; i++) {
      if (data.coins[i].tier === 'active') active.push(data.coins[i]);
    }

    var html = '<div class="sig-grid">';
    for (var i = 0; i < Math.min(active.length, 6); i++) {
      var c = active[i];
      var spark = c.sparkline || [];
      var svg = '';
      if (spark.length >= 2) {
        var sMin = Math.min.apply(null, spark);
        var sMax = Math.max.apply(null, spark);
        var sR = sMax - sMin; if (sR < 0.01) sR = 1;
        var pts = [];
        for (var j = 0; j < spark.length; j++) {
          pts.push((j / (spark.length-1) * 38).toFixed(1) + ',' + (12 - (spark[j]-sMin)/sR*10).toFixed(1));
        }
        svg = '<svg class="sig-spark" viewBox="0 0 38 14" preserveAspectRatio="none"><polyline fill="none" stroke="#c8ff00" stroke-width="1.5" points="' + pts.join(' ') + '"/></svg>';
      }
      html += '<div class="sig-cell">';
      html += '<span class="sig-name">' + c.coin + '</span>';
      html += svg;
      html += '<span class="sig-val">' + (c.current_sharpe != null ? c.current_sharpe.toFixed(1) : '—') + '</span>';
      html += '</div>';
    }
    html += '</div>';
    html += '<div class="sig-more">+ more watching</div>';
    body.innerHTML = html;
  }

  // Populate funnel (Panel C)
  function populateFunnel(data) {
    var body = document.getElementById('pc-body');
    if (!body) return;
    if (!data) { body.innerHTML = '<div class="muted">No funnel data</div>'; return; }

    var total = data.total_signals || 1;
    var executed = data.total_executed || 0;
    var execPct = (executed / total * 100).toFixed(1);

    var html = '';
    html += '<div class="fn-row"><span class="fn-label">signals evaluated</span><div class="fn-bar-wrap"><div class="fn-bar" style="width:100%"></div></div></div>';
    html += '<div class="fn-row"><span class="fn-label">passed all checks</span><div class="fn-bar-wrap"><div class="fn-bar bright" style="width:' + execPct + '%"></div></div></div>';
    html += '<div class="fn-big">' + (data.rejection_rate || 0) + '% rejected</div>';
    html += '<div class="fn-copy">The system\'s intelligence is what it doesn\'t trade.</div>';
    body.innerHTML = html;
  }

  // Fire all API calls
  Promise.all([
    safeJson(API + '/v6/status'),
    safeJson(API + '/portfolio.json'),
    safeJson(API + '/v6/decisions?limit=5'),
    safeJson(API + '/v6/landscape'),
    safeJson(API + '/v6/funnel')
  ]).then(function(results) {
    var status = results[0];
    var portfolio = results[1];
    var decisions = results[2];
    var landscape = results[3];
    var funnel = results[4];

    populateStatus(status);
    populateEquity(portfolio, status);
    populateDecisions(decisions);
    populateLandscape(landscape);
    populateFunnel(funnel);
  });

  // Poll evaluator heartbeat every 15s
  setInterval(function(){
    safeJson(API + '/v6/status').then(function(data){
      if (data) {
        evalAgo = Math.min(Math.max(0, Math.round(data.eval_last_run_ago || 0)), 15);
        setText('b-eval', evalAgo);
      }
    });
  }, 15000);

})();
</script>
