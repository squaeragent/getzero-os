---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="ZERO OS — Live Trading" description="10-agent autonomous trading system. 1,190+ signals across 40 coins. Live on Hyperliquid.">
  <div class="page">
    <div class="terminal-border">

      <!-- NAV BAR -->
      <div class="nav-bar">
        <a href="/" class="nav-item">◇ ZERO OS</a>
        <a href="/thesis" class="nav-item">THESIS</a>
        <span class="nav-item nav-active">PORTFOLIO</span>
        <span class="nav-live"><span class="live-dot">●</span> LIVE</span>
      </div>

      <!-- EQUITY HERO -->
      <div class="hero-pane">
        <div class="hero-body">
          <div class="equity-hero">
            <div class="eq-number" id="eq-number">$—</div>
            <div class="eq-pnl" id="eq-pnl">—</div>
            <div class="eq-meta" id="eq-meta">— trades · — uptime</div>
            <div class="eq-badges">
              <span class="risk-badge" id="risk-badge">—</span>
              <span class="early-badge" id="early-badge" style="display:none">EARLY DATA</span>
            </div>
          </div>
        </div>
      </div>

      <!-- EQUITY CURVE -->
      <div class="section">
        <div class="ph">ACCOUNT VALUE <span class="dim" id="eq-range"></span></div>
        <div class="sb eq-wrap">
          <canvas id="equity-canvas" width="860" height="120"></canvas>
          <div class="muted" id="eq-empty" style="display:none">Collecting data...</div>
        </div>
      </div>

      <!-- OPEN POSITIONS -->
      <div class="section">
        <div class="ph">OPEN POSITIONS <span class="dim" id="pos-count">(0)</span></div>
        <div class="sb" id="positions-body">
          <div class="muted">Fetching live data...</div>
        </div>
      </div>

      <!-- MARKET STATE -->
      <div class="section" id="market-state-section">
        <div class="ph">MARKET STATE</div>
        <div class="sb">
          <div class="regime-map" id="regime-map"></div>
          <div class="regime-legend">
            <span class="leg-dot" style="background:#c8ff00"></span>trending
            <span class="leg-dot" style="background:#aaa"></span>stable
            <span class="leg-dot" style="background:#ffb000"></span>shift
            <span class="leg-dot" style="background:#ff3333"></span>chaotic
          </div>
          <div class="status-line" id="status-line">
            <span class="status-ok">Spreads ✓</span>
            <span class="status-ok">Funding ✓</span>
          </div>
        </div>
      </div>

      <!-- SIGNAL ARCHETYPES -->
      <div class="section" id="archetypes-section">
        <div class="ph">SIGNAL ARCHETYPES</div>
        <div class="sb">
          <div class="archetype-grid" id="archetype-grid">
            <div class="muted">Monitoring 6 signal archetypes...</div>
          </div>
        </div>
      </div>

      <!-- SYSTEM STATUS (collapsed) -->
      <div class="section">
        <div class="ph system-ph" id="system-ph">SYSTEM <span id="system-summary">—</span></div>
        <div class="sb">
          <div class="system-healthy" id="system-healthy">Pipeline healthy — all agents reporting</div>
          <div class="system-body" id="system-body">
            <div class="agent-pipeline" id="agent-pipeline"></div>
          </div>
        </div>
      </div>

      <!-- PERFORMANCE (≥5 trades) -->
      <div class="section" id="stats-section" style="display:none">
        <div class="ph">PERFORMANCE</div>
        <div class="sb stats-grid" id="stats-dashboard">
          <div class="muted">Loading stats...</div>
        </div>
      </div>

      <!-- TRADE HISTORY -->
      <div class="section">
        <div class="ph">CLOSED TRADES <span class="dim" id="closed-count">(0)</span></div>
        <div class="sb" id="closed-body">
          <div class="muted">Fetching live data...</div>
        </div>
      </div>

      <!-- FOOTER -->
      <div class="footer">
        <a href="/" class="footer-link">◇ ZERO OS</a>
        <span class="dim" id="updated">—</span>
      </div>

    </div>
  </div>
</BaseLayout>

<style is:global>
  /* ─── PAGE ─── */
  .page {
    max-width: 960px;
    margin: 0 auto;
    padding: 1rem;
    min-height: 100vh;
  }
  .terminal-border {
    border: 1px solid rgba(200,255,0,0.25);
    min-height: 100vh;
  }

  /* ─── NAV BAR ─── */
  .nav-bar {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 0.5rem 1rem;
    border-bottom: 1px solid var(--border);
    font-family: var(--font-head);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .nav-item {
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-item:hover { color: var(--phosphor); }
  .nav-active { color: var(--phosphor); }
  .nav-live {
    margin-left: auto;
    font-family: var(--font-head);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    color: var(--phosphor);
    text-transform: uppercase;
  }

  /* ─── SECTION HEADERS ─── */
  .ph {
    font-family: var(--font-head);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text);
    padding: 0.5rem 1rem 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border);
    border-left: 2px solid rgba(200,255,0,0.4);
    background: rgba(0,0,0,0.6);
  }
  .section {
    border-bottom: 1px solid var(--border);
  }
  .sb {
    padding: 0.75rem 1rem;
  }
  .dim { opacity: 0.5; font-size: 0.6rem; }
  .muted {
    font-family: var(--font-head);
    font-size: 0.8rem;
    color: var(--text-dim);
    opacity: 0.4;
  }

  /* ─── EQUITY HERO ─── */
  .hero-pane { border-bottom: 1px solid var(--border); }
  .live-dot {
    color: #00ff00;
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }
  .early-badge {
    font-family: var(--font-head);
    font-size: 0.5rem;
    padding: 0.1rem 0.35rem;
    color: #ffb000;
    border: 1px solid rgba(255,176,0,0.4);
    letter-spacing: 0.08em;
    vertical-align: middle;
    margin-left: 0.5rem;
  }
  .hero-body { padding: 1.25rem 1rem; }
  .equity-hero { display: flex; flex-direction: column; }
  .eq-number {
    font-size: clamp(2rem, 8vw, 3.5rem);
    font-weight: 700;
    font-family: var(--font-head);
    color: var(--phosphor);
    line-height: 1;
  }
  .eq-pnl {
    font-size: clamp(1rem, 4vw, 1.5rem);
    font-weight: 600;
    font-family: var(--font-head);
    margin-top: 0.25rem;
  }
  .eq-meta {
    font-size: 0.7rem;
    color: var(--text-dim);
    font-family: var(--font-head);
    margin-top: 0.35rem;
    letter-spacing: 0.05em;
  }
  .eq-badges {
    margin-top: 0.5rem;
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }
  .risk-badge {
    font-family: var(--font-head);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    padding: 0.15rem 0.5rem;
    text-transform: uppercase;
  }

  /* ─── EQUITY CURVE ─── */
  .eq-wrap {
    padding: 0.5rem 1rem;
    overflow: hidden;
  }
  #equity-canvas {
    width: 100%;
    height: 120px;
    display: block;
  }

  /* ─── MARKET STATE ─── */
  .regime-map {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: flex-end;
    margin-bottom: 0.5rem;
  }
  .regime-coin-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }
  .regime-dot {
    width: 10px;
    height: 10px;
    display: block;
  }
  .regime-coin-name {
    font-size: 0.5rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-family: var(--font-head);
  }
  .regime-legend {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-head);
    font-size: 0.55rem;
    color: var(--text-dim);
    letter-spacing: 0.06em;
    margin-bottom: 0.6rem;
  }
  .leg-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    margin-right: 0.2rem;
    vertical-align: middle;
  }
  .status-line {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    font-family: var(--font-head);
    font-size: 0.7rem;
    margin-top: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--border);
  }
  .status-ok { color: #c8ff00; }
  .status-warn { color: #ffb000; }
  .status-err { color: #ff3333; }

  /* ─── SIGNAL ARCHETYPES ─── */
  .archetype-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }
  .archetype-card {
    border: 1px solid var(--border);
    padding: 0.75rem;
    background: rgba(255,255,255,0.02);
  }
  .archetype-card-title {
    font-family: var(--font-head);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    text-transform: uppercase;
    margin-bottom: 0.4rem;
  }
  .archetype-card-main {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.35rem;
  }
  .archetype-prog-wrap {
    flex: 1;
    height: 3px;
    background: rgba(255,255,255,0.08);
    overflow: hidden;
  }
  .archetype-prog-fill {
    height: 100%;
    background: #c8ff00;
    transition: width 0.4s ease;
  }
  .archetype-fraction {
    font-family: var(--font-head);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--phosphor);
    white-space: nowrap;
  }
  .archetype-coin {
    font-family: var(--font-head);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--text);
  }
  .archetype-conditions {
    font-family: var(--font-head);
    font-size: 0.55rem;
    color: var(--text-dim);
    line-height: 1.4;
    opacity: 0.7;
  }

  /* ─── SYSTEM STATUS ─── */
  .system-ph {
    cursor: pointer;
    user-select: none;
    transition: color 0.2s;
  }
  .system-ph:hover { color: var(--phosphor); }
  .system-healthy {
    font-family: var(--font-head);
    font-size: 0.8rem;
    color: var(--text-dim);
  }
  .system-body { display: none; margin-top: 0.75rem; }
  .system-body.expanded { display: block; }

  /* ─── PIPELINE ─── */
  .agent-pipeline {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-family: var(--font-head);
    font-size: 0.65rem;
    overflow-x: auto;
  }
  .pipeline-stage {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 90px;
  }
  .pipeline-stage-label {
    font-size: 0.45rem;
    letter-spacing: 0.12em;
    color: var(--text-dim);
    text-transform: uppercase;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.15rem;
    margin-bottom: 0.2rem;
  }
  .pipeline-agents {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .pipeline-arrow {
    color: var(--text-dim);
    font-size: 0.8rem;
    padding: 0 0.2rem;
    align-self: center;
    margin-top: 1.2rem;
  }
  .agent-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .agent-dot {
    width: 8px;
    height: 8px;
    display: inline-block;
    flex-shrink: 0;
  }
  .agent-name {
    color: var(--text-dim);
    text-transform: uppercase;
    font-size: 0.6rem;
    letter-spacing: 0.08em;
  }
  .agent-time {
    font-size: 0.55rem;
    color: var(--text-dim);
    opacity: 0.6;
  }

  /* ─── POSITION CARDS ─── */
  .pos-cards {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .pos-card {
    border: 1px solid var(--border);
    border-left: 3px solid #c8ff00;
    padding: 0.75rem 1rem;
    background: rgba(255,255,255,0.02);
    position: relative;
  }
  .pos-card.short-card {
    border-left-color: #ff3333;
  }
  .pos-card-top {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }
  .pos-coin {
    font-family: var(--font-head);
    font-size: 1rem;
    font-weight: 700;
    color: var(--phosphor);
  }
  .pos-dir {
    font-family: var(--font-head);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    padding: 0.15rem 0.4rem;
  }
  .pos-dir.long {
    color: #0a0a0a;
    background: #c8ff00;
  }
  .pos-dir.short {
    color: #fff;
    background: #ff3333;
  }
  .regime-badge {
    font-family: var(--font-head);
    font-size: 0.55rem;
    letter-spacing: 0.08em;
    padding: 0.1rem 0.35rem;
    border: 1px solid;
    text-transform: uppercase;
  }
  .regime-badge.trending { color: #c8ff00; border-color: rgba(200,255,0,0.4); }
  .regime-badge.stable { color: var(--text-dim); border-color: var(--border); }
  .regime-badge.shift { color: #ffb000; border-color: rgba(255,176,0,0.4); }
  .regime-badge.chaotic { color: #ff3333; border-color: rgba(255,51,51,0.4); }
  .pos-pnl {
    margin-left: auto;
    font-family: var(--font-head);
    font-size: 0.95rem;
    font-weight: 700;
  }
  .pos-card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.3rem 1rem;
    margin-bottom: 0.4rem;
  }
  .pos-field {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .pos-fl {
    font-family: var(--font-head);
    font-size: 0.55rem;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    text-transform: uppercase;
  }
  .pos-fv {
    font-family: var(--font-head);
    font-size: 0.8rem;
    color: var(--text);
  }
  .pos-exit {
    margin-top: 0.4rem;
    margin-bottom: 0.4rem;
    font-family: var(--font-body);
    font-size: 0.7rem;
    color: var(--text-dim);
    opacity: 0.85;
  }
  /* hold time progress bar */
  .pos-hold-bar-wrap {
    margin-top: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .pos-hold-track {
    flex: 1;
    height: 2px;
    background: rgba(255,255,255,0.08);
    overflow: hidden;
  }
  .pos-hold-fill {
    height: 100%;
    background: rgba(200,255,0,0.5);
  }
  .pos-hold-label {
    font-family: var(--font-head);
    font-size: 0.55rem;
    color: var(--text-dim);
    white-space: nowrap;
  }

  /* ─── STATS / PERFORMANCE ─── */
  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .stats-panel {
    font-family: var(--font-head);
    font-size: 0.8rem;
  }
  .stats-panel-title {
    font-size: 0.55rem;
    letter-spacing: 0.12em;
    color: var(--text-dim);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid var(--border);
  }
  .coin-stats-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-head);
    font-size: 0.7rem;
  }
  .coin-stats-table th {
    font-size: 0.5rem;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    text-transform: uppercase;
    text-align: left;
    padding: 0.2rem 0.4rem;
    border-bottom: 1px solid var(--border);
    font-weight: 400;
  }
  .coin-stats-table td {
    padding: 0.25rem 0.4rem;
    border-bottom: 1px solid rgba(255,255,255,0.03);
    color: var(--text);
  }
  .coin-stats-table th:not(:first-child),
  .coin-stats-table td:not(:first-child) {
    text-align: right;
  }
  .stat-row {
    display: flex;
    justify-content: space-between;
    padding: 0.3rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.03);
    font-size: 0.7rem;
  }
  .stat-row-label { color: var(--text-dim); }
  .stat-row-value { color: var(--text); font-weight: 700; }

  /* ─── TRADE HISTORY (compact rows) ─── */
  .closed-rows {
    display: flex;
    flex-direction: column;
    font-family: var(--font-head);
    font-size: 0.75rem;
  }
  .closed-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.35rem 0.5rem;
    flex-wrap: nowrap;
    overflow: hidden;
  }
  .closed-row:nth-child(even) {
    background: rgba(255,255,255,0.015);
  }
  .cr-coin {
    font-weight: 700;
    color: var(--phosphor);
    min-width: 40px;
    flex-shrink: 0;
  }
  .cr-dir {
    font-size: 0.65rem;
    font-weight: 700;
    min-width: 36px;
    flex-shrink: 0;
  }
  .cr-prices {
    font-size: 0.65rem;
    color: var(--text-dim);
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .cr-pct {
    font-size: 0.7rem;
    font-weight: 700;
    min-width: 52px;
    text-align: right;
    flex-shrink: 0;
  }
  .cr-pnl {
    font-size: 0.7rem;
    font-weight: 700;
    min-width: 48px;
    text-align: right;
    flex-shrink: 0;
  }
  .cr-reason {
    font-size: 0.55rem;
    color: var(--text-dim);
    opacity: 0.6;
    flex-shrink: 0;
    max-width: 70px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .cr-age {
    font-size: 0.55rem;
    color: var(--text-dim);
    opacity: 0.5;
    flex-shrink: 0;
    min-width: 28px;
    text-align: right;
  }

  /* ─── COLORS ─── */
  .c-pos { color: #c8ff00; }
  .c-neg { color: #ff3333; }
  .c-long { color: #c8ff00; }
  .c-short { color: #ff3333; }

  /* ─── FOOTER ─── */
  .footer {
    display: flex;
    justify-content: space-between;
    padding: 0.5rem 1rem;
    font-family: var(--font-head);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    color: var(--text-dim);
  }
  .footer-link {
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-link:hover { color: var(--phosphor); }

  /* ─── MOBILE ─── */
  @media (max-width: 600px) {
    .page { padding: 0.5rem; }
    .pos-card-grid { grid-template-columns: repeat(2, 1fr); }
    .stats-grid { grid-template-columns: 1fr; }
    .archetype-grid { grid-template-columns: 1fr; }
    .agent-pipeline { gap: 0.3rem; }
    .pipeline-arrow { display: none; }
    .cr-reason { display: none; }
    .cr-prices { max-width: 120px; }
  }
</style>

<script is:inline>
(function(){
  var PORTFOLIO_API = '/api/portfolio.json';
  var PRICE_API = '/api/envy?coins=BTC,ETH,SOL,DOGE,AVAX,LINK,ARB,NEAR,SUI,INJ&indicators=CLOSE_PRICE_15M';

  var portfolioData = null;
  var livePrices = {};
  var lastPriceUpdate = 0;
  var startingEquity = 115;

  function fmt$(v){
    if(v==null) return '—';
    var abs = Math.abs(v);
    var s = abs.toLocaleString('en',{minimumFractionDigits:2,maximumFractionDigits:2});
    return v<0 ? '-$'+s : '$'+s;
  }
  function fmtPct(v){
    if(v==null) return '—';
    return (v>=0?'+':'')+v.toFixed(2)+'%';
  }
  function pnlClass(v){ return v>=0?'c-pos':'c-neg'; }
  function ago(ts){
    var s = Math.floor((Date.now() - ts) / 1000);
    if(s < 5) return 'just now';
    if(s < 60) return s+'s ago';
    if(s < 3600) return Math.floor(s/60)+'m ago';
    return Math.floor(s/3600)+'h ago';
  }
  function agoFromISO(iso){
    if(!iso) return Infinity;
    return (Date.now() - new Date(iso).getTime()) / 1000;
  }
  function getCurrentPrice(coin){ return livePrices[coin] || null; }

  function calcPnl(pos, price){
    if(!price || !pos.entry_price) return {pct:0, dollars:0};
    var pct;
    if(pos.direction === 'LONG'){
      pct = ((price - pos.entry_price) / pos.entry_price) * 100;
    } else {
      pct = ((pos.entry_price - price) / pos.entry_price) * 100;
    }
    var size = pos.size_usd || 0;
    return {pct: pct, dollars: size * (pct / 100)};
  }

  function fmtHold(hours){
    if(!hours && hours !== 0) return '—';
    if(hours < 1) return Math.round(hours * 60) + 'm';
    return hours.toFixed(1) + 'h';
  }

  var riskColors = {green:'#c8ff00',yellow:'#ffb000',orange:'#ff8800',red:'#ff3333'};

  // ─── EXIT EXPRESSION TRANSLATION ───
  function translateExit(expr){
    if(!expr) return '';
    var rules = [
      [/RSI_3H30M\s*>=\s*[\d.]+/g, 'RSI overbought'],
      [/RSI_3H30M\s*<=\s*[\d.]+/g, 'RSI oversold'],
      [/RSI_24H\s*>=\s*[\d.]+/g, 'daily RSI overbought'],
      [/RSI_24H\s*<=\s*[\d.]+/g, 'daily RSI oversold'],
      [/XONE_I_NET\s*<=\s*[\d.]+/g, 'social sentiment drops'],
      [/XONE_I_NET\s*>=\s*[\d.]+/g, 'social sentiment peaks'],
      [/XONE_AVG_NET\s*[<>]=?\s*[\d.-]+/g, 'crowd sentiment shifts'],
      [/HURST_24H\s*<\s*[\d.]+/g, 'trend breaks'],
      [/HURST_24H\s*>\s*[\d.]+/g, 'trend strengthens'],
      [/LYAPUNOV_24H\s*>=\s*[\d.]+/g, 'chaos detected'],
      [/LYAPUNOV_24H\s*<\s*[\d.]+/g, 'chaos subsides'],
      [/ADX_3H30M\s*>=\s*[\d.]+/g, 'trend established'],
      [/ADX_3H30M\s*<\s*[\d.]+/g, 'trend weakens'],
      [/DOJI_VELOCITY\s*<\s*[\d.]+/g, 'indecision resolves'],
      [/DOJI_VELOCITY\s*>=\s*[\d.]+/g, 'indecision spikes'],
      [/EMA_N_24H\s*<\s*[\d.]+/g, 'price below average'],
      [/EMA_N_24H\s*>=?\s*[\d.]+/g, 'price above average'],
      [/EMA_N_48H\s*[<>]=?\s*[\d.]+/g, 'long-term trend shifts'],
      [/BB_POSITION_15M\s*>=\s*[\d.]+/g, 'price hits upper band'],
      [/BB_POSITION_15M\s*<=\s*[\d.]+/g, 'price hits lower band'],
      [/BB_POS_24H\s*>=\s*[\d.]+/g, 'daily upper band hit'],
      [/BB_POS_24H\s*<=\s*[\d.]+/g, 'daily lower band hit'],
      [/MACD_N_24H\s*[<>]=?\s*[\d.-]+/g, 'MACD crosses'],
      [/CMO_3H30M\s*>=\s*[\d.]+/g, 'momentum peaks'],
      [/CMO_3H30M\s*<=\s*[\d.-]+/g, 'momentum drops'],
      [/ROC_24H\s*>=\s*[\d.]+/g, 'rate of change spikes'],
      [/ROC_24H\s*<=\s*[\d.]+/g, 'rate of change drops'],
      [/EMA_CROSS_15M_N\s*[<>]=?\s*[\d.-]+/g, 'EMA crossover'],
      [/CLOSE_PRICE_15M\s*[<>]=?\s*[\d.]+/g, 'price target hit'],
    ];
    var translated = expr;
    for(var i=0; i<rules.length; i++){
      translated = translated.replace(rules[i][0], rules[i][1]);
    }
    // Strip any remaining raw indicator codes
    translated = translated.replace(/[A-Z][A-Z0-9_]{3,}\s*[><=!]+\s*[\d.-]+/g, 'condition met');
    // Clean up dangling OR/AND
    translated = translated.replace(/\bOR\s*$/g, '').replace(/^\s*OR\b/g, '');
    translated = translated.replace(/\bAND\s*$/g, '').replace(/^\s*AND\b/g, '');
    translated = translated.replace(/\s{2,}/g, ' ').trim();
    return translated || expr;
  }

  // ─── EQUITY CURVE ───
  function drawEquityCurve(curve, currentEquity){
    var canvas = document.getElementById('equity-canvas');
    var emptyMsg = document.getElementById('eq-empty');

    if(!curve || curve.length < 2){
      if(canvas) canvas.style.display = 'none';
      if(emptyMsg) emptyMsg.style.display = 'block';
      return;
    }

    // Determine line color based on current equity vs starting
    var lineColor = (currentEquity != null && currentEquity >= startingEquity) ? '#c8ff00' : '#ff3333';
    var fillColor = lineColor === '#c8ff00' ? 'rgba(200,255,0,0.06)' : 'rgba(255,51,51,0.06)';
    var gridColor = 'rgba(200,255,0,0.05)';
    var labelColor = 'rgba(200,255,0,0.25)';

    // Early data: < 10 points
    if(curve.length < 10){
      if(emptyMsg) emptyMsg.style.display = 'none';
      if(canvas){
        canvas.style.display = 'block';
        var dpr0 = window.devicePixelRatio || 1;
        var rect0 = canvas.getBoundingClientRect();
        canvas.width = rect0.width * dpr0;
        canvas.height = rect0.height * dpr0;
        var ctx0 = canvas.getContext('2d');
        ctx0.scale(dpr0, dpr0);
        var W0 = rect0.width;
        var H0 = rect0.height;
        ctx0.clearRect(0, 0, W0, H0);
        var midY0 = H0 / 2;
        ctx0.setLineDash([8, 6]);
        ctx0.strokeStyle = 'rgba(200,255,0,0.3)';
        ctx0.lineWidth = 1;
        ctx0.beginPath();
        ctx0.moveTo(20, midY0);
        ctx0.lineTo(W0 - 20, midY0);
        ctx0.stroke();
        ctx0.setLineDash([]);
        ctx0.fillStyle = 'rgba(200,255,0,0.35)';
        ctx0.font = '11px JetBrains Mono, monospace';
        ctx0.textAlign = 'center';
        ctx0.fillText('$' + startingEquity + ' — COLLECTING DATA', W0 / 2, midY0 - 12);
        ctx0.font = '9px JetBrains Mono, monospace';
        ctx0.fillStyle = 'rgba(200,255,0,0.2)';
        ctx0.fillText(curve.length + ' of 10 points', W0 / 2, midY0 + 16);
      }
      return;
    }

    if(canvas) canvas.style.display = 'block';
    if(emptyMsg) emptyMsg.style.display = 'none';

    var dpr = window.devicePixelRatio || 1;
    var rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    var ctx = canvas.getContext('2d');
    ctx.scale(dpr, dpr);
    var W = rect.width;
    var H = rect.height;
    var pad = {t:16, r:50, b:22, l:10};

    var vals = curve.map(function(p){ return p.v; });
    var minV = Math.min.apply(null, vals);
    var maxV = Math.max.apply(null, vals);
    var range = maxV - minV || 1;
    minV -= range * 0.1;
    maxV += range * 0.1;
    range = maxV - minV;

    var cw = W - pad.l - pad.r;
    var ch = H - pad.t - pad.b;

    // Grid lines
    ctx.strokeStyle = gridColor;
    ctx.lineWidth = 1;
    var gridLines = 4;
    for(var i=0; i<=gridLines; i++){
      var y = pad.t + (ch * i / gridLines);
      ctx.beginPath();
      ctx.moveTo(pad.l, y);
      ctx.lineTo(W - pad.r, y);
      ctx.stroke();
      var val = maxV - (range * i / gridLines);
      ctx.fillStyle = labelColor;
      ctx.font = '9px JetBrains Mono, monospace';
      ctx.textAlign = 'left';
      ctx.fillText('$' + val.toFixed(2), W - pad.r + 4, y + 3);
    }

    // Time labels
    ctx.fillStyle = labelColor;
    ctx.font = '8px JetBrains Mono, monospace';
    ctx.textAlign = 'center';
    var tSteps = Math.min(5, curve.length);
    for(var i=0; i<tSteps; i++){
      var idx = Math.floor(i * (curve.length-1) / (tSteps-1));
      var x = pad.l + (idx / (curve.length-1)) * cw;
      var d = new Date(curve[idx].t);
      ctx.fillText(d.toISOString().slice(11,16), x, H - 4);
    }

    function px(i){ return pad.l + (i / (curve.length-1)) * cw; }
    function py(v){ return pad.t + ch - ((v - minV) / range) * ch; }

    // Area fill
    ctx.beginPath();
    ctx.moveTo(px(0), py(vals[0]));
    for(var i=1; i<vals.length; i++) ctx.lineTo(px(i), py(vals[i]));
    ctx.lineTo(px(vals.length-1), pad.t + ch);
    ctx.lineTo(px(0), pad.t + ch);
    ctx.closePath();
    ctx.fillStyle = fillColor;
    ctx.fill();

    // Line
    ctx.beginPath();
    ctx.moveTo(px(0), py(vals[0]));
    for(var i=1; i<vals.length; i++) ctx.lineTo(px(i), py(vals[i]));
    ctx.strokeStyle = lineColor;
    ctx.lineWidth = 1.5;
    ctx.stroke();

    // Current value dot
    var lastX = px(vals.length-1);
    var lastY = py(vals[vals.length-1]);
    ctx.beginPath();
    ctx.arc(lastX, lastY, 3, 0, Math.PI*2);
    ctx.fillStyle = lineColor;
    ctx.fill();

    var el = document.getElementById('eq-range');
    if(el) el.textContent = curve.length + ' points · $' + (minV+range*0.1).toFixed(2) + ' – $' + (maxV-range*0.1).toFixed(2);
  }

  // ─── MARKET STATE ───
  function renderMarketState(data){
    if(!data || !data.agents) return;
    var agents = data.agents;
    var regimeColors = {trending:'#c8ff00',stable:'#aaa',shift:'#ffb000',chaotic:'#ff3333'};

    // Regime map
    var regimeMap = document.getElementById('regime-map');
    if(regimeMap && agents.regimes && agents.regimes.coins){
      var coins = agents.regimes.coins;
      var html = '';
      for(var coin in coins){
        var regime = (coins[coin].regime || 'stable').toLowerCase();
        var color = regimeColors[regime] || '#aaa';
        var shortName = coin.replace('USDT','').replace('PERP','').slice(0,3);
        html += '<div class="regime-coin-wrap">';
        html += '<span class="regime-dot" style="background:'+color+'"></span>';
        html += '<span class="regime-coin-name">'+shortName+'</span>';
        html += '</div>';
      }
      regimeMap.innerHTML = html || '<span class="muted">No regime data</span>';
    }

    // Exception-only status line
    var statusLine = document.getElementById('status-line');
    if(statusLine){
      var spreadOk = true;
      var fundingOk = true;
      var spreadIssues = [];
      var fundingIssues = [];

      if(agents.spread && agents.spread.coins){
        for(var sc in agents.spread.coins){
          var st = agents.spread.coins[sc];
          if(st && st.status && st.status.toLowerCase() !== 'normal'){
            spreadOk = false;
            var shortSC = sc.replace('USDT','').replace('PERP','').slice(0,4);
            spreadIssues.push(shortSC);
          }
        }
      }
      if(agents.funding && agents.funding.coins){
        for(var fc in agents.funding.coins){
          var fd = agents.funding.coins[fc];
          if(fd && fd.velocity_direction && fd.velocity_direction !== 'stable'){
            fundingOk = false;
            var shortFC = fc.replace('USDT','').replace('PERP','').slice(0,4);
            fundingIssues.push(shortFC+'('+fd.velocity_direction+')');
          }
        }
      }

      var sHtml = '';
      if(spreadOk){
        sHtml += '<span class="status-ok">Spreads ✓</span>';
      } else {
        sHtml += '<span class="status-warn">Spreads: '+spreadIssues.join(', ')+'</span>';
      }
      if(fundingOk){
        sHtml += '<span class="status-ok">Funding ✓</span>';
      } else {
        sHtml += '<span class="status-warn">Funding: '+fundingIssues.join(', ')+'</span>';
      }
      statusLine.innerHTML = sHtml;
    }
  }

