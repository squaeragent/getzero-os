---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="ZERO OS — Live Portfolio" description="Paper trading portfolio powered by 300+ signals across 10 coins. Updated every 15 minutes.">
  <div class="page">
    <div class="terminal-border">

      <!-- HERO -->
      <div class="hero-pane">
        <div class="ph">◇ ZERO OS PORTFOLIO — <span class="live-dot">●</span> LIVE</div>
        <div class="hero-body">
          <div class="stats-row" id="stats-row">
            <div class="stat">
              <span class="sl">VALUE</span>
              <span class="sv big" id="s-value">$10,000</span>
            </div>
            <div class="stat">
              <span class="sl">P&L</span>
              <span class="sv" id="s-pnl">—</span>
            </div>
            <div class="stat">
              <span class="sl">WIN RATE</span>
              <span class="sv" id="s-winrate">—</span>
            </div>
            <div class="stat">
              <span class="sl">TRADES</span>
              <span class="sv" id="s-trades">0</span>
            </div>
            <div class="stat">
              <span class="sl">DAYS</span>
              <span class="sv" id="s-days">1</span>
            </div>
          </div>
          <p class="hero-sub">Paper trading $10,000 with autonomous signal detection. Every position backed by backtested entry/exit rules. Updated every 15 minutes.</p>
        </div>
      </div>

      <!-- OPEN POSITIONS -->
      <div class="section">
        <div class="ph">OPEN POSITIONS <span class="dim" id="pos-count">(0)</span></div>
        <div class="sb" id="positions-body">
          <div class="muted">Fetching live data...</div>
        </div>
      </div>

      <!-- RECENT SIGNALS -->
      <div class="section">
        <div class="ph">SIGNAL FEED <span class="dim">last 20 fires</span></div>
        <div class="sb" id="fires-body">
          <div class="muted">Fetching live data...</div>
        </div>
      </div>

      <!-- CLOSED TRADES -->
      <div class="section">
        <div class="ph">CLOSED TRADES <span class="dim" id="closed-count">(0)</span></div>
        <div class="sb" id="closed-body">
          <div class="muted">Fetching live data...</div>
        </div>
      </div>

      <!-- FOOTER -->
      <div class="footer">
        <span>◇ ZERO OS</span>
        <span class="dim" id="updated">—</span>
      </div>

    </div>
  </div>
</BaseLayout>

<style is:global>
  /* ─── PAGE ─── */
  .page {
    max-width: 900px;
    margin: 0 auto;
    padding: 1rem;
    min-height: 100vh;
  }
  .terminal-border {
    border: 1px solid rgba(200,255,0,0.4);
    min-height: 100vh;
  }

  /* ─── SECTION HEADERS ─── */
  .ph {
    font-family: var(--font-head);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
    padding: 0.5rem 1rem;
    border-bottom: 1px solid var(--border);
    background: rgba(0,0,0,0.6);
  }
  .section {
    border-bottom: 1px solid var(--border);
  }
  .sb {
    padding: 0.75rem 1rem;
  }
  .dim { opacity: 0.5; font-size: 0.6rem; }
  .muted {
    font-family: var(--font-head);
    font-size: 0.75rem;
    color: var(--text-dim);
    opacity: 0.4;
  }

  /* ─── HERO ─── */
  .hero-pane { border-bottom: 1px solid var(--border); }
  .live-dot {
    color: #c8ff00;
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }
  .hero-body { padding: 1.25rem 1rem; }
  .stats-row {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }
  .stat { display: flex; flex-direction: column; gap: 0.15rem; }
  .sl {
    font-family: var(--font-head);
    font-size: 0.55rem;
    letter-spacing: 0.15em;
    color: var(--text-dim);
    text-transform: uppercase;
  }
  .sv {
    font-family: var(--font-head);
    font-size: 1.2rem;
    color: var(--phosphor);
    font-weight: 700;
  }
  .sv.big { font-size: 1.5rem; }
  .hero-sub {
    font-family: var(--font-body);
    font-size: 0.8rem;
    line-height: 1.6;
    color: var(--text-dim);
    margin: 0;
    max-width: 600px;
  }

  /* ─── POSITION CARDS ─── */
  .pos-cards {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .pos-card {
    border: 1px solid var(--border);
    padding: 0.75rem 1rem;
    background: rgba(255,255,255,0.02);
  }
  .pos-card-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  .pos-coin {
    font-family: var(--font-head);
    font-size: 1rem;
    font-weight: 700;
    color: var(--phosphor);
  }
  .pos-dir {
    font-family: var(--font-head);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    padding: 0.15rem 0.4rem;
    border-radius: 2px;
  }
  .pos-dir.long {
    color: #0a0a0a;
    background: #c8ff00;
  }
  .pos-dir.short {
    color: #fff;
    background: #cc4422;
  }
  .pos-rarity {
    font-family: var(--font-head);
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    padding: 0.1rem 0.35rem;
    border-radius: 2px;
    border: 1px solid;
  }
  .pos-rarity.trump { color: #ffb000; border-color: rgba(255,176,0,0.4); }
  .pos-rarity.rare { color: #00d4ff; border-color: rgba(0,212,255,0.4); }
  .pos-rarity.common { color: var(--text-dim); border-color: var(--border); }
  .pos-pnl {
    margin-left: auto;
    font-family: var(--font-head);
    font-size: 1rem;
    font-weight: 700;
  }
  .pos-card-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.25rem 1rem;
  }
  .pos-field {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .pos-fl {
    font-family: var(--font-head);
    font-size: 0.5rem;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    text-transform: uppercase;
  }
  .pos-fv {
    font-family: var(--font-head);
    font-size: 0.8rem;
    color: var(--text);
  }

  /* ─── SIGNAL FEED ─── */
  .fire-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .fire-row {
    display: grid;
    grid-template-columns: 140px 50px 55px 1fr auto auto;
    gap: 0.5rem;
    padding: 0.35rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.03);
    align-items: center;
    font-family: var(--font-head);
    font-size: 0.7rem;
  }
  .fire-time { color: var(--text-dim); font-size: 0.6rem; }
  .fire-coin { color: var(--phosphor); font-weight: 700; }
  .fire-name {
    color: var(--text-dim);
    font-size: 0.6rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .fire-sharpe { color: var(--text); text-align: right; }
  .fire-wr { color: var(--text-dim); text-align: right; }

  /* ─── CLOSED TRADES ─── */
  .closed-cards {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .closed-card {
    display: grid;
    grid-template-columns: 50px 55px 1fr auto;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border);
    background: rgba(255,255,255,0.02);
    align-items: center;
    font-family: var(--font-head);
    font-size: 0.75rem;
  }
  .closed-coin { color: var(--phosphor); font-weight: 700; }
  .closed-detail {
    font-size: 0.6rem;
    color: var(--text-dim);
  }
  .closed-pnl {
    font-weight: 700;
    font-size: 0.85rem;
    text-align: right;
  }
  .closed-sub {
    font-size: 0.6rem;
    color: var(--text-dim);
    text-align: right;
  }

  /* ─── COLORS ─── */
  .c-pos { color: #c8ff00; }
  .c-neg { color: #ff3333; }
  .c-long { color: #c8ff00; }
  .c-short { color: #cc4422; }

  /* ─── FOOTER ─── */
  .footer {
    display: flex;
    justify-content: space-between;
    padding: 0.5rem 1rem;
    font-family: var(--font-head);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    color: var(--text-dim);
  }

  /* ─── MOBILE ─── */
  @media (max-width: 600px) {
    .page { padding: 0.5rem; }
    .stats-row { gap: 1.2rem; }
    .sv { font-size: 1rem; }
    .sv.big { font-size: 1.3rem; }
    .pos-card-grid { grid-template-columns: repeat(2, 1fr); }
    .fire-row {
      grid-template-columns: 1fr;
      gap: 0.15rem;
      padding: 0.5rem 0;
    }
    .fire-row > * { text-align: left !important; }
    .closed-card {
      grid-template-columns: 1fr 1fr;
      gap: 0.3rem;
    }
  }
</style>

<script is:inline>
(async function(){
  const API = '/api/portfolio.json';

  function fmt$(v){
    if(v==null) return '—';
    const abs = Math.abs(v);
    const s = abs.toLocaleString('en',{minimumFractionDigits:2,maximumFractionDigits:2});
    return v<0 ? '-$'+s : '$'+s;
  }
  function fmtPct(v){
    if(v==null) return '—';
    return (v>=0?'+':'')+v.toFixed(2)+'%';
  }
  function fmtTime(iso){
    if(!iso) return '—';
    return new Date(iso).toISOString().replace('T',' ').slice(5,16)+' UTC';
  }
  function fmtTimeFull(iso){
    if(!iso) return '—';
    return new Date(iso).toISOString().replace('T',' ').slice(0,16)+' UTC';
  }
  function rarityClass(r){
    if(!r) return 'common';
    return r.toLowerCase();
  }
  function pnlClass(v){ return v>=0?'c-pos':'c-neg'; }

  async function load(){
    try {
      const res = await fetch(API);
      const d = await res.json();
      if(!d.live) return;

      const s = d.summary;

      // Stats
      document.getElementById('s-value').textContent = fmt$(s.currentValue);
      const pnlEl = document.getElementById('s-pnl');
      pnlEl.textContent = fmtPct(s.pnlPct) + ' (' + fmt$(s.pnl) + ')';
      pnlEl.className = 'sv ' + pnlClass(s.pnl);
      document.getElementById('s-winrate').textContent = s.winRate!==null ? s.winRate+'%' : '—';
      document.getElementById('s-trades').textContent = s.totalTrades;
      document.getElementById('s-days').textContent = s.daysRunning;
      document.getElementById('pos-count').textContent = '('+s.openPositions+')';
      document.getElementById('closed-count').textContent = '('+s.totalTrades+')';
      document.getElementById('updated').textContent = 'Updated: '+fmtTimeFull(d.updated);

      // ─── OPEN POSITIONS (cards) ───
      const posBody = document.getElementById('positions-body');
      if(!d.positions || d.positions.length===0){
        posBody.innerHTML = '<div class="muted">No open positions. Scanning every 15 minutes.</div>';
      } else {
        let html = '<div class="pos-cards">';
        for(const p of d.positions){
          const dirCls = p.direction==='LONG' ? 'long' : 'short';
          const rarCls = rarityClass(p.rarity);
          html += '<div class="pos-card">';
          html += '<div class="pos-card-top">';
          html += '<span class="pos-coin">'+p.coin+'</span>';
          html += '<span class="pos-dir '+dirCls+'">'+p.direction+'</span>';
          html += '<span class="pos-rarity '+rarCls+'">'+(p.rarity||'—')+'</span>';
          html += '</div>';
          html += '<div class="pos-card-grid">';
          html += '<div class="pos-field"><span class="pos-fl">Entry</span><span class="pos-fv">'+fmt$(p.entry_price)+'</span></div>';
          html += '<div class="pos-field"><span class="pos-fl">Size</span><span class="pos-fv">'+fmt$(p.size)+'</span></div>';
          html += '<div class="pos-field"><span class="pos-fl">Sharpe</span><span class="pos-fv">'+(p.sharpe||0).toFixed(2)+'</span></div>';
          html += '<div class="pos-field"><span class="pos-fl">Win Rate</span><span class="pos-fv">'+(p.win_rate||0).toFixed(0)+'%</span></div>';
          html += '</div>';
          html += '</div>';
        }
        html += '</div>';
        posBody.innerHTML = html;
      }

      // ─── SIGNAL FEED (compact rows) ───
      const firesBody = document.getElementById('fires-body');
      const fires = (d.recentFires||[]).slice().reverse();
      if(fires.length===0){
        firesBody.innerHTML = '<div class="muted">No signals fired yet.</div>';
      } else {
        let html = '<div class="fire-list">';
        for(const f of fires){
          const name = (f.signal||'').replace(/_/g,' ').toLowerCase().slice(0,45);
          const dirCls = f.direction==='LONG' ? 'c-long' : 'c-short';
          html += '<div class="fire-row">';
          html += '<span class="fire-time">'+fmtTime(f.time)+'</span>';
          html += '<span class="fire-coin">'+f.coin+'</span>';
          html += '<span class="'+dirCls+'">'+f.direction+'</span>';
          html += '<span class="fire-name">'+name+'</span>';
          html += '<span class="fire-sharpe">S '+(f.sharpe||0).toFixed(2)+'</span>';
          html += '<span class="fire-wr">'+(f.win_rate||0).toFixed(0)+'%</span>';
          html += '</div>';
        }
        html += '</div>';
        firesBody.innerHTML = html;
      }

      // ─── CLOSED TRADES (cards) ───
      const closedBody = document.getElementById('closed-body');
      const closed = (d.closed||[]).slice().reverse();
      if(closed.length===0){
        closedBody.innerHTML = '<div class="muted">No trades closed yet. Positions exit when signal conditions trigger or max hold time expires.</div>';
      } else {
        let html = '<div class="closed-cards">';
        for(const c of closed){
          const dirCls = c.direction==='LONG' ? 'c-long' : 'c-short';
          html += '<div class="closed-card">';
          html += '<span class="closed-coin">'+c.coin+'</span>';
          html += '<span class="'+dirCls+'">'+c.direction+'</span>';
          html += '<span class="closed-detail">'+fmt$(c.entry_price)+' → '+fmt$(c.exit_price)+' · '+(c.hours_held||0)+'h · '+c.exit_reason+'</span>';
          html += '<div><div class="closed-pnl '+pnlClass(c.pnl_pct)+'">'+fmtPct(c.pnl_pct)+'</div><div class="closed-sub">'+fmt$(c.pnl_dollars)+'</div></div>';
          html += '</div>';
        }
        html += '</div>';
        closedBody.innerHTML = html;
      }

    } catch(e) {
      console.error('Portfolio fetch failed:', e);
    }
  }

  load();
  setInterval(load, 60000);
})();
</script>
