  // ─── STATS DASHBOARD ───
  function renderStats(stats){
    var section = document.getElementById('stats-section');
    var el = document.getElementById('stats-dashboard');
    var dirCards = document.getElementById('dir-cards');
    if(!el || !section) return;
    if(!stats || !stats.total || stats.total < 5){
      section.style.display = 'none';
      return;
    }
    section.style.display = 'block';

    // ── LONG / SHORT prominent cards ──
    if(dirCards){
      var longPnl = stats.longPnl != null ? stats.longPnl : null;
      var shortPnl = stats.shortPnl != null ? stats.shortPnl : null;
      var longWR = stats.longWinRate != null ? stats.longWinRate.toFixed(0)+'%' : '—';
      var shortWR = stats.shortWinRate != null ? stats.shortWinRate.toFixed(0)+'%' : '—';
      var longCount = stats.longCount || 0;
      var shortCount = stats.shortCount || 0;
      // Color follows P&L, not direction
      var longWRcls = longPnl >= 0 ? 'c-pos' : 'c-neg';
      var shortWRcls = shortPnl >= 0 ? 'c-pos' : 'c-neg';
      var lh = '<div class="dir-card">';
      lh += '<div class="dir-card-label">Long</div>';
      lh += '<div class="dir-card-big '+longWRcls+'">'+longWR+'</div>';
      lh += '<div class="dir-card-pnl '+pnlClass(longPnl)+'">'+(longPnl != null ? fmt$(longPnl) : '—')+'</div>';
      lh += '<div class="dir-card-meta">'+longCount+' trades</div>';
      lh += '</div>';
      var sh = '<div class="dir-card">';
      sh += '<div class="dir-card-label">Short</div>';
      sh += '<div class="dir-card-big '+shortWRcls+'">'+shortWR+'</div>';
      sh += '<div class="dir-card-pnl '+pnlClass(shortPnl)+'">'+(shortPnl != null ? fmt$(shortPnl) : '—')+'</div>';
      sh += '<div class="dir-card-meta">'+shortCount+' trades</div>';
      sh += '</div>';
      dirCards.innerHTML = lh + sh;
    }

    // ── P&L by coin table — sorted by absolute P&L desc ──
    var left = '<div class="stats-panel">';
    left += '<div class="stats-panel-title">P&L by coin</div>';
    left += '<table class="coin-stats-table"><thead><tr><th>Coin</th><th>Trades</th><th>WR%</th><th>P&L</th></tr></thead><tbody>';
    var coins = stats.byCoin || {};
    var coinKeys = Object.keys(coins).sort(function(a,b){
      return Math.abs(coins[b].pnl||0) - Math.abs(coins[a].pnl||0);
    });
    var COIN_LIMIT = 8;
    var showAllCoins = window._showAllCoins || false;
    var visibleCoins = showAllCoins ? coinKeys.length : Math.min(COIN_LIMIT, coinKeys.length);
    for(var i=0; i<visibleCoins; i++){
      var c = coinKeys[i];
      var s = coins[c];
      var pnlCls = pnlClass(s.pnl);
      left += '<tr>';
      left += '<td style="font-weight:700">'+c+'</td>';
      left += '<td>'+s.trades+'</td>';
      left += '<td>'+(s.winRate != null ? s.winRate.toFixed(0)+'%' : '—')+'</td>';
      left += '<td class="'+pnlCls+'" style="font-weight:700">'+fmt$(s.pnl)+'</td>';
      left += '</tr>';
    }
    left += '</tbody></table>';
    if(coinKeys.length > COIN_LIMIT){
      left += '<div class="show-all-toggle" id="coin-toggle" style="margin-top:0.5rem">'+(showAllCoins ? 'show less' : 'show all ('+(coinKeys.length - COIN_LIMIT)+' more)')+'</div>';
    }
    left += '</div>';

    var right = '<div class="stats-panel">';
    right += '<div class="stats-panel-title">Breakdown</div>';
    var best = stats.bestTrade || {};
    var worst = stats.worstTrade || {};
    right += '<div class="stat-row"><span class="stat-row-label">Best Trade</span><span class="stat-row-value c-pos">'+(best.coin||'—')+' '+(best.direction||'')+' '+fmtPct(best.pnlPct * 100)+' ('+fmt$(best.pnl)+')</span></div>';
    right += '<div class="stat-row"><span class="stat-row-label">Worst Trade</span><span class="stat-row-value c-neg">'+(worst.coin||'—')+' '+(worst.direction||'')+' '+fmtPct(worst.pnlPct * 100)+' ('+fmt$(worst.pnl)+')</span></div>';
    right += '<div class="stat-row"><span class="stat-row-label">Avg Hold</span><span class="stat-row-value">'+fmtHold(stats.avgHoldHours)+'</span></div>';
    right += '<div class="stat-row"><span class="stat-row-label">Avg P&L</span><span class="stat-row-value '+pnlClass(stats.avgPnl)+'">'+fmt$(stats.avgPnl)+'</span></div>';
    right += '<div class="stat-row"><span class="stat-row-label">Total P&L</span><span class="stat-row-value '+pnlClass(stats.totalPnl)+'">'+fmt$(stats.totalPnl)+'</span></div>';
    right += '</div>';

    el.innerHTML = left + right;
    var coinToggle = document.getElementById('coin-toggle');
    if(coinToggle){
      coinToggle.onclick = function(){
        window._showAllCoins = !window._showAllCoins;
        renderStats(stats);
      };
    }
  }

  // ─── CLOSED TRADES RENDERER ─── (issues 3, 10)
  var showAllClosed = false;

  function buildClosedHtml(trades, limit){
    if(!trades || trades.length === 0) return '<div class="muted">No closed trades yet.</div>';
    var html = '<div class="closed-rows">';
    var shown = limit ? trades.slice(0, limit) : trades;
    for(var j=0; j<shown.length; j++){
      var c = shown[j];
      var dirCls2 = c.direction === 'LONG' ? 'c-long' : 'c-short';
      var pnlVal = c.pnl_usd || c.pnl_dollars || 0;
      // Hold duration from entry→exit
      var holdStr = '';
      if(c.entry_time && c.exit_time){
        var holdMs = new Date(c.exit_time).getTime() - new Date(c.entry_time).getTime();
        holdStr = fmtHold(Math.round(holdMs / 360000) / 10);
      }
      // Relative time since exit (issue 10)
      var exitAge = '';
      if(c.exit_time){
        exitAge = ago(new Date(c.exit_time).getTime());
      }
      html += '<div class="closed-row">';
      html += '<span class="cr-coin">'+c.coin+'</span>';
      html += '<span class="cr-dir '+dirCls2+'">'+c.direction+'</span>';
      html += '<span class="cr-prices">'+fmtPrice(c.entry_price)+'→'+fmtPrice(c.exit_price)+'</span>';
      // Use dollar P&L as single source of truth for color on both % and $
      html += '<span class="cr-pct '+pnlClass(pnlVal)+'">'+fmtPct(c.pnl_pct * 100)+'</span>';
      html += '<span class="cr-pnl '+pnlClass(pnlVal)+'">'+fmt$(pnlVal)+'</span>';
      html += '<span class="cr-reason">'+(c.exit_reason||'')+'</span>';
      // Show exit age first, then hold duration if available
      html += '<span class="cr-age">'+(exitAge||holdStr||'')+'</span>';
      html += '</div>';
    }
    html += '</div>';
    return html;
  }

  function renderClosedTrades(rawClosed){
    var closedBody = document.getElementById('closed-body');
    var toggle = document.getElementById('show-all-toggle');
    if(!closedBody) return;

    // Deduplicate by trade id or coin+entry_price+entry_time combo
    var seen = {};
    var deduped = [];
    for(var i=0; i<rawClosed.length; i++){
      var t = rawClosed[i];
      var key = t.id || (t.coin + '|' + t.entry_price + '|' + t.entry_time + '|' + (t.exit_time||'') + '|' + (t.exit_price||''));
      if(!seen[key]){
        seen[key] = true;
        deduped.push(t);
      }
    }

    // Most recent first — data arrives from Supabase in exit_time.desc order already
    var sorted = deduped.slice();

    var total = sorted.length;
    var DEFAULT_LIMIT = 10;

    if(toggle){
      if(total > DEFAULT_LIMIT){
        toggle.style.display = 'inline';
        toggle.textContent = showAllClosed ? 'show less' : 'show all (' + (total - DEFAULT_LIMIT) + ' more)';
        toggle.onclick = function(){
          showAllClosed = !showAllClosed;
          renderClosedTrades(rawClosed);
        };
      } else {
        toggle.style.display = 'none';
      }
    }

    var limit = (showAllClosed || total <= DEFAULT_LIMIT) ? null : DEFAULT_LIMIT;
    closedBody.innerHTML = buildClosedHtml(sorted, limit);
  }

  // ─── MAIN RENDER ───
  function render(){
    var d = portfolioData;
    if(!d) return;

    var lt = d.liveTrading;
    if(!lt || !lt.enabled) return;

    var livePos = lt.positions || [];
    var liveClosed = lt.closed || [];
    var regimes = d.agents && d.agents.regimes;

    // Compute unrealized P&L
    var totalUnrealized = 0;
    for(var i=0; i<livePos.length; i++){
      var price = getCurrentPrice(livePos[i].coin);
      if(price){
        var r = calcPnl(livePos[i], price);
        totalUnrealized += r.dollars;
      }
    }

    // Compute realized P&L from closed trades
    var totalRealized = 0;
    for(var i=0; i<liveClosed.length; i++){
      totalRealized += liveClosed[i].pnl_usd || liveClosed[i].pnl_dollars || 0;
    }

    // Use latest equity snapshot if available (accurate — reads real HL balance)
    var eqCurve = d.liveEquityCurve || [];
    var latestSnapshot = eqCurve.length > 0 ? eqCurve[eqCurve.length - 1] : null;
    var equity = latestSnapshot ? (latestSnapshot.v || (startingEquity + totalRealized + totalUnrealized)) : (startingEquity + totalRealized + totalUnrealized);
    var totalPnl = equity - startingEquity;
    var pnlPct = startingEquity > 0 ? (totalPnl / startingEquity) * 100 : 0;

    // Uptime — show time since first trade (oldest closed trade entry_time)
    var uptimeStr = '—';
    (function(){
      var oldest = null;
      // Find oldest trade entry time across all trades
      for(var _j=0; _j<liveClosed.length; _j++){
        if(liveClosed[_j].entry_time){
          var _ms2 = new Date(liveClosed[_j].entry_time).getTime();
          if(!oldest || _ms2 < oldest) oldest = _ms2;
        }
      }
      for(var _i=0; _i<livePos.length; _i++){
        var _et = livePos[_i].entry_time;
        if(_et){
          var _ms = new Date(_et).getTime();
          if(!oldest || _ms < oldest) oldest = _ms;
        }
      }
      if(oldest){
        var _totalMs = Date.now() - oldest;
        var _totalH = Math.round(_totalMs / 3600000);
        if(_totalH < 1){
          var _totalMin = Math.round(_totalMs / 60000);
          uptimeStr = _totalMin + 'min';
        } else if(_totalH < 24){
          uptimeStr = _totalH + 'h';
        } else {
          uptimeStr = Math.floor(_totalH/24) + 'd ' + (_totalH%24) + 'h';
        }
      }
    })();

    var trades = lt.trades || 0;
    var wins = lt.wins || 0;

    // Equity hero
    var eqNumEl = document.getElementById('eq-number');
    if(eqNumEl) eqNumEl.textContent = fmt$(equity);

    var pnlEl = document.getElementById('eq-pnl');
    if(pnlEl){
      pnlEl.textContent = fmtPct(pnlPct) + ' (' + fmt$(totalPnl) + ')';
      pnlEl.style.color = totalPnl >= 0 ? '#c8ff00' : '#ff3333';
    }

    // Realized P&L — only closed trades, only real money
    var realizedEl = document.getElementById('eq-realized');
    if(realizedEl){
      realizedEl.textContent = 'REALIZED P&L: ' + fmt$(totalRealized);
      realizedEl.style.color = totalRealized >= 0 ? 'rgba(200,255,0,0.6)' : 'rgba(255,51,51,0.6)';
    }

    var metaEl = document.getElementById('eq-meta');
    if(metaEl) metaEl.textContent = trades + ' trades · ' + uptimeStr + ' uptime';

    // Early data badge
    var earlyBadge = document.getElementById('early-badge');
    if(earlyBadge) earlyBadge.style.display = (trades < 20) ? 'inline' : 'none';

    // Risk badge
    var risk = d.agents && d.agents.risk;
    if(risk){
      var badge = document.getElementById('risk-badge');
      var st = (risk.status||'green').toLowerCase();
      var col = riskColors[st] || '#c8ff00';
      badge.textContent = 'RISK: ' + st.toUpperCase();
      badge.style.color = st === 'green' ? '#0a0a0a' : '#fff';
      badge.style.background = col;
    }

    document.getElementById('pos-count').textContent = '(' + livePos.length + ')';
    document.getElementById('closed-count').textContent = '(' + liveClosed.length + ')';
    document.getElementById('updated').textContent = lastPriceUpdate ? 'Prices: ' + ago(lastPriceUpdate) : 'Loading prices...';

    // Build trade events for chart markers
    var tradeEvents = [];
    for(var ti=0; ti<liveClosed.length; ti++){
      var tc = liveClosed[ti];
      var exitMs = tc.exit_time ? new Date(tc.exit_time).getTime() : 0;
      if(exitMs) tradeEvents.push({t: exitMs, type: 'close', pnl: tc.pnl_usd || tc.pnl_dollars || 0, coin: tc.coin});
    }
    for(var pi=0; pi<livePos.length; pi++){
      var pp = livePos[pi];
      var entryMs = pp.entry_time ? new Date(pp.entry_time).getTime() : 0;
      if(entryMs) tradeEvents.push({t: entryMs, type: 'entry', coin: pp.coin});
    }

    // Equity curve
    drawEquityCurve(d.liveEquityCurve, equity, tradeEvents);

    // System status
    renderSystemStatus(d.agents);

    // Pipeline (inside collapsed body)
    renderAgents(d.agents);

    // Market state
    renderMarketState(d);

    // Cognitive dashboard features
    renderDecisionStream();
    renderFunnel();
    renderLandscape();
    renderImmune();

    // Stats
    renderStats(lt.stats);

    // ─── OPEN POSITIONS ───
    var posBody = document.getElementById('positions-body');
    if(livePos.length === 0){
      posBody.innerHTML = '<div class="muted">No open positions.</div>';
    } else {
      var html = '<div class="pos-cards">';
      for(var i=0; i<livePos.length; i++){
        var p = livePos[i];
        var isLong = p.direction === 'LONG';
        var dirCls = isLong ? 'long' : 'short';
        var cardCls = isLong ? '' : ' short-card';
        var curPrice = getCurrentPrice(p.coin);
        var pnlResult = curPrice ? calcPnl(p, curPrice) : {pct:null, dollars:null};
        var coinRegime = regimes && regimes.coins && regimes.coins[p.coin];
        var regimeStr = coinRegime ? coinRegime.regime : '';

        // Stop loss display
        var stopDisplay = '—';
        if(p.stop_loss && p.entry_price){
          var stopPct = isLong
            ? ((p.stop_loss - p.entry_price) / p.entry_price * 100)
            : ((p.entry_price - p.stop_loss) / p.entry_price * 100);
          stopDisplay = fmt$(p.stop_loss) + ' (' + stopPct.toFixed(1) + '%)';
        } else if(p.stop_loss){
          stopDisplay = fmt$(p.stop_loss);
        }

        // Hold time progress bar
        var holdPct = 0;
        var holdLabel = '—';
        var maxHoldH = p.max_hold_hours || 24;
        if(p.entry_time){
          var entryMs = new Date(p.entry_time).getTime();
          var holdMs = Date.now() - entryMs;
          var holdH = holdMs / 3600000;
          holdPct = Math.min(100, (holdH / maxHoldH) * 100);
          holdLabel = fmtHold(holdH) + ' / ' + maxHoldH + 'h max';
        } else if(p.entry_time_ms){
          var holdMs2 = Date.now() - p.entry_time_ms;
          var holdH2 = holdMs2 / 3600000;
          holdPct = Math.min(100, (holdH2 / maxHoldH) * 100);
          holdLabel = fmtHold(holdH2) + ' / ' + maxHoldH + 'h max';
        }

        // Signal name — humanize from internal identifiers
        var signalRaw = p.signal_type || p.archetype || p.strategy || '';
        var signalName = humanizeSignal(signalRaw);

        html += '<div class="pos-card'+cardCls+'">';
        html += '<div class="pos-card-top">';
        html += '<span class="pos-coin">'+p.coin+'</span>';
        html += '<span class="pos-dir '+dirCls+'">'+p.direction+'</span>';
        if(regimeStr) html += '<span class="regime-badge '+regimeStr+'">'+regimeStr+'</span>';
        if(pnlResult.pct !== null){
          html += '<span class="pos-pnl '+pnlClass(pnlResult.pct)+'">'+fmtPct(pnlResult.pct)+' ('+fmt$(pnlResult.dollars)+')</span>';
        }
        html += '</div>';

        html += '<div class="pos-card-grid">';
        html += '<div class="pos-field"><span class="pos-fl">Entry</span><span class="pos-fv">'+fmt$(p.entry_price)+'</span></div>';
        html += '<div class="pos-field"><span class="pos-fl">Now</span><span class="pos-fv">'+(curPrice ? fmt$(curPrice) : '—')+'</span></div>';
        html += '<div class="pos-field"><span class="pos-fl">Size</span><span class="pos-fv">'+fmt$(p.size_usd)+'</span></div>';
        html += '<div class="pos-field"><span class="pos-fl">Stop</span><span class="pos-fv c-neg">'+stopDisplay+'</span></div>';
        html += '<div class="pos-field"><span class="pos-fl">Sharpe</span><span class="pos-fv">'+(p.sharpe != null ? p.sharpe.toFixed(2) : '—')+'</span></div>';
        if(signalName) html += '<div class="pos-field"><span class="pos-fl">Signal</span><span class="pos-fv">'+signalName+'</span></div>';
        html += '</div>';

        if(p.exit_expression){
          var translated = translateExit(p.exit_expression);
          html += '<div class="pos-exit">Exit: '+translated+'</div>';
        } else {
          html += '<div class="pos-exit">Exit: stop loss or max hold</div>';
        }

        if(holdLabel !== '—'){
          html += '<div class="pos-hold-bar-wrap">';
          html += '<div class="pos-hold-track"><div class="pos-hold-fill" style="width:'+holdPct.toFixed(1)+'%"></div></div>';
          html += '<span class="pos-hold-label">'+holdLabel+'</span>';
          html += '</div>';
        }

        html += '</div>';
      }
      html += '</div>';
      posBody.innerHTML = html;
    }

    // ─── TRADE HISTORY (compact rows) ─── issues 3, 10 ───
    renderClosedTrades(liveClosed);
  }

  // ─── DATA FETCHING ───
  function fetchPrices(){
    return fetch(PRICE_API).then(function(res){ return res.json(); }).then(function(d){
      if(d.matrix){
        for(var coin in d.matrix){
          if(d.matrix[coin].CLOSE_PRICE_15M != null){
            livePrices[coin] = d.matrix[coin].CLOSE_PRICE_15M;
          }
        }
      }
      lastPriceUpdate = Date.now();
    }).catch(function(e){ console.error('Price fetch failed:', e); });
  }

  function loadPortfolio(){
    return fetchPortfolioData().then(function(d){
      portfolioData = d;
    }).catch(function(supaErr){
      console.warn('API fetch failed, falling back to portfolio.json:', supaErr);
      return fetch(PORTFOLIO_API).then(function(res){ return res.json(); }).then(function(d){
        portfolioData = d;
      }).catch(function(e){ console.error('Fallback portfolio fetch failed:', e); });
    });
  }

  // ─── SYSTEM STATUS TOGGLE ───
  document.addEventListener('DOMContentLoaded', function(){
    var ph = document.getElementById('system-ph');
    var body = document.getElementById('system-body');
    if(ph && body){
      ph.addEventListener('click', function(){
        body.classList.toggle('expanded');
      });
    }
  });

  function buildPriceUrl(){
    var coins = BASE_PRICE_COINS.slice();
    if(portfolioData && portfolioData.liveTrading){
      var positions = portfolioData.liveTrading.positions || [];
      for(var i=0; i<positions.length; i++){
        var c = positions[i].coin;
        if(coins.indexOf(c) === -1) coins.push(c);
      }
    }
    // Envy API max 10 coins per request
    return API_BASE + '/prices?coins=' + coins.slice(0, 10).join(',');
  }

  function fetchAllPrices(){
    var coins = BASE_PRICE_COINS.slice();
    if(portfolioData && portfolioData.liveTrading){
      var positions = portfolioData.liveTrading.positions || [];
      for(var i=0; i<positions.length; i++){
        var c = positions[i].coin;
        if(coins.indexOf(c) === -1) coins.push(c);
      }
    }
    // Batch into groups of 10 (Envy API limit)
    var batches = [];
    for(var i=0; i<coins.length; i+=10){
      batches.push(coins.slice(i, i+10));
    }
    var promises = batches.map(function(batch){
      return fetch(API_BASE + '/prices?coins=' + batch.join(','))
        .then(function(res){ return res.json(); })
        .then(function(d){
          if(d.matrix){
            for(var coin in d.matrix){
              if(d.matrix[coin].CLOSE_PRICE_15M != null){
                livePrices[coin] = d.matrix[coin].CLOSE_PRICE_15M;
              }
            }
          }
        }).catch(function(){});
    });
    return Promise.all(promises).then(function(){ lastPriceUpdate = Date.now(); });
  }

  // Initial load
  loadPortfolio().then(function(){
    render();
    fetchAllPrices().then(function(){ render(); }).catch(function(){});
  }).catch(function(e){ console.error('Initial load failed:', e); });

  // Tick every 5s (agent status + timestamp)
  setInterval(function(){
    if(lastPriceUpdate){
      var el = document.getElementById('updated');
      if(el) el.textContent = 'Prices: ' + ago(lastPriceUpdate);
    }
    if(portfolioData && portfolioData.agents){
      renderAgents(portfolioData.agents);
      renderSystemStatus(portfolioData.agents);
    }
  }, 5000);

  // Decision stream every 15s
  setInterval(function(){
    renderDecisionStream();
  }, 15000);

  // Funnel + landscape + immune every 60s
  setInterval(function(){
    renderFunnel();
    renderLandscape();
    renderImmune();
  }, 60000);

  // Prices every 30s
  setInterval(function(){
    fetchAllPrices().then(function(){ render(); }).catch(function(){});
  }, 30000);

  // Portfolio every 5min
  setInterval(function(){
    loadPortfolio().then(function(){ render(); }).catch(function(){});
  }, 300000);

  // Redraw on resize
  window.addEventListener('resize', function(){
    if(portfolioData){
      var lt = portfolioData.liveTrading;
      var eq = null;
      if(lt && lt.enabled){
        var livePos = lt.positions || [];
        var totalUnrealized = 0;
        for(var i=0; i<livePos.length; i++){
          var price = getCurrentPrice(livePos[i].coin);
          if(price){ totalUnrealized += calcPnl(livePos[i], price).dollars; }
        }
        var liveClosed = lt.closed || [];
        var totalRealized = 0;
        for(var i=0; i<liveClosed.length; i++){
          totalRealized += liveClosed[i].pnl_usd || liveClosed[i].pnl_dollars || 0;
        }
        eq = startingEquity + totalRealized + totalUnrealized;
      }
      // Rebuild trade events for price-update redraws
      var evts = [];
      var lc = lt ? lt.closed || [] : [];
      for(var j=0; j<lc.length; j++){
        var xm = lc[j].exit_time ? new Date(lc[j].exit_time).getTime() : 0;
        if(xm) evts.push({t: xm, type: 'close', pnl: lc[j].pnl_usd || lc[j].pnl_dollars || 0});
      }
      var lp = lt ? lt.positions || [] : [];
      for(var j=0; j<lp.length; j++){
        var em = lp[j].entry_time ? new Date(lp[j].entry_time).getTime() : 0;
        if(em) evts.push({t: em, type: 'entry'});
      }
      drawEquityCurve(portfolioData.liveEquityCurve, eq, evts);
    }
  });
})();
</script>
