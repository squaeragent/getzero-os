  // ─── MAIN RENDER ───
  function render(){
    var d = portfolioData;
    if(!d) return;

    var lt = d.liveTrading;
    if(!lt || !lt.enabled) return;

    var livePos = lt.positions || [];
    var liveClosed = lt.closed || [];
    var regimes = d.agents && d.agents.regimes;

    // Compute unrealized P&L
    var totalUnrealized = 0;
    for(var i=0; i<livePos.length; i++){
      var price = getCurrentPrice(livePos[i].coin);
      if(price){
        var r = calcPnl(livePos[i], price);
        totalUnrealized += r.dollars;
      }
    }

    // Compute realized P&L from closed trades
    var totalRealized = 0;
    for(var i=0; i<liveClosed.length; i++){
      totalRealized += liveClosed[i].pnl_usd || liveClosed[i].pnl_dollars || 0;
    }

    var equity = startingEquity + totalRealized + totalUnrealized;
    var totalPnl = totalRealized + totalUnrealized;
    var pnlPct = startingEquity > 0 ? (totalPnl / startingEquity) * 100 : 0;

    // Uptime
    var uptimeStr = '—';
    if(lt.started){
      var uptimeMs = Date.now() - new Date(lt.started).getTime();
      var uptimeH = Math.floor(uptimeMs / 3600000);
      if(uptimeH < 24){
        uptimeStr = uptimeH + 'h';
      } else {
        uptimeStr = Math.floor(uptimeH / 24) + 'd ' + (uptimeH % 24) + 'h';
      }
    }

    var trades = lt.trades || 0;
    var wins = lt.wins || 0;

    // Equity hero
    var eqNumEl = document.getElementById('eq-number');
    if(eqNumEl) eqNumEl.textContent = fmt$(equity);

    var pnlEl = document.getElementById('eq-pnl');
    if(pnlEl){
      pnlEl.textContent = fmtPct(pnlPct) + ' (' + fmt$(totalPnl) + ')';
      pnlEl.style.color = totalPnl >= 0 ? '#c8ff00' : '#ff3333';
    }

    var metaEl = document.getElementById('eq-meta');
    if(metaEl) metaEl.textContent = trades + ' trades · ' + uptimeStr + ' uptime';

    // Early data badge
    var earlyBadge = document.getElementById('early-badge');
    if(earlyBadge) earlyBadge.style.display = (trades < 20) ? 'inline' : 'none';

    // Risk badge
    var risk = d.agents && d.agents.risk;
    if(risk){
      var badge = document.getElementById('risk-badge');
      var st = (risk.status||'green').toLowerCase();
      var col = riskColors[st] || '#c8ff00';
      badge.textContent = 'RISK: ' + st.toUpperCase();
      badge.style.color = st === 'green' ? '#0a0a0a' : '#fff';
      badge.style.background = col;
    }

    document.getElementById('pos-count').textContent = '(' + livePos.length + ')';
    document.getElementById('closed-count').textContent = '(' + liveClosed.length + ')';
    document.getElementById('updated').textContent = lastPriceUpdate ? 'Prices: ' + ago(lastPriceUpdate) : 'Loading prices...';

    // Equity curve
    drawEquityCurve(d.liveEquityCurve, equity);

    // System status
    renderSystemStatus(d.agents);

    // Pipeline (inside collapsed body)
    renderAgents(d.agents);

    // Market state
    renderMarketState(d);

    // Archetypes
    renderArchetypes(d.agents && d.agents.archetypes);

    // Stats
    renderStats(lt.stats);

    // ─── OPEN POSITIONS ───
    var posBody = document.getElementById('positions-body');
    if(livePos.length === 0){
      posBody.innerHTML = '<div class="muted">No open positions.</div>';
    } else {
      var html = '<div class="pos-cards">';
      for(var i=0; i<livePos.length; i++){
        var p = livePos[i];
        var isLong = p.direction === 'LONG';
        var dirCls = isLong ? 'long' : 'short';
        var cardCls = isLong ? '' : ' short-card';
        var curPrice = getCurrentPrice(p.coin);
        var pnlResult = curPrice ? calcPnl(p, curPrice) : {pct:null, dollars:null};
        var coinRegime = regimes && regimes.coins && regimes.coins[p.coin];
        var regimeStr = coinRegime ? coinRegime.regime : '';

        // Stop loss display
        var stopDisplay = '—';
        if(p.stop_loss && p.entry_price){
          var stopPct = isLong
            ? ((p.stop_loss - p.entry_price) / p.entry_price * 100)
            : ((p.entry_price - p.stop_loss) / p.entry_price * 100);
          stopDisplay = fmt$(p.stop_loss) + ' (' + stopPct.toFixed(1) + '%)';
        } else if(p.stop_loss){
          stopDisplay = fmt$(p.stop_loss);
        }

        // Hold time progress bar
        var holdPct = 0;
        var holdLabel = '—';
        var maxHoldH = p.max_hold_hours || 24;
        if(p.entry_time){
          var entryMs = new Date(p.entry_time).getTime();
          var holdMs = Date.now() - entryMs;
          var holdH = holdMs / 3600000;
          holdPct = Math.min(100, (holdH / maxHoldH) * 100);
          holdLabel = fmtHold(holdH) + ' / ' + maxHoldH + 'h max';
        } else if(p.entry_time_ms){
          var holdMs2 = Date.now() - p.entry_time_ms;
          var holdH2 = holdMs2 / 3600000;
          holdPct = Math.min(100, (holdH2 / maxHoldH) * 100);
          holdLabel = fmtHold(holdH2) + ' / ' + maxHoldH + 'h max';
        }

        // Signal name
        var signalName = p.signal_type || p.archetype || p.strategy || '';

        html += '<div class="pos-card'+cardCls+'">';
        html += '<div class="pos-card-top">';
        html += '<span class="pos-coin">'+p.coin+'</span>';
        html += '<span class="pos-dir '+dirCls+'">'+p.direction+'</span>';
        if(regimeStr) html += '<span class="regime-badge '+regimeStr+'">'+regimeStr+'</span>';
        if(pnlResult.pct !== null){
          html += '<span class="pos-pnl '+pnlClass(pnlResult.pct)+'">'+fmtPct(pnlResult.pct)+' ('+fmt$(pnlResult.dollars)+')</span>';
        }
        html += '</div>';

        html += '<div class="pos-card-grid">';
        html += '<div class="pos-field"><span class="pos-fl">Entry</span><span class="pos-fv">'+fmt$(p.entry_price)+'</span></div>';
        html += '<div class="pos-field"><span class="pos-fl">Now</span><span class="pos-fv '+(curPrice && pnlResult.pct!=null ? pnlClass(pnlResult.pct) : '')+'">'+(curPrice ? fmt$(curPrice) : '—')+'</span></div>';
        html += '<div class="pos-field"><span class="pos-fl">Size</span><span class="pos-fv">'+fmt$(p.size_usd)+'</span></div>';
        html += '<div class="pos-field"><span class="pos-fl">Stop</span><span class="pos-fv c-neg">'+stopDisplay+'</span></div>';
        html += '<div class="pos-field"><span class="pos-fl">Sharpe</span><span class="pos-fv">'+(p.sharpe != null ? p.sharpe.toFixed(2) : '—')+'</span></div>';
        if(signalName) html += '<div class="pos-field"><span class="pos-fl">Signal</span><span class="pos-fv">'+signalName+'</span></div>';
        html += '</div>';

        if(p.exit_expression){
          var translated = translateExit(p.exit_expression);
          html += '<div class="pos-exit">Exit when: '+translated+'</div>';
        }

        if(holdLabel !== '—'){
          html += '<div class="pos-hold-bar-wrap">';
          html += '<div class="pos-hold-track"><div class="pos-hold-fill" style="width:'+holdPct.toFixed(1)+'%"></div></div>';
          html += '<span class="pos-hold-label">'+holdLabel+'</span>';
          html += '</div>';
        }

        html += '</div>';
      }
      html += '</div>';
      posBody.innerHTML = html;
    }

    // ─── TRADE HISTORY (compact rows) ───
    var closedBody = document.getElementById('closed-body');
    if(liveClosed.length === 0){
      closedBody.innerHTML = '<div class="muted">No closed trades yet.</div>';
    } else {
      var html = '<div class="closed-rows">';
      // Most recent first, show last 20
      var recentTrades = liveClosed.slice().reverse().slice(0,20);
      for(var j=0; j<recentTrades.length; j++){
        var c = recentTrades[j];
        var dirCls2 = c.direction === 'LONG' ? 'c-long' : 'c-short';
        var pnlVal = c.pnl_usd || c.pnl_dollars || 0;
        var holdStr = '';
        if(c.entry_time && c.exit_time){
          var ms = new Date(c.exit_time).getTime() - new Date(c.entry_time).getTime();
          holdStr = fmtHold(Math.round(ms / 360000) / 10);
        }
        var entryAge = '';
        if(c.exit_time){
          entryAge = ago(new Date(c.exit_time).getTime());
        }
        html += '<div class="closed-row">';
        html += '<span class="cr-coin">'+c.coin+'</span>';
        html += '<span class="cr-dir '+dirCls2+'">'+c.direction+'</span>';
        html += '<span class="cr-prices">'+fmt$(c.entry_price)+'→'+fmt$(c.exit_price)+'</span>';
        html += '<span class="cr-pct '+pnlClass(c.pnl_pct||pnlVal)+'">'+fmtPct(c.pnl_pct)+'</span>';
        html += '<span class="cr-pnl '+pnlClass(pnlVal)+'">'+fmt$(pnlVal)+'</span>';
        html += '<span class="cr-reason">'+(c.exit_reason||'')+'</span>';
        html += '<span class="cr-age">'+(holdStr||entryAge)+'</span>';
        html += '</div>';
      }
      html += '</div>';
      closedBody.innerHTML = html;
    }
  }

  // ─── DATA FETCHING ───
  function fetchPrices(){
    return fetch(PRICE_API).then(function(res){ return res.json(); }).then(function(d){
      if(d.matrix){
        for(var coin in d.matrix){
          if(d.matrix[coin].CLOSE_PRICE_15M != null){
            livePrices[coin] = d.matrix[coin].CLOSE_PRICE_15M;
          }
        }
      }
      lastPriceUpdate = Date.now();
    }).catch(function(e){ console.error('Price fetch failed:', e); });
  }

  function loadPortfolio(){
    return fetch(PORTFOLIO_API).then(function(res){ return res.json(); }).then(function(d){
      portfolioData = d;
    }).catch(function(e){ console.error('Portfolio fetch failed:', e); });
  }

  // ─── SYSTEM STATUS TOGGLE ───
  document.addEventListener('DOMContentLoaded', function(){
    var ph = document.getElementById('system-ph');
    var body = document.getElementById('system-body');
    if(ph && body){
      ph.addEventListener('click', function(){
        body.classList.toggle('expanded');
      });
    }
  });

  // Initial load
  loadPortfolio().then(function(){
    render();
    fetchPrices().then(function(){ render(); }).catch(function(){});
  }).catch(function(e){ console.error('Initial load failed:', e); });

  // Tick every 5s (agent status + timestamp)
  setInterval(function(){
    if(lastPriceUpdate){
      var el = document.getElementById('updated');
      if(el) el.textContent = 'Prices: ' + ago(lastPriceUpdate);
    }
    if(portfolioData && portfolioData.agents){
      renderAgents(portfolioData.agents);
      renderSystemStatus(portfolioData.agents);
    }
  }, 5000);

  // Prices every 30s
  setInterval(function(){
    fetchPrices().then(function(){ render(); }).catch(function(){});
  }, 30000);

  // Portfolio every 5min
  setInterval(function(){
    loadPortfolio().then(function(){ render(); }).catch(function(){});
  }, 300000);

  // Redraw on resize
  window.addEventListener('resize', function(){
    if(portfolioData){
      var lt = portfolioData.liveTrading;
      var eq = null;
      if(lt && lt.enabled){
        var livePos = lt.positions || [];
        var totalUnrealized = 0;
        for(var i=0; i<livePos.length; i++){
          var price = getCurrentPrice(livePos[i].coin);
          if(price){ totalUnrealized += calcPnl(livePos[i], price).dollars; }
        }
        var liveClosed = lt.closed || [];
        var totalRealized = 0;
        for(var i=0; i<liveClosed.length; i++){
          totalRealized += liveClosed[i].pnl_usd || liveClosed[i].pnl_dollars || 0;
        }
        eq = startingEquity + totalRealized + totalUnrealized;
      }
      drawEquityCurve(portfolioData.liveEquityCurve, eq);
    }
  });
})();
</script>
