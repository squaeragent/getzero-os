<script is:inline>
(function(){
  var API_BASE = 'https://api.getzero.dev';
  var PORTFOLIO_API = API_BASE + '/portfolio.json';
  var BASE_PRICE_COINS = ['BTC','ETH','SOL','DOGE','AVAX','LINK','ARB','NEAR','SUI','INJ'];
  var PRICE_API = API_BASE + '/prices?coins=' + BASE_PRICE_COINS.join(',');

  var portfolioData = null;
  var livePrices = {};
  var lastPriceUpdate = 0;
  var startingEquity = null; // set from equity curve first point — never hardcoded

  // ─── DATA API (replaces Supabase — served from api.getzero.dev) ───
  function apiFetch(path){
    return fetch(API_BASE + path).then(function(res){
      if(!res.ok) throw new Error('API HTTP ' + res.status + ' on ' + path);
      return res.json();
    });
  }

  function computeStats(trades){
    if(!trades || trades.length === 0) return null;
    var total = trades.length;
    var wins = 0;
    var longPnl = 0, shortPnl = 0;
    var longWins = 0, shortWins = 0;
    var longCount = 0, shortCount = 0;
    var totalPnl = 0;
    var totalHoldHours = 0;
    var holdCount = 0;
    var byCoin = {};
    var bestTrade = null, worstTrade = null;
    for(var i = 0; i < trades.length; i++){
      var t = trades[i];
      var pnl = t.pnl_usd || t.pnl_dollars || 0;
      var isWin = pnl > 0;
      if(isWin) wins++;
      totalPnl += pnl;
      if(t.direction === 'LONG'){
        longCount++; longPnl += pnl;
        if(isWin) longWins++;
      } else {
        shortCount++; shortPnl += pnl;
        if(isWin) shortWins++;
      }
      if(t.entry_time && t.exit_time){
        var holdMs = new Date(t.exit_time).getTime() - new Date(t.entry_time).getTime();
        if(holdMs > 0){ totalHoldHours += holdMs / 3600000; holdCount++; }
      }
      if(!byCoin[t.coin]) byCoin[t.coin] = {trades:0, wins:0, pnl:0};
      byCoin[t.coin].trades++;
      if(isWin) byCoin[t.coin].wins++;
      byCoin[t.coin].pnl += pnl;
      if(bestTrade === null || pnl > bestTrade.pnl){
        bestTrade = {coin:t.coin, direction:t.direction, pnlPct:t.pnl_pct, pnl:pnl};
      }
      if(worstTrade === null || pnl < worstTrade.pnl){
        worstTrade = {coin:t.coin, direction:t.direction, pnlPct:t.pnl_pct, pnl:pnl};
      }
    }
    for(var coin in byCoin){
      var cs = byCoin[coin];
      cs.winRate = cs.trades > 0 ? (cs.wins / cs.trades * 100) : 0;
    }
    return {
      total: total,
      wins: wins,
      losses: total - wins,
      winRate: total > 0 ? (wins / total * 100) : 0,
      totalPnl: totalPnl,
      avgPnl: total > 0 ? totalPnl / total : 0,
      avgHoldHours: holdCount > 0 ? totalHoldHours / holdCount : 0,
      longCount: longCount, shortCount: shortCount,
      longPnl: longPnl, shortPnl: shortPnl,
      longWinRate: longCount > 0 ? (longWins / longCount * 100) : 0,
      shortWinRate: shortCount > 0 ? (shortWins / shortCount * 100) : 0,
      byCoin: byCoin,
      bestTrade: bestTrade,
      worstTrade: worstTrade
    };
  }

  function fetchPortfolioData(){
    return Promise.all([
      apiFetch('/v6/positions'),
      apiFetch('/v6/trades?limit=200'),
      apiFetch('/v6/equity?points=200').catch(function(){ return []; }),
      apiFetch('/v6/heartbeats').catch(function(){ return []; }),
      apiFetch('/regime').catch(function(){ return {}; }),
      apiFetch('/world').catch(function(){ return {}; })
    ]).then(function(results){
      var positions        = results[0] || [];
      var trades           = results[1] || [];
      var equitySnapshots  = results[2] || [];
      var heartbeats       = results[3] || [];
      var regimeData       = results[4] || {};
      var worldData        = results[5] || {};

      // Starting equity = first point of equity curve (never hardcoded)
      if(equitySnapshots && equitySnapshots.length > 0) {
        var firstEq = equitySnapshots[0].equity_usd || equitySnapshots[0].eq;
        if(firstEq && firstEq > 100) startingEquity = firstEq;
      }
      // If no equity data at all, use 750 as last resort with a warning
      if(startingEquity === null) startingEquity = 750;

      // Map positions → existing format
      var mappedPositions = positions.map(function(p){
        var stopLoss = null;
        if(p.stop_loss_pct && p.entry_price){
          var isLong = p.direction === 'LONG';
          // stop_loss_pct is already a fraction (0.05 = 5%), not a percentage
          var slp = p.stop_loss_pct > 1 ? p.stop_loss_pct / 100 : p.stop_loss_pct;
          stopLoss = isLong
            ? p.entry_price * (1 - slp)
            : p.entry_price * (1 + slp);
        }
        return {
          coin: p.coin,
          direction: p.direction,
          entry_price: p.entry_price,
          size_usd: p.size_usd,
          entry_time: p.entry_time,
          signal_type: p.signal,
          sharpe: p.sharpe,
          win_rate: p.win_rate,
          stop_loss: stopLoss,
          adversary_verdict: p.adversary_verdict,
          survival_score: p.survival_score,
          exit_expression: p.exit_expression,
          max_hold_hours: p.max_hold_hours,
          metadata: p.metadata
        };
      });

      // Map trades → closed format
      var mappedClosed = trades.map(function(t){
        var pnl = t.pnl_usd || t.pnl_dollars || 0;
        return {
          coin: t.coin,
          direction: t.direction,
          entry_price: t.entry_price,
          exit_price: t.exit_price,
          size_usd: t.size_usd,
          pnl_dollars: pnl,
          pnl_usd: pnl,
          pnl_pct: t.pnl_pct,
          entry_time: t.entry_time,
          exit_time: t.exit_time,
          exit_reason: t.exit_reason,
          signal: t.signal,
          sharpe: t.sharpe
        };
      });

      // Build equity curve (RPC returns data in ascending order already)
      var liveEquityCurve = equitySnapshots.map(function(s){
        return {t: new Date(s.recorded_at).getTime(), v: parseFloat(s.equity_usd)};
      });

      // Build heartbeat map: { agent_name: iso_timestamp }
      var heartbeatMap = {};
      for(var i = 0; i < heartbeats.length; i++){
        var hb = heartbeats[i];
        heartbeatMap[hb.agent_name || hb.agent] = hb.last_heartbeat;
      }

      // Compute stats directly from trades
      var stats = computeStats(trades);

      var wins = 0;
      for(var k = 0; k < trades.length; k++){
        if((trades[k].pnl_usd || trades[k].pnl_dollars || 0) > 0) wins++;
      }

      return {
        liveTrading: {
          enabled: true,
          positions: mappedPositions,
          closed: mappedClosed,
          trades: trades.length,
          wins: wins,
          dailyLoss: 0,
          stats: stats
        },
        liveEquityCurve: liveEquityCurve,
        agents: {
          heartbeat: heartbeatMap,
          risk: { status: 'green' },
          regimes: regimeData,
          spread: worldData.spread || {},
          funding: worldData.funding || {}
        }
      };
    });
  }

  function fmt$(v){
    if(v==null) return '—';
    var abs = Math.abs(v);
    var s = abs.toLocaleString('en',{minimumFractionDigits:2,maximumFractionDigits:2});
    return v<0 ? '-$'+s : '$'+s;
  }
  function fmtPrice(v){
    if(v==null) return '—';
    if(v >= 1000) return '$'+v.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
    if(v >= 1) return '$'+v.toFixed(2);
    if(v >= 0.01) return '$'+v.toFixed(4);
    return '$'+v.toPrecision(3);
  }
  function fmtPct(v){
    if(v==null) return '—';
    return (v>=0?'+':'')+v.toFixed(2)+'%';
  }
  function pnlClass(v){ return v>=0?'c-pos':'c-neg'; }

  function humanizeSignal(raw){
    if(!raw) return '';
    // Strip version/variant suffixes: _V4_MH72_MH36_EX2 etc
    var clean = raw.replace(/_V\d+.*$/i, '').replace(/_MH\d+/gi, '').replace(/_EX\d+/gi, '').replace(/_Q\d+/gi, '');
    // Strip source prefix if redundant
    clean = clean.replace(/^TAAPI_/i, '').replace(/^ARCH_/i, '').replace(/^ENVY_/i, '');
    // Replace underscores with spaces, title case
    return clean.replace(/_/g, ' ').replace(/\b\w/g, function(c){ return c.toUpperCase(); }).replace(/\b(Short|Long|Bull|Bear)\b/gi, '').trim();
  }
  function ago(ts){
    var s = Math.floor((Date.now() - ts) / 1000);
    if(s < 5) return 'just now';
    if(s < 60) return s+'s ago';
    if(s < 3600) return Math.floor(s/60)+'m ago';
    return Math.floor(s/3600)+'h ago';
  }
  function agoFromISO(iso){
    if(!iso) return Infinity;
    return (Date.now() - new Date(iso).getTime()) / 1000;
  }
  function getCurrentPrice(coin){ return livePrices[coin] || null; }

  function calcPnl(pos, price){
    if(!price || !pos.entry_price) return {pct:0, dollars:0};
    var pct;
    if(pos.direction === 'LONG'){
      pct = ((price - pos.entry_price) / pos.entry_price) * 100;
    } else {
      pct = ((pos.entry_price - price) / pos.entry_price) * 100;
    }
    var size = pos.size_usd || 0;
    return {pct: pct, dollars: size * (pct / 100)};
  }

  function fmtHold(hours){
    if(!hours && hours !== 0) return '—';
    if(hours < 1) return Math.round(hours * 60) + 'm';
    var h = Math.floor(hours);
    var m = Math.round((hours - h) * 60);
    if(m === 60){ h++; m = 0; }
    if(h > 0 && m > 0) return h + 'h ' + m + 'm';
    if(h > 0) return h + 'h';
    return m + 'm';
  }

  var riskColors = {green:'#c8ff00',yellow:'#ffb000',orange:'#ff8800',red:'#ff3333'};

  // ─── EXIT EXPRESSION TRANSLATION ───
  function translateExit(expr){
    if(!expr) return '';
    var rules = [
      [/RSI_3H30M\s*>=\s*[\d.]+/g, 'RSI overbought'],
      [/RSI_3H30M\s*<=\s*[\d.]+/g, 'RSI oversold'],
      [/RSI_24H\s*>=\s*[\d.]+/g, 'daily RSI overbought'],
      [/RSI_24H\s*<=\s*[\d.]+/g, 'daily RSI oversold'],
      [/XONE_I_NET\s*<=\s*[\d.]+/g, 'social sentiment drops'],
      [/XONE_I_NET\s*>=\s*[\d.]+/g, 'social sentiment peaks'],
      [/XONE_AVG_NET\s*[<>]=?\s*[\d.-]+/g, 'crowd sentiment shifts'],
      [/HURST_24H\s*<\s*[\d.]+/g, 'trend breaks'],
      [/HURST_24H\s*>\s*[\d.]+/g, 'trend strengthens'],
      [/LYAPUNOV_24H\s*>=\s*[\d.]+/g, 'chaos detected'],
      [/LYAPUNOV_24H\s*<\s*[\d.]+/g, 'chaos subsides'],
      [/ADX_3H30M\s*>=\s*[\d.]+/g, 'trend established'],
      [/ADX_3H30M\s*<\s*[\d.]+/g, 'trend weakens'],
      [/DOJI_VELOCITY\s*<\s*[\d.]+/g, 'indecision resolves'],
      [/DOJI_VELOCITY\s*>=\s*[\d.]+/g, 'indecision spikes'],
      [/EMA_N_24H\s*<\s*[\d.]+/g, 'price below average'],
      [/EMA_N_24H\s*>=?\s*[\d.]+/g, 'price above average'],
      [/EMA_N_48H\s*[<>]=?\s*[\d.]+/g, 'long-term trend shifts'],
      [/BB_POSITION_15M\s*>=\s*[\d.]+/g, 'price hits upper band'],
      [/BB_POSITION_15M\s*<=\s*[\d.]+/g, 'price hits lower band'],
      [/BB_POS_24H\s*>=\s*[\d.]+/g, 'daily upper band hit'],
      [/BB_POS_24H\s*<=\s*[\d.]+/g, 'daily lower band hit'],
      [/MACD_N_24H\s*[<>]=?\s*[\d.-]+/g, 'MACD crosses'],
      [/CMO_3H30M\s*>=\s*[\d.]+/g, 'momentum peaks'],
      [/CMO_3H30M\s*<=\s*[\d.-]+/g, 'momentum drops'],
      [/ROC_24H\s*>=\s*[\d.]+/g, 'rate of change spikes'],
      [/ROC_24H\s*<=\s*[\d.]+/g, 'rate of change drops'],
      [/EMA_CROSS_15M_N\s*[<>]=?\s*[\d.-]+/g, 'EMA crossover'],
      [/CLOSE_PRICE_15M\s*[<>]=?\s*[\d.]+/g, 'price target hit'],
    ];
    var translated = expr;
    for(var i=0; i<rules.length; i++){
      translated = translated.replace(rules[i][0], rules[i][1]);
    }
    // Strip any remaining raw indicator codes
    translated = translated.replace(/[A-Z][A-Z0-9_]{3,}\s*[><=!]+\s*[\d.-]+/g, 'condition met');
    // Clean up dangling OR/AND
    translated = translated.replace(/\bOR\s*$/g, '').replace(/^\s*OR\b/g, '');
    translated = translated.replace(/\bAND\s*$/g, '').replace(/^\s*AND\b/g, '');
    translated = translated.replace(/\s{2,}/g, ' ').trim();
    return translated || expr;
  }

  // ─── EQUITY CURVE ───
  function drawEquityCurve(curve, currentEquity, tradeEvents){
    var canvas = document.getElementById('equity-canvas');
    var emptyMsg = document.getElementById('eq-empty');

    if(!curve || curve.length < 2){
      if(canvas) canvas.style.display = 'none';
      if(emptyMsg) emptyMsg.style.display = 'block';
      return;
    }

    // Determine line color based on current equity vs starting
    var lineColor = (currentEquity != null && currentEquity >= startingEquity) ? '#c8ff00' : '#ff3333';
    var fillColor = lineColor === '#c8ff00' ? 'rgba(200,255,0,0.06)' : 'rgba(255,51,51,0.06)';
    var gridColor = 'rgba(200,255,0,0.05)';
    var labelColor = 'rgba(200,255,0,0.25)';

    // Early data: < 10 points
    if(curve.length < 10){
      if(emptyMsg) emptyMsg.style.display = 'none';
      if(canvas){
        canvas.style.display = 'block';
        var dpr0 = window.devicePixelRatio || 1;
        var rect0 = canvas.getBoundingClientRect();
        canvas.width = rect0.width * dpr0;
        canvas.height = rect0.height * dpr0;
        var ctx0 = canvas.getContext('2d');
        ctx0.scale(dpr0, dpr0);
        var W0 = rect0.width;
        var H0 = rect0.height;
        ctx0.clearRect(0, 0, W0, H0);
        var midY0 = H0 / 2;
        ctx0.setLineDash([8, 6]);
        ctx0.strokeStyle = 'rgba(200,255,0,0.3)';
        ctx0.lineWidth = 1;
        ctx0.beginPath();
        ctx0.moveTo(20, midY0);
        ctx0.lineTo(W0 - 20, midY0);
        ctx0.stroke();
        ctx0.setLineDash([]);
        ctx0.fillStyle = 'rgba(200,255,0,0.35)';
        ctx0.font = '11px JetBrains Mono, monospace';
        ctx0.textAlign = 'center';
        ctx0.fillText('$' + startingEquity + ' — COLLECTING DATA', W0 / 2, midY0 - 12);
        ctx0.font = '9px JetBrains Mono, monospace';
        ctx0.fillStyle = 'rgba(200,255,0,0.2)';
        ctx0.fillText(curve.length + ' of 10 points', W0 / 2, midY0 + 16);
      }
      return;
    }

    if(canvas) canvas.style.display = 'block';
    if(emptyMsg) emptyMsg.style.display = 'none';

    var dpr = window.devicePixelRatio || 1;
    var rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    var ctx = canvas.getContext('2d');
    ctx.scale(dpr, dpr);
    var W = rect.width;
    var H = rect.height;
    var pad = {t:16, r:50, b:22, l:10};

    var vals = curve.map(function(p){ return p.v; });
    var minV = Math.min.apply(null, vals);
    var maxV = Math.max.apply(null, vals);
    var range = maxV - minV || 1;
    minV -= range * 0.1;
    maxV += range * 0.1;
    range = maxV - minV;

    var cw = W - pad.l - pad.r;
    var ch = H - pad.t - pad.b;

    // Grid lines
    ctx.strokeStyle = gridColor;
    ctx.lineWidth = 1;
    var gridLines = 4;
    for(var i=0; i<=gridLines; i++){
      var y = pad.t + (ch * i / gridLines);
      ctx.beginPath();
      ctx.moveTo(pad.l, y);
      ctx.lineTo(W - pad.r, y);
      ctx.stroke();
      var val = maxV - (range * i / gridLines);
      ctx.fillStyle = labelColor;
      ctx.font = '9px JetBrains Mono, monospace';
      ctx.textAlign = 'left';
      ctx.fillText('$' + val.toFixed(2), W - pad.r + 4, y + 3);
    }

    // Time labels
    ctx.fillStyle = labelColor;
    ctx.font = '8px JetBrains Mono, monospace';
    ctx.textAlign = 'center';
    var tSteps = Math.min(5, curve.length);
    for(var i=0; i<tSteps; i++){
      var idx = Math.floor(i * (curve.length-1) / (tSteps-1));
      var x = pad.l + (idx / (curve.length-1)) * cw;
      var d = new Date(curve[idx].t);
      ctx.fillText(d.toISOString().slice(11,16), x, H - 4);
    }

    function px(i){ return pad.l + (i / (curve.length-1)) * cw; }
    function py(v){ return pad.t + ch - ((v - minV) / range) * ch; }

    // Area fill
    ctx.beginPath();
    ctx.moveTo(px(0), py(vals[0]));
    for(var i=1; i<vals.length; i++) ctx.lineTo(px(i), py(vals[i]));
    ctx.lineTo(px(vals.length-1), pad.t + ch);
    ctx.lineTo(px(0), pad.t + ch);
    ctx.closePath();
    ctx.fillStyle = fillColor;
    ctx.fill();

    // Line
    ctx.beginPath();
    ctx.moveTo(px(0), py(vals[0]));
    for(var i=1; i<vals.length; i++) ctx.lineTo(px(i), py(vals[i]));
    ctx.strokeStyle = lineColor;
    ctx.lineWidth = 1.5;
    ctx.stroke();

    // Realized equity line (thin, only moves on trade closes)
    if(tradeEvents && tradeEvents.length > 0 && curve.length >= 2){
      // Build cumulative realized P&L at each curve point
      var closeEvents = tradeEvents.filter(function(e){ return e.type === 'close' && e.pnl !== undefined; });
      closeEvents.sort(function(a,b){ return a.t - b.t; });

      if(closeEvents.length > 0){
        var realizedVals = [];
        var cumPnl = 0;
        var ceIdx = 0;
        for(var ri=0; ri<curve.length; ri++){
          while(ceIdx < closeEvents.length && closeEvents[ceIdx].t <= curve[ri].t){
            cumPnl += closeEvents[ceIdx].pnl;
            ceIdx++;
          }
          realizedVals.push(startingEquity + cumPnl);
        }
        // Finish remaining events
        while(ceIdx < closeEvents.length){ cumPnl += closeEvents[ceIdx].pnl; ceIdx++; }

        // Draw realized line (thin, dimmer)
        ctx.beginPath();
        ctx.moveTo(px(0), py(realizedVals[0]));
        for(var ri=1; ri<realizedVals.length; ri++) ctx.lineTo(px(ri), py(realizedVals[ri]));
        ctx.strokeStyle = 'rgba(200,255,0,0.25)';
        ctx.lineWidth = 1;
        ctx.setLineDash([4, 3]);
        ctx.stroke();
        ctx.setLineDash([]);

        // Shade between realized and market equity (unrealized band)
        ctx.beginPath();
        ctx.moveTo(px(0), py(vals[0]));
        for(var ri=1; ri<vals.length; ri++) ctx.lineTo(px(ri), py(vals[ri]));
        for(var ri=realizedVals.length-1; ri>=0; ri--) ctx.lineTo(px(ri), py(realizedVals[ri]));
        ctx.closePath();
        // Green if current equity > realized, red if below
        var lastRealized = realizedVals[realizedVals.length-1];
        var lastEquity = vals[vals.length-1];
        ctx.fillStyle = lastEquity >= lastRealized ? 'rgba(200,255,0,0.04)' : 'rgba(255,51,51,0.04)';
        ctx.fill();
      }
    }

    // Current value dot
    var lastX = px(vals.length-1);
    var lastY = py(vals[vals.length-1]);
    ctx.beginPath();
    ctx.arc(lastX, lastY, 3, 0, Math.PI*2);
    ctx.fillStyle = lineColor;
    ctx.fill();

    // Trade event markers on the curve
    if(tradeEvents && tradeEvents.length > 0 && curve.length >= 2){
      var tMin = curve[0].t;
      var tMax = curve[curve.length-1].t;
      var tRange = tMax - tMin || 1;
      for(var ei=0; ei<tradeEvents.length; ei++){
        var ev = tradeEvents[ei];
        if(ev.t < tMin || ev.t > tMax) continue;
        // Find nearest equity point for Y position
        var evIdx = 0;
        var bestDist = Infinity;
        for(var ci=0; ci<curve.length; ci++){
          var dist = Math.abs(curve[ci].t - ev.t);
          if(dist < bestDist){ bestDist = dist; evIdx = ci; }
        }
        var evX = px(evIdx);
        var evY = py(vals[evIdx]);
        // Color: green=profitable close, red=losing close, dim=entry
        var evColor = ev.type === 'entry' ? 'rgba(255,255,255,0.4)' :
                      (ev.pnl >= 0 ? '#c8ff00' : '#ff3333');
        // Draw marker
        ctx.beginPath();
        if(ev.type === 'entry'){
          // Small diamond for entries
          ctx.moveTo(evX, evY - 3);
          ctx.lineTo(evX + 3, evY);
          ctx.lineTo(evX, evY + 3);
          ctx.lineTo(evX - 3, evY);
          ctx.closePath();
        } else {
          // Circle for closes
          ctx.arc(evX, evY, 3.5, 0, Math.PI*2);
        }
        ctx.fillStyle = evColor;
        ctx.fill();
        // Thin border for visibility
        ctx.strokeStyle = 'rgba(0,0,0,0.5)';
        ctx.lineWidth = 0.5;
        ctx.stroke();
      }
    }

    var el = document.getElementById('eq-range');
    if(el) el.textContent = curve.length + ' points · $' + (minV+range*0.1).toFixed(2) + ' – $' + (maxV-range*0.1).toFixed(2);
  }

  // ─── DECISION STREAM ───
  function renderDecisionStream(){
    fetch(API_BASE + '/v6/decisions?limit=30').then(function(r){ return r.json(); }).then(function(decisions){
      var body = document.getElementById('ds-body');
      var countEl = document.getElementById('ds-count');
      if(!body) return;
      if(!decisions || !decisions.length){ body.innerHTML = '<div class="muted">No decisions yet</div>'; return; }
      if(countEl) countEl.textContent = '(' + decisions.length + ')';

      var html = '';
      for(var i=0; i<decisions.length; i++){
        var d = decisions[i];
        var ts = d.ts ? new Date(d.ts) : null;
        var timeStr = ts ? ts.toISOString().slice(11,19) : '—';
        var dirClass = (d.direction||'').toLowerCase() === 'long' ? 'long' : 'short';

        var badgeClass = 'rejected';
        var badgeText = d.type;
        if(d.type === 'ENTERED') badgeClass = 'entered';
        else if(d.type === 'CLOSED' && d.won) { badgeClass = 'closed-win'; badgeText = 'CLOSED'; }
        else if(d.type === 'CLOSED' && !d.won) { badgeClass = 'closed-loss'; badgeText = 'CLOSED'; }
        else if(d.type === 'BLOCKED') badgeClass = 'blocked';
        else if(d.type === 'HELD') badgeClass = 'held';

        var reasonText = d.reason || '';
        if(d.type === 'CLOSED'){
          var pnlStr = (d.pnl_usd >= 0 ? '+' : '') + '$' + (d.pnl_usd||0).toFixed(2);
          var pctStr = (d.pnl_pct >= 0 ? '+' : '') + ((d.pnl_pct||0)*100).toFixed(2) + '%';
          reasonText = pnlStr + ' (' + pctStr + ') ' + (d.reason||'');
        }

        var sharpeStr = d.sharpe ? d.sharpe.toFixed(2) : '';

        html += '<div class="ds-row">';
        html += '<span class="ds-time">' + timeStr + '</span>';
        html += '<span class="ds-coin">' + (d.coin||'—') + '</span>';
        html += '<span class="ds-dir ' + dirClass + '">' + (d.direction||'—') + '</span>';
        html += '<span class="ds-badge ' + badgeClass + '">' + badgeText + '</span>';
        html += '<span class="ds-reason" title="' + reasonText.replace(/"/g,'&quot;') + '">' + reasonText + '</span>';
        if(sharpeStr) html += '<span class="ds-sharpe">σ ' + sharpeStr + '</span>';
        html += '</div>';
      }
      body.innerHTML = html;
    }).catch(function(){ /* silent */ });
  }

