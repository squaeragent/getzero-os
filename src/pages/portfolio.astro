  // ─── SIGNAL LANDSCAPE ───
  function renderLandscape(){
    fetch(API_BASE + '/v6/landscape').then(function(r){ return r.json(); }).then(function(data){
      var body = document.getElementById('landscape-body');
      var meta = document.getElementById('landscape-meta');
      if(!body) return;
      if(!data || !data.coins || !data.coins.length){ body.innerHTML = '<div class="muted">No signal data</div>'; return; }

      if(meta) meta.textContent = data.active_count + ' ACTIVE · ' + (data.watching_count||0) + ' WATCHING · ' + (data.blacklisted_count||0) + ' BLACKLISTED';

      var html = '';
      var prevTier = '';

      for(var i=0; i<data.coins.length; i++){
        var c = data.coins[i];
        var tier = c.tier || (c.blacklisted ? 'blacklisted' : (c.active ? 'active' : 'watching'));

        // Tier transition labels
        if(tier !== prevTier){
          if(tier === 'watching' && prevTier === 'active'){
            html += '<div class="ls-tier-label">WATCHING</div>';
          } else if(tier === 'blacklisted'){
            html += '<div class="ls-divider">BLACKLISTED — NEGATIVE PORTFOLIO SHARPE</div>';
          }
          prevTier = tier;
        }

        // Sparkline — normalized to OWN min/max for unique shape
        var spark = c.sparkline || [];
        var svgPath = '';
        if(spark.length >= 2){
          var sMin = Math.min.apply(null, spark);
          var sMax = Math.max.apply(null, spark);
          var sRange = sMax - sMin;
          if(sRange < 0.01) sRange = 1; // flat line guard
          var pts = [];
          for(var j=0; j<spark.length; j++){
            var sx = (j / (spark.length-1)) * 70;
            var sy = 16 - ((spark[j] - sMin) / sRange) * 14;
            pts.push(sx.toFixed(1) + ',' + sy.toFixed(1));
          }
          var sparkColor, sparkWidth;
          if(tier === 'blacklisted'){ sparkColor = '#ff3333'; sparkWidth = '1'; }
          else if(tier === 'active'){ sparkColor = '#c8ff00'; sparkWidth = '2'; }
          else { sparkColor = 'rgba(200,255,0,0.5)'; sparkWidth = '1.2'; }
          svgPath = '<svg class="ls-sparkline" viewBox="0 0 70 18" preserveAspectRatio="none"><polyline fill="none" stroke="' + sparkColor + '" stroke-width="' + sparkWidth + '" stroke-linecap="round" stroke-linejoin="round" points="' + pts.join(' ') + '"/></svg>';
        }

        html += '<div class="ls-coin tier-' + tier + '">';
        html += '<span class="ls-name">' + c.coin + '</span>';
        if(tier === 'active') html += '<span class="ls-tag active">ACTIVE</span>';
        html += svgPath;
        html += '<span class="ls-val tier-' + tier + '">' + (c.current_sharpe !== null ? c.current_sharpe.toFixed(1) : '—') + '</span>';
        if(tier === 'blacklisted') html += '<span style="color:#ff3333;font-size:0.55rem;flex-shrink:0"> ✕</span>';
        html += '</div>';
      }
      body.innerHTML = html;
    }).catch(function(){ /* silent */ });
  }

