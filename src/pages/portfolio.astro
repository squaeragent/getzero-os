---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="ZERO OS — Live Trading" description="10-agent autonomous trading system. 1,190+ signals across 40 coins. Live on Hyperliquid.">
  <div class="page">
    <div class="terminal-border">

      <!-- NAV BAR -->
      <div class="nav-bar">
        <a href="/" class="nav-item">◇ ZERO OS</a>
        <a href="/thesis" class="nav-item">THESIS</a>
        <span class="nav-item nav-active">PORTFOLIO</span>
      </div>

      <!-- HERO -->
      <div class="hero-pane">
        <div class="ph">◇ ZERO OS — <span class="live-dot">●</span> LIVE <span class="early-badge" id="early-badge" style="display:none">EARLY DATA</span></div>
        <div class="hero-body">
          <div class="stats-row" id="stats-row">
            <div class="stat">
              <span class="sl">EQUITY</span>
              <span class="sv big" id="s-equity">—</span>
            </div>
            <div class="stat">
              <span class="sl">P&L</span>
              <span class="sv" id="s-pnl">—</span>
            </div>
            <div class="stat">
              <span class="sl">WIN RATE</span>
              <span class="sv" id="s-winrate">—</span>
            </div>
            <div class="stat">
              <span class="sl">CLOSED TRADES</span>
              <span class="sv" id="s-trades">0</span>
            </div>
            <div class="stat">
              <span class="sl">UPTIME</span>
              <span class="sv" id="s-uptime">—</span>
            </div>
          </div>
          <div class="hero-meta">
            <span class="risk-badge" id="risk-badge">—</span>
            <span class="regime-summary dim" id="regime-summary"></span>
          </div>
        </div>
      </div>

      <!-- EQUITY CURVE -->
      <div class="section">
        <div class="ph">ACCOUNT VALUE <span class="dim" id="eq-range"></span></div>
        <div class="sb eq-wrap">
          <canvas id="equity-canvas" width="860" height="200"></canvas>
          <div class="muted" id="eq-empty" style="display:none">Collecting data...</div>
        </div>
      </div>

      <!-- AGENT PIPELINE -->
      <div class="section">
        <div class="ph">PIPELINE STATUS</div>
        <div class="sb agent-pipeline" id="agent-pipeline"></div>
      </div>

      <!-- MARKET INTELLIGENCE -->
      <div class="section" id="intelligence-section">
        <div class="ph">MARKET INTELLIGENCE</div>
        <div class="sb">
          <div class="intel-panels" id="intel-panels">
            <div class="intel-panel">
              <div class="intel-panel-label">REGIMES</div>
              <div class="regime-grid" id="regime-grid"></div>
            </div>
            <div class="intel-panel">
              <div class="intel-panel-label">SPREAD</div>
              <div class="intel-val" id="spread-val">—</div>
            </div>
            <div class="intel-panel">
              <div class="intel-panel-label">FUNDING</div>
              <div class="intel-val" id="funding-val">—</div>
            </div>
          </div>
          <div class="archetype-row" id="archetype-row">
            <div class="muted">Monitoring 6 signal archetypes...</div>
          </div>
        </div>
      </div>

      <!-- OPEN POSITIONS -->
      <div class="section">
        <div class="ph">OPEN POSITIONS <span class="dim" id="pos-count">(0)</span></div>
        <div class="sb" id="positions-body">
          <div class="muted">Fetching live data...</div>
        </div>
      </div>

      <!-- STATS -->
      <div class="section">
        <div class="ph">STATS</div>
        <div class="sb stats-grid" id="stats-dashboard">
          <div class="muted">Loading stats...</div>
        </div>
      </div>

      <!-- TRADE HISTORY -->
      <div class="section">
        <div class="ph">TRADE HISTORY <span class="dim" id="closed-count">(0)</span></div>
        <div class="sb" id="closed-body">
          <div class="muted">Fetching live data...</div>
        </div>
      </div>

      <!-- FOOTER -->
      <div class="footer">
        <a href="/" class="footer-link">◇ ZERO OS</a>
        <span class="dim" id="updated">—</span>
      </div>

    </div>
  </div>
</BaseLayout>

<style is:global>
  /* ─── PAGE ─── */
  .page {
    max-width: 960px;
    margin: 0 auto;
    padding: 1rem;
    min-height: 100vh;
  }
  .terminal-border {
    border: 1px solid rgba(200,255,0,0.4);
    min-height: 100vh;
  }

  /* ─── NAV BAR ─── */
  .nav-bar {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 0.5rem 1rem;
    border-bottom: 1px solid var(--border);
    font-family: var(--font-head);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .nav-item {
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-item:hover { color: var(--phosphor); }
  .nav-active { color: var(--phosphor); }

  /* ─── SECTION HEADERS ─── */
  .ph {
    font-family: var(--font-head);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
    padding: 0.5rem 1rem;
    border-bottom: 1px solid var(--border);
    background: rgba(0,0,0,0.6);
  }
  .section {
    border-bottom: 1px solid var(--border);
  }
  .sb {
    padding: 0.75rem 1rem;
  }
  .dim { opacity: 0.5; font-size: 0.6rem; }
  .muted {
    font-family: var(--font-head);
    font-size: 0.75rem;
    color: var(--text-dim);
    opacity: 0.4;
  }

  /* ─── HERO ─── */
  .hero-pane { border-bottom: 1px solid var(--border); }
  .live-dot {
    color: #00ff00;
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }
  .early-badge {
    font-family: var(--font-head);
    font-size: 0.5rem;
    padding: 0.1rem 0.35rem;
    color: #ffb000;
    border: 1px solid rgba(255,176,0,0.4);
    letter-spacing: 0.08em;
    vertical-align: middle;
    margin-left: 0.5rem;
  }
  .hero-body { padding: 1.25rem 1rem; }
  .stats-row {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }
  .stat { display: flex; flex-direction: column; gap: 0.15rem; }
  .sl {
    font-family: var(--font-head);
    font-size: 0.55rem;
    letter-spacing: 0.15em;
    color: var(--text-dim);
    text-transform: uppercase;
  }
  .sv {
    font-family: var(--font-head);
    font-size: 1.2rem;
    color: var(--phosphor);
    font-weight: 700;
  }
  .sv.big { font-size: 1.5rem; }
  .hero-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .risk-badge {
    font-family: var(--font-head);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    padding: 0.15rem 0.5rem;
    text-transform: uppercase;
  }
  .regime-summary {
    font-family: var(--font-head);
    font-size: 0.65rem;
    letter-spacing: 0.05em;
    color: var(--text-dim);
  }

  /* ─── EQUITY CURVE ─── */
  .eq-wrap {
    padding: 0.5rem 1rem;
    overflow: hidden;
  }
  #equity-canvas {
    width: 100%;
    height: 200px;
    display: block;
  }

  /* ─── PIPELINE ─── */
  .agent-pipeline {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-family: var(--font-head);
    font-size: 0.65rem;
    overflow-x: auto;
  }
  .pipeline-stage {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 90px;
  }
  .pipeline-stage-label {
    font-size: 0.45rem;
    letter-spacing: 0.12em;
    color: var(--text-dim);
    text-transform: uppercase;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.15rem;
    margin-bottom: 0.2rem;
  }
  .pipeline-agents {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .pipeline-arrow {
    color: var(--text-dim);
    font-size: 0.8rem;
    padding: 0 0.2rem;
    align-self: center;
    margin-top: 1.2rem;
  }

  /* ─── AGENT DOT (shared by pipeline + old bar) ─── */
  .agent-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .agent-dot {
    width: 8px;
    height: 8px;
    display: inline-block;
    flex-shrink: 0;
  }
  .agent-name {
    color: var(--text-dim);
    text-transform: uppercase;
    font-size: 0.6rem;
    letter-spacing: 0.08em;
  }
  .agent-time {
    font-size: 0.55rem;
    color: var(--text-dim);
    opacity: 0.6;
  }

  /* ─── MARKET INTELLIGENCE ─── */
  .intel-panels {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }
  .intel-panel {
    flex: 1;
    min-width: 160px;
    font-family: var(--font-head);
  }
  .intel-panel-label {
    font-size: 0.5rem;
    letter-spacing: 0.12em;
    color: var(--text-dim);
    text-transform: uppercase;
    margin-bottom: 0.4rem;
  }
  .intel-val {
    font-size: 0.7rem;
    color: var(--text);
    line-height: 1.6;
  }
  .regime-grid {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    align-items: flex-end;
  }
  .regime-coin-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
  }
  .regime-square {
    width: 8px;
    height: 8px;
    display: block;
  }
  .regime-coin-name {
    font-size: 0.45rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-family: var(--font-head);
  }
  .archetype-row {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    font-family: var(--font-head);
    font-size: 0.65rem;
    margin-top: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--border);
    align-items: center;
  }
  .archetype-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }
  .archetype-name {
    font-size: 0.5rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .archetype-bar {
    font-size: 0.65rem;
    color: var(--phosphor);
    letter-spacing: -0.03em;
  }
  .archetype-detail {
    font-size: 0.5rem;
    color: var(--text-dim);
    opacity: 0.7;
  }

  /* ─── POSITION CARDS ─── */
  .pos-cards {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .pos-card {
    border: 1px solid var(--border);
    border-left: 2px solid #ff3333;
    padding: 0.75rem 1rem;
    background: rgba(255,255,255,0.02);
  }
  .pos-card-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }
  .pos-coin {
    font-family: var(--font-head);
    font-size: 1rem;
    font-weight: 700;
    color: var(--phosphor);
  }
  .pos-dir {
    font-family: var(--font-head);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    padding: 0.15rem 0.4rem;
  }
  .pos-dir.long {
    color: #0a0a0a;
    background: #c8ff00;
  }
  .pos-dir.short {
    color: #fff;
    background: #ff3333;
  }
  .regime-badge {
    font-family: var(--font-head);
    font-size: 0.55rem;
    letter-spacing: 0.08em;
    padding: 0.1rem 0.35rem;
    border: 1px solid;
    text-transform: uppercase;
  }
  .regime-badge.trending { color: #c8ff00; border-color: rgba(200,255,0,0.4); }
  .regime-badge.stable { color: var(--text-dim); border-color: var(--border); }
  .regime-badge.shift { color: #ffb000; border-color: rgba(255,176,0,0.4); }
  .regime-badge.chaotic { color: #ff3333; border-color: rgba(255,51,51,0.4); }
  .pos-pnl {
    margin-left: auto;
    font-family: var(--font-head);
    font-size: 1rem;
    font-weight: 700;
  }
  .pos-card-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.25rem 1rem;
  }
  .pos-field {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .pos-fl {
    font-family: var(--font-head);
    font-size: 0.5rem;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    text-transform: uppercase;
  }
  .pos-fv {
    font-family: var(--font-head);
    font-size: 0.8rem;
    color: var(--text);
  }
  .pos-exit {
    margin-top: 0.4rem;
    font-family: var(--font-body);
    font-size: 0.65rem;
    color: var(--text-dim);
    opacity: 0.8;
    word-break: break-all;
  }
  .pos-exit-raw {
    font-size: 0.5rem;
    color: var(--text-dim);
    opacity: 0.4;
    word-break: break-all;
    margin-top: 0.1rem;
    font-family: var(--font-body);
  }

  /* ─── STATS DASHBOARD ─── */
  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .stats-panel {
    font-family: var(--font-head);
    font-size: 0.75rem;
  }
  .stats-panel-title {
    font-size: 0.55rem;
    letter-spacing: 0.12em;
    color: var(--text-dim);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid var(--border);
  }
  .coin-stats-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-head);
    font-size: 0.7rem;
  }
  .coin-stats-table th {
    font-size: 0.5rem;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    text-transform: uppercase;
    text-align: left;
    padding: 0.2rem 0.4rem;
    border-bottom: 1px solid var(--border);
    font-weight: 400;
  }
  .coin-stats-table td {
    padding: 0.25rem 0.4rem;
    border-bottom: 1px solid rgba(255,255,255,0.03);
    color: var(--text);
  }
  .coin-stats-table th:not(:first-child),
  .coin-stats-table td:not(:first-child) {
    text-align: right;
  }
  .stat-row {
    display: flex;
    justify-content: space-between;
    padding: 0.3rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.03);
    font-size: 0.7rem;
  }
  .stat-row-label { color: var(--text-dim); }
  .stat-row-value { color: var(--text); font-weight: 700; }

  /* ─── CLOSED TRADES ─── */
  .closed-cards {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .closed-card {
    display: grid;
    grid-template-columns: 50px 55px 1fr auto;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border);
    border-left: 2px solid #ff3333;
    background: rgba(255,255,255,0.02);
    align-items: center;
    font-family: var(--font-head);
    font-size: 0.75rem;
  }
  .closed-coin { color: var(--phosphor); font-weight: 700; }
  .closed-detail {
    font-size: 0.6rem;
    color: var(--text-dim);
  }
  .closed-pnl {
    font-weight: 700;
    font-size: 0.85rem;
    text-align: right;
  }
  .closed-sub {
    font-size: 0.6rem;
    color: var(--text-dim);
    text-align: right;
  }

  /* ─── COLORS ─── */
  .c-pos { color: #c8ff00; }
  .c-neg { color: #ff3333; }
  .c-long { color: #c8ff00; }
  .c-short { color: #ff3333; }

  /* ─── FOOTER ─── */
  .footer {
    display: flex;
    justify-content: space-between;
    padding: 0.5rem 1rem;
    font-family: var(--font-head);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    color: var(--text-dim);
  }
  .footer-link {
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-link:hover {
    color: var(--phosphor);
  }

  /* ─── MOBILE ─── */
  @media (max-width: 600px) {
    .page { padding: 0.5rem; }
    .stats-row { gap: 1.2rem; }
    .sv { font-size: 1rem; }
    .sv.big { font-size: 1.3rem; }
    .pos-card-grid { grid-template-columns: repeat(2, 1fr); }
    .stats-grid { grid-template-columns: 1fr; }
    .closed-card {
      grid-template-columns: 1fr 1fr;
      gap: 0.3rem;
    }
    .intel-panels { flex-direction: column; gap: 1rem; }
    .agent-pipeline { gap: 0.3rem; }
    .pipeline-arrow { display: none; }
  }
</style>

<script is:inline>
(function(){
  var PORTFOLIO_API = '/api/portfolio.json';
  var PRICE_API = '/api/envy?coins=BTC,ETH,SOL,DOGE,AVAX,LINK,ARB,NEAR,SUI,INJ&indicators=CLOSE_PRICE_15M';

  var portfolioData = null;
  var livePrices = {};
  var lastPriceUpdate = 0;

  function fmt$(v){
    if(v==null) return '—';
    var abs = Math.abs(v);
    var s = abs.toLocaleString('en',{minimumFractionDigits:2,maximumFractionDigits:2});
    return v<0 ? '-$'+s : '$'+s;
  }
  function fmtPct(v){
    if(v==null) return '—';
    return (v>=0?'+':'')+v.toFixed(2)+'%';
  }
  function fmtTime(iso){
    if(!iso) return '—';
    return new Date(iso).toISOString().replace('T',' ').slice(5,16)+' UTC';
  }
  function pnlClass(v){ return v>=0?'c-pos':'c-neg'; }
  function ago(ts){
    var s = Math.floor((Date.now() - ts) / 1000);
    if(s < 5) return 'just now';
    if(s < 60) return s+'s ago';
    if(s < 3600) return Math.floor(s/60)+'m ago';
    return Math.floor(s/3600)+'h ago';
  }
  function agoFromISO(iso){
    if(!iso) return Infinity;
    return (Date.now() - new Date(iso).getTime()) / 1000;
  }
  function getCurrentPrice(coin){ return livePrices[coin] || null; }

  function calcPnl(pos, price){
    if(!price || !pos.entry_price) return {pct:0, dollars:0};
    var pct;
    if(pos.direction === 'LONG'){
      pct = ((price - pos.entry_price) / pos.entry_price) * 100;
    } else {
      pct = ((pos.entry_price - price) / pos.entry_price) * 100;
    }
    var size = pos.size_usd || 0;
    return {pct: pct, dollars: size * (pct / 100)};
  }

  function fmtHold(hours){
    if(!hours && hours !== 0) return '—';
    if(hours < 1) return Math.round(hours * 60) + 'm';
    return hours + 'h';
  }

  var riskColors = {green:'#c8ff00',yellow:'#ffb000',orange:'#ff8800',red:'#ff3333'};

  // ─── EXIT EXPRESSION TRANSLATION ───
  function translateExit(expr){
    if(!expr) return '';
    var rules = [
      [/RSI_3H30M\s*>=\s*85/g, 'RSI overbought'],
      [/RSI_3H30M\s*<=\s*15/g, 'RSI oversold'],
      [/XONE_I_NET\s*<=\s*10/g, 'social sentiment drops'],
      [/XONE_I_NET\s*>=\s*90/g, 'social sentiment peaks'],
      [/HURST_24H\s*<\s*0\.50/g, 'trend breaks'],
      [/LYAPUNOV_24H\s*>=\s*1\.90/g, 'chaos detected'],
      [/ADX_3H30M\s*>=\s*40/g, 'trend established'],
      [/DOJI_VELOCITY\s*<\s*1\.0/g, 'indecision resolves'],
      [/EMA_N_24H\s*<\s*1\.0/g, 'below average'],
    ];
    var translated = expr;
    for(var i=0; i<rules.length; i++){
      translated = translated.replace(rules[i][0], rules[i][1]);
    }
    return translated;
  }

  // ─── EQUITY CURVE (raw canvas) ───
  function drawEquityCurve(curve){
    var canvas = document.getElementById('equity-canvas');
    var emptyMsg = document.getElementById('eq-empty');

    if(!curve || curve.length < 2){
      if(canvas) canvas.style.display = 'none';
      if(emptyMsg) emptyMsg.style.display = 'block';
      return;
    }

    // Early data: < 10 points — draw placeholder dashed line
    if(curve.length < 10){
      if(emptyMsg) emptyMsg.style.display = 'none';
      if(canvas){
        canvas.style.display = 'block';
        var dpr0 = window.devicePixelRatio || 1;
        var rect0 = canvas.getBoundingClientRect();
        canvas.width = rect0.width * dpr0;
        canvas.height = rect0.height * dpr0;
        var ctx0 = canvas.getContext('2d');
        ctx0.scale(dpr0, dpr0);
        var W0 = rect0.width;
        var H0 = rect0.height;
        ctx0.clearRect(0, 0, W0, H0);
        var midY0 = H0 / 2;
        ctx0.setLineDash([8, 6]);
        ctx0.strokeStyle = 'rgba(200,255,0,0.3)';
        ctx0.lineWidth = 1;
        ctx0.beginPath();
        ctx0.moveTo(20, midY0);
        ctx0.lineTo(W0 - 20, midY0);
        ctx0.stroke();
        ctx0.setLineDash([]);
        ctx0.fillStyle = 'rgba(200,255,0,0.35)';
        ctx0.font = '11px JetBrains Mono, monospace';
        ctx0.textAlign = 'center';
        ctx0.fillText('$115 — COLLECTING DATA', W0 / 2, midY0 - 12);
        ctx0.font = '9px JetBrains Mono, monospace';
        ctx0.fillStyle = 'rgba(200,255,0,0.2)';
        ctx0.fillText(curve.length + ' of 10 points', W0 / 2, midY0 + 16);
      }
      return;
    }

    if(canvas) canvas.style.display = 'block';
    if(emptyMsg) emptyMsg.style.display = 'none';

    var dpr = window.devicePixelRatio || 1;
    var rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    var ctx = canvas.getContext('2d');
    ctx.scale(dpr, dpr);
    var W = rect.width;
    var H = rect.height;
    var pad = {t:20, r:50, b:25, l:10};

    var vals = curve.map(function(p){ return p.v; });
    var minV = Math.min.apply(null, vals);
    var maxV = Math.max.apply(null, vals);
    var range = maxV - minV || 1;
    minV -= range * 0.1;
    maxV += range * 0.1;
    range = maxV - minV;

    var cw = W - pad.l - pad.r;
    var ch = H - pad.t - pad.b;

    // Grid lines
    ctx.strokeStyle = 'rgba(255,51,51,0.08)';
    ctx.lineWidth = 1;
    var gridLines = 5;
    for(var i=0; i<=gridLines; i++){
      var y = pad.t + (ch * i / gridLines);
      ctx.beginPath();
      ctx.moveTo(pad.l, y);
      ctx.lineTo(W - pad.r, y);
      ctx.stroke();
      var val = maxV - (range * i / gridLines);
      ctx.fillStyle = 'rgba(255,51,51,0.3)';
      ctx.font = '10px JetBrains Mono, monospace';
      ctx.textAlign = 'left';
      ctx.fillText('$' + val.toFixed(2), W - pad.r + 4, y + 3);
    }

    // Time labels
    ctx.fillStyle = 'rgba(255,51,51,0.2)';
    ctx.font = '9px JetBrains Mono, monospace';
    ctx.textAlign = 'center';
    var tSteps = Math.min(6, curve.length);
    for(var i=0; i<tSteps; i++){
      var idx = Math.floor(i * (curve.length-1) / (tSteps-1));
      var x = pad.l + (idx / (curve.length-1)) * cw;
      var d = new Date(curve[idx].t);
      ctx.fillText(d.toISOString().slice(11,16), x, H - 5);
    }

    function px(i){ return pad.l + (i / (curve.length-1)) * cw; }
    function py(v){ return pad.t + ch - ((v - minV) / range) * ch; }

    // Area fill
    ctx.beginPath();
    ctx.moveTo(px(0), py(vals[0]));
    for(var i=1; i<vals.length; i++) ctx.lineTo(px(i), py(vals[i]));
    ctx.lineTo(px(vals.length-1), pad.t + ch);
    ctx.lineTo(px(0), pad.t + ch);
    ctx.closePath();
    ctx.fillStyle = 'rgba(255,51,51,0.08)';
    ctx.fill();

    // Line
    ctx.beginPath();
    ctx.moveTo(px(0), py(vals[0]));
    for(var i=1; i<vals.length; i++) ctx.lineTo(px(i), py(vals[i]));
    ctx.strokeStyle = '#ff3333';
    ctx.lineWidth = 1.5;
    ctx.stroke();

    // Current value dot
    var lastX = px(vals.length-1);
    var lastY = py(vals[vals.length-1]);
    ctx.beginPath();
    ctx.arc(lastX, lastY, 3, 0, Math.PI*2);
    ctx.fillStyle = '#ff3333';
    ctx.fill();

    // Range label
    var el = document.getElementById('eq-range');
    if(el) el.textContent = curve.length + ' points · $' + minV.toFixed(2) + ' – $' + maxV.toFixed(2);
  }

  // ─── PIPELINE STATUS ───
  function renderAgents(agents){
    var pipeline = document.getElementById('agent-pipeline');
    if(!pipeline || !agents || !agents.heartbeat) return;
    var stages = [
      {label:'DATA', agents:['regime','liquidity','spread_monitor']},
      {label:'ANALYSIS', agents:['cross_timeframe','funding']},
      {label:'SIGNALS', agents:['harvester','correlation']},
      {label:'ACTION', agents:['risk','evolution','execution']},
    ];
    var html = '';
    for(var s=0; s<stages.length; s++){
      if(s > 0) html += '<span class="pipeline-arrow">→</span>';
      var stage = stages[s];
      html += '<div class="pipeline-stage">';
      html += '<div class="pipeline-stage-label">'+stage.label+'</div>';
      html += '<div class="pipeline-agents">';
      for(var a=0; a<stage.agents.length; a++){
        var name = stage.agents[a];
        var ts = agents.heartbeat[name];
        var secs = agoFromISO(ts);
        var color = secs < 900 ? '#c8ff00' : (secs < 2400 ? '#ffb000' : '#ff3333');
        var label = ts ? ago(new Date(ts).getTime()) : 'unknown';
        html += '<div class="agent-item">';
        html += '<span class="agent-dot" style="background:'+color+'"></span>';
        html += '<span class="agent-name">'+name+'</span>';
        html += '<span class="agent-time">'+label+'</span>';
        html += '</div>';
      }
      html += '</div></div>';
    }
    pipeline.innerHTML = html;
  }

  // ─── MARKET INTELLIGENCE ───
  function renderIntelligence(){
    if(!portfolioData || !portfolioData.agents) return;
    var agents = portfolioData.agents;

    // REGIMES
    var regimeGrid = document.getElementById('regime-grid');
    if(regimeGrid && agents.regimes && agents.regimes.coins){
      var coins = agents.regimes.coins;
      var regimeColors = {trending:'#c8ff00',stable:'#666',shift:'#ffb000',chaotic:'#ff3333'};
      var html = '';
      for(var coin in coins){
        var regime = coins[coin].regime || 'stable';
        var color = regimeColors[regime] || '#666';
        var shortName = coin.replace('USDT','').replace('PERP','').slice(0,3);
        html += '<div class="regime-coin-wrap">';
        html += '<span class="regime-square" style="background:'+color+'"></span>';
        html += '<span class="regime-coin-name">'+shortName+'</span>';
        html += '</div>';
      }
      regimeGrid.innerHTML = html || '<span class="muted">No data</span>';
    }

    // SPREAD
    var spreadVal = document.getElementById('spread-val');
    if(spreadVal){
      var spread = agents.spread;
      if(!spread || !spread.coins){
        spreadVal.textContent = 'All clear — no anomalies';
      } else {
        var anomalies = [];
        for(var sc in spread.coins){
          var st = spread.coins[sc];
          if(st && st.status && st.status !== 'normal'){
            anomalies.push(sc+': '+st.status);
          }
        }
        spreadVal.textContent = anomalies.length ? anomalies.join(' · ') : 'All clear — no anomalies';
      }
    }

    // FUNDING
    var fundingVal = document.getElementById('funding-val');
    if(fundingVal){
      var funding = agents.funding;
      if(!funding || !funding.coins){
        fundingVal.textContent = 'Neutral — no pressure';
      } else {
        var unstable = [];
        for(var fc in funding.coins){
          var fd = funding.coins[fc];
          if(fd && fd.velocity_direction && fd.velocity_direction !== 'stable'){
            unstable.push(fc+'('+fd.velocity_direction+')');
          }
        }
        fundingVal.textContent = unstable.length ? unstable.join(' · ') : 'Neutral — no pressure';
      }
    }

    // ARCHETYPES
    var archetypeRow = document.getElementById('archetype-row');
    if(archetypeRow){
      var archetypes = agents.archetypes;
      if(!archetypes || archetypes.length === 0){
        archetypeRow.innerHTML = '<div class="muted">Monitoring 6 signal archetypes...</div>';
      } else {
        var html = '';
        for(var i=0; i<archetypes.length; i++){
          var arch = archetypes[i];
          var total = arch.conditions_total || 4;
          var met = arch.conditions_met || 0;
          var filled = Math.round((met / total) * 4);
          var bar = '';
          for(var b=0; b<4; b++) bar += (b < filled ? '▓' : '░');
          html += '<div class="archetype-item">';
          html += '<span class="archetype-name">'+arch.name+'</span>';
          html += '<span class="archetype-bar">'+bar+'</span>';
          if(arch.closest_coin){
            html += '<span class="archetype-detail">'+arch.closest_coin+' '+met+'/'+total+'</span>';
          }
          html += '</div>';
        }
        archetypeRow.innerHTML = html;
      }
    }
  }

  // ─── STATS DASHBOARD ───
  function renderStats(stats){
    var el = document.getElementById('stats-dashboard');
    if(!el) return;
    var section = el.closest('.section');
    if(!stats || !stats.total || stats.total < 5){
      if(section) section.style.display = 'none';
      return;
    }
    if(section) section.style.display = 'block';

    // Left: P&L by coin
    var left = '<div class="stats-panel">';
    left += '<div class="stats-panel-title">P&L by coin</div>';
    left += '<table class="coin-stats-table"><thead><tr><th>Coin</th><th>Trades</th><th>WR%</th><th>P&L</th></tr></thead><tbody>';
    var coins = stats.byCoin || {};
    var coinKeys = Object.keys(coins).sort(function(a,b){ return (coins[b].pnl||0) - (coins[a].pnl||0); });
    for(var i=0; i<coinKeys.length; i++){
      var c = coinKeys[i];
      var s = coins[c];
      left += '<tr>';
      left += '<td style="color:var(--phosphor);font-weight:700">'+c+'</td>';
      left += '<td>'+s.trades+'</td>';
      left += '<td>'+(s.winRate != null ? s.winRate.toFixed(0)+'%' : '—')+'</td>';
      left += '<td class="'+pnlClass(s.pnl)+'">'+fmt$(s.pnl)+'</td>';
      left += '</tr>';
    }
    left += '</tbody></table></div>';

    // Right: performance
    var right = '<div class="stats-panel">';
    right += '<div class="stats-panel-title">Performance</div>';
    var best = stats.bestTrade || {};
    var worst = stats.worstTrade || {};
    right += '<div class="stat-row"><span class="stat-row-label">Best Trade</span><span class="stat-row-value c-pos">'+(best.coin||'—')+' '+(best.direction||'')+' '+fmtPct(best.pnlPct)+' ('+fmt$(best.pnl)+')</span></div>';
    right += '<div class="stat-row"><span class="stat-row-label">Worst Trade</span><span class="stat-row-value c-neg">'+(worst.coin||'—')+' '+(worst.direction||'')+' '+fmtPct(worst.pnlPct)+' ('+fmt$(worst.pnl)+')</span></div>';
    right += '<div class="stat-row"><span class="stat-row-label">Avg Hold Time</span><span class="stat-row-value">'+fmtHold(stats.avgHoldHours)+'</span></div>';
    right += '<div class="stat-row"><span class="stat-row-label">Avg P&L</span><span class="stat-row-value '+pnlClass(stats.avgPnl)+'">'+fmt$(stats.avgPnl)+'</span></div>';
    right += '<div class="stat-row"><span class="stat-row-label">Total P&L</span><span class="stat-row-value '+pnlClass(stats.totalPnl)+'">'+fmt$(stats.totalPnl)+'</span></div>';

    right += '<div class="stats-panel-title" style="margin-top:0.75rem">Long vs Short</div>';
    right += '<div class="stat-row"><span class="stat-row-label">Long WR ('+(stats.longCount||0)+' trades)</span><span class="stat-row-value">'+(stats.longWinRate != null ? stats.longWinRate.toFixed(1)+'%' : '—')+'</span></div>';
    right += '<div class="stat-row"><span class="stat-row-label">Short WR ('+(stats.shortCount||0)+' trades)</span><span class="stat-row-value">'+(stats.shortWinRate != null ? stats.shortWinRate.toFixed(1)+'%' : '—')+'</span></div>';
    right += '</div>';

    el.innerHTML = left + right;
  }

  // ─── RENDER ───
  function render(){
    var d = portfolioData;
    if(!d) return;

    var lt = d.liveTrading;
    if(!lt || !lt.enabled) return;

    var livePos = lt.positions || [];
    var liveClosed = lt.closed || [];
    var regimes = d.agents && d.agents.regimes;

    // Compute unrealized P&L across live positions
    var totalUnrealized = 0;
    for(var i=0; i<livePos.length; i++){
      var price = getCurrentPrice(livePos[i].coin);
      if(price){
        var r = calcPnl(livePos[i], price);
        totalUnrealized += r.dollars;
      }
    }
    var totalInPositions = 0;
    for(var i=0; i<livePos.length; i++) totalInPositions += (livePos[i].size_usd||0);

    // Hero: equity from HL account value
    var startingEquity = 115;
    var equity = startingEquity + totalUnrealized;
    var totalPnl = totalUnrealized;
    var pnlPct = startingEquity > 0 ? (totalPnl / startingEquity) * 100 : 0;

    // Uptime
    var uptimeStr = '—';
    if(lt.started){
      var uptimeMs = Date.now() - new Date(lt.started).getTime();
      var uptimeH = Math.floor(uptimeMs / 3600000);
      if(uptimeH < 24){
        uptimeStr = uptimeH + 'h';
      } else {
        uptimeStr = Math.floor(uptimeH / 24) + 'd ' + (uptimeH % 24) + 'h';
      }
    }

    document.getElementById('s-equity').textContent = fmt$(equity);
    var pnlEl = document.getElementById('s-pnl');
    pnlEl.textContent = fmtPct(pnlPct) + ' (' + fmt$(totalPnl) + ')';
    pnlEl.className = 'sv ' + pnlClass(totalPnl);

    // Win rate: early data context vs normal
    var winRateEl = document.getElementById('s-winrate');
    var trades = lt.trades || 0;
    var wins = lt.wins || 0;
    if(trades < 20){
      var losses = trades - wins;
      var closedPnl = 0;
      for(var j=0; j<liveClosed.length; j++){
        closedPnl += (liveClosed[j].pnl_dollars || liveClosed[j].pnl_usd || 0);
      }
      winRateEl.textContent = wins+'W '+losses+'L · '+fmt$(closedPnl);
    } else {
      winRateEl.textContent = (wins / trades * 100).toFixed(0) + '%';
    }

    document.getElementById('s-trades').textContent = trades;
    document.getElementById('s-uptime').textContent = uptimeStr;

    // EARLY DATA badge
    var earlyBadge = document.getElementById('early-badge');
    if(earlyBadge) earlyBadge.style.display = (trades < 20) ? 'inline' : 'none';

    document.getElementById('pos-count').textContent = '(' + livePos.length + ')';
    document.getElementById('closed-count').textContent = '(' + liveClosed.length + ')';
    document.getElementById('updated').textContent = lastPriceUpdate ? 'Prices: ' + ago(lastPriceUpdate) : 'Loading prices...';

    // Risk badge
    var risk = d.agents && d.agents.risk;
    if(risk){
      var badge = document.getElementById('risk-badge');
      var st = (risk.status||'green').toLowerCase();
      var col = riskColors[st] || '#c8ff00';
      badge.textContent = 'RISK: ' + st.toUpperCase();
      badge.style.color = st === 'green' ? '#0a0a0a' : '#fff';
      badge.style.background = col;
    }

    // Regime summary
    if(regimes && regimes.summary){
      var rs = regimes.summary;
      var parts = [];
      if(rs.trending) parts.push(rs.trending + ' trending');
      if(rs.stable) parts.push(rs.stable + ' stable');
      if(rs.shift) parts.push(rs.shift + ' shift');
      if(rs.chaotic) parts.push(rs.chaotic + ' chaotic');
      document.getElementById('regime-summary').textContent = parts.join(' · ');
    }

    // Equity curve
    drawEquityCurve(d.liveEquityCurve);

    // Pipeline
    renderAgents(d.agents);

    // Market intelligence
    renderIntelligence();

    // Stats
    renderStats(lt.stats);

    // ─── OPEN POSITIONS ───
    var posBody = document.getElementById('positions-body');
    if(livePos.length === 0){
      posBody.innerHTML = '<div class="muted">No open positions.</div>';
    } else {
      var html = '<div class="pos-cards">';
      for(var i=0; i<livePos.length; i++){
        var p = livePos[i];
        var dirCls = p.direction==='LONG' ? 'long' : 'short';
        var curPrice = getCurrentPrice(p.coin);
        var pnlResult = curPrice ? calcPnl(p, curPrice) : {pct:null, dollars:null};
        var coinRegime = regimes && regimes.coins && regimes.coins[p.coin];
        var regimeStr = coinRegime ? coinRegime.regime : '';

        html += '<div class="pos-card">';
        html += '<div class="pos-card-top">';
        html += '<span class="pos-coin">'+p.coin+'</span>';
        html += '<span class="pos-dir '+dirCls+'">'+p.direction+'</span>';
        if(regimeStr) html += '<span class="regime-badge '+regimeStr+'">'+regimeStr+'</span>';
        if(pnlResult.pct !== null){
          html += '<span class="pos-pnl '+pnlClass(pnlResult.pct)+'">'+fmtPct(pnlResult.pct)+' ('+fmt$(pnlResult.dollars)+')</span>';
        }
        html += '</div>';
        html += '<div class="pos-card-grid">';
        html += '<div class="pos-field"><span class="pos-fl">Entry</span><span class="pos-fv">'+fmt$(p.entry_price)+'</span></div>';
        html += '<div class="pos-field"><span class="pos-fl">Current</span><span class="pos-fv '+(curPrice?pnlClass(pnlResult.pct||0):'')+'">'+(curPrice?fmt$(curPrice):'—')+'</span></div>';
        html += '<div class="pos-field"><span class="pos-fl">Size</span><span class="pos-fv">'+fmt$(p.size_usd)+'</span></div>';
        html += '<div class="pos-field"><span class="pos-fl">Sharpe</span><span class="pos-fv">'+(p.sharpe||0).toFixed(2)+'</span></div>';
        html += '<div class="pos-field"><span class="pos-fl">Stop Loss</span><span class="pos-fv">'+fmt$(p.stop_loss)+'</span></div>';
        html += '</div>';
        if(p.exit_expression){
          var translated = translateExit(p.exit_expression);
          html += '<div class="pos-exit">EXIT: '+translated;
          if(translated !== p.exit_expression){
            html += '<div class="pos-exit-raw">'+p.exit_expression+'</div>';
          }
          html += '</div>';
        }
        html += '</div>';
      }
      html += '</div>';
      posBody.innerHTML = html;
    }

    // ─── TRADE HISTORY ───
    var closedBody = document.getElementById('closed-body');
    if(liveClosed.length === 0){
      closedBody.innerHTML = '<div class="muted">No closed trades yet.</div>';
    } else {
      var html = '<div class="closed-cards">';
      for(var j=liveClosed.length-1; j>=0; j--){
        var c = liveClosed[j];
        var dirCls = c.direction==='LONG' ? 'c-long' : 'c-short';
        var holdH = '';
        if(c.entry_time && c.exit_time){
          var ms = new Date(c.exit_time).getTime() - new Date(c.entry_time).getTime();
          holdH = fmtHold(Math.round(ms / 3600000 * 10) / 10);
        }
        html += '<div class="closed-card">';
        html += '<span class="closed-coin">'+c.coin+'</span>';
        html += '<span class="'+dirCls+'">'+c.direction+'</span>';
        html += '<span class="closed-detail">'+fmt$(c.entry_price)+' → '+fmt$(c.exit_price)+' · '+fmtPct(c.pnl_pct)+' · '+c.exit_reason+(holdH ? ' · '+holdH : '')+'</span>';
        html += '<div><div class="closed-pnl '+pnlClass(c.pnl_pct)+'">'+fmt$(c.pnl_usd)+'</div></div>';
        html += '</div>';
      }
      html += '</div>';
      closedBody.innerHTML = html;
    }
  }

  // ─── DATA FETCHING ───
  function fetchPrices(){
    return fetch(PRICE_API).then(function(res){ return res.json(); }).then(function(d){
      if(d.matrix){
        for(var coin in d.matrix){
          if(d.matrix[coin].CLOSE_PRICE_15M != null){
            livePrices[coin] = d.matrix[coin].CLOSE_PRICE_15M;
          }
        }
      }
      lastPriceUpdate = Date.now();
    }).catch(function(e){ console.error('Price fetch failed:', e); });
  }

  function loadPortfolio(){
    return fetch(PORTFOLIO_API).then(function(res){ return res.json(); }).then(function(d){
      portfolioData = d;
    }).catch(function(e){ console.error('Portfolio fetch failed:', e); });
  }

  // Initial load
  loadPortfolio().then(function(){
    render();
    renderIntelligence();
    fetchPrices().then(function(){ render(); }).catch(function(){});
  }).catch(function(e){ console.error('Initial load failed:', e); });

  // Tick agent status every 5s
  setInterval(function(){
    if(lastPriceUpdate){
      var el = document.getElementById('updated');
      if(el) el.textContent = 'Prices: ' + ago(lastPriceUpdate);
    }
    if(portfolioData && portfolioData.agents) renderAgents(portfolioData.agents);
  }, 5000);

  // Prices every 30s
  setInterval(function(){
    fetchPrices().then(function(){ render(); }).catch(function(){});
  }, 30000);

  // Portfolio every 5min
  setInterval(function(){
    loadPortfolio().then(function(){ render(); renderIntelligence(); }).catch(function(){});
  }, 300000);

  // Redraw equity on resize
  window.addEventListener('resize', function(){
    if(portfolioData && portfolioData.liveEquityCurve) drawEquityCurve(portfolioData.liveEquityCurve);
  });
})();
</script>
