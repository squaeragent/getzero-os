  // ─── MARKET STATE ───
  function renderMarketState(data){
    if(!data || !data.agents) return;
    var agents = data.agents;

    // Regime summary as text counts
    var regimeSummary = document.getElementById('regime-summary');
    if(regimeSummary && agents.regimes && agents.regimes.coins){
      var coins = agents.regimes.coins;
      var counts = {trending:0, stable:0, chaotic:0, shift:0};
      for(var coin in coins){
        var r = (coins[coin].regime || 'stable').toLowerCase();
        if(counts[r] != null) counts[r]++;
        else counts.stable++;
      }
      var parts = [];
      if(counts.trending > 0) parts.push('<span class="regime-trending">'+counts.trending+' trending</span>');
      if(counts.stable > 0) parts.push('<span class="regime-stable">'+counts.stable+' stable</span>');
      if(counts.chaotic > 0) parts.push('<span class="regime-chaotic">'+counts.chaotic+' chaotic</span>');
      if(counts.shift > 0) parts.push('<span class="regime-shift">'+counts.shift+' shift</span>');
      regimeSummary.innerHTML = parts.length > 0 ? parts.join(' · ') : '<span class="muted">No regime data</span>';
    }

    // Exception-only status line
    var statusLine = document.getElementById('status-line');
    if(statusLine){
      var spreadOk = true;
      var fundingOk = true;
      var spreadIssues = [];
      var fundingIssues = [];

      if(agents.spread && agents.spread.coins){
        for(var sc in agents.spread.coins){
          var st = agents.spread.coins[sc];
          if(st && st.status && st.status.toLowerCase() !== 'normal'){
            spreadOk = false;
            var shortSC = sc.replace('USDT','').replace('PERP','').slice(0,4);
            spreadIssues.push(shortSC);
          }
        }
      }
      if(agents.funding && agents.funding.coins){
        for(var fc in agents.funding.coins){
          var fd = agents.funding.coins[fc];
          if(fd && fd.velocity_direction && fd.velocity_direction !== 'stable'){
            fundingOk = false;
            var shortFC = fc.replace('USDT','').replace('PERP','').slice(0,4);
            fundingIssues.push(shortFC+'('+fd.velocity_direction+')');
          }
        }
      }

      var sHtml = '';
      if(spreadOk){
        sHtml += '<span class="status-ok">Spreads ✓</span>';
      } else {
        sHtml += '<span class="status-warn">Spreads: '+spreadIssues.join(', ')+'</span>';
      }
      if(fundingOk){
        sHtml += '<span class="status-ok">Funding ✓</span>';
      } else {
        sHtml += '<span class="status-warn">Funding: '+fundingIssues.join(', ')+'</span>';
      }
      statusLine.innerHTML = sHtml;
    }
  }

  // ─── SIGNAL ARCHETYPES ───
  function renderArchetypes(archetypes){
    var grid = document.getElementById('archetype-grid');
    if(!grid) return;

    if(!archetypes || archetypes.length === 0){
      grid.innerHTML = '<div class="muted" style="grid-column:1/-1">Not enough data</div>';
      return;
    }

    var html = '';
    for(var i=0; i<archetypes.length; i++){
      var arch = archetypes[i];
      var total = arch.conditions_total || 4;
      var met = arch.conditions_met || 0;
      var pct = total > 0 ? (met / total * 100) : 0;
      var coin = arch.closest_coin || '—';
      var conditions = arch.conditions || [];

      html += '<div class="archetype-card">';
      html += '<div class="archetype-card-title">'+(arch.name||'UNKNOWN')+'</div>';
      html += '<div class="archetype-card-main">';
      html += '<div class="archetype-prog-wrap"><div class="archetype-prog-fill" style="width:'+pct+'%"></div></div>';
      html += '<span class="archetype-coin">'+coin+'</span>';
      html += '<span class="archetype-fraction">'+met+'/'+total+'</span>';
      html += '</div>';
      if(conditions.length > 0){
        html += '<div class="archetype-conditions">'+conditions.join(' · ')+'</div>';
      } else if(arch.conditions_summary){
        html += '<div class="archetype-conditions">'+arch.conditions_summary+'</div>';
      }
      html += '</div>';
    }
    grid.innerHTML = html;
