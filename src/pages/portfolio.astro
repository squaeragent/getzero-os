---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="ZERO OS — Live Trading" description="14-agent autonomous trading system. 1,190+ signals across 40 coins. Live on Hyperliquid.">
  <div class="page">
    <div class="terminal-border">

      <!-- NAV BAR -->
      <div class="nav-bar">
        <a href="/" class="nav-item">◇ ZERO OS</a>
        <a href="/thesis" class="nav-item">THESIS</a>
        <span class="nav-item nav-active">PORTFOLIO</span>
        <span class="nav-live"><span class="live-dot">●</span> LIVE</span>
      </div>

      <!-- EQUITY HERO -->
      <div class="hero-pane">
        <div class="hero-body">
          <div class="equity-hero">
            <div class="eq-number" id="eq-number">$—</div>
            <div class="eq-pnl" id="eq-pnl">—</div>
            <div class="eq-realized" id="eq-realized">—</div>
            <div class="eq-meta" id="eq-meta">— trades · — uptime</div>
            <div class="eq-badges">
              <span class="risk-badge" id="risk-badge">—</span>
              <span class="early-badge" id="early-badge" style="display:none">EARLY DATA</span>
            </div>
          </div>
        </div>
      </div>

      <!-- EQUITY CURVE -->
      <div class="section">
        <div class="ph">ACCOUNT VALUE <span class="dim" id="eq-range"></span></div>
        <div class="sb eq-wrap">
          <canvas id="equity-canvas" width="860" height="120"></canvas>
          <div class="muted" id="eq-empty" style="display:none">Collecting data...</div>
        </div>
      </div>

      <!-- DECISION STREAM -->
      <div class="section">
        <div class="ph">DECISION STREAM <span class="dim" id="ds-count"></span> <span class="ds-live" id="ds-live">● LIVE</span></div>
        <div class="sb ds-wrap" id="ds-body">
          <div class="muted">Loading decisions...</div>
        </div>
      </div>

      <!-- OPEN POSITIONS -->
      <div class="section">
        <div class="ph">OPEN POSITIONS <span class="dim" id="pos-count">(0)</span></div>
        <div class="sb" id="positions-body">
          <div class="muted">Fetching live data...</div>
        </div>
      </div>

      <!-- MARKET STATE -->
      <div class="section" id="market-state-section">
        <div class="ph">MARKET STATE</div>
        <div class="sb">
          <div class="regime-summary" id="regime-summary"><span class="muted">Loading regimes...</span></div>
          <div class="status-line" id="status-line">
            <span class="status-ok">Spreads ✓</span>
            <span class="status-ok">Funding ✓</span>
          </div>
        </div>
      </div>

      <!-- GATE FUNNEL -->
      <div class="section" id="funnel-section">
        <div class="ph">GATE FUNNEL <span class="dim" id="funnel-meta"></span></div>
        <div class="sb" id="funnel-body">
          <div class="muted">Loading funnel...</div>
        </div>
      </div>

      <!-- SIGNAL LANDSCAPE -->
      <div class="section" id="landscape-section">
        <div class="ph">SIGNAL UNIVERSE <span class="dim" id="landscape-meta"></span></div>
        <div class="sb landscape-grid" id="landscape-body">
          <div class="muted">Loading signals...</div>
        </div>
      </div>

      <!-- IMMUNE HEARTBEAT -->
      <div class="section" id="immune-section">
        <div class="ph">IMMUNE SYSTEM <span class="dim" id="immune-meta">(24h)</span></div>
        <div class="sb" id="immune-body">
          <div class="muted">Loading health...</div>
        </div>
      </div>

      <!-- SYSTEM STATUS (collapsed) -->
      <div class="section">
        <div class="ph system-ph" id="system-ph">SYSTEM <span id="system-summary">—</span></div>
        <div class="sb">
          <div class="system-healthy" id="system-healthy">Pipeline healthy — all agents reporting</div>
          <div class="system-body" id="system-body">
            <div class="agent-pipeline" id="agent-pipeline"></div>
          </div>
        </div>
      </div>

      <!-- PERFORMANCE (≥5 trades) -->
      <div class="section" id="stats-section" style="display:none">
        <div class="ph">PERFORMANCE</div>
        <div class="sb">
          <div class="dir-cards" id="dir-cards"></div>
          <div class="stats-grid" id="stats-dashboard">
            <div class="muted">Loading stats...</div>
          </div>
        </div>
      </div>

      <!-- TRADE HISTORY -->
      <div class="section">
        <div class="ph">CLOSED TRADES <span class="dim" id="closed-count">(0)</span> <span class="show-all-toggle" id="show-all-toggle" style="display:none">show all</span></div>
        <div class="sb" id="closed-body">
          <div class="muted">Fetching live data...</div>
        </div>
      </div>

      <!-- FOOTER -->
      <div class="footer">
        <a href="/" class="footer-link">◇ ZERO OS</a>
        <span class="dim" id="updated">—</span>
      </div>

    </div>
  </div>
</BaseLayout>

<style is:global>
  /* ─── PAGE ─── */
  .page {
    max-width: 960px;
    margin: 0 auto;
    padding: 1rem;
    min-height: 100vh;
  }
  .terminal-border {
    border: 1px solid rgba(200,255,0,0.25);
    min-height: 100vh;
  }

  /* ─── NAV BAR ─── */
  .nav-bar {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 0.5rem 1rem;
    border-bottom: 1px solid var(--border);
    font-family: var(--font-head);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .nav-item {
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-item:hover { color: var(--phosphor); }
  .nav-active { color: var(--phosphor); }
  .nav-live {
    margin-left: auto;
    font-family: var(--font-head);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    color: var(--phosphor);
    text-transform: uppercase;
  }

  /* ─── SECTION HEADERS ─── */
  .ph {
    font-family: var(--font-head);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text);
    padding: 0.5rem 1rem 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border);
    border-left: 2px solid rgba(200,255,0,0.4);
    background: rgba(0,0,0,0.6);
  }
  .section {
    border-bottom: 1px solid var(--border);
    margin-bottom: 0.5rem;
  }
  .sb {
    padding: 0.75rem 1rem 1rem;
  }
  .dim { opacity: 0.5; font-size: 0.6rem; }
  .muted {
    font-family: var(--font-head);
    font-size: 0.8rem;
    color: var(--text-dim);
    opacity: 0.4;
  }

  /* ─── EQUITY HERO ─── */
  .hero-pane { border-bottom: 1px solid var(--border); }
  .live-dot {
    color: #00ff00;
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }
  .early-badge {
    font-family: var(--font-head);
    font-size: 0.5rem;
    padding: 0.1rem 0.35rem;
    color: #ffb000;
    border: 1px solid rgba(255,176,0,0.4);
    letter-spacing: 0.08em;
    vertical-align: middle;
    margin-left: 0.5rem;
  }
  .hero-body { padding: 1.25rem 1rem; }
  .equity-hero { display: flex; flex-direction: column; }
  .eq-number {
    font-size: clamp(2rem, 8vw, 3.5rem);
    font-weight: 700;
    font-family: var(--font-head);
    color: var(--phosphor);
    line-height: 1;
  }
  .eq-pnl {
    font-size: clamp(1rem, 4vw, 1.5rem);
    font-weight: 600;
    font-family: var(--font-head);
    margin-top: 0.25rem;
  }
  .eq-realized {
    font-size: 0.75rem;
    font-family: var(--font-head);
    color: var(--text-dim);
    margin-top: 0.15rem;
    letter-spacing: 0.02em;
  }
  .eq-meta {
    font-size: 0.7rem;
    color: var(--text-dim);
    font-family: var(--font-head);
    margin-top: 0.35rem;
    letter-spacing: 0.05em;
  }
  .eq-badges {
    margin-top: 0.5rem;
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }
  .risk-badge {
    font-family: var(--font-head);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    padding: 0.15rem 0.5rem;
    text-transform: uppercase;
  }

  /* ─── EQUITY CURVE ─── */
  .eq-wrap {
    padding: 0.5rem 1rem;
    overflow: hidden;
  }
  #equity-canvas {
    width: 100%;
    height: 120px;
    display: block;
  }

  /* ─── MARKET STATE ─── */
  .regime-map {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: flex-end;
    margin-bottom: 0.5rem;
  }
  .regime-coin-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }
  .regime-dot {
    width: 10px;
    height: 10px;
    display: block;
  }
  .regime-coin-name {
    font-size: 0.5rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-family: var(--font-head);
  }
  .regime-legend {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-head);
    font-size: 0.55rem;
    color: var(--text-dim);
    letter-spacing: 0.06em;
    margin-bottom: 0.6rem;
  }
  .leg-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    margin-right: 0.2rem;
    vertical-align: middle;
  }
  .status-line {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    font-family: var(--font-head);
    font-size: 0.7rem;
    margin-top: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--border);
  }
  .status-ok { color: #c8ff00; }
  .status-warn { color: #ffb000; }
  .status-err { color: #ff3333; }

  /* ─── SIGNAL ARCHETYPES ─── */
  .archetype-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }
  .archetype-card {
    border: 1px solid var(--border);
    padding: 0.75rem;
    background: rgba(255,255,255,0.02);
  }
  .archetype-card-title {
    font-family: var(--font-head);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    text-transform: uppercase;
    margin-bottom: 0.4rem;
  }
  .archetype-card-main {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.35rem;
  }
  .archetype-prog-wrap {
    flex: 1;
    height: 3px;
    background: rgba(255,255,255,0.08);
    overflow: hidden;
  }
  .archetype-prog-fill {
    height: 100%;
    background: #c8ff00;
    transition: width 0.4s ease;
  }
  .archetype-fraction {
    font-family: var(--font-head);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--phosphor);
    white-space: nowrap;
  }
  .archetype-coin {
    font-family: var(--font-head);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--text);
  }
  .archetype-conditions {
    font-family: var(--font-head);
    font-size: 0.55rem;
    color: var(--text-dim);
    line-height: 1.4;
    opacity: 0.7;
  }

  /* ─── SYSTEM STATUS ─── */
  .system-ph {
    cursor: pointer;
    user-select: none;
    transition: color 0.2s;
  }
  .system-ph:hover { color: var(--phosphor); }
  .system-healthy {
    font-family: var(--font-head);
    font-size: 0.7rem;
    color: var(--text-dim);
    line-height: 1.4;
    word-break: break-word;
  }
  .system-body { display: none; margin-top: 0.75rem; }
  .system-body.expanded { display: block; }

  /* ─── PIPELINE ─── */
  .agent-pipeline {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-family: var(--font-head);
    font-size: 0.65rem;
    overflow-x: auto;
  }
  .pipeline-stage {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 90px;
  }
  .pipeline-stage-label {
    font-size: 0.45rem;
    letter-spacing: 0.12em;
    color: var(--text-dim);
    text-transform: uppercase;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.15rem;
    margin-bottom: 0.2rem;
  }
  .pipeline-agents {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .pipeline-arrow {
    color: var(--text-dim);
    font-size: 0.8rem;
    padding: 0 0.2rem;
    align-self: center;
    margin-top: 1.2rem;
  }
  .agent-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .agent-dot {
    width: 8px;
    height: 8px;
    display: inline-block;
    flex-shrink: 0;
  }
  .agent-name {
    color: var(--text-dim);
    text-transform: uppercase;
    font-size: 0.6rem;
    letter-spacing: 0.08em;
  }
  .agent-time {
    font-size: 0.55rem;
    color: var(--text-dim);
    opacity: 0.6;
  }

  /* ─── POSITION CARDS ─── */
  .pos-cards {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .pos-card {
    border: 1px solid var(--border);
    border-left: 3px solid #c8ff00;
    padding: 0.75rem 1rem;
    background: rgba(255,255,255,0.02);
    position: relative;
  }
  .pos-card.short-card {
    border-left-color: #ff3333;
  }
  .pos-card-top {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }
  .pos-coin {
    font-family: var(--font-head);
    font-size: 1rem;
    font-weight: 700;
    color: var(--phosphor);
  }
  .pos-dir {
    font-family: var(--font-head);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    padding: 0.15rem 0.4rem;
  }
  .pos-dir.long {
    color: #0a0a0a;
    background: #c8ff00;
  }
  .pos-dir.short {
    color: #fff;
    background: #ff3333;
  }
  .regime-badge {
    font-family: var(--font-head);
    font-size: 0.55rem;
    letter-spacing: 0.08em;
    padding: 0.1rem 0.35rem;
    border: 1px solid;
    text-transform: uppercase;
  }
  .regime-badge.trending { color: #c8ff00; border-color: rgba(200,255,0,0.4); }
  .regime-badge.stable { color: var(--text-dim); border-color: var(--border); }
  .regime-badge.shift { color: #ffb000; border-color: rgba(255,176,0,0.4); }
  .regime-badge.chaotic { color: #ff3333; border-color: rgba(255,51,51,0.4); }
  .pos-pnl {
    margin-left: auto;
    font-family: var(--font-head);
    font-size: 0.95rem;
    font-weight: 700;
  }
  .pos-card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem 1.2rem;
    margin-bottom: 0.4rem;
  }
  .pos-field {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .pos-fl {
    font-family: var(--font-head);
    font-size: 0.55rem;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    text-transform: uppercase;
  }
  .pos-fv {
    font-family: var(--font-head);
    font-size: 0.8rem;
    color: var(--text);
  }
  .pos-exit {
    margin-top: 0.4rem;
    margin-bottom: 0.4rem;
    font-family: var(--font-body);
    font-size: 0.7rem;
    color: var(--text-dim);
    opacity: 0.85;
  }
  /* hold time progress bar */
  .pos-hold-bar-wrap {
    margin-top: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .pos-hold-track {
    flex: 1;
    height: 2px;
    background: rgba(255,255,255,0.08);
    overflow: hidden;
  }
  .pos-hold-fill {
    height: 100%;
    min-width: 6px;
    border-radius: 1px;
    background: rgba(200,255,0,0.5);
  }
  .pos-hold-label {
    font-family: var(--font-head);
    font-size: 0.55rem;
    color: var(--text-dim);
    white-space: nowrap;
  }

  /* ─── STATS / PERFORMANCE ─── */
  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  .stats-panel {
    font-family: var(--font-head);
    font-size: 0.8rem;
  }
  .stats-panel-title {
    font-size: 0.55rem;
    letter-spacing: 0.12em;
    color: var(--text-dim);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid var(--border);
  }
  .coin-stats-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-head);
    font-size: 0.7rem;
  }
  .coin-stats-table th {
    font-size: 0.5rem;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    text-transform: uppercase;
    text-align: left;
    padding: 0.2rem 0.4rem;
    border-bottom: 1px solid var(--border);
    font-weight: 400;
  }
  .coin-stats-table td {
    padding: 0.25rem 0.4rem;
    border-bottom: 1px solid rgba(255,255,255,0.03);
    color: var(--text);
  }
  .coin-stats-table th:not(:first-child),
  .coin-stats-table td:not(:first-child) {
    text-align: right;
  }
  .stat-row {
    display: flex;
    justify-content: space-between;
    padding: 0.3rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.03);
    font-size: 0.7rem;
  }
  .stat-row-label { color: var(--text-dim); }
  .stat-row-value { color: var(--text); font-weight: 700; }

  /* ─── TRADE HISTORY (compact rows) ─── */
  .closed-rows {
    display: flex;
    flex-direction: column;
    font-family: var(--font-head);
    font-size: 0.75rem;
  }
  .closed-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.35rem 0.5rem;
    flex-wrap: nowrap;
    overflow: hidden;
  }
  .closed-row:nth-child(even) {
    background: rgba(255,255,255,0.015);
  }
  .cr-coin {
    font-weight: 700;
    color: var(--phosphor);
    min-width: 40px;
    flex-shrink: 0;
  }
  .cr-dir {
    font-size: 0.65rem;
    font-weight: 700;
    min-width: 36px;
    flex-shrink: 0;
  }
  .cr-prices {
    font-size: 0.65rem;
    color: var(--text-dim);
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .cr-pct {
    font-size: 0.7rem;
    font-weight: 700;
    min-width: 52px;
    text-align: right;
    flex-shrink: 0;
  }
  .cr-pnl {
    font-size: 0.7rem;
    font-weight: 700;
    min-width: 48px;
    text-align: right;
    flex-shrink: 0;
  }
  .cr-reason {
    font-size: 0.55rem;
    color: var(--text-dim);
    opacity: 0.6;
    flex-shrink: 0;
    max-width: 70px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .cr-age {
    font-size: 0.55rem;
    color: var(--text-dim);
    opacity: 0.5;
    flex-shrink: 0;
    min-width: 28px;
    text-align: right;
  }

  /* ─── COLORS ─── */
  .c-pos { color: #c8ff00; }
  .c-neg { color: #ff3333; }
  .c-long { color: #c8ff00; }
  .c-short { color: #ff3333; }

  /* ─── FOOTER ─── */
  .footer {
    display: flex;
    justify-content: space-between;
    padding: 0.5rem 1rem;
    font-family: var(--font-head);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    color: var(--text-dim);
  }
  .footer-link {
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-link:hover { color: var(--phosphor); }

  /* ─── DECISION STREAM ─── */
  .ds-wrap {
    max-height: 280px;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(200,255,0,0.15) transparent;
  }
  .ds-live {
    color: #c8ff00;
    font-size: 0.55rem;
    animation: ds-pulse 2s infinite;
  }
  @keyframes ds-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  .ds-row {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.2rem 0;
    font-family: var(--font-head);
    font-size: 0.7rem;
    border-bottom: 1px solid rgba(200,255,0,0.04);
    line-height: 1.4;
  }
  .ds-time { color: var(--text-dim); min-width: 3.5rem; flex-shrink: 0; }
  .ds-coin { min-width: 5rem; flex-shrink: 0; font-weight: 600; }
  .ds-dir { min-width: 3rem; flex-shrink: 0; }
  .ds-dir.long { color: #c8ff00; }
  .ds-dir.short { color: #ff3333; }
  .ds-badge {
    padding: 0.05rem 0.3rem;
    border-radius: 2px;
    font-size: 0.6rem;
    min-width: 4.5rem;
