  // ─── SYSTEM STATUS ───
  function renderSystemStatus(agents){
    var summaryEl = document.getElementById('system-summary');
    var healthyEl = document.getElementById('system-healthy');
    if(!agents || !agents.heartbeat){
      if(summaryEl) summaryEl.textContent = '—';
      return;
    }

    var allAgents = ['regime','liquidity','spread_monitor','cross_timeframe','funding','harvester','correlation','risk','evolution','execution'];
    var online = 0;
    var failed = [];
    for(var i=0; i<allAgents.length; i++){
      var name = allAgents[i];
      var ts = agents.heartbeat[name];
      var secs = agoFromISO(ts);
      if(secs < 900){
        online++;
      } else {
        failed.push(name);
      }
    }
    var total = allAgents.length;
    if(summaryEl){
      if(online === total){
        summaryEl.innerHTML = '<span class="c-pos">'+total+'/'+total+' ✓</span>';
      } else {
        summaryEl.innerHTML = '<span class="c-neg">'+online+'/'+total+'</span>';
      }
    }
    if(healthyEl){
      if(online === total){
        healthyEl.textContent = 'Pipeline healthy — all agents reporting';
        healthyEl.style.color = '';
      } else {
        healthyEl.textContent = 'Agents offline: ' + failed.join(', ');
        healthyEl.style.color = '#ff3333';
      }
    }
  }

